GH_KEY=

# ── Sélection du backend LLM ──────────────────────────────────────────────────
# Le backend actif se choisit dans configs/agent.yaml (clé `backend:`), PAS ici.
# Ce fichier ne porte plus que les SECRETS (clés API) et les overrides d'infra
# mobile / de modèle (*_BASE_URL / *_MODEL) consommés par agent/llm_call.
# `manual` (backend: manual dans agent.yaml) écrit les prompts dans .llm_io/inbox/
# et lit la réponse dans .llm_io/outbox/ — aucune API key ni quota.

# ── Ollama (local, illimité) ──────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3.5:4b

# ── Qwopus3.5-9B-Coder (Ollama sur la machine GPU du LAN) ─────────────────────
# Modèle de raisonnement : /v1 renvoie un content propre + reasoning séparé.
# Ne PAS forcer think:false (casse le template de ce finetune).
QWOPUS_BASE_URL=http://192.168.1.42:11434/v1
QWOPUS_MODEL=hf.co/Jackrong/Qwopus3.5-9B-Coder-GGUF:Q5_K_M

# ── Groq (free tier, ~1000 RPD sur llama-3.3-70b-versatile) ───────────────────
# Get key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Google AI Studio (Gemini) ─────────────────────────────────────────────────
# Free tier: 15 RPM, 1M tokens/day for gemini-2.5-flash
# Create keys: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── vLLM server ───────────────────────────────────────────────────────────────
# Used by agent/llm_call (vllm backend) and validator_server (score_with_llm)
VLLM_BASE_URL=http://promaxgb10-bcae:8000/v1
VLLM_MODEL=/models/qwen3.6-27b-fp8

# ── Tavily MCP (optional — internet search) ──────────────────────────────────
# Param = tavilyApiKey (PAS apiKey, qui renvoie 401). Le serveur tavily est
# automatiquement skippé si TAVILY_MCP n'est pas défini.
# TAVILY_KEY=tvly-...
# TAVILY_MCP=https://mcp.tavily.com/mcp/?tavilyApiKey=${TAVILY_KEY}