GH_KEY=

# ── Backend LLM par défaut pour le graph et la factory LLM_interface ──────────
# Valeurs: gemini | groq | ollama | manual | lmstudio | vllm | copilot
LLM_BACKEND=manual

# `manual` = écrit les prompts dans .llm_io/inbox/ et lit la réponse dans
# .llm_io/outbox/. Aucune API key ni quota. Voir scripts/llm_inbox_responder.md.

# ── Ollama (local, illimité) ──────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3.5:4b

# ── Groq (free tier, ~1000 RPD sur llama-3.3-70b-versatile) ───────────────────
# Get key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Google AI Studio (Gemini) ─────────────────────────────────────────────────
# Free tier: 15 RPM, 1M tokens/day for gemini-2.5-flash
# Create keys: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── vLLM server ───────────────────────────────────────────────────────────────
# Used by agent/helpers.py (graph LLM calls) and validator_server (score_with_llm)
VLLM_BASE_URL=http://promaxgb10-bcae:8000/v1
VLLM_MODEL=/models/qwen3.6-27b-fp8

# ── Tavily MCP (optional — internet search) ──────────────────────────────────
# TAVILY_MCP=https://mcp.tavily.com/mcp/?apiKey=YOUR_KEY_HERE