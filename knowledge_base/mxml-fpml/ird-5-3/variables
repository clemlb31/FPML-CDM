<xsl:stylesheet xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
				xmlns="http://www.fpml.org/FpML-5/confirmation" 
				xmlns:str="http://exslt.org/strings"
				xmlns:math="http://exslt.org/math" 
				xmlns:xalan="http://xml.apache.org/xalan"
				xmlns:exsl="http://exslt.org/common" 
				xmlns:exslt="http://exslt.org/common"
				xmlns:mx="http://murex.com/xslt/common" 
				xmlns:date="http://exslt.org/dates-and-times"
				version="1.0" 
				xmlns:my="myfunc" 
				xmlns:func="http://exslt.org/functions"
				exclude-result-prefixes="date str math xalan exslt exsl mx my func">

	<xsl:import href="mx.xml2xml.extract.mxml.products.ird.templates"/>
	<xsl:import href="mx.xml2xml.transform.mxml2fpml.5-3.products.ird.utils.calculateDayCountYearFraction"/>
	<xsl:import href="mx.xml2xml.transform.any2fpml.5-3.products.common.partyTradeIdentifier"/>
	<xsl:import href="mx.xml2xml.transform.any2fpml.5-3.products.common.spreadSchedule"/>
	<xsl:import href="mx.xml2xml.transform.any2fpml.5-3.products.ird.common.principalExchange"/>
	<xsl:import href="mx.xml2xml.transform.any2fpml.5-3.products.ird.common.fxLinkedNotionalAmount"/>
	<xsl:import href="mx.generic.exslt.date.difference"/>
	<xsl:import href="mx.generic.exslt.date.day-name"/>
	<xsl:import href="mx.xml2xml.transform.mxml2fpml.5-3.products.common.common"/>
	<xsl:import href="mx.xml2xml.transform.mxml2fpml.utils.schedule"/>
	<xsl:import href="mx.xml2xml.transform.mxml2fpml.5-3.products.ird.utils.numberOfDaysByObservation"/>
	<xsl:include href="mx.xml2xml.transform.mxml2fpml.5-3.products.variables"/>

	<xsl:variable name="tradeIdScheme1" select="'TradeRefNbr'"/>
	<xsl:variable name="mapShifterLabel" select="'public.xml2xml.mapping.mxml2fpml.common.shifterLabel'"/>
	<xsl:variable name="mapBusinessDayConv" select="'public.xml2xml.mapping.mxml2fpml.common.businessDayConvention'"/>
	<xsl:variable name="mapDayCountBasis" select="'public.xml2xml.mapping.mxml2fpml.common.dayCountBasis'"/>
	<xsl:variable name="mapBusinessCenter" select="'public.ECN.import.FpML.mapping.outbound.businessCenter'"/>
	<!-- select="$mapBusinessCenter"/>-->
	<xsl:variable name="mapInterpolationMethod" select="'public.xml2xml.mapping.mxml2fpml.interpolationMethod'"/>
	<xsl:variable name="mapCompounding" select="'public.xml2xml.mapping.mxml2fpml.bmfcompounding'"/>

	<!--specific OIS-->
	<xsl:variable name="year.number.days" select="365"/>
	<xsl:variable name="settlementPayOrReceive">
		<xsl:call-template name="extract-settlementSign">
			<xsl:with-param name="legNb" select="1"/>
		</xsl:call-template>
	</xsl:variable>

	<!-- <xsl:variable name="creationTimestamp"
        select="mx:execute-formula('mx.xml2xml.transform.mxml2fpml.5-3.products.common.time.releaseTime')"/>-->
	<xsl:variable name="FpMLDateFormula" select="'mx.xml2xml.ECN.common.utils.adaptDate'"/>

	<!-- ============================ -->
	<!--           Common             -->
	<!-- ============================ -->
	<xsl:variable name="nbTradeNode" select="count(/MxML/trades/trade)"/>
	<xsl:variable name="status1" select="/MxML/trades/trade[1]/tradeStatus/physicalStatus"/>
	<xsl:variable name="status2" select="/MxML/trades/trade[2]/tradeStatus/physicalStatus"/>
	<xsl:variable name="trdNb">
		<xsl:choose>
			<xsl:when test="$nbTradeNode = '2'">
				<xsl:choose>
					<xsl:when test="$status1 = $status2 and not($status1 = 'dead')">
						<xsl:value-of select="'1'"/>
					</xsl:when>
					<xsl:when test="not($status1 = 'dead') and $status2 = 'dead'">
						<xsl:value-of select="'1'"/>
					</xsl:when>
					<xsl:when test="not($status2 = 'dead') and $status1 = 'dead'">
						<xsl:value-of select="'2'"/>
					</xsl:when>
					<xsl:otherwise>
						<xsl:for-each select="/MxML/trades/trade">
							<xsl:if test="not(tradeStatus/physicalStatus = 'dead')">
								<xsl:value-of select="position()"/>
							</xsl:if>
						</xsl:for-each>
					</xsl:otherwise>
				</xsl:choose>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="'1'"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>
	<xsl:variable name="swapStream1.effectiveDate.dateAdjustments.businessDayConvention.overriding"/>
	<xsl:variable name="swapStream2.effectiveDate.dateAdjustments.businessDayConvention.overriding"/>

	<!-- new party -->
	<xsl:variable name="issuedContractReference">
		<xsl:choose>
			<xsl:when
                test="/MxML/contractEvents/contractEvent/contractEventBody/partyAssignment/contractEventBusinessObjectReference/packageReference">
				<!-- back-to-back trade : package -->
				<xsl:variable name="packageReference">
					<xsl:value-of
                        select="substring-after(/MxML/contractEvents/contractEvent/contractEventBody/partyAssignment/contractEventBusinessObjectReference/packageReference/@href, '#')"
                    />
				</xsl:variable>
				<xsl:value-of
                    select="substring-after(/MxML/packages/package[@id = $packageReference]/packageComponents/packageComponent[./typologyId = '1']/contractReference/@href, '#')"
                />
			</xsl:when>
			<xsl:otherwise>
				<xsl:choose>
					<xsl:when
                        test="string-length(/MxML/contractEvents/contractEvent/contractEventBody/partyAssignment/issuedContractReference/@href) &gt; 0">
						<xsl:value-of
                            select="substring-after(/MxML/contractEvents/contractEvent/contractEventBody/partyAssignment/issuedContractReference/@href, '#')"
                        />
					</xsl:when>
					<xsl:otherwise>
						<xsl:choose>
							<xsl:when test="number(string-length(/MxML/contractEvents)) = 0">
								<xsl:value-of
                                    select="substring-after(/MxML/packages/package/packageComponents/packageComponent[2]/contractReference/@href, '#')"
                                />
							</xsl:when>
							<xsl:otherwise>
								<xsl:value-of
                                    select="/MxML/contracts/contract[./contractId/internalId != ./contractId/rootContract]/@id"
                                />
							</xsl:otherwise>
						</xsl:choose>
					</xsl:otherwise>
				</xsl:choose>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<!-- old party -->
	<xsl:variable name="targetContractReference">
		<xsl:choose>
			<xsl:when
                test="/MxML/contractEvents/contractEvent/contractEventBody/partyAssignment/contractEventTargetReference/packageReference">
				<!-- back-to-back trade : package -->
				<xsl:variable name="packageReference">
					<xsl:value-of
                        select="substring-after(/MxML/contractEvents/contractEvent/contractEventBody/partyAssignment/contractEventTargetReference/packageReference/@href, '#')"
                    />
				</xsl:variable>
				<xsl:value-of
                    select="substring-after(/MxML/packages/package[@id = $packageReference]/packageComponents/packageComponent[./typologyId = '1']/contractReference/@href, '#')"
                />
			</xsl:when>
			<xsl:otherwise>
				<xsl:choose>
					<xsl:when test="number(string-length(/MxML/contractEvents)) = 0">
						<xsl:value-of
                            select="substring-after(/MxML/packages/package/packageComponents/packageComponent[1]/contractReference/@href, '#')"
                        />
					</xsl:when>
					<xsl:otherwise>
						<xsl:value-of
                            select="substring-after(/MxML/contractEvents/contractEvent/contractEventBody/partyAssignment/targetContractReference/@href, '#')"
                        />
					</xsl:otherwise>
				</xsl:choose>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<xsl:variable name="contractRef">
		<xsl:choose>
			<xsl:when test="$nbTradeNode = '2'">
				<xsl:choose>
					<xsl:when test="$fpmlType = 'NovationOld'">
						<!-- 
							case of full event (novation) : to get trade ref of the non dead trade 
							targetContractReference : to extract the trade ref. in the contract in case of Cpty assgnment
						-->
						<xsl:choose>
							<xsl:when
                                test="/MxML/contracts/contract[@id = $targetContractReference]/contractComponents">
								<xsl:value-of
                                    select="substring-after(/MxML/contracts/contract[@id = $targetContractReference]/contractComponents/contractComponent/tradeReference/@href, '#')"
                                />
							</xsl:when>
							<xsl:otherwise>
								<xsl:choose>
									<xsl:when
                                        test="/MxML/contracts/contract[@id = $issuedContractReference]/contractComponents">
										<xsl:value-of
                                            select="substring-after(/MxML/contracts/contract[@id = $issuedContractReference]/contractComponents/contractComponent/tradeReference/@href, '#')"
                                        />
									</xsl:when>
									<xsl:otherwise>
										<xsl:value-of
                                            select="substring-after(/MxML/contracts/contract[./contractId/internalId != ./contractId/rootContract]/contractComponents/contractComponent/tradeReference/@href, '#')"
                                        />
									</xsl:otherwise>
								</xsl:choose>
							</xsl:otherwise>
						</xsl:choose>
					</xsl:when>
					<xsl:when test="$fpmlType = 'NovationNew'">
						<!--
							issuedContractReference : to extract the trade ref. in the contract in case of Cpty assgnment
						-->
						<xsl:value-of
                            select="substring-after(/MxML/contracts/contract[@id = $issuedContractReference]/contractComponents/contractComponent/tradeReference/@href, '#')"
                        />
					</xsl:when>
					<xsl:otherwise>
						<!-- xsl:value-of select="substring-after(/MxML/contracts/contract/contractComponents/contractComponent/tradeReference/@href, '#')" / -->
						<xsl:value-of
                            select="/MxML/trades/trade[not(./tradeStatus/physicalStatus = 'dead')]/@id"
                        />
					</xsl:otherwise>
				</xsl:choose>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of
                    select="substring-after(/MxML/contracts/contract/contractComponents/contractComponent/tradeReference/@href, '#')"
                />
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<!-- ============================================================================= -->
	<!-- EXTRACT FROM MXML -->
	<!-- ============================================================================= -->
	<!--<xsl:variable name="tradeDate">
        <xsl:variable name="tradeDateMx">
            <xsl:call-template name="extract-tradeDate">
                <xsl:with-param name="legNb" select="1"/>
            </xsl:call-template>
        </xsl:variable>
        <xsl:value-of
            select="mx:execute-formula('mx.xml2xml.ECN.common.utils.adaptDate', concat('date:', $tradeDateMx, ',format:yyyymmdd,outputFormat:yyyy-mm-dd'))"
        />
    </xsl:variable>-->

	<xsl:variable name="tradeIdOld1">
		<xsl:call-template name="extract-tradeID">
			<xsl:with-param name="legNb" select="1"/>
		</xsl:call-template>
	</xsl:variable>

	<xsl:variable name="tradeIdOld2">
		<xsl:call-template name="extract-tradeID">
			<xsl:with-param name="legNb" select="2"/>
		</xsl:call-template>
	</xsl:variable>

	<xsl:variable name="tradeId.scheme" select="'TradeRefNbr'"/>

	<!-- ===================== -->
	<!-- Premium if any -->
	<!-- ===================== -->
	<xsl:variable name="premium.amount">
		<xsl:call-template name="extract-settlementFlow-amount">
			<xsl:with-param name="legNb" select="1"/>
		</xsl:call-template>
	</xsl:variable>

	<xsl:variable name="premium.currency">
		<xsl:call-template name="extract-settlementCurrency">
			<xsl:with-param name="legNb" select="1"/>
		</xsl:call-template>
	</xsl:variable>

	<xsl:variable name="premium.date">
		<xsl:variable name="premiumDateMx">
			<xsl:call-template name="extract-settlementFlow-date">
				<xsl:with-param name="legNb" select="1"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:if test="string-length($premiumDateMx) &gt; 0">
			<xsl:value-of
                select="mx:execute-formula('mx.xml2xml.ECN.common.utils.adaptDate', concat('date:', $premiumDateMx, ',format:yyyymmdd,outputFormat:yyyy-mm-dd'))"
            />
		</xsl:if>
	</xsl:variable>

	<xsl:variable name="premium.pay.or.receive">
		<xsl:call-template name="extract-settlementFlow-payOrReceive">
			<xsl:with-param name="legNb" select="1"/>
		</xsl:call-template>
	</xsl:variable>

	<!-- ===================== -->
	<!-- Extendable swaps: commencementDate      -->
	<!-- ===================== -->

	<xsl:variable name="commencementDate.unadjustedDate">
		<xsl:variable name="commencementDate.unadjustedDate.tmp">
			<xsl:call-template name="extract-tradeDate">
				<xsl:with-param name="trdNb" select="2"/>
				<xsl:with-param name="legNb" select="1"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:value-of
            select="mx:execute-formula('mx.xml2xml.ECN.common.utils.adaptDate', concat('date:', $commencementDate.unadjustedDate.tmp, ',format:yyyymmdd,outputFormat:yyyy-mm-dd'))"
        />
	</xsl:variable>

	<xsl:variable name="commencementDate.dateAdjustments.businessDayConvention">
		<xsl:variable name="commencementDate.dateAdjustments.businessDayConvention.tmp">
			<xsl:call-template name="extract-businessDayConvention">
				<xsl:with-param name="legNb" select="1"/>
				<xsl:with-param name="schedule" select="'calculationSchedule'"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:value-of
            select="mx:execute-formula($mapBusinessDayConv, concat('businessDayConvention:', $commencementDate.dateAdjustments.businessDayConvention.tmp))"
        />
	</xsl:variable>


	<!-- ===================== -->
	<!-- Extendable swaps: expirationDate      -->
	<!-- ===================== -->

	<xsl:variable name="expirationDate.unadjustedDate">
		<xsl:variable name="expirationDate.unadjustedDate.tmp">
			<xsl:call-template name="extract-optionMaturityDate">
				<xsl:with-param name="trdNb" select="2"/>
				<xsl:with-param name="legNb" select="1"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:value-of
            select="mx:execute-formula('mx.xml2xml.ECN.common.utils.adaptDate', concat('date:', $expirationDate.unadjustedDate.tmp, ',format:yyyymmdd,outputFormat:yyyy-mm-dd'))"
        />
	</xsl:variable>

	<xsl:variable name="expirationDate.dateAdjustments.businessDayConvention">
		<xsl:variable name="expirationDate.dateAdjustments.businessDayConvention.tmp">
			<xsl:call-template name="extract-businessDayConvention">
				<xsl:with-param name="legNb" select="1"/>
				<xsl:with-param name="schedule" select="'calculationSchedule'"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:value-of
            select="mx:execute-formula($mapBusinessDayConv, concat('businessDayConvention:', $expirationDate.dateAdjustments.businessDayConvention.tmp))"
        />
	</xsl:variable>



	<!-- <xsl:variable name="expirationDate.dateAdjustments.businessCenter">
        <xsl:variable name="expirationDate.dateAdjustments.businessCenter.tmp">
            <xsl:call-template name="extract-businessCenterLabel"/>
        </xsl:variable>
        <xsl:choose>
            <xsl:when test="string-length($mapBusinessCenter) &gt; 0">
                <xsl:value-of
                    select="mx:execute-formula($mapBusinessCenter, concat('businessCenter:', $expirationDate.dateAdjustments.businessCenter.tmp))"
                />
            </xsl:when>
            <xsl:otherwise>
                <xsl:value-of select="$expirationDate.dateAdjustments.businessCenter.tmp"/>
            </xsl:otherwise>
        </xsl:choose>
    </xsl:variable>-->

	<!-- ===================== -->
	<!-- Extendable swaps: relevantUnderlyingDate      -->
	<!-- ===================== -->

	<xsl:variable name="relevantUnderlyingDate.unadjustedDate">
		<xsl:variable name="maturityDate">
			<xsl:call-template name="extract-maturityDate">
				<xsl:with-param name="trdNb" select="2"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:value-of
            select="mx:execute-formula('mx.xml2xml.ECN.common.utils.adaptDate', concat('date:', $maturityDate, ',format:yyyymmdd,outputFormat:yyyy-mm-dd'))"
        />
	</xsl:variable>

	<xsl:variable name="indexFamily">
		<xsl:choose>
			<xsl:when
                test="contains($leg1.floatingRateIndex, 'EURIBOR') or contains($leg2.floatingRateIndex, 'EURIBOR')"
                >EURIBOR</xsl:when>
			<xsl:when
                test="contains($leg1.floatingRateIndex, 'LIBOR') or contains($leg2.floatingRateIndex, 'LIBOR')"
                >LIBOR</xsl:when>
		</xsl:choose>
	</xsl:variable>

	<!-- early termination settlement -->
	<xsl:variable name="exerciseSettlement"
        select="mx:execute-formula('public.xml2xml.mapping.mxml2fpml.ird.earlyTerminationSettlementMatrix', concat('currency:', $swapStream1.notionalSchedule.notionalStepSchedule.currency, ',indexFamily:', $indexFamily))"/>

	<!-- ===================== -->
	<!-- Extendable swaps: bermudaExerciseDates     -->
	<!-- ===================== -->

	<xsl:variable name="bermudaExerciseDates.unadjustedDate.nodes">   
		<xsl:for-each select="/MxML/trades/trade/tradeBody/*/payout/option/exercizeSchedule/exercizeEvents/exercizeEvent/exercizeDate">
			<xsl:variable name="exercizeDate">
				<xsl:value-of select="."/>
			</xsl:variable>
			<unadjustedDate>       
				<xsl:value-of select="mx:execute-formula('mx.xml2xml.ECN.common.utils.adaptDate', concat('date:',$exercizeDate,',format:yyyymmdd,outputFormat:yyyy-mm-dd'))" />
			</unadjustedDate>
		</xsl:for-each>    
	</xsl:variable>    

	<!-- ========================= -->
	<!-- earliestExerciseTime node -->
	<!-- ========================= -->
	<xsl:variable name="earliestExerciseTime.hourMinuteTime" select="$exerciseSettlement//row[5]"/>
	<xsl:variable name="earliestExerciseTime.businessCenter.name"
        select="$exerciseSettlement//row[6]"/>

	<!-- ========================= -->
	<!-- latestExerciseTime node -->
	<!-- ========================= -->
	<xsl:variable name="latestExerciseTime.hourMinuteTime" select="$exerciseSettlement//row[7]"/>
	<xsl:variable name="latestExerciseTime.businessCenter.name" select="$exerciseSettlement//row[8]"/>

	<!-- ========================= -->
	<!-- expirationTime node   -->
	<!-- ========================= -->
	<xsl:variable name="expirationTime.hourMinuteTime" select="$exerciseSettlement//row[7]"/>
	<xsl:variable name="expirationTime.businessCenter.name" select="$exerciseSettlement//row[8]"/>

	<!-- ========================= -->
	<!-- cashSettlementValuationTime node   -->
	<!-- ========================= -->
	<xsl:variable name="cashSettlementValuationTime.hourMinuteTime" select="$exerciseSettlement//row[7]"/>
	<xsl:variable name="cashSettlementValuationTime.businessCenter.name" select="$exerciseSettlement//row[8]"/>

	<xsl:variable name="exercise.businessCenters.names" select="$exerciseSettlement//row[2]"/>

	<xsl:variable name="exercise.dateAdjustments.businessCenter.nodes">
		<xsl:if test="string-length($exercise.businessCenters.names) &gt; 0">
			<xsl:variable name="_value.tokens">
				<xsl:call-template name="str:_split-pattern">
					<xsl:with-param name="string" select="$exercise.businessCenters.names"/>
					<xsl:with-param name="pattern" select="';'"/>
				</xsl:call-template>
			</xsl:variable>
			<xsl:variable name="value.tokens" select="exsl:node-set($_value.tokens)/token"/>
			<xsl:for-each select="$value.tokens">
				<xsl:variable name="pos" select="position()"/>
				<xsl:variable name="token" select="string($value.tokens[$pos])"/>
				<businessCenter>
					<xsl:value-of select="$token"/>
				</businessCenter>
			</xsl:for-each>
		</xsl:if>
	</xsl:variable>


	<!-- ===================== -->
	<!-- LEG 1 -->
	<!-- ===================== -->
	<xsl:variable name="leg1.pay.or.receive">
		<xsl:call-template name="extract-pay-or-receive">
			<xsl:with-param name="legNb" select="'1'"/>
			<xsl:with-param name="stream" select="'1'"/>
		</xsl:call-template>
	</xsl:variable>

	<xsl:variable name="leg1.payoutType">
		<xsl:call-template name="extract-streamPayoutType">
			<xsl:with-param name="legNb" select="1"/>
			<xsl:with-param name="stream" select="1"/>
		</xsl:call-template>
	</xsl:variable>

	<xsl:variable name="leg1.effectiveDate">
		<xsl:variable name="effectiveDateMx">
			<xsl:call-template name="extract-effectiveDate">
				<xsl:with-param name="legNb" select="1"/>
				<xsl:with-param name="stream" select="1"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:value-of
            select="mx:execute-formula('mx.xml2xml.ECN.common.utils.adaptDate', concat('date:', $effectiveDateMx, ',format:yyyymmdd,outputFormat:yyyy-mm-dd'))"
        />
	</xsl:variable>

	<xsl:variable name="leg1.startDateTreatment.dateTreatment">
		<xsl:call-template name="extract-startDateTreatment-dateTreatment">
			<xsl:with-param name="legNb" select="1"/>
			<xsl:with-param name="stream" select="1"/>
		</xsl:call-template>
	</xsl:variable>

	<xsl:variable name="leg1.maturityDate">
		<xsl:call-template name="extract-maturityDate">
			<xsl:with-param name="legNb" select="1"/>
			<xsl:with-param name="stream" select="1"/>
		</xsl:call-template>
	</xsl:variable>

	<xsl:variable name="leg1.adjustedMaturityDate">
		<xsl:call-template name="extract-adjustedMaturityDate">
			<xsl:with-param name="stream" select="1"/>
		</xsl:call-template>
	</xsl:variable>

	<xsl:variable name="leg1.maturity">
		<xsl:choose>
			<xsl:when test="$swapStream1.calculationPeriodFrequency.rollConvention = 'IMMAUD'">
				<xsl:value-of select="$leg1.adjustedMaturityDate"/>
			</xsl:when>
			<xsl:when test="$swapStream1.calculationPeriodFrequency.rollConvention = 'IMM'">
				<xsl:call-template name="imm-force-unadjusted-day">
					<xsl:with-param name="adjustedDate" select="$leg1.adjustedMaturityDate"/>
				</xsl:call-template>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="$leg1.maturityDate"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<xsl:variable name="leg1.maturity.businessDayConvention">
		<xsl:call-template name="extract-businessDayConvention">
			<xsl:with-param name="legNb" select="1"/>
			<xsl:with-param name="stream" select="1"/>
			<xsl:with-param name="schedule" select="'calculationSchedule'"/>
		</xsl:call-template>
	</xsl:variable>

	<xsl:variable name="leg1.paymentBusinessCenters">
		<xsl:call-template name="extract-businessCenterLabel">
			<xsl:with-param name="legNb" select="1"/>
			<xsl:with-param name="stream" select="1"/>
		</xsl:call-template>
	</xsl:variable>

	<xsl:variable name="leg1.calculation.periodMultiplier">
		<xsl:call-template name="extract-periodMultiplier">
			<xsl:with-param name="legNb" select="1"/>
			<xsl:with-param name="stream" select="1"/>
		</xsl:call-template>
	</xsl:variable>

	<xsl:variable name="leg1.calculation.periodUnit">
		<xsl:call-template name="extract-periodUnit">
			<xsl:with-param name="legNb" select="1"/>
			<xsl:with-param name="stream" select="1"/>
		</xsl:call-template>
	</xsl:variable>

	<!-- Zero Coupon Mode -->
	<!-- swapStream1.paymentSchedule.zeroCouponMode -->
	<xsl:variable name="swapStream1.paymentSchedule.zeroCouponMode">
		<xsl:call-template name="extract-paymentSchedule-zeroCouponMode">
			<xsl:with-param name="stream" select="1"/>
		</xsl:call-template>
	</xsl:variable>

	<xsl:variable name="leg1.calculation.businessDayConvention">
		<xsl:call-template name="extract-businessDayConvention">
			<xsl:with-param name="legNb" select="$trdNb"/>
			<xsl:with-param name="stream" select="1"/>
			<xsl:with-param name="schedule" select="'calculationSchedule'"/>
		</xsl:call-template>
