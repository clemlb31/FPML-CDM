	<!-- ============================== -->
	<!-- cashSettlementPaymentDate node -->
	<!-- ============================== -->
	<xsl:variable name="earlyTerminationProvision.unadjustedDate.nodes">
		<xsl:for-each
            select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/payout/option/mutualBreakSchedule/exercizeEvents/exercizeEvent">
			<unadjustedDate>
				<xsl:value-of
                    select="mx:execute-formula($FpMLDateFormula, concat('date:', exercizeEffectiveDate, ',format:yyyymmdd,outputFormat:yyyy-mm-dd'))"
                />
			</unadjustedDate>
		</xsl:for-each>
	</xsl:variable>

	<xsl:variable name="mandatoryEarlyTerminationProvision.unadjustedDate.nodes">

		<xsl:variable name="FpMLDateFormula" select="'mx.xml2xml.ECN.common.utils.adaptDate'"/>
		<xsl:variable name="upper.case" select="'ABCDEFGHIJKLMNOPQRSTUVWXYZ'"/>
		<xsl:variable name="lower.case" select="'abcdefghijklmnopqrstuvwxyz'"/>
		<xsl:variable name="tradeDate">
			<xsl:value-of select="/MxML/trades/trade[@id = $contractRef]/tradeHeader/tradeDate"/>
		</xsl:variable>
		<xsl:variable name="unadjustedDate">
			<xsl:choose>
				<xsl:when
                    test="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/payout/option/mutualBreakSchedule/notificationEffectiveRelationship/notificationEffectiveCalendarSource = 'specific'">
					<xsl:choose>
						<xsl:when
                            test="string-length(/MxML/trades/trade[@id = $contractRef]/tradeBody/*/payout/option/mutualBreakSchedule/exercizeEvents/exercizeEvent[1]/exercizeEffectiveDate) &gt; 0">
							<xsl:value-of
                                select="mx:execute-formula($FpMLDateFormula, concat('date:', /MxML/trades/trade[@id = $contractRef]/tradeBody/*/payout/option/mutualBreakSchedule/exercizeEvents/exercizeEvent[1]/exercizeEffectiveDate, ',format:yyyymmdd,outputFormat:yyyy-mm-dd'))"
                            />
						</xsl:when>
						<xsl:otherwise>
							<xsl:choose>
								<xsl:when
                                    test="string-length(/MxML/trades/trade[@id = $contractRef]/tradeBody/*/payout/option/mutualBreakSchedule/exercizeScheduleBuilder/exercizeStartDate) = 0">
									<xsl:value-of
                                        select="mx:execute-formula($FpMLDateFormula, concat('date:', /MxML/trades/trade[@id = $contractRef]/tradeBody/*/payout/option/mutualBreakSchedule/exercizeEvents/exercizeEvent[1]/exercizeEffectiveDate, ',format:yyyymmdd,outputFormat:yyyy-mm-dd'))"/>

								</xsl:when>
								<xsl:otherwise>
									<xsl:if
                                        test="string-length(/MxML/trades/trade[@id = $contractRef]/tradeBody/*/payout/option/mutualBreakSchedule/exercizeScheduleBuilder/exercizeStartDate) &gt; 0">
										<xsl:value-of
                                            select="mx:execute-formula($FpMLDateFormula, concat('date:', /MxML/trades/trade[@id = $contractRef]/tradeBody/*/payout/option/mutualBreakSchedule/exercizeScheduleBuilder/exercizeStartDate, ',format:yyyymmdd,outputFormat:yyyy-mm-dd'))"
                                        />
									</xsl:if>
								</xsl:otherwise>
							</xsl:choose>
						</xsl:otherwise>
					</xsl:choose>
				</xsl:when>
				<xsl:otherwise>
					<xsl:if
                        test="string-length(/MxML/trades/trade[@id = $contractRef]/tradeBody/*/payout/option/mutualBreakSchedule/exercizeScheduleBuilder/exercizeStartDate) &gt; 0">
						<xsl:value-of
                            select="mx:execute-formula($FpMLDateFormula, concat('date:', /MxML/trades/trade[@id = $contractRef]/tradeBody/*/payout/option/mutualBreakSchedule/exercizeScheduleBuilder/exercizeStartDate, ',format:yyyymmdd,outputFormat:yyyy-mm-dd'))"/>

					</xsl:if>
				</xsl:otherwise>
			</xsl:choose>
		</xsl:variable>
		<xsl:if test="string-length($unadjustedDate) &gt; 0">
			<unadjustedDate>
				<xsl:value-of select="$unadjustedDate"/>
			</unadjustedDate>
		</xsl:if>
	</xsl:variable>

	<xsl:variable name="optionalEarlyTerminationModel.dateAdjustments.businessDayConvention">
		<xsl:variable name="businessDayConventionTmpMx">
			<xsl:choose>
				<xsl:when
                    test="/MxML/trades/trade[(not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeBody/*/payout/option/mutualBreakSchedule/exercizeScheduleBuilder/exercizeStreamSchedule/scheduleGenerator/standardScheduleGenerator/businessDayConvention">
					<xsl:variable name="businessDayConventionTmpMxTmp">
						<xsl:value-of
                            select="/MxML/trades/trade[(not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeBody/*/payout/option/mutualBreakSchedule/exercizeScheduleBuilder/exercizeStreamSchedule/scheduleGenerator/standardScheduleGenerator/businessDayConvention"
                        />
					</xsl:variable>
					<xsl:value-of
                        select="concat('businessDayConvention:', normalize-space($businessDayConventionTmpMxTmp))"
                    />
				</xsl:when>
				<xsl:otherwise>
					<xsl:value-of select="$swapStream1.paramBusinessDayConvention"/>
				</xsl:otherwise>
			</xsl:choose>
		</xsl:variable>
		<xsl:variable name="businessDayConventionMx">
			<xsl:value-of select="$businessDayConventionTmpMx"/>
		</xsl:variable>
		<xsl:variable name="businessDayConventionTmp">
			<xsl:value-of
                select="mx:execute-formula($mapBusinessDayConv, $businessDayConventionMx)"
            />
		</xsl:variable>
		<xsl:value-of select="$businessDayConventionTmp"/>
	</xsl:variable>

	<xsl:variable name="earlyTerminationProvision.cashSettlementPaymentDate.businessCenter.nodes">
		<xsl:choose>
			<xsl:when
                test="/MxML/trades/trade/tradeBody/*/payout/option/mutualBreakSchedule/exercizeScheduleBuilder/exercizeLegNature = 'floating'">
				<xsl:choose>
					<xsl:when
                        test="$leg1.payoutType = 'floatingRate' and $leg2.payoutType = 'floatingRate'">
						<xsl:copy-of select="$swapStream1.paymentBusinessCenter.nodes"/>
					</xsl:when>
					<xsl:when
                        test="$leg1.payoutType = 'floatingRate' and $leg2.payoutType != 'floatingRate'">
						<xsl:copy-of select="$swapStream1.paymentBusinessCenter.nodes"/>
					</xsl:when>
					<xsl:when
                        test="$leg1.payoutType != 'floatingRate' and $leg2.payoutType = 'floatingRate'">
						<xsl:copy-of select="$swapStream2.paymentBusinessCenter.nodes"/>
					</xsl:when>
				</xsl:choose>
			</xsl:when>
			<xsl:otherwise>
				<xsl:choose>
					<xsl:when
                        test="$leg1.payoutType = 'floatingRate' and $leg2.payoutType = 'floatingRate'">
						<xsl:copy-of select="$swapStream1.paymentBusinessCenter.nodes"/>
					</xsl:when>
					<xsl:when test="$leg1.payoutType = 'fixedRate'">
						<xsl:copy-of select="$swapStream1.paymentBusinessCenter.nodes"/>
					</xsl:when>
					<xsl:when test="$leg2.payoutType = 'fixedRate'">
						<xsl:copy-of select="$swapStream2.paymentBusinessCenter.nodes"/>
					</xsl:when>
					<xsl:otherwise/>
				</xsl:choose>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<xsl:variable name="mandatoryEarlyTerminationModel.unadjustedDate">
		<xsl:variable name="mandatoryEarlyTerminationModel.unadjustedDateTmp">
			<xsl:choose>
				<xsl:when
                    test="$isMandatoryEarlyTermination = 'false' and string-length(/MxML/trades/trade[@id = $contractRef]/tradeBody/*/payout/option/mutualBreakSchedule/exercizeEvents/exercizeEvent[1]/exercizeDate) &gt; 0">
					<xsl:value-of
                        select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/payout/option/mutualBreakSchedule/exercizeEvents/exercizeEvent[1]/exercizeDate"
                    />
				</xsl:when>
				<xsl:when
                    test="$isMandatoryEarlyTermination = 'true' and string-length(/MxML/trades/trade[@id = $contractRef]/tradeBody/*/payout/option/mutualBreakSchedule/exercizeEvents/exercizeEvent[1]/exercizeEffectiveDate) &gt; 0">
					<xsl:value-of
                        select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/payout/option/mutualBreakSchedule/exercizeEvents/exercizeEvent[1]/exercizeEffectiveDate"
                    />
				</xsl:when>
				<xsl:when
                    test="string-length(/MxML/trades/trade[@id = $contractRef]/tradeBody/*/payout/option/mutualBreakSchedule/exercizeScheduleBuilder/exercizeStartDate) &gt; 0">
					<xsl:value-of
                        select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/payout/option/mutualBreakSchedule/exercizeScheduleBuilder/exercizeStartDate"
                    />
				</xsl:when>
			</xsl:choose>
		</xsl:variable>
		<xsl:if test="string-length($mandatoryEarlyTerminationModel.unadjustedDateTmp) &gt; 0">
			<xsl:value-of
                select="mx:execute-formula('mx.xml2xml.transform.mxml2fpml.utils.toFpMLDate', concat('mxmlDate:', $mandatoryEarlyTerminationModel.unadjustedDateTmp))"
            />
		</xsl:if>
	</xsl:variable>

	<xsl:variable name="isMandatoryEarlyTermination">
		<xsl:variable name="nbOpt">
			<xsl:for-each
                select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/payout/option/mutualBreakSchedule/exercizeEvents/exercizeEvent">
				<xsl:variable name="optionalBreakClause" select="optionalBreakClause"/>
				<xsl:if test="$optionalBreakClause = 'Optional'">
					<xsl:value-of select="'1'"/>
				</xsl:if>
			</xsl:for-each>
		</xsl:variable>
		<xsl:choose>
			<xsl:when test="string-length($nbOpt) &gt; 0">
				<xsl:value-of select="'false'"/>
			</xsl:when>
			<xsl:when
                test="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/payout/option/mutualBreakSchedule">
				<xsl:value-of select="'true'"/>
			</xsl:when>
		</xsl:choose>
	</xsl:variable>

	<xsl:variable name="mandatoryEarlyTerminationModel.calculationAgentParty">
		<xsl:value-of select="'AsSpecifiedInMasterAgreement'"/>
	</xsl:variable>

	<xsl:variable name="mxmlProduct">
		<xsl:value-of select="local-name(/MxML/trades/trade[1]/tradeBody/*[1])"/>
	</xsl:variable>

	<xsl:variable name="bondSecurityLabel">
		<xsl:value-of select="/MxML/trades/trade[1]/tradeBody/bond/securityId/securityLabel"/>
	</xsl:variable>

	<!-- ========================================= -->
	<!-- Partial Termination - Xccy NotionalAmount -->
	<!-- ========================================= -->
	<!-- unwoundRatio -->
	<xsl:variable name="unwoundRatio">
		<xsl:call-template name="extract-UnwoundRatio"/>
	</xsl:variable>

	<!-- nonUnwoundRatio -->
	<xsl:variable name="nonUnwoundRatio">
		<xsl:value-of select="number(1 - $unwoundRatio)"/>
	</xsl:variable>

	<!-- referenceCapitalCurrency -->
	<xsl:variable name="referenceCapitalCurrency">
		<xsl:value-of
            select="/MxML/trades/trade/tradeBody/*/stream[1]/capital/referenceCapitalCurrency"/>
	</xsl:variable>

	<!-- referenceCapitalCurrency -->
	<xsl:variable name="oldReferenceCapitalCurrency">
		<xsl:value-of
            select="/MxML/trades/trade[2]/tradeBody/*/stream[1]/capital/referenceCapitalCurrency"/>
	</xsl:variable>

	<!-- feeCurrency -->
	<xsl:variable name="feeCurrency">
		<xsl:choose>
			<xsl:when
                test="/MxML/trades/trade/operations/operation/operationSettlementFlows/settlementFlow/flow/currency[../flowType != 'C']">
				<xsl:value-of
                    select="/MxML/trades/trade/operations/operation/operationSettlementFlows/settlementFlow/flow/currency[../flowType != 'C']"
                />
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="$referenceCapitalCurrency"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<!-- fee currency exchange -->
	<xsl:variable name="isFeeCurrencyExchange">
		<xsl:choose>
			<xsl:when
                test="$feeCurrency != $referenceCapitalCurrency and count(/MxML/trades/trade/operations/operation/operationSettlementFlows/settlementFlow/flow) &gt; 2">
				<xsl:value-of select="'yes'"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="'no'"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<!-- capital exchange -->
	<xsl:variable name="isCaptitalExchange">
		<xsl:choose>
			<xsl:when
                test="count(/MxML/trades/trade/operations/operation/operationSettlementFlows/settlementFlow/flow) &lt; 2">
				<xsl:value-of select="'no'"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="'yes'"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<!--- initialCapitalAmount -->
	<xsl:variable name="initialCapitalAmount">
		<xsl:choose>
			<xsl:when
                test="/MxML/trades/trade/tradeBody/*/stream[1]/capital/initialCapitalCurrency != MxML/trades/trade/tradeBody/*/stream[1]/capital/referenceCapitalCurrency">
				<xsl:value-of
                    select="/MxML/trades/trade/tradeBody/*/stream[1]/capital/initialCapitalAmount"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of
                    select="/MxML/trades/trade/tradeBody/*/stream[2]/capital/initialCapitalAmount"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<!--- referenceCapitalAmount -->
	<xsl:variable name="referenceCapitalAmount">
		<xsl:value-of
            select="/MxML/trades/trade/tradeBody/*/stream[1]/capital/referenceCapitalAmount"/>
	</xsl:variable>

	<xsl:variable name="secondNotionalAmount"
        select="/MxML/contractEvents/contractEvent/contractEventFlows/contractEventFlow[3]/contractEventFlowBody/cashFlow/amount"/>

	<!-- settlementCurrency -->
	<xsl:variable name="settlementCurrency">
		<xsl:choose>
			<xsl:when test="$isFeeCurrencyExchange = 'no'">
				<xsl:value-of select="$referenceCapitalCurrency"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="$feeCurrency"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<!-- observedRate -->
	<xsl:variable name="observedRate">
		<!-- default Currency in Flow -->
		<xsl:variable name="obsRteDefault">
			<xsl:value-of select="number($initialCapitalAmount div $referenceCapitalAmount)"/>
		</xsl:variable>

		<!-- capital conversion -->
		<xsl:variable name="obsRte">
			<xsl:value-of
                select="number(/MxML/trades/trade[(not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeBody/*/stream[./streamTemplate/payoutType = 'floatingRate']/indexationLists/indexationList/indexationSchedules/indexationSchedule/indexations/indexation[1]/observedRate)"
            />
		</xsl:variable>

		<xsl:choose>
			<xsl:when test="contains($typology, 'Xccy') = 'true'">
				<xsl:choose>
					<xsl:when test="$isFeeCurrencyExchange = 'no'">
						<xsl:value-of select="$obsRteDefault"/>
					</xsl:when>
					<xsl:otherwise>
						<xsl:choose>
							<xsl:when test="$obsRte != 'NaN' and $isCaptitalExchange = 'yes'">
								<xsl:value-of select="$obsRte"/>
							</xsl:when>
							<xsl:otherwise>
								<xsl:value-of
                                    select="number($referenceCapitalAmount div $initialCapitalAmount)"
                                />
							</xsl:otherwise>
						</xsl:choose>
					</xsl:otherwise>
				</xsl:choose>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="1"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<!-- changeInNotionalAmount : impactQuantity (1st current live quantity) -->
	<xsl:variable name="impactQuantity">
		<xsl:call-template name="extract-impactQuantity"/>
	</xsl:variable>

	<xsl:variable name="impactInitialQuantity">
		<xsl:call-template name="extract-impactInitialQuantity"/>
	</xsl:variable>

	<xsl:variable name="isFullTermination">
		<xsl:choose>
			<xsl:when
                test="number(/MxML/trades/trade[(not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeHeader/tradeProcessing/remainingLiveQuantity) &gt; 0 and number(/MxML/trades/trade[(not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeHeader/tradeProcessing/nonUnwoundRatio) &gt; 0">
				<xsl:value-of select="'no'"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="'yes'"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<!-- changeInNotionalAmount : impactSecondQuantity (2nd current live quantity) -->
	<xsl:variable name="impactSecondQuantity">
		<xsl:value-of select="format-number($impactQuantity * $observedRate, '##.########')"/>
	</xsl:variable>

	<!-- settlementSecondCurrency -->
	<xsl:variable name="settlementSecondCurrency">
		<xsl:choose>
			<xsl:when test="contains($typology, 'Xccy') = 'true'">
				<xsl:choose>
					<xsl:when
                        test="count(/MxML/trades/trade/operations/operation/operationSettlementFlows/settlementFlow/flow) &lt; 2">
						<xsl:value-of
                            select="/MxML/trades/trade[(not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeBody/*/stream[./streamTemplate/paymentCurrency != $settlementCurrency]/streamTemplate/paymentCurrency"
                        />
					</xsl:when>
					<xsl:otherwise>
						<xsl:choose>
							<xsl:when
                                test="/MxML/trades/trade/tradeBody/*/stream[1]/capital/initialCapitalCurrency != $settlementCurrency">
								<xsl:value-of
                                    select="/MxML/trades/trade/tradeBody/*/stream[1]/capital/initialCapitalCurrency"
                                />
							</xsl:when>
							<xsl:otherwise>
								<xsl:value-of
                                    select="/MxML/trades/trade/tradeBody/*/stream[2]/capital/initialCapitalCurrency"
                                />
							</xsl:otherwise>
						</xsl:choose>
					</xsl:otherwise>
				</xsl:choose>
			</xsl:when>
			<xsl:otherwise/>
		</xsl:choose>
	</xsl:variable>

	<!-- SwapStream1 notional is taken the remaining live quantity in case of an amendment events like restructure -->
	<xsl:variable name="swapStream1.notionalSchedule.remainingLiveQuantity">
		<xsl:variable name="effectiveDate">
			<xsl:call-template name="extract-postTradeEffectiveDate">
				<xsl:with-param name="legNb" select="$trdNb"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:variable name="tmp">
			<xsl:value-of
                select="/MxML/trades/trade[number($trdNb)]/tradeBody/*/stream[1]/cashFlows/interestFlows/interestPaymentPeriod[calculationPeriod/calculationStartDate &lt;= $effectiveDate and calculationPeriod/calculationEndDate &gt; $effectiveDate]//calculationPeriod/notionalAmount"
            />
		</xsl:variable>
		<xsl:choose>
			<xsl:when test="string-length($tmp) &gt; 0 and $tmp != '0.' and $tmp != '0'">
				<xsl:value-of select="$tmp"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:call-template name="extract-initialCapitalAmount">
					<xsl:with-param name="legNb" select="$trdNb"/>
					<xsl:with-param name="stream" select="1"/>
				</xsl:call-template>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<!-- SwapStream2 notional is the remaining live quantity in case of an amendment events like restructure -->
	<xsl:variable name="swapStream2.notionalSchedule.remainingLiveQuantity">
		<xsl:variable name="effectiveDate">
			<xsl:call-template name="extract-postTradeEffectiveDate">
				<xsl:with-param name="legNb" select="$trdNb"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:variable name="tmp">
			<xsl:value-of
                select="/MxML/trades/trade[number($trdNb)]/tradeBody/*/stream[2]/cashFlows/interestFlows/interestPaymentPeriod[calculationPeriod/calculationStartDate &lt;= $effectiveDate and calculationPeriod/calculationEndDate &gt; $effectiveDate]//calculationPeriod/notionalAmount"
            />
		</xsl:variable>
		<xsl:choose>
			<xsl:when test="string-length($tmp) &gt; 0 and $tmp != '0.' and $tmp != '0'">
				<xsl:value-of select="$tmp"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:call-template name="extract-initialCapitalAmount">
					<xsl:with-param name="legNb" select="$trdNb"/>
					<xsl:with-param name="stream" select="2"/>
				</xsl:call-template>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<xsl:variable name="indexCategory">
		<xsl:choose>
			<xsl:when test="$leg1.payoutType = 'floatingRate'">
				<xsl:call-template name="extract-indexCategory">
					<xsl:with-param name="legNb" select="1"/>
					<xsl:with-param name="stream" select="1"/>
				</xsl:call-template>
			</xsl:when>
			<xsl:otherwise>
				<xsl:call-template name="extract-indexCategory">
					<xsl:with-param name="legNb" select="1"/>
					<xsl:with-param name="stream" select="2"/>
				</xsl:call-template>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<xsl:variable name="swapStream1.indexCategory">
		<xsl:if test="$leg1.payoutType = 'floatingRate'">
			<xsl:call-template name="extract-indexCategory">
				<xsl:with-param name="legNb" select="1"/>
				<xsl:with-param name="stream" select="1"/>
			</xsl:call-template>
		</xsl:if>
	</xsl:variable>

	<xsl:variable name="swapStream2.indexCategory">
		<xsl:if test="$leg2.payoutType = 'floatingRate'">
			<xsl:call-template name="extract-indexCategory">
				<xsl:with-param name="legNb" select="1"/>
				<xsl:with-param name="stream" select="2"/>
			</xsl:call-template>
		</xsl:if>
	</xsl:variable>

	<!-- Mutual Break Mode -->
	<xsl:variable name="mutualBreakMode">
		<xsl:call-template name="extract-mutualBreakMode"/>
	</xsl:variable>

	<xsl:variable name="indexCategoryIndexation">
		<xsl:variable name="result">
			<xsl:call-template name="extract-indexation-indexCategory">
				<xsl:with-param name="legNb" select="$trdNb"/>
				<xsl:with-param name="stream" select="1"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:choose>
			<xsl:when test="string-length($result) &gt; 0">
				<xsl:value-of select="$result"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:call-template name="extract-indexation-indexCategory">
					<xsl:with-param name="legNb" select="$trdNb"/>
					<xsl:with-param name="stream" select="2"/>
				</xsl:call-template>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>
	<xsl:variable name="swapStream1.isInflationIndexed">
		<xsl:value-of
            select="string-length($indexCategoryIndexation) &gt; 0 and $indexCategoryIndexation = 'inflationIndex' and string-length($swapStream1.indexedObjectNature) &gt; 0 and $swapStream1.indexedObjectNature = 'interestFlows'"
        />
	</xsl:variable>
	<xsl:variable name="swapStream2.isInflationIndexed">
		<xsl:value-of
            select="string-length($indexCategoryIndexation) &gt; 0 and $indexCategoryIndexation = 'inflationIndex' and string-length($swapStream2.indexedObjectNature) &gt; 0 and $swapStream2.indexedObjectNature = 'interestFlows'"
        />
	</xsl:variable>

	<xsl:variable name="swapStream1.id">
		<xsl:choose>
			<xsl:when
                test="$swapStream1.isInflationIndexed = 'true' and $leg1.payoutType = 'fixedRate'">
				<!--For Inflation Asset swap asset leg, it is always floating -->
				<xsl:value-of select="'floatingLeg'"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:choose>
					<!--Basis swap-->
					<xsl:when
                        test="$leg1.payoutType = 'floatingRate' and $leg2.payoutType = 'floatingRate'">
						<xsl:value-of select="'floatingLeg'"/>
					</xsl:when>
					<xsl:when
                        test="$leg2.payoutType = 'fixedRate' and $leg1.payoutType = 'fixedRate'">
						<xsl:value-of select="'fixedLeg'"/>
					</xsl:when>
					<xsl:when test="$leg1.payoutType = 'fixedRate'">
						<xsl:value-of select="'fixedLeg'"/>
					</xsl:when>
					<xsl:when test="$leg1.payoutType = 'floatingRate'">
						<xsl:value-of select="'floatingLeg'"/>
					</xsl:when>
					<xsl:otherwise>
						<xsl:value-of select="$leg1.payoutType"/>
					</xsl:otherwise>
				</xsl:choose>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<!-- ===================== -->
	<!-- SWAP STREAM 2 -->
	<!-- ===================== -->
	<xsl:variable name="swapStream2.id">
		<xsl:choose>
			<xsl:when
                test="$swapStream2.isInflationIndexed = 'true' and $leg2.payoutType = 'fixedRate'">
				<!--For Inflation Asset swap, it is always floating -->
				<xsl:choose>
					<xsl:when test="$swapStream1.id = 'floatingLeg'">
						<xsl:value-of select="'floatingLeg2'"/>
					</xsl:when>
					<xsl:otherwise>
						<xsl:value-of select="'floatingLeg'"/>
					</xsl:otherwise>
				</xsl:choose>
			</xsl:when>
			<xsl:otherwise>
				<xsl:choose>
					<!--Basis swap-->
					<xsl:when
                        test="$leg2.payoutType = 'floatingRate' and ($leg1.payoutType = 'floatingRate' or $swapStream1.id = 'floatingLeg')">
						<xsl:value-of select="'floatingLeg2'"/>
					</xsl:when>
					<xsl:when
                        test="$leg1.payoutType = 'fixedRate' and $leg2.payoutType = 'fixedRate'">
						<xsl:value-of select="'fixedLeg2'"/>
					</xsl:when>
					<xsl:when test="$leg2.payoutType = 'fixedRate'">
						<xsl:value-of select="'fixedLeg'"/>
					</xsl:when>
					<xsl:when test="$leg2.payoutType = 'floatingRate'">
						<xsl:value-of select="'floatingLeg'"/>
					</xsl:when>
					<xsl:otherwise>
						<xsl:value-of select="$leg2.payoutType"/>
					</xsl:otherwise>
				</xsl:choose>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>


	<xsl:variable name="swapStream1.inflationRate.interpolationMethod">
		<xsl:if
            test="$indexCategory = 'inflationIndex' or $typology = 'Inflation Swap' or $Mxgroup = 'INFLS' or $swapStream1.isInflationIndexed = 'true'">
			<xsl:variable name="interpolationMethodMX">
				<xsl:call-template name="extract-return-interpolation">
					<xsl:with-param name="legNb" select="1"/>
					<xsl:with-param name="stream" select="1"/>
				</xsl:call-template>
			</xsl:variable>
			<xsl:if test="string-length($interpolationMethodMX) &gt; 0">
				<xsl:variable name="result"
                    select="mx:execute-formula($mapInterpolationMethod, concat('interpolation:', $interpolationMethodMX))"/>
				<xsl:call-template name="AssertNotMapped">
					<xsl:with-param name="value" select="$result"/>
					<xsl:with-param name="message"
                        select="concat('Interpolation method ', $interpolationMethodMX, ' not mapped')"/>
					<xsl:with-param name="formula" select="$mapInterpolationMethod"/>
				</xsl:call-template>
				<xsl:value-of select="$result"/>
			</xsl:if>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="swapStream2.inflationRate.interpolationMethod">
		<xsl:if
            test="$indexCategory = 'inflationIndex' or $typology = 'Inflation Swap' or $Mxgroup = 'INFLS' or $swapStream2.isInflationIndexed = 'true'">
			<xsl:variable name="interpolationMethodMX">
				<xsl:call-template name="extract-return-interpolation">
					<xsl:with-param name="legNb" select="1"/>
					<xsl:with-param name="stream" select="2"/>
				</xsl:call-template>
			</xsl:variable>
			<xsl:if test="string-length($interpolationMethodMX) &gt; 0">
				<xsl:variable name="result"
                    select="mx:execute-formula($mapInterpolationMethod, concat('interpolation:', $interpolationMethodMX))"/>
				<xsl:call-template name="AssertNotMapped">
					<xsl:with-param name="value" select="$result"/>
					<xsl:with-param name="message"
                        select="concat('Interpolation method ', $interpolationMethodMX, ' not mapped')"/>
					<xsl:with-param name="formula" select="$mapInterpolationMethod"/>
				</xsl:call-template>
				<xsl:value-of select="$result"/>
			</xsl:if>
		</xsl:if>
	</xsl:variable>

	<xsl:template name="create-paymentCalculationPeriod-nodes">
		<xsl:param name="legNb" select="'1'"/>
		<xsl:param name="stream" select="'1'"/>
		<xsl:variable name="streamHasFxLinkedNotional"
            select="my:streamHasFxLinkedNotional($stream)"/>
		<xsl:variable name="indexationIndex"
            select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[$stream]/streamTemplate/indexationRulesLists/indexationRulesList/indexationRules/indexationRule/index/indexLabel"/>
		<xsl:variable name="FpMLDateFormula" select="'mx.xml2xml.ECN.common.utils.adaptDate'"/>
		<xsl:variable name="streamPayerParty"
            select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[$stream]/payerPartyReference/@href"/>
		<xsl:variable name="legNumber"
            select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[$stream]/streamTemplate/leg"/>
		<!-- For Restructure, Unwind, Party Assignment & Fixing events: generate past settled IR cashflows -->
		<xsl:if
            test="$event = 'restructure' or $event = 'unwind' or $event = 'partyAssignment' or $event = 'fixingEvent'">
			<xsl:apply-templates
                select="/MxML/trades/trade[@id = $contractRef]/tradeBody/inheritedFlows/inheritedFlow[leg = $legNumber and flow/amount != 0 and flowTypologies/flowTypology[label = 'Typology0']/value = 'REV' and flowTypologies/flowTypology[label = 'Typology1']/value = 'CPN']">
				<xsl:with-param name="streamPayerPartyReference" select="$streamPayerParty"/>
			</xsl:apply-templates>
		</xsl:if>
		<xsl:variable name="pfolioAssignmentOffset">
			<xsl:variable name="temp">
				<xsl:value-of select="count(/MxML/trades/trade[@id = 	$contractRef]/tradeBody/*/stream[position()=$stream]/indexationLists/indexationList[indexedObjectNature='outstandingCapital']/indexationSchedules/indexationSchedule/indexations/indexation ) 
       				- 
				count(/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[position()=$stream]/cashFlows/interestFlows/interestPaymentPeriod)"/>
			</xsl:variable>
			<xsl:choose>
				<xsl:when test="number($temp) &gt; 0">
					<xsl:value-of select="$temp"/>
				</xsl:when>
				<xsl:otherwise>
					<xsl:value-of select="'0'"/>
				</xsl:otherwise>
			</xsl:choose>
		</xsl:variable>

		<xsl:for-each
            select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[$stream]/cashFlows/interestFlows/interestPaymentPeriod">
			<xsl:variable name="position" select="position()"/>
			<xsl:variable name="observedRate">
				<xsl:value-of
                    select="calculationPeriod/floatingRatePeriod/observations/observation/observedRate"
                />
			</xsl:variable>
			<xsl:variable name="mxmlObservationDate">
				<xsl:choose>
					<xsl:when test="calculationPeriod/floatingRatePeriod">
						<xsl:value-of
                            select="calculationPeriod/floatingRatePeriod/observations/observation/observationDate"
                        />
					</xsl:when>
					<xsl:otherwise>
						<xsl:value-of
                            select="../../../indexationLists/indexationList/indexationSchedules/indexationSchedule/indexations/indexation[position() = (number($position) + number($pfolioAssignmentOffset))]/date"
                        />
					</xsl:otherwise>
				</xsl:choose>
			</xsl:variable>
			<xsl:variable name="mxmlFxObservationDate">
				<xsl:value-of
                    select="../../../indexationLists/indexationList/indexationSchedules/indexationSchedule/indexations/indexation[position() = (number($position) + number($pfolioAssignmentOffset))]/date"/>
			</xsl:variable>			
			<xsl:variable name="observationDate">
				<xsl:value-of
                    select="mx:execute-formula($FpMLDateFormula, concat('date:', $mxmlObservationDate, ',format:yyyymmdd,outputFormat:yyyy-mm-dd'))"
                />
			</xsl:variable>
			<xsl:variable name="fxObservationDate">
				<xsl:value-of
                    select="mx:execute-formula($FpMLDateFormula, concat('date:', $mxmlFxObservationDate, ',format:yyyymmdd,outputFormat:yyyy-mm-dd'))"
                />
			</xsl:variable>

			<paymentCalculationPeriod>
				<adjustedPaymentDate>
					<xsl:value-of
                        select="mx:execute-formula($FpMLDateFormula, concat('date:', paymentDate, ',format:yyyymmdd,outputFormat:yyyy-mm-dd'))"
                    />
				</adjustedPaymentDate>
				<xsl:choose>
					<xsl:when
                        test="string-length(./calculationPeriod/contributionFlows/contributionFlow/calculationPeriod) &gt; 0 and ./calculationPeriod/notionalAmount &gt; 0">
						<xsl:for-each
                            select="./calculationPeriod/contributionFlows/contributionFlow/calculationPeriod">

							<xsl:if
                                test="string-length(../../../floatingRatePeriod) &gt; 0 or string-length(../../../fixedRatePeriod) &gt; 0">
								<xsl:variable name="unStartDate">
									<xsl:choose>
										<xsl:when
                                            test="string-length(../../../unadjustedStartDate) &gt; 0">
											<xsl:value-of
                                                select="mx:execute-formula($FpMLDateFormula, concat('date:', ../../../unadjustedStartDate, ',format:yyyymmdd,outputFormat:yyyy-mm-dd'))"
                                            />
										</xsl:when>
										<xsl:otherwise>
											<xsl:value-of
                                                select="mx:execute-formula($FpMLDateFormula, concat('date:', calculationStartDate, ',format:yyyymmdd,outputFormat:yyyy-mm-dd'))"
                                            />
										</xsl:otherwise>
									</xsl:choose>
								</xsl:variable>
								<xsl:variable name="unEndDate">
									<xsl:choose>
										<xsl:when
                                            test="string-length(../../../unadjustedEndDate) &gt; 0">
											<xsl:value-of
                                                select="mx:execute-formula($FpMLDateFormula, concat('date:', ../../../unadjustedEndDate, ',format:yyyymmdd,outputFormat:yyyy-mm-dd'))"
                                            />
										</xsl:when>
										<xsl:otherwise>
											<xsl:value-of
                                                select="mx:execute-formula($FpMLDateFormula, concat('date:', calculationEndDate, ',format:yyyymmdd,outputFormat:yyyy-mm-dd'))"
                                            />
										</xsl:otherwise>
									</xsl:choose>
								</xsl:variable>
								<calculationPeriod>
									<unadjustedStartDate>
										<xsl:value-of select="$unStartDate"/>
									</unadjustedStartDate>
									<unadjustedEndDate>
										<xsl:value-of select="$unEndDate"/>
									</unadjustedEndDate>
									<adjustedStartDate>
										<xsl:value-of
                                            select="mx:execute-formula($FpMLDateFormula, concat('date:', calculationStartDate, ',format:yyyymmdd,outputFormat:yyyy-mm-dd'))"
                                        />
									</adjustedStartDate>
									<adjustedEndDate>
										<xsl:value-of
                                            select="mx:execute-formula($FpMLDateFormula, concat('date:', calculationEndDate, ',format:yyyymmdd,outputFormat:yyyy-mm-dd'))"
                                        />
									</adjustedEndDate>
									<xsl:call-template name="createNotionalAmount">
										<xsl:with-param name="streamNumber" select="1"/>
										<xsl:with-param name="isFxLinked"
                                            select="$streamHasFxLinkedNotional"/>
										<xsl:with-param name="observationDate"
                                            select="$fxObservationDate"/>
										<xsl:with-param name="mxmlObservationDate"
                                            select="$mxmlFxObservationDate"/>
										<xsl:with-param name="indexationIndex"
                                            select="$indexationIndex"/>
									</xsl:call-template>
									<xsl:if test="string-length(../../../floatingRatePeriod) &gt; 0">
										<floatingRateDefinition>
											<xsl:if
                                                test="
                                                    string-length(../../../floatingRatePeriod/observations/observation/observedRate) &gt; 0
                                                    and ../../../floatingRatePeriod/observations/observation/observationDate &lt;=
                                                    /MxML/trades/trade[@id = $contractRef]/tradeInputConditions/systemDate">
												<xsl:if
                                                  test="
                                                        $indexCategory = 'inflationIndex' or $typology = 'Inflation Swap' or $Mxgroup = 'INFLS' or
                                                        ($stream = 1 and $swapStream1.isInflationIndexed = 'true') or ($stream = 2 and $swapStream2.isInflationIndexed = 'true')">
													<!--For Inflation Zero Coupon, there is no spread (margin)in floating leg
													Equation: marginFlow = MarginFlowBasedOnSpread + MarginFlowBasedOnObservation
																		 = notionalAmount x Spread x Y + notionalAmount x MxMLObservedRate/100
													Can be simplified to: marginFlow = notionalAmount x MxMLObservedRate/100 ==> calculatedRate = MxMLObservedRate/100 -->
													<calculatedRate>
														<xsl:value-of
                                                  select="format-number(../../../floatingRatePeriod/observations/observation/observedRate div 100, '##.##########')"
                                                  />
													</calculatedRate>
												</xsl:if>
											</xsl:if>
											<xsl:choose>
												<xsl:when
                                                  test="($stream = 1 and $swapStream1.indexCategory = 'inflationIndex') or ($stream = 2 and $swapStream2.indexCategory = 'inflationIndex')">
													<xsl:choose>
														<xsl:when
                                                  test="($stream = 1 and $swapStream1.inflationRate.interpolationMethod != 'None') or ($stream = 2 and $swapStream2.inflationRate.interpolationMethod != 'None')">
															<xsl:for-each
                                                  select="../../../floatingRatePeriod/observations/observation/contributingObservations/observation">
																<xsl:variable name="adjustedFixingDate">
																	<xsl:value-of
                                                  select="mx:execute-formula($FpMLDateFormula, concat('date:', effectiveObservationDate, ',format:yyyymmdd,outputFormat:yyyy-mm-dd'))"
                                                  />
																</xsl:variable>
																<xsl:for-each
                                                  select="contributingObservations/observation">
																	<xsl:if test="observationWeight &gt; 0">
																		<rateObservation>
																			<adjustedFixingDate>
																				<xsl:value-of select="$adjustedFixingDate"/>
																			</adjustedFixingDate>
																			<xsl:if test="string-length(observedRate) &gt; 0">
																				<observedRate>
																					<xsl:value-of
                                                  select="format-number(observedRate, '##.##########')"
                                                  />
																				</observedRate>
																			</xsl:if>
																			<observationWeight>
																				<!--observationWeight is 1) an Integer > 0 and is 2) a number of days weighting. 
																					This template is defined in: mx.xml2xml.transform.mxml2fpml.5-3.products.ird.utils.numberOfDaysByObservation-->
																				<xsl:call-template name="calculateDayBegMonth">
																					<xsl:with-param name="date"
                                                  select="../../observationDate"/>
																					<xsl:with-param name="position"
                                                  select="position()"/>
																				</xsl:call-template>

																			</observationWeight>
																		</rateObservation>
																	</xsl:if>
																</xsl:for-each>
															</xsl:for-each>
														</xsl:when>
														<xsl:otherwise>
															<xsl:for-each
                                                  select="../../../floatingRatePeriod/observations/observation/contributingObservations/observation">
																<xsl:if test="observationWeight &gt; 0">
																	<rateObservation>
																		<adjustedFixingDate>
																			<xsl:value-of
                                                  select="mx:execute-formula($FpMLDateFormula, concat('date:', effectiveObservationDate, ',format:yyyymmdd,outputFormat:yyyy-mm-dd'))"
                                                  />
																		</adjustedFixingDate>
																		<xsl:if test="string-length(observedRate) &gt; 0">
																			<observedRate>
																				<xsl:value-of
                                                  select="format-number(observedRate, '##.##########')"
                                                  />
																			</observedRate>
																		</xsl:if>
																		<observationWeight>
																			<xsl:value-of select="observationWeight"/>
																		</observationWeight>
																	</rateObservation>
																</xsl:if>
															</xsl:for-each>
														</xsl:otherwise>
													</xsl:choose>
												</xsl:when>
												<xsl:otherwise>
													<xsl:for-each
                                                  select="../../../floatingRatePeriod/observations/observation">
														<xsl:if test="observationWeight &gt; 0">
															<rateObservation>
																<adjustedFixingDate>
																	<xsl:value-of
                                                  select="mx:execute-formula($FpMLDateFormula, concat('date:', observationDate, ',format:yyyymmdd,outputFormat:yyyy-mm-dd'))"/>
																</adjustedFixingDate>
																<xsl:if test="string-length(observedRate) &gt; 0">
																	<observedRate>
																		<xsl:value-of
                                                  select="format-number(observedRate div 100, '##.##########')"
                                                  />
																	</observedRate>
																</xsl:if>
																<observationWeight>
																	<xsl:value-of select="observationWeight"/>
																</observationWeight>
															</rateObservation>
														</xsl:if>
													</xsl:for-each>
												</xsl:otherwise>
											</xsl:choose>
											<spread>
												<xsl:value-of
                                                  select="format-number(../../../floatingRatePeriod/margin div 100, '##.##########')"
                                                />
											</spread>

										</floatingRateDefinition>
									</xsl:if>
									<xsl:choose>
										<xsl:when
                                            test="($stream = 1 and $swapStream1.isInflationIndexed = 'true') or ($stream = 2 and $swapStream2.isInflationIndexed = 'true')">
											<floatingRateDefinition>
												<xsl:variable name="currentPaymentDate">
													<xsl:value-of select="../../../../paymentDate"/>
												</xsl:variable>
												<xsl:variable name="displayCalculatedRate">
													<xsl:choose>
														<xsl:when
                                                  test="
                                                                ../../../../../../../indexationLists/indexationList[indexedObjectNature = 'interestFlows']
                                                                /indexationSchedules/indexationSchedule/indexations/indexation[date = $currentPaymentDate]
                                                                /contributingIndexations/observation[position() = last]/date
                                                                &lt;=
                                                                /MxML/trades/trade[@id = $contractRef]/tradeInputConditions/systemDate
                                                                or 
                                                                ../../../../../../../indexationLists/indexationList[indexedObjectNature = 'interestFlows']
                                                                /indexationSchedules/indexationSchedule/indexations/indexation[date = $currentPaymentDate]
                                                                /contributingIndexations/indexation[position() = last]/date
                                                                &lt;=
                                                                /MxML/trades/trade[@id = $contractRef]/tradeInputConditions/systemDate">
															<xsl:value-of select="'true'"/>
														</xsl:when>
														<xsl:when
                                                  test="
                                                                (../../../../../../../indexationLists/indexationList[indexedObjectNature = 'interestFlows']
                                                                /indexationSchedules/indexationSchedule/indexations/indexation[date = $currentPaymentDate]
                                                                /effectiveObservationDate
                                                                &lt;=
                                                                /MxML/trades/trade[@id = $contractRef]/tradeInputConditions/systemDate)
                                                                and not(../../../../../../../indexationLists/indexationList[indexedObjectNature = 'interestFlows']
                                                                /indexationSchedules/indexationSchedule/indexations/indexation[date = $currentPaymentDate]
                                                                /contributingIndexations)">
															<xsl:value-of select="'true'"/>
														</xsl:when>
														<xsl:otherwise>
															<xsl:value-of select="'false'"/>
														</xsl:otherwise>
													</xsl:choose>
												</xsl:variable>
												<xsl:variable name="amount">
													<xsl:value-of
                                                  select="format-number(../../../../interestFlow, '##.##########')"
                                                  />
												</xsl:variable>
												<xsl:variable name="initial">
													<xsl:value-of select="notionalAmount"/>
												</xsl:variable>
												<xsl:if test="$displayCalculatedRate = 'true'">
													<calculatedRate>
														<xsl:choose>
															<xsl:when
                                                  test="$initial = '0' or $initial = '0.0'"
                                                  >0</xsl:when>
															<xsl:otherwise>
																<xsl:value-of
                                                  select="format-number($amount div $initial, '##.##########')"
                                                  />
															</xsl:otherwise>
														</xsl:choose>
													</calculatedRate>
												</xsl:if>
												<xsl:choose>
													<xsl:when
                                                  test="($stream = 1 and $swapStream1.inflationRate.interpolationMethod != 'None') or ($stream = 2 and $swapStream2.inflationRate.interpolationMethod != 'None')">
														<xsl:for-each
                                                  select="../../../../../../../indexationLists/indexationList[indexedObjectNature = 'interestFlows']/indexationSchedules/indexationSchedule/indexations/indexation">
															<xsl:variable name="yearDif"
                                                  select="substring($currentPaymentDate, 1, 4) - substring(date, 1, 4)"/>
															<xsl:if
                                                  test="$yearDif &lt;= 1 and $yearDif &gt;= -1">
																<xsl:variable name="numberOfDaysTmp">
																	<xsl:variable name="dif">
																		<xsl:call-template name="date:difference">
																			<xsl:with-param name="start" select="date"/>
																			<xsl:with-param name="end"
                                                  select="$currentPaymentDate"/>
																		</xsl:call-template>
																	</xsl:variable>
																	<xsl:variable name="length"
                                                  select="string-length($dif)"/>
																	<xsl:choose>
																		<xsl:when
                                                  test="contains(substring($dif, 2, ($length - 2)), 'P')">
																			<xsl:value-of
                                                  select="substring-after(substring($dif, 2, ($length - 2)), 'P')"
                                                  />
																		</xsl:when>
																		<xsl:otherwise>
																			<xsl:value-of
                                                  select="substring($dif, 2, ($length - 2))"/>
																		</xsl:otherwise>
																	</xsl:choose>
																</xsl:variable>
																<xsl:if
                                                  test="$numberOfDaysTmp &lt; 7 and $numberOfDaysTmp &gt; -7">
																	<xsl:variable name="sample.on.end.date">
																		<xsl:choose>
																			<xsl:when test="substring(referenceDate,7,2) = substring(contributingIndexations/observation[1]/date,7,2) or substring(referenceDate,7,2) = substring(contributingIndexations/indexation[1]/date,7,2)">
																				<xsl:value-of select="'true'"/>
																			</xsl:when>
																			<xsl:otherwise>
																				<xsl:value-of select="'false'"/>
																			</xsl:otherwise>
																		</xsl:choose>
																	</xsl:variable>
																	<xsl:variable name="obsWeight1">
																		<xsl:variable name="obsWeight2Temp">
																			<xsl:call-template name="calculateDayBegMonth">
																				<xsl:with-param name="date" select="referenceDate"/>
																				<xsl:with-param name="position" select="2"/>
																			</xsl:call-template>
																		</xsl:variable>
																		<xsl:choose>
																			<xsl:when test="$obsWeight2Temp = 0">1</xsl:when>
																			<xsl:otherwise>
																				<xsl:call-template name="calculateDayBegMonth">
																					<xsl:with-param name="date" select="referenceDate"/>
																					<xsl:with-param name="position" select="1"/>
																				</xsl:call-template>
																			</xsl:otherwise>
																		</xsl:choose>
																	</xsl:variable>
																	<xsl:variable name="obsWeight2">
																		<xsl:variable name="obsWeight1Temp">
																			<xsl:call-template name="calculateDayBegMonth">
																				<xsl:with-param name="date" select="referenceDate"/>
																				<xsl:with-param name="position" select="1"/>
																			</xsl:call-template>
																		</xsl:variable>
																		<xsl:choose>
																			<xsl:when test="$obsWeight1Temp = 0">1</xsl:when>
																			<xsl:otherwise>
																				<xsl:call-template name="calculateDayBegMonth">
																					<xsl:with-param name="date" select="referenceDate"/>
																					<xsl:with-param name="position" select="2"/>
																				</xsl:call-template>
																			</xsl:otherwise>
																		</xsl:choose>
																	</xsl:variable>
																	<xsl:if test="string-length(referenceRateDetails) &gt; 0 or string-length(referenceRate) &gt; 0">
																		<xsl:choose>
																			<xsl:when test="string-length(referenceRateDetails) &gt; 0">
																				<xsl:variable name="refDate1" select="referenceRateDetails/contributingIndexations/indexation[1]/date"/>
																				<xsl:variable name="refDate2" select="referenceRateDetails/contributingIndexations/indexation[2]/date"/>
																				<xsl:variable name="obsRate1" select="referenceRateDetails/contributingIndexations/indexation[1]/observedRate"/>
																				<xsl:variable name="obsRate2" select="referenceRateDetails/contributingIndexations/indexation[2]/observedRate"/>
																				<xsl:if test="$obsWeight1 != 0 and $sample.on.end.date = 'false'">
																					<rateObservation>
																						<adjustedFixingDate>
																							<xsl:value-of
																								select="mx:execute-formula($FpMLDateFormula, concat('date:',$refDate1 , ',format:yyyymmdd,outputFormat:yyyy-mm-dd'))"/>
																						</adjustedFixingDate>
																						<xsl:if
																							test="string-length($obsRate1) &gt; 0 and /MxML/trades/trade[@id = $contractRef]/tradeInputConditions/systemDate &gt;= $refDate1">
																							<observedRate>
																								<xsl:value-of select="format-number($obsRate1, '##.##########')"/>
																							</observedRate>
																						</xsl:if>
																						<observationWeight>
																							<xsl:value-of select="$obsWeight1"/>
																						</observationWeight>
																					</rateObservation>
																				</xsl:if>
																				<xsl:if test="$obsWeight2 != 0">
																					<rateObservation>
																						<adjustedFixingDate>
																							<xsl:value-of
