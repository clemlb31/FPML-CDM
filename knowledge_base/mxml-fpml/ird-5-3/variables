												../../../indexationLists/indexationList[indexedObjectNature = 'interestFlows']/indexationSchedules/indexationSchedule/indexations/indexation[substring(date,1,6)=substring($period.end.date,1,6)]/contributingIndexations/observation[1]/observedRate &gt; 0.0 and
												../../../indexationLists/indexationList[indexedObjectNature = 'interestFlows']/indexationSchedules/indexationSchedule/indexations/indexation[substring(date,1,6)=substring($period.end.date,1,6)]/contributingIndexations/observation[2]/observedRate &gt; 0.0  and 
												../../../indexationLists/indexationList[indexedObjectNature = 'interestFlows']/indexationSchedules/indexationSchedule/indexations/indexation[substring(date,1,6)=substring($period.end.date,1,6)]/contributingIndexations/observation[1]/date &lt; /MxML/trades/trade[@id = $contractRef]/tradeInputConditions/systemDate   and 
												../../../indexationLists/indexationList[indexedObjectNature = 'interestFlows']/indexationSchedules/indexationSchedule/indexations/indexation[substring(date,1,6)=substring($period.end.date,1,6)]/contributingIndexations/observation[2]/date &lt; /MxML/trades/trade[@id = $contractRef]/tradeInputConditions/systemDate
												or 
												../../../indexationLists/indexationList[indexedObjectNature = 'interestFlows']/indexationSchedules/indexationSchedule/indexations/indexation[substring(date,1,6)=substring($period.end.date,1,6)]/contributingIndexations/indexation[1]/observedRate &gt; 0.0 and
												../../../indexationLists/indexationList[indexedObjectNature = 'interestFlows']/indexationSchedules/indexationSchedule/indexations/indexation[substring(date,1,6)=substring($period.end.date,1,6)]/contributingIndexations/indexation[2]/observedRate &gt; 0.0  and 
												../../../indexationLists/indexationList[indexedObjectNature = 'interestFlows']/indexationSchedules/indexationSchedule/indexations/indexation[substring(date,1,6)=substring($period.end.date,1,6)]/contributingIndexations/indexation[1]/date &lt; /MxML/trades/trade[@id = $contractRef]/tradeInputConditions/systemDate   and 
												../../../indexationLists/indexationList[indexedObjectNature = 'interestFlows']/indexationSchedules/indexationSchedule/indexations/indexation[substring(date,1,6)=substring($period.end.date,1,6)]/contributingIndexations/indexation[2]/date &lt; /MxML/trades/trade[@id = $contractRef]/tradeInputConditions/systemDate
												">
													<xsl:value-of select="interestFlow"/>
												</xsl:when>
												<xsl:otherwise>
													<xsl:value-of select="0."/>
												</xsl:otherwise>
											</xsl:choose>							
										</xsl:when>
										<xsl:otherwise>
											<xsl:choose>
												<xsl:when test="
														../../../indexationLists/indexationList[indexedObjectNature = 'interestFlows']/indexationSchedules/indexationSchedule/indexations/indexation[substring(date,1,6)=substring($period.end.date,1,6)]/observedRate &gt; 0.0 	and 
														../../../indexationLists/indexationList[indexedObjectNature = 'interestFlows']/indexationSchedules/indexationSchedule/indexations/indexation[substring(date,1,6)=substring($period.end.date,1,6)]/effectiveObservationDate &lt; /MxML/trades/trade[@id = $contractRef]/tradeInputConditions/systemDate														
													">
													<xsl:value-of select="interestFlow"/>
												</xsl:when>
												<xsl:otherwise>
													<xsl:value-of select="0."/>											
												</xsl:otherwise>												
											</xsl:choose>											
										</xsl:otherwise>		
									</xsl:choose>
								</xsl:when>
								<xsl:otherwise>
									<xsl:value-of select="interestFlow"/>
								</xsl:otherwise>
							</xsl:choose>							
						</xsl:variable>
						<xsl:choose>
							<xsl:when
                                test="contains($amountTmp, '.') and string-length(substring-after($amountTmp, '.')) = 0">
								<xsl:value-of select="substring-before($amountTmp, '.')"/>
							</xsl:when>
							<xsl:when test="string-length($amountTmp) = 0">
								<xsl:value-of select="'0'"/>
							</xsl:when>
							<xsl:otherwise>
								<xsl:value-of select="$amountTmp"/>
							</xsl:otherwise>
						</xsl:choose>
					</xsl:variable>
					<xsl:if test="string-length($amount) &gt; 0">
						<amount>
							<xsl:value-of select="$amount"/>
						</amount>
					</xsl:if>
				</presentValueAmount>
			</paymentCalculationPeriod>
		</xsl:for-each>
