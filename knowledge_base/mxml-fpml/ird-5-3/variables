																					<adjustedFixingDate>
																						<xsl:value-of
																							select="mx:execute-formula($FpMLDateFormula, concat('date:', date, ',format:yyyymmdd,outputFormat:yyyy-mm-dd'))"
																						/>
																					</adjustedFixingDate>
																					<xsl:if
																						test="string-length(observedRate) &gt; 0 and /MxML/trades/trade[@id = $contractRef]/tradeInputConditions/systemDate &gt;= effectiveObservationDate">
