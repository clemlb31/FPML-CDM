	<xsl:template
        match="inheritedFlow[flowTypologies/flowTypology[label = 'Typology0']/value = 'REV' and flowTypologies/flowTypology[label = 'Typology1']/value = 'CPN']">
		<xsl:param name="streamPayerPartyReference"/>
		<xsl:variable name="FpMLDateFormula" select="'mx.xml2xml.ECN.common.utils.adaptDate'"/>
		<xsl:variable name="amount">
			<xsl:choose>
				<xsl:when test="$streamPayerPartyReference = flow/payerPartyReference/@href">
					<xsl:value-of select="flow/amount"/>
				</xsl:when>
				<xsl:otherwise>
					<xsl:value-of select="flow/amount * -1"/>
				</xsl:otherwise>
			</xsl:choose>
		</xsl:variable>
		<paymentCalculationPeriod>
			<adjustedPaymentDate>
				<xsl:value-of
                    select="mx:execute-formula($FpMLDateFormula, concat('date:', flow/date, ',format:yyyymmdd,outputFormat:yyyy-mm-dd'))"
                />
			</adjustedPaymentDate>
			<fixedPaymentAmount>
				<xsl:value-of select="$amount"/>
			</fixedPaymentAmount>
		</paymentCalculationPeriod>
	</xsl:template>

	<xsl:template name="swapStream-payerPartyReferenceHref">
		<xsl:param name="nbTradeNode" select="'1'"/>
		<xsl:param name="leg" select="'1'"/>
		<xsl:choose>
			<xsl:when test="$nbTradeNode = '2'">
				<xsl:choose>
					<!-- partial event : novation 
						 Both 2 trades are not dead trades. -->
					<xsl:when
                        test="($status1 = $status2 and not($status1 = 'dead')) or $eventType = 'mxContractEventIASSIGNMENT'">
						<xsl:value-of
                            select="substring-after(/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[streamTemplate/leg = $leg]/payerPartyReference/@href, '#')"
                        />
					</xsl:when>
					<xsl:otherwise>
						<xsl:value-of
                            select="substring-after(/MxML/trades/trade[1]/tradeBody/*/stream[streamTemplate/leg = $leg]/payerPartyReference/@href, '#')"
                        />
					</xsl:otherwise>
				</xsl:choose>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of
                    select="substring-after(/MxML/trades/trade[1]/tradeBody/*/stream[streamTemplate/leg = $leg]/payerPartyReference/@href, '#')"
                />
			</xsl:otherwise>
		</xsl:choose>
	</xsl:template>

	<xsl:template name="swapStream-receiverPartyReferenceHref">
		<xsl:param name="nbTradeNode" select="'1'"/>
		<xsl:param name="leg" select="'1'"/>
		<xsl:choose>
			<xsl:when test="$nbTradeNode = '2'">
				<xsl:choose>
					<!-- partial event : novation 
					 Both 2 trades are not dead trades. -->
					<xsl:when
                        test="($status1 = $status2 and not($status1 = 'dead')) or $eventType = 'mxContractEventIASSIGNMENT'">
						<xsl:value-of
                            select="substring-after(/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[streamTemplate/leg = $leg]/receiverPartyReference/@href, '#')"
                        />
					</xsl:when>
					<xsl:otherwise>
						<xsl:value-of
                            select="substring-after(/MxML/trades/trade[1]/tradeBody/*/stream[streamTemplate/leg = $leg]/receiverPartyReference/@href, '#')"
                        />
					</xsl:otherwise>
				</xsl:choose>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of
                    select="substring-after(/MxML/trades/trade[1]/tradeBody/*/stream[streamTemplate/leg = $leg]/receiverPartyReference/@href, '#')"
                />
			</xsl:otherwise>
		</xsl:choose>
	</xsl:template>

	<xsl:template name="createNotionalAmount">
		<xsl:param name="streamNumber"/>
		<xsl:param name="observationDate"/>
		<xsl:param name="mxmlObservationDate"/>
		<xsl:param name="isFxLinked"/>
		<xsl:param name="indexationIndex"/>
		<!-- context: /MxML/trades/trade/tradeBody/currencySwap/stream/cashFlows/interestFlows/interestPaymentPeriod/calculationPeriod/contributionFlows/contributionFlow/calculationPeriod or MxML/trades/trade/tradeBody/currencySwap/stream/cashFlows/interestFlows/interestPaymentPeriod/calculationPeriod/-->
		<xsl:choose>
			<xsl:when test="$isFxLinked = 'true'">
				<fxLinkedNotionalAmount>
					<xsl:variable name="lastFixingEventDate">
						<xsl:value-of select="/MxML/contract/contractEvent[businessObject/@mefClass='mxContractEventIFIXING']/contractEventHeader/contractEventDate" />
					</xsl:variable>
					<xsl:variable name="documentDate">
						<xsl:value-of select="/MxML/documentProperties/systemDate" />
					</xsl:variable>
					<xsl:variable name="systemDate">
						<xsl:choose>
							<xsl:when test="string-length($documentDate) &gt; 0">
								<xsl:value-of select="$documentDate"/>
							</xsl:when>
							<xsl:when test="string-length($lastFixingEventDate) &gt; 0">
								<xsl:value-of select="$lastFixingEventDate"/>          
							</xsl:when>
							<xsl:otherwise>
								<xsl:value-of select="/MxML/trades/trade[@id = $contractRef]/tradeInputConditions/systemDate" />          
							</xsl:otherwise>
						</xsl:choose>
					</xsl:variable>
					<xsl:variable name="fixingValue"
                        select="/MxML/trades/trade[@id = $contractRef]/tradeImpacts/tradeImpact[@mefClass = 'mxContractEventIIMPACT_FIXING']/contractEventImpactBody/fixingImpact[./streamFixingReference/periodFixingDescription[./fixingDate = $mxmlObservationDate and ./indexLabel = $indexationIndex and contains(./archiving, 'FIXINGS')]]/fixingValue"/>
					<xsl:variable name="indexationObservedRate">
						<xsl:choose>
							<xsl:when test="number($fixingValue) &gt; 0">
								<xsl:value-of select="$fixingValue"/>
							</xsl:when>
							<xsl:otherwise>
								<xsl:choose>
									<xsl:when
                                        test="number($mxmlObservationDate) &lt; number($systemDate)">
										<xsl:choose>
											<xsl:when
                                                test="string-length(/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[1]/indexationLists/indexationList) &gt; 0">
												<xsl:value-of
                                                  select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[1]/indexationLists/indexationList[./indexedObjectNature = 'outstandingCapital']/indexationSchedules/indexationSchedule/indexations/indexation[date = $mxmlObservationDate]/observedRate"
                                                />
											</xsl:when>
											<xsl:otherwise>
												<xsl:value-of
                                                  select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[2]/indexationLists/indexationList[./indexedObjectNature = 'outstandingCapital']/indexationSchedules/indexationSchedule/indexations/indexation[date = $mxmlObservationDate]/observedRate"
                                                />
											</xsl:otherwise>
										</xsl:choose>
									</xsl:when>
									<xsl:otherwise/>
								</xsl:choose>
							</xsl:otherwise>
						</xsl:choose>
					</xsl:variable>
					<xsl:variable name="isIndexationFixingDone">
						<xsl:value-of select=" my:isObservationFixed($mxmlObservationDate, $indexationIndex) or ( my:streamHasFxLinkedNotionalSchedule() and my:isObservationFixedInSchedule( $mxmlObservationDate, $systemDate)  ) "/>
					</xsl:variable>
					<xsl:call-template name="create-fxLinkedNotionalAmount">
						<xsl:with-param name="resetDate">
							<xsl:value-of
                                select="mx:execute-formula($FpMLDateFormula, concat('date:', calculationStartDate, ',format:yyyymmdd,outputFormat:yyyy-mm-dd'))"
                            />
						</xsl:with-param>
						<xsl:with-param name="adjustedFxSpotFixingDate" select="$observationDate"/>
						<xsl:with-param name="observedFxSpotRate">
							<xsl:if test="$isIndexationFixingDone = 'true'">
								<xsl:value-of
                                    select="format-number($indexationObservedRate, '##.##########')"
                                />
							</xsl:if>
						</xsl:with-param>
						<xsl:with-param name="notionalAmount">
							<xsl:if test="$isIndexationFixingDone = 'true'">
								<xsl:value-of select="format-number(notionalAmount, '##.########')"
                                />
							</xsl:if>
						</xsl:with-param>
					</xsl:call-template>
				</fxLinkedNotionalAmount>
			</xsl:when>
			<xsl:otherwise>
				<notionalAmount>
					<xsl:value-of select="format-number(notionalAmount, '##.########')"/>
				</notionalAmount>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:template>

	<func:function name="my:streamHasFxLinkedNotionalSchedule">
		<xsl:param name="stream" select="'1'"/>
		<xsl:variable name="returnValue">
			<xsl:choose>
				<xsl:when test="count( /MxML/trades/trade[@id = $contractRef]/tradeBody/currencySwap/stream[position()=$stream]/indexationLists/indexationList[./indexedObjectNature = 'outstandingCapital']/indexationSchedules/indexationSchedule/indexations/indexation/date ) &gt; 1">
					<xsl:value-of select="'true'"/>     
				</xsl:when>
				<xsl:otherwise>
					<xsl:value-of select="'false'"/>     
				</xsl:otherwise>
			</xsl:choose>
		</xsl:variable>      
		<func:result select="$returnValue" />
	</func:function>

	<func:function name="my:isObservationFixedInSchedule">
		<xsl:param name="fixingDate" />
		<xsl:param name="documentDate" />
		<func:result select="number($fixingDate) &lt;  number($documentDate)" />
	</func:function>
	<func:function name="my:isObservationFixed">
		<xsl:param name="fixingDate"/>
		<xsl:param name="index"/>
		<xsl:variable name="systemDate">
			<xsl:value-of
                select="/MxML/trades/trade[@id = $contractRef]/tradeInputConditions/systemDate"/>
		</xsl:variable>
		<xsl:variable name="IndexationDateLeg1">
			<xsl:variable name="dateTmp">
				<xsl:value-of
                    select="/MxML/trades/trade[@id = $contractRef]/tradeBody/currencySwap/stream[1]/indexationLists/indexationList[./indexedObjectNature = 'outstandingCapital']/indexationSchedules/indexationSchedule/indexations/indexation/date"
                />
			</xsl:variable>
			<xsl:if test="number($dateTmp) &lt; number($systemDate)">
				<xsl:value-of select="$dateTmp"/>
			</xsl:if>
		</xsl:variable>
		<xsl:variable name="IndexationDateLeg2">
			<xsl:variable name="dateTmp">
				<xsl:value-of
                    select="/MxML/trades/trade[@id = $contractRef]/tradeBody/currencySwap/stream[2]/indexationLists/indexationList[./indexedObjectNature = 'outstandingCapital']/indexationSchedules/indexationSchedule/indexations/indexation/date"
                />
			</xsl:variable>
			<xsl:if test="number($dateTmp) &lt; number($systemDate)">
				<xsl:value-of select="$dateTmp"/>
			</xsl:if>
		</xsl:variable>
		<xsl:variable name="periodFixingDescriptionImpact">
			<xsl:value-of
                select="/MxML/trades/trade[@id = $contractRef]/tradeImpacts/tradeImpact[@mefClass = 'mxContractEventIIMPACT_FIXING']/contractEventImpactBody/fixingImpact/streamFixingReference/periodFixingDescription[./fixingDate = $fixingDate and ./indexLabel = $index and contains(./archiving, 'FIXINGS')]"
            />
		</xsl:variable>
		<xsl:variable name="periodFixingDescription">
			<xsl:choose>
				<xsl:when test="string-length($periodFixingDescriptionImpact) &gt; 0">
					<xsl:value-of select="$periodFixingDescriptionImpact"/>
				</xsl:when>
				<xsl:otherwise>
					<xsl:choose>
						<xsl:when
                            test="string-length($IndexationDateLeg1) &gt; 0 and number($fixingDate) &lt; number($systemDate)">
							<xsl:value-of select="$IndexationDateLeg1"/>
						</xsl:when>
						<xsl:when
                            test="string-length($IndexationDateLeg2) &gt; 0 and number($fixingDate) &lt; number($systemDate)">
							<xsl:value-of select="$IndexationDateLeg2"/>
						</xsl:when>
						<xsl:otherwise/>
					</xsl:choose>
				</xsl:otherwise>
			</xsl:choose>
		</xsl:variable>
		<func:result select="string-length($periodFixingDescription) &gt; 0"/>
	</func:function>

	<func:function name="my:streamHasFxLinkedNotional">
		<xsl:param name="streamNumber"/>
		<xsl:variable name="isOutstandingCapital">
			<xsl:for-each
                select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[$streamNumber]/streamTemplate/indexationRulesLists/indexationRulesList">
				<xsl:if test="./indexedObjectNature = 'outstandingCapital'">
					<xsl:value-of select="'yes'"/>
				</xsl:if>
			</xsl:for-each>
		</xsl:variable>
		<xsl:choose>
			<xsl:when test="$isOutstandingCapital = 'yes'">
				<xsl:variable name="indexedObjectNature">
					<xsl:value-of select="'outstandingCapital'"/>
				</xsl:variable>
				<xsl:variable name="indexationNature">
					<xsl:value-of
                        select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[$streamNumber]/streamTemplate/indexationRulesLists/indexationRulesList[./indexedObjectNature = 'outstandingCapital']/indexationRules/indexationRule/indexationNature"
                    />
				</xsl:variable>
				<func:result
                    select="$indexedObjectNature='outstandingCapital' and $indexationNature = 'fxSpot'"
                />
			</xsl:when>
			<xsl:otherwise>
				<xsl:variable name="indexedObjectNature">
					<xsl:value-of
                        select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[$streamNumber]/streamTemplate/indexationRulesLists/indexationRulesList/indexedObjectNature"
                    />
				</xsl:variable>
				<xsl:variable name="indexationNature">
					<xsl:value-of
                        select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[$streamNumber]/streamTemplate/indexationRulesLists/indexationRulesList/indexationRules/indexationRule/indexationNature"
                    />
				</xsl:variable>
				<func:result
                    select="$indexedObjectNature='outstandingCapital' and $indexationNature = 'fxSpot'"
                />
			</xsl:otherwise>
		</xsl:choose>
	</func:function>

	<!-- ========================================= -->
	<!-- Extendable swap -->
	<!-- ========================================= -->

	<xsl:variable name="contract.mefClassInstanceType">
		<xsl:call-template name="extract-contract-mefClassInstanceType"/>
	</xsl:variable>

	<xsl:variable name="isExtendableSwap">
		<xsl:choose>
			<xsl:when
                test="$contract.mefClassInstanceType &gt; 0 and substring($contract.mefClassInstanceType, 1, 4) = '1911'">
				<xsl:value-of select="'true'"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="'false'"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

</xsl:stylesheet>
