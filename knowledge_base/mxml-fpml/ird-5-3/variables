                    test="/MxML/trades/trade[1]/tradeBody/*/payout/option/mutualBreakSchedule/exercizeScheduleBuilder/exercizeStreamSchedule/scheduleGenerator/standardScheduleGenerator/businessDayConvention">
					<xsl:variable name="businessDayConventionTmpMxTmp">
						<xsl:value-of
