																						</adjustedFixingDate>
																						<xsl:if
																							test="string-length(observedRate) &gt; 0 and /MxML/trades/trade[@id = $contractRef]/tradeInputConditions/systemDate &gt;= date">
																							<observedRate>
																								<xsl:value-of
																									select="format-number(observedRate, '##.##########')"
																								/>
																							</observedRate>
																						</xsl:if>
																						<observationWeight>
																							<!--observationWeight is 1) an Integer > 0 and is 2) a number of days weighting. 
																					This template is defined in: mx.xml2xml.transform.mxml2fpml.5-3.products.ird.utils.numberOfDaysByObservation
																					DEF: Correct the "date" (<xsl:with-param name="date" select="../../date"/>) by $unEndDate"
																					-->
																							<xsl:call-template name="calculateDayBegMonth">
																								<xsl:with-param name="date" select="mx:execute-formula($FpMLDateFormula, concat('date:', $unEndDate, ',format:yyyy-mm-dd,outputFormat:yyyymmdd'))"/>
