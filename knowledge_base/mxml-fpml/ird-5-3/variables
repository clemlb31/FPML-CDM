				<presentValueAmount>
					<currency>
						<xsl:value-of select="currency"/>
					</currency>
					<!--DEF -->
					<xsl:variable name="amount">
						<xsl:variable name="period.end.date" select="calculationPeriod/calculationEndDate"/>
						<xsl:variable name="amountTmp">
							<xsl:choose>
