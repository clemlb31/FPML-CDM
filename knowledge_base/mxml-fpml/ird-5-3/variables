	<xsl:variable name="earlyTerminationProvision.cashSettlementValuationDate.periodTmp"
        select="concat('periodUnit:', $periodMxTmp)"/>

	<xsl:variable name="optionalEarlyTerminationModel.businessDayConventionTmp">
		<xsl:variable name="businessDayConventionTmpMx">
			<xsl:choose>
