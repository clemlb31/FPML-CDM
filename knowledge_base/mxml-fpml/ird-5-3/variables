                test="$event = 'partyAssignment' and $lastContractEventReference.mefClass = 'mxContractEventICANCEL'">
				<xsl:call-template name="create-principalExchange-nodes">
					<xsl:with-param name="legNb" select="1"/>
					<xsl:with-param name="stream" select="1"/>
				</xsl:call-template>
			</xsl:when>
			<xsl:otherwise>
				<xsl:call-template name="create-principalExchange-nodes">
					<xsl:with-param name="legNb" select="2"/>
					<xsl:with-param name="stream" select="1"/>
				</xsl:call-template>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<xsl:variable name="oldSwapStream2.principalExchange.nodes">
		<xsl:choose>
			<xsl:when
                test="$event = 'partyAssignment' and $lastContractEventReference.mefClass = 'mxContractEventICANCEL'">
				<xsl:call-template name="create-principalExchange-nodes">
					<xsl:with-param name="legNb" select="1"/>
					<xsl:with-param name="stream" select="2"/>
				</xsl:call-template>
			</xsl:when>
			<xsl:otherwise>
				<xsl:call-template name="create-principalExchange-nodes">
					<xsl:with-param name="legNb" select="2"/>
					<xsl:with-param name="stream" select="2"/>
				</xsl:call-template>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<xsl:template name="create-principalExchange-nodes">
		<xsl:param name="legNb" select="'1'"/>
		<xsl:param name="stream" select="'1'"/>
		<xsl:variable name="legNumber"
            select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[$stream]/streamTemplate/leg"/>
		<xsl:variable name="streamPayerParty"
            select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[$stream]/payerPartyReference/@href"/>
		<xsl:apply-templates
            select="/MxML/trades/trade[@id = $contractRef]/tradeBody/inheritedFlows/inheritedFlow[leg = $legNumber and flow/amount != 0 and flowTypologies/flowTypology[label = 'Typology0']/value = 'CAP' and flowTypologies/flowTypology[label = 'Typology1']/value = 'NOM']">
			<xsl:with-param name="streamPayerPartyReference" select="$streamPayerParty"/>
		</xsl:apply-templates>
		<xsl:for-each
            select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[$stream]/cashFlows/capitalFlows/flow[amount != 0]">
			<xsl:variable name="isPayerParty">
				<xsl:variable name="flowPayerParty" select="payerPartyReference/@href"/>
				<xsl:value-of select="$flowPayerParty = $streamPayerParty"/>
			</xsl:variable>
			<xsl:variable name="amountValue" select="amount"/>
			<principalExchange>
				<adjustedPrincipalExchangeDate>
					<xsl:value-of
                        select="mx:execute-formula($FpMLDateFormula, concat('date:', date, ',format:yyyymmdd,outputFormat:yyyy-mm-dd'))"
                    />
				</adjustedPrincipalExchangeDate>
				<principalExchangeAmount>
					<xsl:choose>
						<xsl:when test="$isPayerParty = 'true'">
							<xsl:value-of select="$amountValue"/>
						</xsl:when>
						<xsl:otherwise>
							<xsl:value-of select="concat('-', $amountValue)"/>
						</xsl:otherwise>
					</xsl:choose>
				</principalExchangeAmount>
				<presentValuePrincipalExchangeAmount>
					<currency>
						<xsl:value-of select="currency"/>
					</currency>
					<amount>
						<xsl:choose>
							<xsl:when test="$isPayerParty = 'true'">
								<xsl:value-of select="$amountValue"/>
							</xsl:when>
							<xsl:otherwise>
								<xsl:value-of select="concat('-', $amountValue)"/>
							</xsl:otherwise>
						</xsl:choose>
					</amount>
				</presentValuePrincipalExchangeAmount>
			</principalExchange>
		</xsl:for-each>
	</xsl:template>

	<!-- For Restructure & Unwind events: generate past settled IR cashflows -->
	<xsl:template
        match="inheritedFlow[flowTypologies/flowTypology[label = 'Typology0']/value = 'CAP' and flowTypologies/flowTypology[label = 'Typology1']/value = 'NOM']">
		<xsl:param name="streamPayerPartyReference"/>
		<xsl:variable name="amount">
			<xsl:choose>
				<xsl:when test="$streamPayerPartyReference = flow/payerPartyReference/@href">
					<xsl:value-of select="flow/amount"/>
				</xsl:when>
				<xsl:otherwise>
					<xsl:value-of select="flow/amount * -1"/>
				</xsl:otherwise>
			</xsl:choose>
		</xsl:variable>
		<xsl:call-template name="create-principalExchange-principalExchange">
			<xsl:with-param name="adjustedPrincipalExchangeDate"
                select="mx:execute-formula($FpMLDateFormula, concat('date:', flow/date, ',format:yyyymmdd,outputFormat:yyyy-mm-dd'))"/>
			<xsl:with-param name="principalExchangeAmount" select="$amount"/>
			<xsl:with-param name="amount" select="$amount"/>
			<xsl:with-param name="currency" select="flow/currency"/>
		</xsl:call-template>
	</xsl:template>

	<!-- Cash Settlement Valuation Date -->
	<xsl:variable name="mutualBreakSchedule.notificationSchedulesRelationship"
        select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/payout/option/mutualBreakSchedule/notificationEffectiveRelationship/notificationSchedulesRelationship"/>
	<xsl:variable name="mutualBreakSchedule.notificationSchedulesShifter.shiftPeriodMultiplier"
        select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/payout/option/mutualBreakSchedule/notificationEffectiveRelationship/notificationSchedulesShifter/shift/periodMultiplier"/>
	<xsl:variable name="mutualBreakSchedule.notificationEffectiveRelationship.dateShifterLabel"
        select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/payout/option/mutualBreakSchedule/notificationEffectiveRelationship/notificationEffectiveShifter/dateShifterLabel"/>

	<xsl:variable name="mutualBreakSchedule.notificationEffectiveShifter.dateShifterLabelMultiplier">
		<xsl:if
            test="string-length($mutualBreakSchedule.notificationEffectiveRelationship.dateShifterLabel)">
			<xsl:variable name="mappedValue"
                select="mx:execute-formula($mapShifterLabel, concat('shifterLabel:', $mutualBreakSchedule.notificationEffectiveRelationship.dateShifterLabel))//row[3]"/>
			<xsl:call-template name="AssertNotMapped">
				<xsl:with-param name="value" select="$mappedValue"/>
				<xsl:with-param name="message"
                    select="concat('Shifter label not Mapped for : ', $mutualBreakSchedule.notificationEffectiveRelationship.dateShifterLabel)"/>
				<xsl:with-param name="formula" select="$mapShifterLabel"/>
			</xsl:call-template>
			<xsl:value-of select="$mappedValue"/>
		</xsl:if>
	</xsl:variable>

	<xsl:variable name="earlyTerminationProvision.cashSettlementValuationDate.periodMultiplier">
		<xsl:if test="$mutualBreakSchedule.notificationSchedulesRelationship = 'deducedFrom'">
			<xsl:choose>
				<xsl:when
                    test="(string-length($mutualBreakSchedule.notificationSchedulesShifter.shiftPeriodMultiplier) &gt; 0) and (string-length($mutualBreakSchedule.notificationEffectiveShifter.dateShifterLabelMultiplier) &gt; 0)">
					<xsl:value-of
                        select="$mutualBreakSchedule.notificationSchedulesShifter.shiftPeriodMultiplier + $mutualBreakSchedule.notificationEffectiveShifter.dateShifterLabelMultiplier"
                    />
				</xsl:when>
				<xsl:when
                    test="(string-length($mutualBreakSchedule.notificationSchedulesShifter.shiftPeriodMultiplier) &gt; 0) and (string-length($mutualBreakSchedule.notificationEffectiveShifter.dateShifterLabelMultiplier) = 0)">
					<xsl:value-of
                        select="$mutualBreakSchedule.notificationSchedulesShifter.shiftPeriodMultiplier"
                    />
				</xsl:when>
				<xsl:when
                    test="(string-length($mutualBreakSchedule.notificationSchedulesShifter.shiftPeriodMultiplier) = 0) and (string-length($mutualBreakSchedule.notificationEffectiveShifter.dateShifterLabelMultiplier) &gt; 0)">
					<xsl:value-of
                        select="$mutualBreakSchedule.notificationEffectiveShifter.dateShifterLabelMultiplier"
                    />
				</xsl:when>
				<xsl:otherwise/>
			</xsl:choose>
		</xsl:if>
	</xsl:variable>

	<xsl:variable name="periodMxTmp">
		<xsl:value-of
            select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/payout/option/mutualBreakSchedule/notificationEffectiveRelationship/notificationSchedulesShifter/shift/periodUnit"
        />
