                                                test="($stream = 1 and mx:execute-formula($mapDayCountBasis, $swapStream1.paramDayCountFraction) = '1/1') or ($stream = 2 and not($leg2.singlePeriod = 'true') and mx:execute-formula($mapDayCountBasis, $swapStream2.paramDayCountFraction) = '1/1')">
												<xsl:call-template
