							<xsl:with-param name="floatingRateIndexScheme" select="$swapStream2.initialStub.floatingRate2.floatingRateIndexScheme"/>
							<xsl:with-param name="period" select="$swapStream2.initialStub.floatingRate2.period"/>
							<xsl:with-param name="periodMultiplier" select="$swapStream2.initialStub.floatingRate2.periodMultiplier"/>
