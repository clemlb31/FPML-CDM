						<xsl:with-param name="exerciseFrequency.period" select="$exerciseFrequency.period"/>
						<xsl:with-param name="optionalEarlyTerminationModel.calculationAgentParty" select="$optionalEarlyTerminationModel.calculationAgentParty"/>
