						<xsl:with-param name="mandatoryEarlyTerminationModel.period" select="$mandatoryEarlyTerminationModel.period"/>
						<xsl:with-param name="mandatoryEarlyTerminationModel.periodMultiplier" select="$mandatoryEarlyTerminationModel.periodMultiplier"/>
