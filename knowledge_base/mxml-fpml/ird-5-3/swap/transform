<xsl:stylesheet xmlns="http://www.fpml.org/FpML-5/confirmation" 
				xmlns:xsl="http://www.w3.org/1999/XSL/Transform" 
				xmlns:str="http://exslt.org/strings" 
				xmlns:exsl="http://exslt.org/common" 
				xmlns:dyn="http://exslt.org/dynamic" 
				xmlns:mx="http://murex.com/xslt/common"
				xmlns:exslt="http://exslt.org/common" 
				xmlns:func="http://exslt.org/functions"
				xmlns:my="myfunc" 
				exclude-result-prefixes="mx exslt dyn str exsl" 
				version="1.0">
				
	<xsl:import href="mx.xml2xml.transform.mxml2fpml.5-3.products.common.correctableRequestMessage"/>
	<xsl:import href="mx.xml2xml.transform.any2fpml.5-3.products.common.party"/>
	<xsl:import href="mx.xml2xml.transform.any2fpml.5-3.products.common.payment"/>
	<xsl:import href="mx.xml2xml.transform.any2fpml.5-3.products.ird.swap.tradeNode"/>
	<xsl:import href="mx.xml2xml.transform.mxml2fpml.5-3.products.ird.swap.variables"/>
	<xsl:import href="mx.xml2xml.transform.mxml2fpml.5-3.events.variables"/>
	<xsl:import href="mx.xml2xml.transform.mxml2fpml.5-3.products.common.addNamespace"/>
	<xsl:import href="mx.xml2xml.transform.any2fpml.5-3.events.tradeAmendmentContent"/>
	<xsl:import href="mx.xml2xml.transform.any2fpml.5-3.events.tradeNovationContent"/>
	<xsl:import href="mx.xml2xml.transform.any2fpml.5-3.events.tradeNotionalChange"/>
	<xsl:import href="mx.xml2xml.transform.any2fpml.5-3.products.ird.common.fxLinkedNotionalAmount"/>
	<xsl:import href="mx.xml2xml.transform.mxml2fpml.5-3.products.tradePosition"/>
	<xsl:import href="mx.generic.errorHandling.assert"/>
	<xsl:import href="mx.generic.exslt.str.split"/>
	
	<!--Generate FpML node-->
	<xsl:template name="create-fpml-node-data-document-ird-swap">
		<!-- ====== -->
		<!-- params -->
		<!-- ====== -->
		<xsl:param name="fpmlType"/>
		<!-- Header -->
		<xsl:param name="tradeId2"/>
		<xsl:param name="tradeId2.scheme"/>
		<!-- optional parameters -->
		<xsl:param name="messageId"/>
		<xsl:param name="messageIdScheme"/>
		<xsl:param name="sendBy.partyIdScheme"/>
		<xsl:param name="sendTo.partyIdScheme"/>
		<xsl:param name="tradeId1"/>
		<xsl:param name="tradeId1.scheme"/>
		<!-- parties -->
		<xsl:param name="party.partyId1"/>
		<xsl:param name="party.partyId2"/>
		<xsl:param name="party.partyIdScheme1"/>
		<xsl:param name="party.partyIdScheme2"/>
		<!-- specific for novation -->
		<xsl:param name="party.partyId3"/>
		<xsl:param name="party.partyIdScheme3"/>
		<!-- swapStream1 -->
		<xsl:param name="swapStream1.id"/>
		<xsl:param name="swapStream1.effectiveDate.dateAdjustments.businessCenter.nodes"/>
		<xsl:param name="swapStream1.calculationPeriodDatesAdjustments.businessCenter.nodes"/>
		<xsl:param name="swapStream1.paymentDatesAdjustments.businessCenter.nodes"/>
		<xsl:param name="swapStream1.effectiveDate.dateAdjustments.businessDayConvention"/>
		<xsl:param name="swapStream1.terminationDate.dateAdjustments.businessDayConvention"/>
		<xsl:param name="swapStream1.terminationDate.dateAdjustments.businessCenter.nodes"/>
		<xsl:param name="swapStream1.calculationPeriodFrequency.rollConvention"/>
		<xsl:param name="swapStream1.calculationPeriodDatesAdjustments.businessDayConvention"/>
		<xsl:param name="swapStream1.resetFrequency.period"/>
		<xsl:param name="swapStream1.fixingDates.period"/>
		<xsl:param name="swapStream1.initialFixingDate.periodMultiplier"/>
		<xsl:param name="swapStream1.floatingRateIndex"/>
		<xsl:param name="swapStream1.floatingRateIndexScheme"/>
		<!-- first fixing -->
		<xsl:param name="swapStream1.initialRate"/>
		<xsl:param name="swapStream1.calculationPeriodAmount.periodMultiplier"/>
		<xsl:param name="swapStream1.calculationPeriodAmount.period"/>
		<xsl:param name="swapStream1.calculationPeriodFrequency.period"/>
		<xsl:param name="swapStream1.resetDatesAdjustments.businessDayConvention"/>
		<xsl:param name="swapStream1.resetDatesAdjustments.businessCenter.nodes"/>
		<xsl:param name="swapStream1.frequency.period"/>
		<xsl:param name="swapStream1.businessDayConvention"/>
		<xsl:param name="swapStream1.dayCountFraction"/>
		<!-- Cash flows -->
		<xsl:param name="swapStream1.cashflowsMatchParameters"/>
		<!--xsl:param name="swapStream1.paymentCalculationPeriod.nodes"/-->
		<xsl:param name="swapStream1.principalExchange.nodes"/>
		<xsl:param name="oldSwapStream1.principalExchange.nodes"/>
		<!-- initialStub -->
		<xsl:param name="swapStream1.initialStub.floatingRate.floatingRateIndex"/>
		<xsl:param name="swapStream1.initialStub.floatingRate.floatingRateIndexScheme"/>
		<xsl:param name="swapStream1.initialStub.floatingRate.periodMultiplier"/>
		<xsl:param name="swapStream1.initialStub.floatingRate.period"/>
		<xsl:param name="swapStream1.initialStub.floatingRate2.floatingRateIndex"/>
		<xsl:param name="swapStream1.initialStub.floatingRate2.floatingRateIndexScheme"/>
		<xsl:param name="swapStream1.initialStub.floatingRate2.periodMultiplier"/>
		<xsl:param name="swapStream1.initialStub.floatingRate2.period"/>
		<!-- finalStub -->
		<xsl:param name="swapStream1.finalStub.floatingRate.floatingRateIndex"/>
		<xsl:param name="swapStream1.finalStub.floatingRate.floatingRateIndexScheme"/>
		<xsl:param name="swapStream1.finalStub.floatingRate.periodMultiplier"/>
		<xsl:param name="swapStream1.finalStub.floatingRate.period"/>
		<xsl:param name="swapStream1.finalStub.floatingRate2.floatingRateIndex"/>
		<xsl:param name="swapStream1.finalStub.floatingRate2.floatingRateIndexScheme"/>
		<xsl:param name="swapStream1.finalStub.floatingRate2.periodMultiplier"/>
		<xsl:param name="swapStream1.finalStub.floatingRate2.period"/>
		<!-- Rounding -->
		<xsl:param name="swapStream1.roundingDirection"/>
		<!-- CS MTM -->
		<xsl:param name="swapStream1.fxLinkedNotionalSchedule.fxSpotRateSource.primaryRateSource.rateSource"/>
		<xsl:param name="swapStream1.fxLinkedNotionalSchedule.fxSpotRateSource.primaryRateSource.rateSourcePage"/>
		<xsl:param name="swapStream1.fxLinkedNotionalSchedule.fxSpotRateSource.fixingTime.hourMinuteTime"/>
		<xsl:param name="swapStream1.fxLinkedNotionalSchedule.fxSpotRateSource.fixingTime.businessCenter.name"/>
		<!-- inflation -->
		<xsl:param name="swapStream1.inflationRate.floatingRateIndex"/>
		<xsl:param name="swapStream1.inflationRate.floatingRateIndexScheme"/>
		<xsl:param name="swapStream1.inflationRate.periodMultiplier"/>
		<xsl:param name="swapStream1.inflationRate.period"/>
		<xsl:param name="swapStream1.inflationRate.dayType"/>
		<xsl:param name="swapStream1.inflationRate.interpolationMethod"/>
		<xsl:param name="swapStream1.inflationRate.initialIndexLevel"/>
		<xsl:param name="swapStream1.inflationRate.fallbackBondApplicable"/>
		<xsl:param name="swapStream1.inflationRate.floatingRateMultiplierSchedule.nodes"/>
		<xsl:param name="swapStream1.inflationRate.rateSourcePageScheme"/>
		<xsl:param name="swapStream1.inflationRate.indexSource"/>
		<xsl:param name="swapStream1.inflationRate.interpolationMethodScheme"/>
		<xsl:param name="swapStream1.inflationRate.mainPublication"/>
		<xsl:param name="swapStream1.inflationRate.mainPublicationScheme"/>
		<!-- swapStream2 -->
		<xsl:param name="swapStream2.id"/>
		<xsl:param name="swapStream2.effectiveDate.dateAdjustments.businessCenter.nodes"/>
		<xsl:param name="swapStream2.effectiveDate.dateAdjustments.businessDayConvention"/>
		<xsl:param name="swapStream2.terminationDate.dateAdjustments.businessDayConvention"/>
		<xsl:param name="swapStream2.terminationDate.dateAdjustments.businessCenter.nodes"/>
		<xsl:param name="swapStream2.calculationPeriodDatesAdjustments.businessDayConvention"/>
		<xsl:param name="swapStream2.floatingRateIndex"/>
		<xsl:param name="swapStream2.floatingRateIndexScheme"/>
		<!-- first fixing -->
		<xsl:param name="swapStream2.initialRate"/>
		<xsl:param name="swapStream2.calculationPeriodAmount.periodMultiplier"/>
		<xsl:param name="swapStream2.calculationPeriodAmount.period"/>
		<xsl:param name="swapStream2.frequency.period"/>
		<xsl:param name="swapStream2.resetDatesAdjustments.businessDayConvention"/>
		<xsl:param name="swapStream2.businessDayConvention"/>
		<xsl:param name="swapStream2.calculationPeriodFrequency.period"/>
		<xsl:param name="swapStream2.calculationPeriodFrequency.rollConvention"/>
		<xsl:param name="swapStream2.calculationPeriodDatesAdjustments.businessCenter.nodes"/>
		<xsl:param name="swapStream2.paymentDatesAdjustments.businessCenter.nodes"/>
		<xsl:param name="swapStream2.resetFrequency.period"/>
		<xsl:param name="swapStream2.resetDatesAdjustments.businessCenter.nodes"/>
		<xsl:param name="swapStream2.paymentDates.period"/>
		<xsl:param name="swapStream2.fixingDates.period"/>
		<xsl:param name="swapStream2.initialFixingDate.periodMultiplier"/>
		<xsl:param name="swapStream2.dayCountFraction"/>
		<!-- Cash flows -->
		<xsl:param name="swapStream2.cashflowsMatchParameters"/>
		<!--xsl:param name="swapStream2.paymentCalculationPeriod.nodes"/-->
		<xsl:param name="swapStream2.principalExchange.nodes"/>
		<xsl:param name="oldSwapStream2.principalExchange.nodes"/>
		<!-- initialStub -->
		<xsl:param name="swapStream2.initialStub.floatingRate.floatingRateIndex"/>
		<xsl:param name="swapStream2.initialStub.floatingRate.floatingRateIndexScheme"/>
		<xsl:param name="swapStream2.initialStub.floatingRate.periodMultiplier"/>
		<xsl:param name="swapStream2.initialStub.floatingRate.period"/>
		<xsl:param name="swapStream2.initialStub.floatingRate2.floatingRateIndex"/>
		<xsl:param name="swapStream2.initialStub.floatingRate2.floatingRateIndexScheme"/>
		<xsl:param name="swapStream2.initialStub.floatingRate2.periodMultiplier"/>
		<xsl:param name="swapStream2.initialStub.floatingRate2.period"/>
		<!-- finalStub -->
		<xsl:param name="swapStream2.finalStub.floatingRate.floatingRateIndex"/>
		<xsl:param name="swapStream2.finalStub.floatingRate.floatingRateIndexScheme"/>
		<xsl:param name="swapStream2.finalStub.floatingRate.periodMultiplier"/>
		<xsl:param name="swapStream2.finalStub.floatingRate.period"/>
		<xsl:param name="swapStream2.finalStub.floatingRate2.floatingRateIndex"/>
		<xsl:param name="swapStream2.finalStub.floatingRate2.floatingRateIndexScheme"/>
		<xsl:param name="swapStream2.finalStub.floatingRate2.periodMultiplier"/>
		<xsl:param name="swapStream2.finalStub.floatingRate2.period"/>
		<!-- roundingDirection -->
		<xsl:param name="swapStream2.roundingDirection"/>
		<!-- Specific CS MTM -->
		<xsl:param name="swapStream2.fxLinkedNotionalSchedule.fxSpotRateSource.primaryRateSource.rateSource"/>
		<xsl:param name="swapStream2.fxLinkedNotionalSchedule.fxSpotRateSource.primaryRateSource.rateSourcePage"/>
		<xsl:param name="swapStream2.fxLinkedNotionalSchedule.fxSpotRateSource.fixingTime.hourMinuteTime"/>
		<xsl:param name="swapStream2.fxLinkedNotionalSchedule.fxSpotRateSource.fixingTime.businessCenter.name"/>
		<!-- inflation -->
		<xsl:param name="swapStream2.inflationRate.floatingRateIndex"/>
		<xsl:param name="swapStream2.inflationRate.floatingRateIndexScheme"/>
		<xsl:param name="swapStream2.inflationRate.periodMultiplier"/>
		<xsl:param name="swapStream2.inflationRate.period"/>
		<xsl:param name="swapStream2.inflationRate.dayType"/>
		<xsl:param name="swapStream2.inflationRate.interpolationMethod"/>
		<xsl:param name="swapStream2.inflationRate.initialIndexLevel"/>
		<xsl:param name="swapStream2.inflationRate.fallbackBondApplicable"/>
		<xsl:param name="swapStream2.inflationRate.floatingRateMultiplierSchedule.nodes"/>
		<xsl:param name="swapStream2.inflationRate.rateSourcePageScheme"/>
		<xsl:param name="swapStream2.inflationRate.indexSource"/>
		<xsl:param name="swapStream2.inflationRate.interpolationMethodScheme"/>
		<xsl:param name="swapStream2.inflationRate.mainPublication"/>
		<xsl:param name="swapStream2.inflationRate.mainPublicationScheme"/>
		<!-- cancelableProvision -->
		<xsl:param name="exercise.exerciseElement"/>
		<!-- specific amendment -->
		<xsl:param name="isCorrection"/>
		<xsl:param name="sequenceNumber"/>
		<xsl:param name="correlationId"/>
		<xsl:param name="correlationIdScheme"/>
		<xsl:param name="generateCashFlows"/>
		<xsl:param name="expirationTime.hourMinuteTime"/>
		<xsl:param name="earliestExerciseTime.hourMinuteTime"/>
		<xsl:param name="latestExerciseTime.hourMinuteTime"/>
		<!-- Parameter used to change the direction of the deal -->
		<xsl:param name="reversePayReceive"/>
		<xsl:param name="earlyTerminationProvision.cashSettlementValuationDate.period"/>
		<xsl:param name="earlyTerminationProvision.cashSettlementValuationDate.dayType"/>
		<xsl:param name="earlyTerminationProvision.cashPriceMethod.currency"/>
		<xsl:param name="earlyTerminationProvision.cashPriceMethod.quotationRateType"/>
		<xsl:param name="earlyTerminationProvision.cashPriceMethod.referenceBank.node"/>
		<xsl:param name="earliestExerciseTime.businessCenter.name"/>
		<xsl:param name="expirationTime.businessCenter.name"/>
		<xsl:param name="latestExerciseTime.businessCenter.name"/>
		<xsl:param name="cashSettlementValuationTime.hourMinuteTime"/>
		<xsl:param name="cashSettlementValuationTime.businessCenter.name"/>
		<xsl:param name="productId.nodes"/>
		<!-- In case of zero coupon deals -->
		<xsl:variable name="swapStream1.knownAmountSchedule.initialValue">
			<xsl:variable name="customPaymentAmount1">
				<xsl:call-template name="extract-customPaymentAmount">
					<xsl:with-param name="legNb" select="number($tradePos)"/>
					<xsl:with-param name="customization" select="1"/>
					<xsl:with-param name="stream" select="1"/>
				</xsl:call-template>
			</xsl:variable>
			<xsl:variable name="nonCustomPaymentAmount1">
				<xsl:call-template name="extract-singlePeriodPayment">
					<xsl:with-param name="legNb" select="number($tradePos)"/>
					<xsl:with-param name="customization" select="1"/>
					<xsl:with-param name="stream" select="1"/>
				</xsl:call-template>
			</xsl:variable>
			<xsl:variable name="fixedRateTmp">
				<xsl:call-template name="extract-fixedRateFixFloat">
					<xsl:with-param name="legNb" select="1"/>
				</xsl:call-template>
			</xsl:variable>			
			<xsl:variable name="absFixedRateTmp" select="number(translate( $fixedRateTmp, '-','') )"/>
			
			<xsl:choose>
				<!-- ZC (Fixed Amount on fixed leg) - Customized flow -->
				<xsl:when test="$leg1.payoutType = 'fixedRate' and string-length($customPaymentAmount1) &gt; 0 and ($swapStream1.paymentSchedule.zeroCouponMode = 'true' or $swapStream1.singlePeriod = 'true')">
					<xsl:variable name="customPaymentAmount1Tmp" select="mx:execute-formula('mx.generic.xmlf.abs', concat('number:', $customPaymentAmount1))"/>
					<xsl:value-of select="format-number($customPaymentAmount1Tmp, '##.##')"/>
				</xsl:when>
				<xsl:when test="$leg1.payoutType = 'fixedRate' and ( number($absFixedRateTmp) &lt;= number(0.000000) ) and string-length($nonCustomPaymentAmount1) &gt; 0 and ($swapStream1.paymentSchedule.zeroCouponMode = 'true' or $swapStream1.singlePeriod = 'true')">
					<xsl:variable name="nonCustomPaymentAmount1Tmp" select="mx:execute-formula('mx.generic.xmlf.abs', concat('number:', $nonCustomPaymentAmount1))"/>
					<xsl:value-of select="format-number($nonCustomPaymentAmount1Tmp, '##.##')"/>
				</xsl:when>	
				<xsl:otherwise>
					<xsl:variable name="repaymentAmount1Tmp">
						<xsl:call-template name="extract-repaymentAmount">
							<xsl:with-param name="legNb" select="number($tradePos)"/>
							<xsl:with-param name="stream" select="1"/>
						</xsl:call-template>
					</xsl:variable>
					<xsl:if test="string-length($repaymentAmount1Tmp) &gt; 0">
						<xsl:value-of select="format-number($repaymentAmount1Tmp, '##.##')"/>
					</xsl:if>
				</xsl:otherwise>
			</xsl:choose>
		</xsl:variable>
		<xsl:variable name="swapStream1.knownAmountSchedule.currency">
			<xsl:if test="$swapStream1.knownAmountSchedule.initialValue &gt; 0">
				<xsl:value-of select="$swapStream1.notionalSchedule.notionalStepSchedule.currency"/>
			</xsl:if>
		</xsl:variable>
		<!-- =================== -->
		<!-- SwapStream2 -->
		<!-- =================== -->
		<!-- In case of zero coupon deals -->
		<xsl:variable name="swapStream2.knownAmountSchedule.initialValue">
			<xsl:variable name="customPaymentAmount2">
				<xsl:call-template name="extract-customPaymentAmount">
					<xsl:with-param name="legNb" select="number($tradePos)"/>
					<xsl:with-param name="customization" select="1"/>
					<xsl:with-param name="stream" select="2"/>
				</xsl:call-template>
			</xsl:variable>
			<xsl:variable name="nonCustomPaymentAmount2">
				<xsl:call-template name="extract-singlePeriodPayment">
					<xsl:with-param name="legNb" select="number($tradePos)"/>
					<xsl:with-param name="customization" select="1"/>
					<xsl:with-param name="stream" select="2"/>
				</xsl:call-template>
			</xsl:variable>
			<xsl:variable name="fixedRateTmp">
				<xsl:call-template name="extract-fixedRateFixFloat">
					<xsl:with-param name="legNb" select="2"/>
				</xsl:call-template>
			</xsl:variable>
			<xsl:variable name="absFixedRateTmp" select="number(translate( $fixedRateTmp, '-','') )"/>
			
			<xsl:choose>
				<!-- ZC (Fixed Amount on fixed leg) - Customized flow -->
				<xsl:when test="$leg2.payoutType = 'fixedRate' and string-length($customPaymentAmount2) &gt; 0 and ($swapStream2.paymentSchedule.zeroCouponMode = 'true' or $swapStream2.singlePeriod = 'true')">
					<xsl:variable name="customPaymentAmount2Tmp" select="mx:execute-formula('mx.generic.xmlf.abs', concat('number:', $customPaymentAmount2))"/>
					<xsl:value-of select="format-number($customPaymentAmount2Tmp, '##.##')"/>
				</xsl:when>
				<xsl:when test="$leg2.payoutType = 'fixedRate' and ( number($absFixedRateTmp) &lt;= number(0.000000) ) and string-length($nonCustomPaymentAmount2) &gt; 0 and ($swapStream2.paymentSchedule.zeroCouponMode = 'true' or $swapStream2.singlePeriod = 'true')">
					<xsl:variable name="nonCustomPaymentAmount1Tmp" select="mx:execute-formula('mx.generic.xmlf.abs', concat('number:', $nonCustomPaymentAmount2))"/>
					<xsl:value-of select="format-number($nonCustomPaymentAmount1Tmp, '##.##')"/>
				</xsl:when>
				<xsl:otherwise>
					<xsl:variable name="repaymentAmount2Tmp">
						<xsl:call-template name="extract-repaymentAmount">
							<xsl:with-param name="legNb" select="number($tradePos)"/>
							<xsl:with-param name="stream" select="2"/>
						</xsl:call-template>
					</xsl:variable>
					<xsl:if test="string-length($repaymentAmount2Tmp) &gt; 0">
						<xsl:value-of select="format-number($repaymentAmount2Tmp, '##.##')"/>
					</xsl:if>
				</xsl:otherwise>
			</xsl:choose>
		</xsl:variable>
		<xsl:variable name="swapStream2.knownAmountSchedule.currency">
			<xsl:if test="$swapStream2.knownAmountSchedule.initialValue &gt; 0">
				<xsl:value-of select="$swapStream2.notionalSchedule.notionalStepSchedule.currency"/>
			</xsl:if>
		</xsl:variable>
		<!-- ========== Deduced variables =========== -->
		<!-- swapStream1.fixingDates.dayType -->
		<xsl:variable name="swapStream1.fixingDates.dayType">
			<xsl:choose>
				<xsl:when test="$leg1.reset.shifter.periodMultiplier = '0' and ($swapStream1.fixingDates.period = 'businessDay' or $leg1.reset.shifter.periodUnit = 'day')"/>
				<xsl:otherwise>
					<xsl:choose>
						<xsl:when test="$leg1.reset.shifter.periodUnit = 'day'">Calendar</xsl:when>
						<xsl:otherwise>Business</xsl:otherwise>
					</xsl:choose>
				</xsl:otherwise>
			</xsl:choose>
		</xsl:variable>
		<!-- swapStream1.businessCenter.nodes -->
		<xsl:variable name="swapStream1.businessCenter.nodes">
			<xsl:if test="$swapStream1.businessDayConvention != 'NONE'">
				<xsl:copy-of select="$swapStream1.paymentDatesAdjustments.businessCenter.nodes"/>
			</xsl:if>
		</xsl:variable>
		<!-- swapStream1.initialStub.nodes -->
		<xsl:variable name="swapStream1.initialStub.nodes">
			<xsl:variable name="firstFixing" select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[streamTemplate/leg = 1]/floatingRateStream/firstFixing"/>
			<xsl:variable name="initialStub" select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[streamTemplate/leg = 1]/stubPeriods/initialStub"/>
			<xsl:variable name="potentialStubs" select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[streamTemplate/leg = 1]/streamTemplate/potentialStubs"/>
			<xsl:variable name="firstFixingCustomized" select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[streamTemplate/leg = 1]/floatingRateStream/firstFixingCustomized"/>
			<xsl:choose>
				<!--MX generates misleading <stubPeriods><initialStub/></stubPeriods> elements for OIS with maturity<12M-->
				<xsl:when test="$typology = 'OIS' and $periodUnitOIS = 'T'"/>
				<!-- In case of a non regular stub with a first fixing customization -->
				<xsl:when test="(string-length($firstFixing) &gt; 0) and $initialStub and (string-length($potentialStubs) &gt; 0) and ($firstFixingCustomized = 'true')">
					<stubRate>
						<xsl:value-of select="format-number($firstFixing div 100, '##.##########')"/>
					</stubRate>
				</xsl:when>
				<xsl:when test="$swapStream1.initialStubCharacteristics.periodIndex = 'currentIndex'"/>
				<!--fpml.org: "If a stub period uses the same floating rate index, including tenor, as the regular calculation periods then this should not be specified again within this component, i.e. the stub calculation period amount component may not need to be specified even if there is an initial or final stub period"-->
				<xsl:otherwise>
					<xsl:if test="string-length($swapStream1.initialStub.floatingRate.params) &gt; 0">
						<xsl:call-template name="create-floatingRate-floatingRate">
							<xsl:with-param name="floatingRateIndex" select="$swapStream1.initialStub.floatingRate.floatingRateIndex"/>
							<xsl:with-param name="floatingRateIndexScheme" select="$swapStream1.initialStub.floatingRate.floatingRateIndexScheme"/>
							<xsl:with-param name="period" select="$swapStream1.initialStub.floatingRate.period"/>
							<xsl:with-param name="periodMultiplier" select="$swapStream1.initialStub.floatingRate.periodMultiplier"/>
						</xsl:call-template>
					</xsl:if>
					<xsl:if test="string-length($swapStream1.initialStub.floatingRate2.params) &gt; 0">
						<xsl:call-template name="create-floatingRate-floatingRate">
							<xsl:with-param name="floatingRateIndex" select="$swapStream1.initialStub.floatingRate2.floatingRateIndex"/>
							<xsl:with-param name="floatingRateIndexScheme" select="$swapStream1.initialStub.floatingRate2.floatingRateIndexScheme"/>
							<xsl:with-param name="period" select="$swapStream1.initialStub.floatingRate2.period"/>
							<xsl:with-param name="periodMultiplier" select="$swapStream1.initialStub.floatingRate2.periodMultiplier"/>
						</xsl:call-template>
					</xsl:if>
				</xsl:otherwise>
			</xsl:choose>
		</xsl:variable>
		<!-- swapStream1.finalStub.nodes -->
		<xsl:variable name="swapStream1.finalStub.nodes">
			<xsl:choose>
				<!--MX generates misleading <stubPeriods><initialStub/></stubPeriods> elements for OIS with maturity<12M-->
				<xsl:when test="$typology = 'OIS' and $periodUnitOIS = 'T'"/>
				<xsl:when test="$swapStream1.finalStubCharacteristics.periodIndex = 'currentIndex'"/>
				<!--fpml.org: "If a stub period uses the same floating rate index, including tenor, as the regular calculation periods then this should not be specified again within this component, i.e. the stub calculation period amount component may not need to be specified even if there is an initial or final stub period"-->
