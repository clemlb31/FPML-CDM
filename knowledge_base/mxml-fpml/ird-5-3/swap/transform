						<xsl:with-param name="earliestExerciseTime.hourMinuteTime" select="$earliestExerciseTime.hourMinuteTime"/>
						<xsl:with-param name="latestExerciseTime.hourMinuteTime" select="$latestExerciseTime.hourMinuteTime"/>
						<xsl:with-param name="expirationTime.hourMinuteTime" select="$expirationTime.hourMinuteTime"/>
						<xsl:with-param name="earliestExerciseTime.businessCenter.name" select="$earliestExerciseTime.businessCenter.name"/>
						<xsl:with-param name="expirationTime.businessCenter.name" select="$expirationTime.businessCenter.name"/>
						<xsl:with-param name="latestExerciseTime.businessCenter.name" select="$latestExerciseTime.businessCenter.name"/>
						<xsl:with-param name="bermudaExerciseDates.dateAdjustments.businessDayConvention" select="$bermudaExerciseDates.dateAdjustments.businessDayConvention"/>
						<xsl:with-param name="optionalEarlyTerminationModel.optionStyle" select="$optionalEarlyTerminationModel.optionStyle"/>
						<xsl:with-param name="bermudaExerciseDates.id" select="$bermudaExerciseDates.id"/>
						<xsl:with-param name="relevantUnderlyingDate.id" select="$relevantUnderlyingDate.id"/>
						<xsl:with-param name="relevantUnderlyingDate.dateAdjustments.businessDayConvention" select="$relevantUnderlyingDate.dateAdjustments.businessDayConvention"/>
						<xsl:with-param name="optionalEarlyTerminationModel.id" select="$optionalEarlyTerminationModel.id"/>
						<xsl:with-param name="isMandatoryEarlyTermination" select="$isMandatoryEarlyTermination"/>
						<xsl:with-param name="mutualBreakMode" select="$mutualBreakMode"/>
						<xsl:with-param name="relevantUnderlyingDate.dateAdjustments.businessCenter" select="$relevantUnderlyingDate.dateAdjustments.businessCenter"/>
						<xsl:with-param name="bermudaExerciseDates.dateAdjustments.businessCenter" select="$bermudaExerciseDates.dateAdjustments.businessCenter"/>
						<xsl:with-param name="mandatoryEarlyTerminationModel.calculationAgentPartyReference" select="$mandatoryEarlyTerminationModel.calculationAgentPartyReference"/>
						<xsl:with-param name="mandatoryEarlyTerminationModel.calculationAgentParty" select="$mandatoryEarlyTerminationModel.calculationAgentParty"/>
						<xsl:with-param name="generateCashFlows" select="$generateCashFlows"/>
						<!-- Early Termination -->
						<xsl:with-param name="optionalEarlyTermination.singlePartyOption.buyerRef" select="$optionalEarlyTermination.singlePartyOption.buyerRef"/>
						<xsl:with-param name="optionalEarlyTermination.singlePartyOption.sellerRef" select="$optionalEarlyTermination.singlePartyOption.sellerRef"/>
						<xsl:with-param name="exerciseNotice.node" select="$exerciseNotice.node"/>
						<!-- Cash Settlement Valuation Date -->
						<xsl:with-param name="earlyTerminationProvision.cashSettlementValuationDate.periodMultiplier" select="$earlyTerminationProvision.cashSettlementValuationDate.periodMultiplier"/>
						<xsl:with-param name="earlyTerminationProvision.cashSettlementValuationDate.period" select="$earlyTerminationProvision.cashSettlementValuationDate.period"/>
						<xsl:with-param name="earlyTerminationProvision.cashSettlementValuationDate.dayType" select="$earlyTerminationProvision.cashSettlementValuationDate.dayType"/>
						<xsl:with-param name="mandatoryEarlyTerminationModel.cashSettlementValuationDate.businessCenter.nodes" select="$earlyTerminationProvision.cashSettlementValuationDate.businessCenter.nodes"/>
						<xsl:with-param name="earlyTerminationProvision.businessDayConvention" select="$earlyTerminationProvision.businessDayConvention"/>
						<xsl:with-param name="mandatoryEarlyTerminationModel.cashSettlementValuationDate.dateRelativeTo.href" select="$earlyTerminationModel.cashSettlementValuationDate.dateRelativeTo.href"/>
						<xsl:with-param name="mandatoryEarlyTerminationModel.cashSettlementValuationDate.id" select="$earlyTerminationModel.cashSettlementValuationDate.id"/>
						<xsl:with-param name="earlyTerminationProvision.unadjustedDate.nodes" select="$earlyTerminationProvision.unadjustedDate.nodes"/>
						<xsl:with-param name="optionalEarlyTerminationModel.dateAdjustments.businessDayConvention" select="$optionalEarlyTerminationModel.dateAdjustments.businessDayConvention"/>
						<xsl:with-param name="optionalEarlyTerminationModel.cashSettlementPaymentDate.id" select="$optionalEarlyTerminationModel.cashSettlementPaymentDate.id"/>
						<xsl:with-param name="optionalEarlyTerminationModel.dateAdjustments.businessCenter.nodes" select="$earlyTerminationProvision.cashSettlementPaymentDate.businessCenter.nodes"/>
						<xsl:with-param name="optionalEarlyTerminationModel.cashSettlementValuationDate.dateRelativeTo.href" select="$earlyTerminationProvision.cashSettlementValuationDate.dateRelativeTo.href"/>
						<xsl:with-param name="earlyTerminationProvision.cashSettlementValuationDate.businessCenter.nodes" select="$earlyTerminationProvision.cashSettlementValuationDate.businessCenter.nodes"/>
						<xsl:with-param name="earlyTerminationProvision.cashPriceMethod.currency" select="$earlyTerminationProvision.cashPriceMethod.currency"/>
						<xsl:with-param name="earlyTerminationProvision.cashPriceMethod.quotationRateType" select="$earlyTerminationProvision.cashPriceMethod.quotationRateType"/>
						<xsl:with-param name="earlyTerminationProvision.cashPriceMethod.referenceBank.node" select="$earlyTerminationProvision.cashPriceMethod.referenceBank.node"/>
						<xsl:with-param name="earlyTerminationProvision.cashSettlementPaymentDate.businessCenter.nodes" select="$earlyTerminationProvision.cashSettlementPaymentDate.businessCenter.nodes"/>
						<xsl:with-param name="earlyTerminationProvision.dateAdjustments.businessDayConvention" select="$earlyTerminationProvision.dateAdjustments.businessDayConvention"/>
						<xsl:with-param name="cashSettlement.unadjustedDate.nodes" select="$mandatoryEarlyTerminationProvision.unadjustedDate.nodes"/>
						<xsl:with-param name="optionalEarlyTerminationModel.hourMinuteTime" select="$cashSettlementValuationTime.hourMinuteTime"/>
						<xsl:with-param name="optionalEarlyTerminationModel.businessCenter.name" select="$cashSettlementValuationTime.businessCenter.name"/>
						<xsl:with-param name="mandatoryEarlyTerminationModel.hourMinuteTime" select="$cashSettlementValuationTime.hourMinuteTime"/>
						<xsl:with-param name="mandatoryEarlyTerminationModel.businessCenter.name" select="$cashSettlementValuationTime.businessCenter.name"/>
						<!-- Rate cut-off -->
						<xsl:with-param name="swapStream1.rateCutOffDaysOffset.period" select="$swapStream1.rateCutOffDaysOffset.period"/>
						<xsl:with-param name="swapStream1.rateCutOffDaysOffset.periodMultiplier" select="$swapStream1.rateCutOffDaysOffset.periodMultiplier"/>
						<xsl:with-param name="swapStream1.rateCutOffDaysOffset.dayType" select="$swapStream1.rateCutOffDaysOffset.dayType"/>
						<xsl:with-param name="swapStream2.rateCutOffDaysOffset.period" select="$swapStream2.rateCutOffDaysOffset.period"/>
						<xsl:with-param name="swapStream2.rateCutOffDaysOffset.periodMultiplier" select="$swapStream2.rateCutOffDaysOffset.periodMultiplier"/>
						<xsl:with-param name="swapStream2.rateCutOffDaysOffset.dayType" select="$swapStream2.rateCutOffDaysOffset.dayType"/>
						<!-- Master Agreement -->							  
						<xsl:with-param name="masterAgreementType" select="$masterAgreementType"/>
						<xsl:with-param name="masterAgreementTypeScheme" select="$masterAgreementTypeScheme"/>
						<xsl:with-param name="contractualDefinitionsScheme" select="$contractualDefinitionsScheme"/>
						<xsl:with-param name="contractualDefinitions" select="$contractualDefinitions"/>
						<xsl:with-param name="productId.nodes" select="$productId.nodes"/>								
					</xsl:call-template>
				</xsl:variable>
				<xsl:choose>
					<xsl:when test="$fpmlType = 'RequestTradeConfirmation'">
						<!-- Create amendment node -->
						<xsl:call-template name="create-tradeAmendmentContent">
							<xsl:with-param name="eventIdentifier.partyReference.href" select="$party.id2"/>
							<xsl:with-param name="eventIdentifier.eventId" select="$eventId"/>
							<xsl:with-param name="trade.nodes" select="$trade.nodes"/>
							<xsl:with-param name="executionDateTime" select="$contractEventDateTime"/>
							<xsl:with-param name="agreementDate" select="$contractEventDate"/>
							<xsl:with-param name="effectiveDate" select="$postTradeEffectiveDate"/>
							<!-- payment -->
							<xsl:with-param name="payment.payerPartyReference.href" select="$payment.payerPartyReference.href"/>
							<xsl:with-param name="payment.receiverPartyReference.href" select="$payment.receiverPartyReference.href"/>
							<xsl:with-param name="payment.paymentAmount.currency" select="$payment.paymentAmount.currency"/>
							<xsl:with-param name="payment.paymentAmount.currency.currencyScheme" select="$currencyScheme"/>
							<xsl:with-param name="payment.paymentAmount.amount" select="$payment.paymentAmount.amount"/>
							<xsl:with-param name="payment.adjustedPaymentDate" select="$payment.adjustedDate"/>
							<xsl:with-param name="payment.paymentType" select="$payment.paymentType"/>
							<xsl:with-param name="payment.adjustableDateNode" select="'false'"/>
						</xsl:call-template>
					</xsl:when>
					<xsl:when test="$fpmlType = 'Termination'">
						<termination>
							<!-- Create termination node -->
							<xsl:call-template name="create-tradeNotionalChange">
								<xsl:with-param name="tradeChangeBase.businessEventIdentifier.eventId" select="$eventId"/>
								<xsl:with-param name="tradeChangeBase.businessEventIdentifier.issuer.partyIdScheme" select="$party.partyIdScheme2"/>
								<xsl:with-param name="tradeChangeBase.businessEventIdentifier.partyReference.href" select="$party.id2"/>
								<xsl:with-param name="tradeChangeBase.tradeIdentifier.partyReference.href" select="$party.id2"/>
								<xsl:with-param name="tradeChangeBase.tradeIdentifier.tradeId" select="$tradeId2"/>
								<xsl:with-param name="tradeChangeBase.tradeIdentifier.tradeId.tradeIdScheme" select="$tradeId2.scheme"/>
								<xsl:with-param name="tradeChangeBase.executionDateTime" select="$contractEventDateTime"/>
								<xsl:with-param name="tradeChangeBase.agreementDate" select="$contractEventDate"/>
								<xsl:with-param name="tradeChangeBase.effectiveDate" select="$contractEventDate"/>
								<xsl:with-param name="tradeChangeBase.payment.payerPartyReference.href" select="$payment.payerPartyReference.href"/>
								<xsl:with-param name="tradeChangeBase.payment.receiverPartyReference.href" select="$payment.receiverPartyReference.href"/>
								<xsl:with-param name="tradeChangeBase.payment.paymentAmount.currency" select="$payment.paymentAmount.currency"/>
								<xsl:with-param name="tradeChangeBase.payment.paymentAmount.currency.currencyScheme" select="$currencyScheme"/>
								<xsl:with-param name="tradeChangeBase.payment.paymentAmount.amount" select="$payment.paymentAmount.amount"/>
								<xsl:with-param name="tradeChangeBase.payment.adjustableDateNode" select="'false'"/>
								<xsl:with-param name="tradeChangeBase.payment.adjustedPaymentDate" select="$payment.adjustedDate"/>
								<xsl:with-param name="tradeChangeBase.payment.paymentType" select="$payment.paymentType"/>
								<!-- changeInNotionalAmount -->
								<xsl:with-param name="changeInNotionalAmount.currency" select="$settlementCurrency"/>
								<xsl:with-param name="changeInNotionalAmount.currency.currencyScheme" select="$currencyScheme"/>
								<xsl:with-param name="changeInNotionalAmount.amount" select="$impactQuantity"/>
								<xsl:with-param name="changeInNotionalAmount.secondAmount" select="$impactSecondQuantity"/>
								<!-- outstandingNotionalAmount -->
								<xsl:with-param name="outstandingNotionalAmount.currency" select="$settlementCurrency"/>
								<xsl:with-param name="outstandingNotionalAmount.currency.currencyScheme" select="$currencyScheme"/>
								<xsl:with-param name="outstandingNotionalAmount.amount">
									<xsl:choose>
										<xsl:when test="$fpmlType = 'Termination' and $eventType = 'mxContractEventIASSIGNMENT'">
											<xsl:value-of select="$impactInitialQuantity - $impactQuantity"/>
										</xsl:when>
										<xsl:otherwise>
											<xsl:value-of select="$outstandingQuantity"/>
										</xsl:otherwise>
									</xsl:choose>
								</xsl:with-param>
								<xsl:with-param name="outstandingNotionalAmount.secondCurrency" select="$settlementSecondCurrency"/>
								<xsl:with-param name="outstandingNotionalAmount.secondAmount" select="$outstandingSecondQuantity"/>
								<xsl:with-param name="tradeChangeBase.originalTrade.nodes" select="$originalTrade.nodes"/>
								<xsl:with-param name="tradeChangeBase.payment.nodes" select="$payment.node"/>
							</xsl:call-template>
						</termination>
					</xsl:when>
					<xsl:when test="$fpmlType = 'NovationNew' or $fpmlType = 'NovationOld'">
						<!-- Create novation node -->
						<xsl:call-template name="create-tradeNovationContent">
							<xsl:with-param name="eventIdentifier.eventId" select="$eventIdRef"/>
							<xsl:with-param name="eventIdentifier.partyReference.href" select="$party.id2"/>
							<xsl:with-param name="newTrade.nodes">
								<xsl:if test="$fpmlType = 'NovationNew'">
									<xsl:element name="newTrade">
										<xsl:copy-of select="exslt:node-set($trade.nodes)/*/*"/>
									</xsl:element>
								</xsl:if>
							</xsl:with-param>
							<xsl:with-param name="oldTrade.nodes">
								<xsl:if test="$fpmlType = 'NovationOld'">
									<xsl:element name="oldTrade">
										<xsl:copy-of select="exslt:node-set($trade.nodes)/*/*"/>
									</xsl:element>
								</xsl:if>
							</xsl:with-param>
							<!-- executionDateTime -->
							<xsl:with-param name="executionDateTime" select="$executionDateTime"/>
							<xsl:with-param name="novationDate" select="$novationDate"/>
							<xsl:with-param name="novationTradeDate" select="$novationTradeDate"/>
							<!-- novated amount -->
							<xsl:with-param name="novatedAmount.amount">
								<xsl:variable name="isFeeCurrencyExchange">
									<xsl:call-template name="isFeeCurrencyExchange"/>
								</xsl:variable>
								<xsl:variable name="isPackage">
									<xsl:variable name="packageId">
										<xsl:call-template name="extract-package-id">
											<xsl:with-param name="pkgNb" select="1"/>
										</xsl:call-template>
									</xsl:variable>
									<xsl:choose>
										<xsl:when test="string-length($packageId) &gt; 0">
											<xsl:value-of select="'yes'"/>
										</xsl:when>
										<xsl:otherwise>
											<xsl:value-of select="'no'"/>
										</xsl:otherwise>
									</xsl:choose>
								</xsl:variable>
								<xsl:variable name="assignedRatio">
									<xsl:call-template name="extract-assignedRatio"/>
								</xsl:variable>
								<xsl:variable name="initialCapitalAmountImpact">
									<xsl:value-of select="/MxML/trades/trade[(not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeBody/*/stream[1]/capital/initialCapitalAmount"/>
								</xsl:variable>
								<xsl:variable name="leg1.referenceCapitalCurrency">
									<xsl:value-of select="/MxML/trades/trade[(not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeBody/*/stream[1]/capital/referenceCapitalCurrency"/>
								</xsl:variable>
								<xsl:variable name="isInitialCapitalCurrencyChanged">
									<xsl:choose>
										<xsl:when test="$novatedAmount.currency = $leg1.referenceCapitalCurrency">
											<xsl:value-of select="'no'"/>
										</xsl:when>
										<xsl:otherwise>
											<xsl:value-of select="'yes'"/>
										</xsl:otherwise>
									</xsl:choose>
								</xsl:variable>
								<xsl:choose>
									<xsl:when test="$isInitialCapitalCurrencyChanged = 'no'">
										<xsl:value-of select="$impactQuantity"/>
									</xsl:when>
									<xsl:otherwise>
										<xsl:value-of select="format-number($initialCapitalAmountImpact * $assignedRatio * 0.01, '##.########')"/>
									</xsl:otherwise>
								</xsl:choose>
							</xsl:with-param>
							<xsl:with-param name="novatedAmount.currency" select="$novatedAmount.currency"/>
							<!-- remaining amount -->
							<xsl:with-param name="remainingAmount.currency" select="$novatedAmount.currency"/>
							<xsl:with-param name="remainingAmount.amount" select="$remainingAmount.amount"/>
							<!-- parties -->
							<xsl:with-param name="transferor.href" select="$transferor.href"/>
							<xsl:with-param name="transferee.href" select="$transferee.href"/>
							<xsl:with-param name="remainingParty.href" select="$remainingParty.href"/>
							<!-- payment -->
							<xsl:with-param name="payment.payerPartyReference.href" select="$payment.payerPartyReference.href"/>
							<xsl:with-param name="payment.receiverPartyReference.href" select="$payment.receiverPartyReference.href"/>
							<xsl:with-param name="payment.paymentAmount.currency" select="$payment.paymentAmount.currency"/>
							<xsl:with-param name="payment.paymentAmount.currency.currencyScheme" select="$currencyScheme"/>
							<xsl:with-param name="payment.paymentAmount.amount" select="$payment.paymentAmount.amount"/>
							<xsl:with-param name="payment.adjustedPaymentDate" select="$payment.adjustedDate"/>
							<xsl:with-param name="payment.paymentType" select="$payment.paymentType"/>
							<xsl:with-param name="payment.adjustableDateNode" select="'false'"/>
						</xsl:call-template>
					</xsl:when>
					<xsl:otherwise>
						<xsl:copy-of select="$trade.nodes"/>
					</xsl:otherwise>
				</xsl:choose>
				<!-- Create the first party tag -->
				<xsl:call-template name="create-trade-party">
					<xsl:with-param name="party.id" select="$party.id1"/>
					<xsl:with-param name="party.partyId" select="$party.partyId1"/>
					<xsl:with-param name="party.partyIdScheme" select="$party.partyIdScheme1"/>
				</xsl:call-template>
				<!-- Create the second party tag -->
				<xsl:call-template name="create-trade-party">
					<xsl:with-param name="party.id" select="$party.id2"/>
					<xsl:with-param name="party.partyId" select="$party.partyId2"/>
					<xsl:with-param name="party.partyIdScheme" select="$party.partyIdScheme2"/>
				</xsl:call-template>
				<!-- specific for novation events -->
				<xsl:if test="string-length($party3Id) &gt; 0 and ($fpmlType = 'NovationNew' or $fpmlType = 'NovationOld')">
					<xsl:call-template name="create-trade-party">
						<xsl:with-param name="party.id" select="$party3Id"/>
						<xsl:with-param name="party.partyId" select="$party.partyId3"/>
						<xsl:with-param name="party.partyIdScheme" select="$party.partyIdScheme3"/>
					</xsl:call-template>
				</xsl:if>
			</xsl:element>
		</xsl:variable>
		<xsl:apply-templates select="exslt:node-set($fpmlNode)" mode="change-ns"/>
	</xsl:template>
</xsl:stylesheet>