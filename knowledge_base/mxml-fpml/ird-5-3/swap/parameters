												</xsl:when>
												<xsl:when
												test="$paymentSchedule.scheduleNature = 'deducedFrom'">
												<!-- get it from calculation schedule -->
												<xsl:value-of
												select="mx:execute-formula($mapBusinessDayConv, concat('businessDayConvention:', $streamSchedules.businessDayConvention))"
												/>
												</xsl:when>
											</xsl:choose>
										</xsl:when>
										<!-- calculation schedule -->
										<xsl:when
											test="$exercizeScheduleBuilder.underlyingSchedule = 'calculationSchedule'">
											<xsl:value-of
												select="mx:execute-formula($mapBusinessDayConv, concat('businessDayConvention:', $streamSchedules.businessDayConvention))"
											/>
										</xsl:when>
									</xsl:choose>
								</xsl:when>
								<!-- equalTo -->
								<xsl:when test="$exercizeScheduleBuilder.scheduleNature = 'equalTo'">
									<xsl:choose>
										<!-- payment schedule -->
										<xsl:when
											test="$exercizeScheduleBuilder.underlyingSchedule = 'paymentSchedule'">
											<xsl:choose>
												<xsl:when
												test="$paymentSchedule.scheduleNature = 'drivingSchedule'">
												<xsl:value-of
												select="mx:execute-formula($mapBusinessDayConv, concat('businessDayConvention:', $paymentSchedule.businessDayConvention))"
												/>
												</xsl:when>
												<xsl:when
												test="$paymentSchedule.scheduleNature = 'deducedFrom'">
												<!-- get it from calculation schedule -->
												<xsl:value-of
												select="mx:execute-formula($mapBusinessDayConv, concat('businessDayConvention:', $streamSchedules.businessDayConvention))"
												/>
												</xsl:when>
												<xsl:when
												test="$paymentSchedule.scheduleNature = 'equalTo'">
												<!-- get it from calculation schedule -->
												<xsl:value-of
												select="mx:execute-formula($mapBusinessDayConv, concat('businessDayConvention:', $streamSchedules.businessDayConvention))"
												/>
												</xsl:when>
											</xsl:choose>
										</xsl:when>
										<!-- calculation schedule -->
										<xsl:when
											test="$exercizeScheduleBuilder.underlyingSchedule = 'calculationSchedule'">
											<xsl:value-of
												select="mx:execute-formula($mapBusinessDayConv, concat('businessDayConvention:', $streamSchedules.businessDayConvention))"
											/>
										</xsl:when>
									</xsl:choose>
								</xsl:when>
								<xsl:otherwise>
									<xsl:value-of
										select="mx:execute-formula($mapBusinessDayConv, 'businessDayConvention:none')"
									/>
								</xsl:otherwise>
							</xsl:choose>
						</xsl:variable>
						<xsl:variable name="bermudaExerciseDates.unadjustedDate.nodes">
							<xsl:call-template name="create-adjustableDates-adjustableDates">
								<xsl:with-param name="optionStyle" select="'bermudan'"/>
								<xsl:with-param name="dateAdjustments.businessDayConvention"
									select="'NONE'"/>
								<xsl:with-param name="dateAdjustments.businessCenter.nodes">
									<!-- generate business adjustement business center if a businessDayConvention is specified-->
									<xsl:if
										test="$bermudan.dateAdjustments.businessDayConvention != 'NONE'">
										<xsl:call-template name="makePaymentBusinessCenterNodes">
											<xsl:with-param name="legNumber" select="1"/>
										</xsl:call-template>
									</xsl:if>
								</xsl:with-param>
							</xsl:call-template>
						</xsl:variable>
						<xsl:variable name="relevantUnderlyingDate.unadjustedDate.nodes">
							<xsl:call-template name="create-adjustableDates-adjustableDates">
								<xsl:with-param name="relevantUnderlyingDate" select="'true'"/>
								<xsl:with-param name="optionStyle" select="'bermudan'"/>
								<xsl:with-param name="dateAdjustments.businessDayConvention" select="'NONE'"/>
								<xsl:with-param name="dateAdjustments.businessCenter.nodes">
									<!-- generate business adjustement business center if a businessDayConvention is specified-->
									<xsl:if test="$bermudan.dateAdjustments.businessDayConvention != 'NONE'">
										<xsl:call-template name="makePaymentBusinessCenterNodes">
											<xsl:with-param name="legNumber" select="1"/>
										</xsl:call-template>
									</xsl:if>
								</xsl:with-param>
							</xsl:call-template>
						</xsl:variable>
						<xsl:variable name="exerciseFeeSchedule.steps">
							<xsl:variable name="initialFeeRate"
								select="/MxML/trades/trade/tradeBody/*/payout/option/exercizeSchedule/exercizeEvents/exercizeEvent[1]/exercizePenaltyFee"/>
							<xsl:for-each
								select="/MxML/trades/trade/tradeBody/*/payout/option/exercizeSchedule/exercizeEvents/exercizeEvent">
								<xsl:variable name="previousFeeRate">
									<xsl:choose>
										<xsl:when test="position() = 1">
											<xsl:value-of select="$initialFeeRate"/>
										</xsl:when>
										<xsl:otherwise>
											<xsl:value-of
												select="preceding-sibling::exercizePenaltyFee"/>
										</xsl:otherwise>
									</xsl:choose>
								</xsl:variable>
								<xsl:variable name="thisPeriodFeeRate" select="exercizePenaltyFee"/>
								<xsl:if test="$previousFeeRate != $thisPeriodFeeRate">
									<xsl:element name="step">
										<xsl:if test="string-length(exercizeDate) &gt; 0">
											<xsl:element name="stepDate">
												<xsl:value-of
												select="mx:execute-formula('mx.xml2xml.transform.mxml2fpml.utils.toFpMLDate', concat('mxmlDate:', exercizeDate))"
												/>
											</xsl:element>
										</xsl:if>
										<xsl:element name="stepValue">
											<xsl:value-of
												select="format-number($thisPeriodFeeRate, '##.########')"
											/>
										</xsl:element>
									</xsl:element>
								</xsl:if>
							</xsl:for-each>
						</xsl:variable>
						<!-- bermudaExercise -->
						<xsl:element name="bermudaExercise">
							<xsl:attribute name="id">
								<xsl:value-of select="'swaptionExerciseDate'"/>
							</xsl:attribute>
							<xsl:element name="bermudaExerciseDates">
								<xsl:attribute name="id">
									<xsl:value-of select="'exerciseSchedule'"/>
								</xsl:attribute>
								<xsl:copy-of
									select="exslt:node-set($bermudaExerciseDates.unadjustedDate.nodes)"
								/>
							</xsl:element>
							<xsl:element name="relevantUnderlyingDate">
								<xsl:attribute name="id">
									<xsl:value-of select="'relevantUnderlyingSchedule'"/>
								</xsl:attribute>
								<xsl:copy-of
									select="exslt:node-set($relevantUnderlyingDate.unadjustedDate.nodes)"
								/>
							</xsl:element>
							<xsl:element name="exerciseFeeSchedule">
								<xsl:call-template name="create-exerciseFeeSchedule">
									<xsl:with-param name="payerPartyReference.href"
										select="substring-after(/MxML/trades/trade/tradeBody/*/payout/option/optionHolderReference/@href, '#')"/>
									<xsl:with-param name="receiverPartyReference.href"
										select="substring-after(/MxML/trades/trade/tradeBody/*/payout/option/optionWriterReference/@href, '#')"/>
									<!--agreed with the client that we will specify 2 for the floating leg-->
									<xsl:with-param name="notionalReference.href"
										select="concat('leg_', '2', '_notionalSchedule')"/>
									<xsl:with-param name="initialValue"
										select="/MxML/trades/trade/tradeBody/*/payout/option/exercizeSchedule/exercizeEvents/exercizeEvent[1]/exercizePenaltyFee"/>
									<xsl:with-param name="steps" select="$exerciseFeeSchedule.steps"/>
									<xsl:with-param name="period" select="'D'"/>
									<xsl:with-param name="periodMultiplier" select="'0'"/>
									<xsl:with-param name="businessDayConvention" select="'NONE'"/>
									<xsl:with-param name="dateRelativeTo.href"
										select="'relevantUnderlyingSchedule'"/>
								</xsl:call-template>
							</xsl:element>
						</xsl:element>
					</xsl:when>
				</xsl:choose>
			</xsl:otherwise>			
		</xsl:choose>
	</xsl:variable>

