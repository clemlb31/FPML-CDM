			<xsl:value-of select="$result"/>
		</xsl:if>
	</xsl:variable>

	<xsl:variable name="swapStream2.inflationRate.dayType">
		<xsl:if
			test="$swapStream2.inflationRate.period = 'D' and ($indexCategory = 'inflationIndex' or $typology = 'Inflation Swap' or $Mxgroup = 'INFLS' or $swapStream2.isInflationIndexed = 'true')">
			<xsl:variable name="tmp">
				<xsl:call-template name="extract-returnShifter-periodUnit">
					<xsl:with-param name="legNb" select="1"/>
					<xsl:with-param name="stream" select="2"/>
				</xsl:call-template>
			</xsl:variable>
			<xsl:variable name="result">
				<xsl:if test="string-length($tmp) &gt; 0">
					<xsl:value-of
						select="mx:execute-formula($mapPeriodUnit, concat('periodUnit:', $tmp))/row[2]"
					/>
				</xsl:if>
			</xsl:variable>
			<xsl:call-template name="AssertNotMapped">
				<xsl:with-param name="value" select="$result"/>
				<xsl:with-param name="message"
					select="concat('Period Unit for Inflation Lag Shifter ', $tmp, ' not mapped')"/>
				<xsl:with-param name="formula" select="$mapPeriodUnit"/>
			</xsl:call-template>
			<xsl:value-of select="$result"/>
		</xsl:if>
	</xsl:variable>

	<xsl:variable name="mapInterpolationMethod"	select="'public.xml2xml.mapping.mxml2fpml.interpolationMethod'"/>
	<xsl:variable name="swapStream1.inflationRate.interpolationMethod">
		<xsl:if	test="$indexCategory = 'inflationIndex' or $typology = 'Inflation Swap' or $Mxgroup = 'INFLS' or $swapStream1.isInflationIndexed = 'true'">
			<xsl:variable name="interpolationMethodMX">
				<xsl:call-template name="extract-return-interpolation">
					<xsl:with-param name="legNb" select="1"/>
					<xsl:with-param name="stream" select="1"/>
				</xsl:call-template>
			</xsl:variable>
			<xsl:if test="string-length($interpolationMethodMX) &gt; 0">
				<xsl:variable name="result"	select="mx:execute-formula($mapInterpolationMethod, concat('interpolation:', $interpolationMethodMX))"/>
				
				<xsl:call-template name="AssertNotMapped">
					<xsl:with-param name="value" select="$result"/>
					<xsl:with-param name="message"
						select="concat('Interpolation method ', $interpolationMethodMX, ' not mapped')"/>
					<xsl:with-param name="formula" select="$mapInterpolationMethod"/>
				</xsl:call-template>
				
				<xsl:value-of select="$result"/>
			</xsl:if>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="swapStream2.inflationRate.interpolationMethod">
		<xsl:if	test="$indexCategory = 'inflationIndex' or $typology = 'Inflation Swap' or $Mxgroup = 'INFLS' or $swapStream2.isInflationIndexed = 'true'">
			<xsl:variable name="interpolationMethodMX">
				<xsl:call-template name="extract-return-interpolation">
					<xsl:with-param name="legNb" select="1"/>
					<xsl:with-param name="stream" select="2"/>
				</xsl:call-template>
			</xsl:variable>
			<xsl:if test="string-length($interpolationMethodMX) &gt; 0">
				<xsl:variable name="result"	select="mx:execute-formula($mapInterpolationMethod, concat('interpolation:', $interpolationMethodMX))"/>
				<xsl:call-template name="AssertNotMapped">
					<xsl:with-param name="value" select="$result"/>
					<xsl:with-param name="message" select="concat('Interpolation method ', $interpolationMethodMX, ' not mapped')"/>
					<xsl:with-param name="formula" select="$mapInterpolationMethod"/>
				</xsl:call-template>
				<xsl:value-of select="$result"/>
			</xsl:if>
		</xsl:if>
	</xsl:variable>

	<xsl:variable name="swapStream1_extract-indexationIndexLabel">
		<xsl:call-template name="extract-indexationIndexLabel">
			<xsl:with-param name="legNb" select="1"/>
			<xsl:with-param name="stream" select="1"/>
		</xsl:call-template>
	</xsl:variable>
	
	<xsl:variable name="swapStream2_extract-indexationIndexLabel">
		<xsl:call-template name="extract-indexationIndexLabel">
			<xsl:with-param name="legNb" select="1"/>
			<xsl:with-param name="stream" select="2"/>
		</xsl:call-template>
	</xsl:variable>

	<xsl:variable name="swapStream1_floatingRateIndex_FPML" select="mx:execute-formula('public.ECN.import.FpML.mapping.outbound.index', concat('index:', $swapStream1_extract-indexationIndexLabel))" />
	<xsl:variable name="swapStream2_floatingRateIndex_FPML" select="mx:execute-formula('public.ECN.import.FpML.mapping.outbound.index',	concat('index:', $swapStream2_extract-indexationIndexLabel))" />

	<xsl:variable name="swapStream1.inflationRate.floatingRateIndex">
		<xsl:choose>
			<xsl:when test="$indexCategory = 'inflationIndex' or $typology = 'Inflation Swap' or $Mxgroup = 'INFLS'">
				<xsl:value-of select="$swapStream1.floatingRateIndex"/>
			</xsl:when>
			<xsl:when test="$swapStream1.isInflationIndexed = 'true'">
				<!--Deprecated implementation-->
				<!--<xsl:call-template name="extract-indexationIndexLabel">
					<xsl:with-param name="legNb" select="1"/>
					<xsl:with-param name="stream" select="1"/>
				</xsl:call-template>-->
				<xsl:value-of select="$swapStream1_floatingRateIndex_FPML//row[1]"/>
			</xsl:when>
		</xsl:choose>
	</xsl:variable>
	<xsl:variable name="swapStream1.inflationRate.floatingRateIndexScheme">
		<xsl:if	test="$indexCategory = 'inflationIndex' or $typology = 'Inflation Swap' or $Mxgroup = 'INFLS' or $swapStream1.isInflationIndexed = 'true'">
			<xsl:value-of select="'http://www.fpml.org/coding-scheme/inflation-index-description'"/>
		</xsl:if>
	</xsl:variable>

	<xsl:variable name="swapStream2.inflationRate.floatingRateIndex">
		<xsl:choose>
			<xsl:when test="$indexCategory = 'inflationIndex' or $typology = 'Inflation Swap' or $Mxgroup = 'INFLS'">
				<xsl:value-of select="$swapStream2.floatingRateIndex"/>
			</xsl:when>
			<xsl:when test="($indexCategoryIndexation = 'inflationIndex' and $swapStream2.indexedObjectNature = 'interestFlows')">
				<!--Deprecated implementation-->
				<!--<xsl:call-template name="extract-indexationIndexLabel">
					<xsl:with-param name="legNb" select="1"/>
					<xsl:with-param name="stream" select="2"/>
				</xsl:call-template>-->
				<xsl:value-of select="$swapStream2_floatingRateIndex_FPML//row[1]"/>
			</xsl:when>
		</xsl:choose>
	</xsl:variable>
	<xsl:variable name="swapStream2.inflationRate.floatingRateIndexScheme">
		<xsl:if	test="$indexCategory = 'inflationIndex' or $typology = 'Inflation Swap' or $Mxgroup = 'INFLS' or $swapStream2.isInflationIndexed = 'true'">
			<xsl:value-of select="'http://www.fpml.org/coding-scheme/inflation-index-description'"/>
		</xsl:if>
	</xsl:variable>

	<xsl:variable name="swapStream1.inflationRate.floatingRateMultiplierSchedule.nodes">
		<xsl:variable name="value">
			<xsl:call-template name="extract-inflationRateCalculation-floatingRateMultiplierSchedule-initialValue">
				<xsl:with-param name="stream" select="1"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:if test="string-length($value) &gt; 0">
			<xsl:element name="floatingRateMultiplierSchedule">
				<xsl:element name="initialValue">
					<xsl:value-of select="format-number($value div 100, '##.##########')"/>
				</xsl:element>
			</xsl:element>
		</xsl:if>
	</xsl:variable>

	<xsl:variable name="swapStream2.inflationRate.floatingRateMultiplierSchedule.nodes">
		<xsl:variable name="value">
			<xsl:call-template name="extract-inflationRateCalculation-floatingRateMultiplierSchedule-initialValue">
				<xsl:with-param name="stream" select="2"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:if test="string-length($value) &gt; 0">
			<xsl:element name="floatingRateMultiplierSchedule">
				<xsl:element name="initialValue">
					<xsl:value-of select="format-number($value div 100, '##.##########')"/>
				</xsl:element>
			</xsl:element>
		</xsl:if>
	</xsl:variable>
	
</xsl:stylesheet>