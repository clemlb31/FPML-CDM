				<xsl:value-of select="mx:execute-formula($mapBusinessDayConv, $swapStream2.paramMaturityBusinessDayConvention)"	/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<!-- swapStream2.calculationPeriodDatesAdjustments.businessDayConvention -->
	<xsl:variable name="swapStream2.paramCalculationBusinessDayConvention" select="concat('businessDayConvention:', $leg2.calculation.businessDayConvention)"/>
	<xsl:variable name="swapStream2.calculationPeriodDatesAdjustments.businessDayConvention" select="mx:execute-formula($mapBusinessDayConv, $swapStream2.paramCalculationBusinessDayConvention)"/>

	<!-- swapStream2.terminationDate.dateAdjustments.businessCenter.nodes -->
	<xsl:variable name="swapStream2.terminationDate.dateAdjustments.businessCenter.nodes">
		<xsl:if test="$swapStream2.terminationDate.dateAdjustments.businessDayConvention != 'NONE'">
			<xsl:call-template name="makePaymentBusinessCenterNodes">
				<xsl:with-param name="legNumber" select="2"/>
			</xsl:call-template>
		</xsl:if>
	</xsl:variable>

	<xsl:variable name="leg2.singlePeriod.periodDayCountFactor"
		select="number(/MxML/trades/trade[1]/tradeBody/*/stream[./streamTemplate/streamSchedules/singlePeriod = 'true' and ./streamTemplate/leg = 2]/cashFlows/interestFlows/interestPaymentPeriod/calculationPeriod/periodDayCountFactor)"/>
	<!-- swapStream2.frequency.period -->
	<xsl:variable name="swapStream2.frequency.period">
		<xsl:choose>
			<xsl:when test="$swapStream2.paymentSchedule.zeroCouponMode = 'true'">
				<xsl:value-of select="'T'"/>
			</xsl:when>
			<xsl:when test="$leg2.singlePeriod = 'true'">T</xsl:when>
			<xsl:otherwise>
				<xsl:value-of
					select="mx:execute-formula($mapPeriodUnit, $swapStream2.paramFrequencyPeriodUnit)//row[1]"
				/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<!-- swapStream2.resetFrequency.period -->
	<xsl:variable name="swapStream2.resetFrequency.period">
		<xsl:choose>
			<xsl:when test="$leg2.calculation.periodMultiplier = '0'">
				<xsl:value-of select="'T'"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of
					select="mx:execute-formula($mapPeriodUnit, $swapStream2.paramResetFrequencyPeriodUnit)//row[1]"
				/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<!-- swapStream2.floatingRateIndex -->
	<xsl:variable name="swapStream2.params" select="concat('index:', $leg2.floatingRateIndex,',contractualDefinitions:',$contractualDefinitions)"/>
	<xsl:variable name="swapStream2.params.details">
		<xsl:if test="$leg2.payoutType != 'fixedRate'">
			<xsl:copy-of select="mx:execute-formula($mapIndex, $swapStream2.params)"/>
		</xsl:if>
	</xsl:variable>

	<xsl:variable name="swapStream2.floatingRateIndex">
		<xsl:if test="$leg2.payoutType != 'fixedRate'">
			<xsl:variable name="swapStream2.index.resultPre"
				select="exslt:node-set($swapStream2.params.details)/table/row[1]"/>
			<xsl:choose>
				<xsl:when test="$swapStream2.index.resultPre = 'UNMAPPED'">
					<xsl:value-of
						select="mx:execute-formula('mx.xml2xml.ECN.common.errorHandling.throwException', concat('errorMessage: Unmapped index (second leg)-', concat($mapIndex, translate($swapStream2.params, ',', '|'))))"
					/>
				</xsl:when>
				<xsl:otherwise>
					<xsl:value-of select="$swapStream2.index.resultPre"/>
				</xsl:otherwise>
			</xsl:choose>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="swapStream2.floatingRateIndexScheme">
		<xsl:if test="$leg2.payoutType != 'fixedRate'">
			<xsl:value-of select="exslt:node-set($swapStream2.params.details)/table/row[4]"/>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="swapStream2.calculationPeriodAmount.periodMultiplier">
		<xsl:if test="$leg2.payoutType != 'fixedRate'">
			<xsl:value-of select="exslt:node-set($swapStream2.params.details)/table/row[3]"/>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="swapStream2.calculationPeriodAmount.period">
		<xsl:if test="$leg2.payoutType != 'fixedRate'">
			<xsl:value-of select="exslt:node-set($swapStream2.params.details)/table/row[2]"/>
		</xsl:if>
	</xsl:variable>

	<!-- swapStream2.calculationPeriodDatesAdjustments.businessCenter.nodes -->
	<xsl:variable name="swapStream2.calculationPeriodDatesAdjustments.businessCenter.nodes">
		<xsl:choose>
			<xsl:when
				test="/MxML/trades/trade[$trdNb]/tradeBody/*/stream[streamTemplate/leg = 2]/streamTemplate/streamSchedules/calculationEndSchedule/scheduleGenerator/standardScheduleGenerator/businessCenters/businessCenter">
				<xsl:value-of
					select="/MxML/trades/trade[$trdNb]/tradeBody/*/stream[streamTemplate/leg = 2]/streamTemplate/streamSchedules/calculationEndSchedule/scheduleGenerator/standardScheduleGenerator/businessCenters/businessCenter"
				/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:choose>
					<xsl:when
						test="$swapStream2.calculationPeriodDatesAdjustments.businessDayConvention != 'NONE'">
						<xsl:call-template name="calculationPeriodDatesAdjustments.businessCenter">
							<xsl:with-param name="legNumber" select="'2'"/>
							<xsl:with-param name="nbTrade" select="$trdNb"/>
						</xsl:call-template>
					</xsl:when>
					<xsl:otherwise/>
				</xsl:choose>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<!-- swapStream2.paymentDatesAdjustments.businessCenter.nodes -->
	<xsl:variable name="swapStream2.paymentDatesAdjustments.businessCenter.nodes">
		<xsl:choose>
			<xsl:when
				test="/MxML/trades/trade/tradeBody/*/stream[streamTemplate/leg = 2]/streamTemplate/streamSchedules/paymentSchedule/scheduleGenerator/standardScheduleGenerator/businessCenters/businessCenter">
				<xsl:call-template name="paymentSchedule.businessCenter">
					<xsl:with-param name="legNumber" select="2"/>
					<xsl:with-param name="nbTrade" select="$trdNb"/>
				</xsl:call-template>
			</xsl:when>
			<xsl:otherwise>
				<xsl:call-template name="paymentDates.businessCenter">
					<xsl:with-param name="legNumber" select="2"/>
					<xsl:with-param name="nbTrade" select="$trdNb"/>
				</xsl:call-template>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<!-- swapStream2.resetDatesAdjustments.businessDayConvention -->
	<xsl:variable name="swapStream2.resetDatesAdjustments.businessDayConvention">
		<xsl:choose>
			<xsl:when test="$swapStream2.isInflationIndexed = 'true'">
				<xsl:value-of select="'NONE'"/>
			</xsl:when>
			<xsl:when
				test="$leg2.reset.shifter.periodMultiplier = '0' and $swapStream2.fixingDates.period = 'businessDay'">
				<xsl:choose>
					<xsl:when test="$dateShifterDirection = 'forward'">FOLLOWING</xsl:when>
					<xsl:otherwise>PRECEDING</xsl:otherwise>
				</xsl:choose>
			</xsl:when>
			<xsl:otherwise>
				<xsl:choose>
					<xsl:when test="$leg2.reset.businessDayConvention = 'none'">
						<xsl:choose>
							<xsl:when
								test="/MxML/trades/trade[(not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeBody/*/stream[1]/streamTemplate/streamSchedules/resetSchedule/shifter/dateShifterDirection = 'backward'">
								<xsl:value-of select="'PRECEDING'"/>
							</xsl:when>
							<xsl:otherwise>
								<xsl:value-of select="'FOLLOWING'"/>
							</xsl:otherwise>
						</xsl:choose>
					</xsl:when>
					<xsl:otherwise>
						<xsl:value-of
							select="mx:execute-formula($mapBusinessDayConv, $swapStream2.paramResetDatesAdjustmentsBusinessDayConvention)"
						/>
					</xsl:otherwise>
				</xsl:choose>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<!-- swapStream2.resetDatesAdjustments.businessCenter.nodes -->
	<xsl:variable name="swapStream2.resetDatesAdjustments.businessCenter.nodes">
		<xsl:choose>
			<xsl:when
				test="string-length(/MxML/trades/trade[(not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeBody/*/stream[streamTemplate/leg = 2]/streamTemplate/streamSchedules/resetSchedule/scheduleGenerator/standardScheduleGenerator/businessCenters/businessCenter) &gt; 0 and $swapStream2.resetDatesAdjustments.businessDayConvention != 'NONE'">
				<xsl:call-template name="resetSchedule.businessCenter">
					<xsl:with-param name="legNumber" select="2"/>
				</xsl:call-template>
			</xsl:when>
			<xsl:otherwise>
				<xsl:choose>
					<xsl:when
						test="$swapStream2.resetDatesAdjustments.businessDayConvention != 'NONE'">
						<xsl:call-template name="resetDates.businessCenter">
							<xsl:with-param name="legNumber" select="2"/>
						</xsl:call-template>
					</xsl:when>
					<xsl:otherwise/>
				</xsl:choose>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<!-- swapStream2.dayCountFraction -->
	<xsl:variable name="leg2.dayCountFractionLabel">
		<xsl:call-template name="extract-dayCountFractionLabel">
			<xsl:with-param name="legNb" select="1"/>
			<xsl:with-param name="stream" select="2"/>

		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="leg2.paramDayCountFraction"
		select="concat('rateConventionLabel:', $leg2.dayCountFractionLabel)"/>
	<xsl:variable name="swapStream2.dayCountFraction">
		<xsl:variable name="swapStream2.dayCountFractionPre"
			select="mx:execute-formula($mapDayCountBasis, $leg2.paramDayCountFraction)"/>
		<xsl:choose>
			<xsl:when test="$swapStream2.dayCountFractionPre = 'UNMAPPED'">
				<xsl:value-of
					select="mx:execute-formula('mx.xml2xml.ECN.common.errorHandling.throwException', concat('errorMessage: Unmapped dayCountFraction (second leg)-', concat($mapDayCountBasis, translate($leg2.paramDayCountFraction, ',', '|'))))"
				/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="$swapStream2.dayCountFractionPre"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<!-- swapStream2.calculationPeriodFrequency.period -->
	<xsl:variable name="swapStream2.calculationPeriodFrequency.period">
		<xsl:choose>
			<xsl:when test="$leg2.singlePeriod = 'true' and $swapStream2.dayCountFraction = '1/1'">
				<xsl:choose>
					<xsl:when
						test="($indexCategory = 'inflationIndex' or $typology = 'Inflation Swap' or $Mxgroup = 'INFLS')">
						<xsl:choose>
							<xsl:when test="$leg2.payoutType = 'fixedRate'">
								<xsl:value-of select="'Y'"/>
							</xsl:when>
							<xsl:otherwise>
								<xsl:value-of select="'T'"/>
							</xsl:otherwise>
						</xsl:choose>
					</xsl:when>
					<xsl:otherwise>
						<xsl:value-of select="'Y'"/>
					</xsl:otherwise>
				</xsl:choose>
			</xsl:when>

			<xsl:when test="$leg2.calculation.periodMultiplier = '0'">
				<xsl:value-of select="'T'"/>
			</xsl:when>
			<xsl:when
				test="$swapStream2.paymentSchedule.zeroCouponMode = 'true' and $leg2.payoutType = 'fixedRate'">
				<xsl:value-of select="'T'"/>
			</xsl:when>
			<xsl:when test="$leg2.singlePeriod = 'true' and $leg2.payoutType = 'fixedRate'">
				<xsl:value-of select="'T'"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of
					select="mx:execute-formula($mapPeriodUnit, $swapStream2.paramCalculationPeriodUnit)//row[1]"
				/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<!-- swapStream2.paymentDates.period -->
	<xsl:variable name="swapStream2.paymentDates.period">
		<xsl:value-of
			select="mx:execute-formula($mapPeriodUnit, $swapStream2.paramFrequencyPeriodUnit)//row[1]"
		/>
	</xsl:variable>

	<!-- swapStream2.fixingDates.period -->
	<xsl:variable name="swapStream2.fixingDates.period">
		<xsl:variable name="swapStream2.fixingDates.periodTmp"
			select="mx:execute-formula($mapPeriodUnit, $swapStream2.paramFixingPeriodUnit)//row[1]"/>
		<xsl:choose>
			<xsl:when test="$swapStream2.isInflationIndexed = 'true'">
				<xsl:value-of select="$swapStream2.inflationRate.period"/>
			</xsl:when>
			<xsl:when test="$swapStream2.fixingDates.periodTmp = 'UNMAPPED'">
				<xsl:value-of select="'D'"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="$swapStream2.fixingDates.periodTmp"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<!-- swapStream2.initialFixingDate.periodMultiplier -->
	<xsl:variable name="swapStream2.initialFixingDate.periodMultiplier">
		<xsl:variable name="fixingDate.customization">
			<xsl:call-template name="extract-fixingDate-customization">
				<xsl:with-param name="legNb" select="$trdNb"/>
				<xsl:with-param name="stream" select="2"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:variable name="fixingDate.customizedValue">
			<xsl:call-template name="extract-fixingDate-customizedValue">
				<xsl:with-param name="legNb" select="$trdNb"/>
				<xsl:with-param name="stream" select="2"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:variable name="fixingDate.calculationStartDate">
			<xsl:call-template name="extract-fixingDate-calculationStartDate">
				<xsl:with-param name="legNb" select="$trdNb"/>
				<xsl:with-param name="stream" select="2"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:choose>
			<xsl:when test="$swapStream2.isInflationIndexed = 'true'">
				<xsl:value-of select="$swapStream2.inflationRate.periodMultiplier"/>
			</xsl:when>
			<xsl:when test="string-length($fixingDate.customization) &gt; 0">
				<xsl:variable name="fixingDate.custom.julian">
					<xsl:call-template name="julianday-from-gregorian">
						<xsl:with-param name="date" select="$fixingDate.customizedValue"/>
					</xsl:call-template>
				</xsl:variable>
				<xsl:variable name="fixingDate.calc.julian">
					<xsl:call-template name="julianday-from-gregorian">
						<xsl:with-param name="date" select="$fixingDate.calculationStartDate"/>
					</xsl:call-template>
				</xsl:variable>
				<xsl:value-of select="$fixingDate.custom.julian - $fixingDate.calc.julian"/>
			</xsl:when>
			<xsl:otherwise/>
		</xsl:choose>
	</xsl:variable>

	<!-- When the initial fixing date is customised, the dayType is set to Calendar -->
	<xsl:variable name="swapStream2.initialFixingDate.dayType">
		<xsl:if test="string-length($swapStream2.initialFixingDate.periodMultiplier) &gt; 0">
			<xsl:value-of select="'Calendar'"/>
		</xsl:if>
	</xsl:variable>

	<!-- When the initial fixing date is customised, the period is D -->
	<xsl:variable name="swapStream2.initialFixingDate.period">
		<xsl:if
			test="string-length($swapStream2.initialFixingDate.periodMultiplier) &gt; 0 and not($swapStream2.isInflationIndexed = 'true')">
			<xsl:value-of select="'D'"/>
		</xsl:if>
	</xsl:variable>

	<!-- When the initial fixing date is customised, the bdc is NONE -->
	<xsl:variable name="swapStream2.initialFixingDate.businessDayConvention">
		<xsl:if test="string-length($swapStream2.initialFixingDate.periodMultiplier) &gt; 0">
			<xsl:value-of select="'NONE'"/>
		</xsl:if>
	</xsl:variable>

	<!-- When the initial fixing date is customised, business center for initial fixing date is blank -->
	<xsl:variable name="swapStream2.initialFixingDate.businessCenter.nodes"/>

	<!-- swapStream2.fixingDates.businessDayConvention -->
	<xsl:variable name="swapStream2.fixingDates.businessDayConvention">
		<xsl:choose>
			<!-- businessDayConvention must equal 'PRECEDING' if periodMultiplier is '0' and period is 'D' -->
			<xsl:when
				test="$swapStream2.fixingDates.periodMultiplier = '0' and ($swapStream2.fixingDates.period = 'D' or string-length($swapStream2.fixingDates.period) = 0)">
				<xsl:value-of select="'PRECEDING'"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="'NONE'"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<!-- swapStream2.businessDayConvention -->
	<xsl:variable name="leg2.periodMultiplier">
		<xsl:call-template name="extract-shifter-payment-periodMultiplier">
			<xsl:with-param name="legNb" select="2"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="leg2.periodUnit">
		<xsl:call-template name="extract-shifter-payment-periodUnit">
			<xsl:with-param name="legNb" select="2"/>
		</xsl:call-template>
	</xsl:variable>

	<xsl:variable name="swapStream2.businessDayConvention">
		<!--xsl:choose-->
		<!-- Commenting the choose as we didn't figure out where this condition is coming from - According to FpML samples, paymentDatesAdjustments BDC should not be NONE for ZC -->
		<!--xsl:when test="$leg2.singlePeriod = 'true' or $zeroCouponMode = 'true'">NONE</xsl:when-->
		<!--xsl:otherwise-->
		<!-- Commenting the choose as we didn't figure out where this condition is coming from and it is interfering with a test case -->
		<!--<xsl:choose>
					<xsl:when test="$leg2.periodMultiplier = '0' and $leg2.periodUnit = 'businessDay'">
						<xsl:choose>
							<xsl:when test="$dateShifterDirection='forward'">FOLLOWING</xsl:when>
							<xsl:otherwise>PRECEDING</xsl:otherwise>
						</xsl:choose>
					</xsl:when>
					<xsl:otherwise> -->
		<xsl:variable name="swapStream2.businessDayConvention.tmp">
			<xsl:call-template name="paymentDates.businessDayConvention">
				<xsl:with-param name="legNumber" select="2"/>
				<xsl:with-param name="nbTrade" select="$trdNb"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:choose>
			<xsl:when test="$swapStream2.businessDayConvention.tmp = 'NONE'">
				<xsl:choose>
					<xsl:when
						test="/MxML/trades/trade[(not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeBody/*/stream[2]/streamTemplate/streamSchedules/paymentSchedule/shifter/dateShifterDirection = 'backward'">
						<xsl:value-of select="'PRECEDING'"/>
					</xsl:when>
					<xsl:otherwise>
						<xsl:value-of select="'FOLLOWING'"/>
					</xsl:otherwise>
				</xsl:choose>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="$swapStream2.businessDayConvention.tmp"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<!-- swapStream2.calculationPeriodFrequency.rollConvention -->
	<xsl:variable name="leg2.calculationSchedule.scheduleGeneratorLabel">
		<xsl:call-template name="extract-scheduleGenerationLabel">
			<xsl:with-param name="legNb" select="1"/>
			<xsl:with-param name="stream" select="2"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="swapStream2.calculationPeriodFrequency.rollConvention">
		<xsl:variable name="calculationPeriodFrequency.rollConvention2"
			select="mx:execute-formula($mapRollConvention, concat('rollConventionLabel:', $leg2.calculationSchedule.scheduleGeneratorLabel))"/>
		<xsl:choose>
			<!-- ZC - Fixed Leg -->
			<!-- ZC control had been removed because 'NONE' is not the correct value according to the specs (case 2135) -->
			<!-- Reactivated: because values should be 1T for calc pay freq and NONE for Roll convention -->
			<xsl:when test="$leg2.singlePeriod = 'true' and $swapStream2.dayCountFraction = '1/1'">
				<xsl:choose>
					<xsl:when
						test="($indexCategory = 'inflationIndex' or $typology = 'Inflation Swap' or $Mxgroup = 'INFLS')">
						<xsl:choose>
							<xsl:when test="$leg2.payoutType = 'fixedRate'">
								<!-- When calculation frequency period is Y -->
								<xsl:choose>
									<xsl:when
										test="$calculationPeriodFrequency.rollConvention2 = $leg2.calculationSchedule.scheduleGeneratorLabel or $calculationPeriodFrequency.rollConvention2 = ''">
										<xsl:call-template name="getRollConvention">
											<xsl:with-param name="stream" select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[streamTemplate/leg = 2]" />
										</xsl:call-template>
									</xsl:when>
									<xsl:otherwise>
										<xsl:value-of
											select="$calculationPeriodFrequency.rollConvention2"/>
									</xsl:otherwise>
								</xsl:choose>
							</xsl:when>
							<xsl:otherwise>
								<!-- When calculation frequency period is T -->
								<xsl:value-of select="'NONE'"/>
							</xsl:otherwise>
						</xsl:choose>
					</xsl:when>
					<xsl:otherwise>
						<!-- When calculation frequency period is Y -->
						<xsl:choose>
							<xsl:when
								test="$calculationPeriodFrequency.rollConvention2 = $leg2.calculationSchedule.scheduleGeneratorLabel or $calculationPeriodFrequency.rollConvention2 = ''">
								<xsl:call-template name="getRollConvention">
									<xsl:with-param name="stream" select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[streamTemplate/leg = 2]" />
								</xsl:call-template>
							</xsl:when>
							<xsl:otherwise>
								<xsl:value-of select="$calculationPeriodFrequency.rollConvention2"/>
							</xsl:otherwise>
						</xsl:choose>
					</xsl:otherwise>
				</xsl:choose>
			</xsl:when>

			<xsl:when test="$swapStream2.paymentSchedule.zeroCouponMode = 'true' and $leg2.payoutType = 'fixedRate'">
				<xsl:value-of select="'NONE'"/>
			</xsl:when>
			<xsl:when test="$leg2.singlePeriod = 'true' and $leg2.payoutType = 'fixedRate'">
				<xsl:value-of select="'NONE'"/>
			</xsl:when>
			<xsl:when test="($swapStream2.calculationPeriodFrequency.endOfMonthTreatment = 'stickIfEndOfMonth' or $swapStream2.calculationPeriodFrequency.endOfMonthTreatment = 'stickIfUsualEndOfMonth') and (substring($leg2.maturityDate, 5, 4) = '0131' or substring($leg2.maturityDate, 5, 4) = '0228' or substring($leg2.maturityDate, 5, 4) = '0229' or substring($leg2.maturityDate, 5, 4) = '0331' or substring($leg2.maturityDate, 5, 4) = '0430' or substring($leg2.maturityDate, 5, 4) = '0531' or substring($leg2.maturityDate, 5, 4) = '0630' or substring($leg2.maturityDate, 5, 4) = '3101' or substring($leg2.maturityDate, 5, 4) = '0731' or substring($leg2.maturityDate, 5, 4) = '0831' or substring($leg2.maturityDate, 5, 4) = '0930' or substring($leg2.maturityDate, 5, 4) = '1031' or substring($leg2.maturityDate, 5, 4) = '1130' or substring($leg2.maturityDate, 5, 4) = '1231')">
				<xsl:value-of select="'EOM'"/>
			</xsl:when>
			<!--OIS and compound Term -->
			<xsl:when test="$leg2.calculation.periodUnit = 'term'">
				<xsl:value-of select="'NONE'"/>
			</xsl:when>
			<xsl:when test="$leg2.calculation.periodMultiplier = '0'">
				<xsl:value-of select="'NONE'"/>
