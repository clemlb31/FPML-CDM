				<xsl:call-template name="extract-ctpNameByRef">
					<xsl:with-param name="partyID"
						select="$optionalEarlyTermination.exerciseNotice1.exerciseNoticePartyRef"/>
				</xsl:call-template>
			</xsl:variable>
			<xsl:variable name="templateLabel">
				<xsl:call-template name="extract-templateLabel"> </xsl:call-template>
			</xsl:variable>
			<xsl:variable name="exerciseNotificationLocation"
				select="mx:execute-formula($mapNotificationLocation, concat('instrument:', $templateLabel, ',counterparty:', $partyName))"/>
			<xsl:choose>
				<xsl:when
					test="string-length($exerciseNotificationLocation/row[1]) &gt; 0 and not($exerciseNotificationLocation/row[1] = '') and not($exerciseNotificationLocation/row[1] = 'UNMAPPED')">
					<xsl:value-of select="$exerciseNotificationLocation/row[1]"/>
				</xsl:when>
				<xsl:otherwise>
					<xsl:value-of select="$bermudaExerciseDates.dateAdjustments.businessCenter"/>
				</xsl:otherwise>
			</xsl:choose>
		</xsl:variable>
		<xsl:variable name="optionalEarlyTermination.exerciseNotice2.businessCenter">
			<xsl:variable name="partyName">
				<xsl:call-template name="extract-ctpNameByRef">
					<xsl:with-param name="partyID"
						select="$optionalEarlyTermination.exerciseNotice2.exerciseNoticePartyRef"/>
				</xsl:call-template>
			</xsl:variable>
			<xsl:variable name="templateLabel">
				<xsl:call-template name="extract-templateLabel"> </xsl:call-template>
			</xsl:variable>
			<xsl:variable name="exerciseNotificationLocation"
				select="mx:execute-formula($mapNotificationLocation, concat('instrument:', $templateLabel, ',counterparty:', $partyName))"/>
			<xsl:choose>
				<xsl:when
					test="string-length($exerciseNotificationLocation/row[1]) &gt; 0 and not($exerciseNotificationLocation/row[1] = '') and not($exerciseNotificationLocation/row[1] = 'UNMAPPED')">
					<xsl:value-of select="$exerciseNotificationLocation/row[1]"/>
				</xsl:when>
				<xsl:otherwise>
					<xsl:value-of select="$bermudaExerciseDates.dateAdjustments.businessCenter"/>
				</xsl:otherwise>
			</xsl:choose>
		</xsl:variable>
		<exerciseNotice>
			<xsl:if test="string-length($optionalEarlyTermination.exerciseNotice1.partyRef) &gt; 0">
				<partyReference>
					<xsl:attribute name="href">
						<xsl:value-of select="$optionalEarlyTermination.exerciseNotice1.partyRef"/>
					</xsl:attribute>
				</partyReference>
			</xsl:if>
			<xsl:if
				test="string-length($optionalEarlyTermination.exerciseNotice1.exerciseNoticePartyRef) &gt; 0">
				<exerciseNoticePartyReference>
					<xsl:attribute name="href">
						<xsl:value-of
							select="$optionalEarlyTermination.exerciseNotice1.exerciseNoticePartyRef"
						/>
					</xsl:attribute>
				</exerciseNoticePartyReference>
			</xsl:if>
			<xsl:if
				test="string-length($optionalEarlyTermination.exerciseNotice1.businessCenter) &gt; 0">
				<xsl:variable name="_value.tokens">
					<xsl:call-template name="str:_split-pattern">
						<xsl:with-param name="string"
							select="$optionalEarlyTermination.exerciseNotice1.businessCenter"/>
						<xsl:with-param name="pattern" select="';'"/>
					</xsl:call-template>
				</xsl:variable>
				<xsl:variable name="value.tokens" select="exsl:node-set($_value.tokens)/token"/>
				<xsl:for-each select="$value.tokens">
					<xsl:variable name="pos" select="position()"/>
					<xsl:variable name="token" select="string($value.tokens[$pos])"/>
					<businessCenter>
						<xsl:value-of select="$token"/>
					</businessCenter>
				</xsl:for-each>
			</xsl:if>
		</exerciseNotice>
		<xsl:if test="$breakableBy = 'both' or string-length($breakableBy) = 0">
			<exerciseNotice>
				<xsl:if
					test="string-length($optionalEarlyTermination.exerciseNotice2.partyRef) &gt; 0">
					<partyReference>
						<xsl:attribute name="href">
							<xsl:value-of
								select="$optionalEarlyTermination.exerciseNotice2.partyRef"/>
						</xsl:attribute>
					</partyReference>
				</xsl:if>
				<xsl:if
					test="string-length($optionalEarlyTermination.exerciseNotice2.exerciseNoticePartyRef) &gt; 0">
					<exerciseNoticePartyReference>
						<xsl:attribute name="href">
							<xsl:value-of
								select="$optionalEarlyTermination.exerciseNotice2.exerciseNoticePartyRef"
							/>
						</xsl:attribute>
					</exerciseNoticePartyReference>
				</xsl:if>
				<xsl:if
					test="string-length($optionalEarlyTermination.exerciseNotice2.businessCenter) &gt; 0">
					<xsl:variable name="_value.tokens">
						<xsl:call-template name="str:_split-pattern">
							<xsl:with-param name="string"
								select="$optionalEarlyTermination.exerciseNotice2.businessCenter"/>
							<xsl:with-param name="pattern" select="';'"/>
						</xsl:call-template>
					</xsl:variable>
					<xsl:variable name="value.tokens" select="exsl:node-set($_value.tokens)/token"/>
					<xsl:for-each select="$value.tokens">
						<xsl:variable name="pos" select="position()"/>
						<xsl:variable name="token" select="string($value.tokens[$pos])"/>
						<businessCenter>
							<xsl:value-of select="$token"/>
						</businessCenter>
					</xsl:for-each>
				</xsl:if>
			</exerciseNotice>
		</xsl:if>
	</xsl:variable>

	<!-- Rate Cut-Off variables -->
	<xsl:variable name="swapStream1.rateCutOffDaysOffset.periodMultiplier">
		<xsl:call-template name="extract-rateCutOffDaysOffset-periodMultiplier">
			<xsl:with-param name="stream" select="1"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="swapStream1.rateCutOffDaysOffset.period">
		<xsl:if test="string-length($swapStream1.rateCutOffDaysOffset.periodMultiplier) &gt; 0">
			<xsl:value-of select="'D'"/>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="swapStream1.rateCutOffDaysOffset.dayType">
		<xsl:if test="string-length($swapStream1.rateCutOffDaysOffset.periodMultiplier) &gt; 0">
			<xsl:value-of select="'Business'"/>
		</xsl:if>
	</xsl:variable>

	<xsl:variable name="swapStream2.rateCutOffDaysOffset.periodMultiplier">
		<xsl:call-template name="extract-rateCutOffDaysOffset-periodMultiplier">
			<xsl:with-param name="stream" select="2"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="swapStream2.rateCutOffDaysOffset.period">
		<xsl:if test="string-length($swapStream2.rateCutOffDaysOffset.periodMultiplier) &gt; 0">
			<xsl:value-of select="'D'"/>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="swapStream2.rateCutOffDaysOffset.dayType">
		<xsl:if test="string-length($swapStream2.rateCutOffDaysOffset.periodMultiplier) &gt; 0">
			<xsl:value-of select="'Business'"/>
		</xsl:if>
	</xsl:variable>

	<!-- **************** -->
	<!-- Additional Terms -->
	<!-- **************** -->
	<!-- Assuming the fixed leg is always the first one -->
	<xsl:variable name="additionalTerms.bondReference.bond.couponRate">
		<xsl:call-template name="extract-fixedRate">
			<xsl:with-param name="legNb" select="1"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="instrumentIds"
		select="mx:execute-formula('public.ECN.import.FpML.mapping.outbound.bondInstrumentId')"/>
	<xsl:variable name="additionalTerms.bondReference.bond.instrumentId.nodes">
		<xsl:choose>
			<xsl:when test="$typology = 'Asset Swap IRS'">
				<!-- Generation of intrument ids -->
				<xsl:for-each select="exsl:node-set($instrumentIds)//row[position() mod 2 = 0]">
					<xsl:if
						test="string-length(preceding-sibling::row[1]/cell) &gt; 0 and string-length(cell) &gt; 0">
						<xsl:element name="instrumentId">
							<xsl:attribute name="instrumentIdScheme">
								<xsl:value-of select="preceding-sibling::row[1]/cell"/>
							</xsl:attribute>
							<xsl:value-of select="cell"/>
						</xsl:element>
					</xsl:if>
				</xsl:for-each>
			</xsl:when>
		</xsl:choose>
	</xsl:variable>

	<!-- ======================= -->
	<!-- stub periods management -->
	<!-- ======================= -->
	<xsl:variable name="swapStream1.initialStubCharacteristics.periodIndex">
		<xsl:call-template name="extract-initialStubCharacteristics-periodIndex">
			<xsl:with-param name="stream" select="1"/>
		</xsl:call-template>
	</xsl:variable>

	<xsl:variable name="swapStream2.initialStubCharacteristics.periodIndex">
		<xsl:call-template name="extract-initialStubCharacteristics-periodIndex">
			<xsl:with-param name="stream" select="2"/>
		</xsl:call-template>
	</xsl:variable>

	<xsl:variable name="swapStream1.finalStubCharacteristics.periodIndex">
		<xsl:call-template name="extract-finalStubCharacteristics-periodIndex">
			<xsl:with-param name="stream" select="1"/>
		</xsl:call-template>
	</xsl:variable>

	<xsl:variable name="swapStream2.finalStubCharacteristics.periodIndex">
		<xsl:call-template name="extract-finalStubCharacteristics-periodIndex">
			<xsl:with-param name="stream" select="2"/>
		</xsl:call-template>
	</xsl:variable>

	<!-- ======================= -->
	<!-- Extendable swap         -->
	<!-- ======================= -->

	<xsl:variable name="extendable.exerciseNotice.node">
		<exerciseNotice>
			<xsl:if test="string-length($exercise.buyerPartyReference.href) &gt; 0">
				<partyReference>
					<xsl:attribute name="href">
						<xsl:value-of select="$exercise.buyerPartyReference.href"/>
					</xsl:attribute>
				</partyReference>
			</xsl:if>
			<xsl:if test="string-length($exercise.sellerPartyReference.href) &gt; 0">
				<exerciseNoticePartyReference>
					<xsl:attribute name="href">
						<xsl:value-of select="$exercise.sellerPartyReference.href"/>
					</xsl:attribute>
				</exerciseNoticePartyReference>
			</xsl:if>
			<xsl:variable name="relevantUnderlyingDate.dateAdjustments.businessCenter.tmp">
				<xsl:call-template name="extract-businessCenterLabel"/>
			</xsl:variable>
			<businessCenter>
				<xsl:choose>
					<xsl:when test="string-length($mapBusinessCenter) &gt; 0">
						<xsl:value-of	select="mx:execute-formula($mapBusinessCenter, concat('businessCenter:', $relevantUnderlyingDate.dateAdjustments.businessCenter.tmp))"	/>
					</xsl:when>
					<xsl:otherwise>
						<xsl:value-of	select="$relevantUnderlyingDate.dateAdjustments.businessCenter.tmp"/>
					</xsl:otherwise>
				</xsl:choose>
			</businessCenter>
		</exerciseNotice>
	</xsl:variable>
	
