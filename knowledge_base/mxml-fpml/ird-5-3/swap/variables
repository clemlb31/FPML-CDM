	<xsl:variable name="swapStream2.fxLinkedNotionalSchedule.constantNotionalScheduleReference.href">
		<xsl:choose>
			<xsl:when test="$swapStream2.isInflationIndexed = 'true'">
				<xsl:value-of select="''"/>
