		<xsl:variable name="optionalEarlyTermination.exerciseNotice2.partyRef">
			<xsl:choose>
				<xsl:when test="$breakableBy = 'both' or string-length($breakableBy) = 0">
					<xsl:call-template name="extract-ourNameRef">
						<xsl:with-param name="tradeRef" select="$contractRef"/>
