				<xsl:when
					test="/MxML/trades/trade[@id = $contractRef]/tradeBody/currencySwap/stream[2]/streamTemplate/indexationRulesLists/indexationRulesList/indexedObjectNature = 'initialCapital' and /MxML/trades/trade[@id = $contractRef]/tradeBody/currencySwap/stream[2]/indexationLists/indexationList[indexedObjectNature = 'initialCapital']/indexationSchedules/indexationSchedule/indexations/indexation/date &gt; /MxML/trades/trade[@id = $contractRef]/tradeInputConditions/systemDate"/>
				<xsl:when
					test="/MxML/trades/trade[@id = $contractRef]/tradeBody/currencySwap/stream[2]/streamTemplate/indexationRulesLists/indexationRulesList/indexedObjectNature = 'initialCapital' and /MxML/trades/trade[@id = $contractRef]/tradeBody/currencySwap/stream[2]/indexationLists/indexationList[indexedObjectNature = 'initialCapital']/indexationSchedules/indexationSchedule/indexations/indexation/date = /MxML/trades/trade[@id = $contractRef]/tradeInputConditions/systemDate"/>
				<xsl:when
					test="$event = 'unwind' and $unwoundRatio = 1 and not($swapStream2.isInflationIndexed = 'true')">
