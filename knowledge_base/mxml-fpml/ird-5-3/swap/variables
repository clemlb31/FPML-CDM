	<!-- ================= End specific MTM ================= -->
	<!-- Optional Early Termination -->
	<xsl:variable name="optionalEarlyTermination.singlePartyOption.buyerRef">
		<xsl:variable name="breakableBy"
			select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/payout/option/breakableBy"/>
		<xsl:choose>
