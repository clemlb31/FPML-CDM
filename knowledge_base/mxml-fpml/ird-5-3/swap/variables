	<!-- Exercise Notice -->
	<xsl:variable name="exerciseNotice.node">
		<xsl:variable name="breakableBy"
			select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/payout/option/breakableBy"/>
		<xsl:variable name="optionalEarlyTermination.exerciseNotice1.partyRef">
			<xsl:choose>
				<xsl:when
					test="$breakableBy = 'both' or string-length($breakableBy) = 0 or $breakableBy = 'them'">
					<xsl:call-template name="extract-ctpNameRef">
						<xsl:with-param name="tradeRef" select="$contractRef"/>
					</xsl:call-template>
				</xsl:when>
				<xsl:otherwise>
					<xsl:call-template name="extract-ourNameRef">
						<xsl:with-param name="tradeRef" select="$contractRef"/>
					</xsl:call-template>
				</xsl:otherwise>
			</xsl:choose>
