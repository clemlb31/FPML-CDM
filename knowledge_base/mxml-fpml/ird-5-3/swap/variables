				<xsl:call-template name="extract-ctpNameRef">
					<xsl:with-param name="tradeRef" select="$contractRef"/>
				</xsl:call-template>
			</xsl:when>
			<xsl:when test="$breakableBy = 'us'">
				<!-- ourparty reference -->
				<xsl:call-template name="extract-ourNameRef">
					<xsl:with-param name="tradeRef" select="$contractRef"/>
				</xsl:call-template>
			</xsl:when>
			<xsl:otherwise/>
		</xsl:choose>
	</xsl:variable>

	<xsl:variable name="optionalEarlyTermination.singlePartyOption.sellerRef">
