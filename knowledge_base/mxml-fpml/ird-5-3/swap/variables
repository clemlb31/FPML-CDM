	<!-- swapStream1 : to extract initialValue if absence of Fwd start capital -->
	<xsl:variable name="swapStream1.fxLinkedNotionalSchedule.initialValue">
		<xsl:variable name="initialCapitalAmount">
			<xsl:call-template name="extract-initialCapitalAmount">
				<xsl:with-param name="legNb" select="1"/>
				<xsl:with-param name="stream" select="1"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:if
			test="string-length($swapStream1.indexedObjectNature) &gt; 0 and $swapStream1.indexed = 'true'">
			<xsl:choose>
				<!-- In case of forward start and fixing referenceDate is greater than systemDate or equal, the intial amount is not fixed -->
				<xsl:when
					test="/MxML/trades/trade[@id = $contractRef]/tradeBody/currencySwap/stream[1]/streamTemplate/indexationRulesLists/indexationRulesList/indexedObjectNature = 'initialCapital' and /MxML/trades/trade[@id = $contractRef]/tradeBody/currencySwap/stream[1]/indexationLists/indexationList[indexedObjectNature = 'initialCapital']/indexationSchedules/indexationSchedule/indexations/indexation/date &gt; /MxML/trades/trade[@id = $contractRef]/tradeInputConditions/systemDate"/>
				<xsl:when
					test="/MxML/trades/trade[@id = $contractRef]/tradeBody/currencySwap/stream[1]/streamTemplate/indexationRulesLists/indexationRulesList/indexedObjectNature = 'initialCapital' and /MxML/trades/trade[@id = $contractRef]/tradeBody/currencySwap/stream[1]/indexationLists/indexationList[indexedObjectNature = 'initialCapital']/indexationSchedules/indexationSchedule/indexations/indexation/date = /MxML/trades/trade[@id = $contractRef]/tradeInputConditions/systemDate"/>
				<xsl:when
					test="$event = 'unwind' and $unwoundRatio = 1 and not($swapStream1.isInflationIndexed = 'true')">
					<xsl:value-of select="$initialCapitalAmount"/>
				</xsl:when>
				<xsl:otherwise>
					<xsl:choose>
						<xsl:when test="$swapStream1.isInflationIndexed = 'true'">
							<xsl:value-of select="''"/>
						</xsl:when>
						<xsl:otherwise>
							<xsl:value-of
								select="$swapStream1.notionalSchedule.notionalStepSchedule.initialValue"
							/>
						</xsl:otherwise>
					</xsl:choose>
				</xsl:otherwise>
			</xsl:choose>
		</xsl:if>
	</xsl:variable>
	<!-- swapStream2 : to extract initialValue if absence of Fwd start capital -->
