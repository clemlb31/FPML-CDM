					</xsl:call-template>
				</xsl:when>
				<xsl:otherwise>
					<xsl:call-template name="extract-ourNameRef">
						<xsl:with-param name="tradeRef" select="$contractRef"/>
					</xsl:call-template>
				</xsl:otherwise>
			</xsl:choose>
		</xsl:variable>
		<xsl:variable name="optionalEarlyTermination.exerciseNotice2.exerciseNoticePartyRef">
			<xsl:choose>
				<xsl:when test="$breakableBy = 'both' or string-length($breakableBy) = 0">
					<xsl:call-template name="extract-ctpNameRef">
						<xsl:with-param name="tradeRef" select="$contractRef"/>
					</xsl:call-template>
				</xsl:when>
				<xsl:otherwise/>
			</xsl:choose>
		</xsl:variable>
		<xsl:variable name="optionalEarlyTermination.exerciseNotice1.businessCenter">
