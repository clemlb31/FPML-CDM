	<xsl:variable
		name="swapStream1.fxLinkedNotionalSchedule.varyingNotionalFixingDates.businessCenter.nodes">
		<xsl:if test="$swapStream1.indexed = 'true'">
			<xsl:variable name="indexationRulesListsBusinessCenterNodes">
				<xsl:call-template name="extract-indexationRulesListsBusinessCenterNodes">
					<xsl:with-param name="tradeRef" select="$nbTradeNode"/>
					<xsl:with-param name="legNb" select="1"/>
				</xsl:call-template>
			</xsl:variable>
			<xsl:variable name="varyingNotionalFixingDates.HolidaysBC">
				<xsl:value-of select="exsl:node-set($swapStream1.fxSpotRateSource)//row[5]"/>
			</xsl:variable>
			<xsl:choose>
				<xsl:when test="string-length($indexationRulesListsBusinessCenterNodes) &gt; 0">
					<xsl:copy-of select="$indexationRulesListsBusinessCenterNodes"/>
				</xsl:when>
				<xsl:when
					test="string-length($varyingNotionalFixingDates.HolidaysBC) &gt; 0 and $varyingNotionalFixingDates.HolidaysBC != 'UNMAPPED'">
					<xsl:variable name="holidaysBCToken">
						<xsl:call-template name="str:tokenize">
							<xsl:with-param name="string"
								select="$varyingNotionalFixingDates.HolidaysBC"/>
							<xsl:with-param name="delimiters" select="';'"/>
						</xsl:call-template>
					</xsl:variable>
					<xsl:variable name="holidaysBCToken.tokens"
						select="exsl:node-set($holidaysBCToken)/token"/>
					<xsl:for-each select="$holidaysBCToken.tokens">
						<xsl:variable name="pos" select="position()"/>
						<businessCenter>
							<xsl:value-of select="$holidaysBCToken.tokens[$pos]"/>
						</businessCenter>
					</xsl:for-each>
				</xsl:when>
			</xsl:choose>
		</xsl:if>
	</xsl:variable>

	<xsl:variable
		name="swapStream2.fxLinkedNotionalSchedule.varyingNotionalFixingDates.businessCenter.nodes">
		<xsl:if test="$swapStream2.indexed = 'true'">
			<xsl:variable name="indexationRulesListsBusinessCenterNodes">
				<xsl:call-template name="extract-indexationRulesListsBusinessCenterNodes">
					<xsl:with-param name="tradeRef" select="$nbTradeNode"/>
					<xsl:with-param name="legNb" select="2"/>
				</xsl:call-template>
			</xsl:variable>
			<xsl:variable name="varyingNotionalFixingDates.HolidaysBC">
				<xsl:value-of select="exsl:node-set($swapStream2.fxSpotRateSource)//row[5]"/>
			</xsl:variable>
			<xsl:choose>
				<xsl:when test="string-length($indexationRulesListsBusinessCenterNodes) &gt; 0">
					<xsl:copy-of select="$indexationRulesListsBusinessCenterNodes"/>
				</xsl:when>
				<xsl:when
					test="string-length($varyingNotionalFixingDates.HolidaysBC) &gt; 0 and $varyingNotionalFixingDates.HolidaysBC != 'UNMAPPED'">
					<xsl:variable name="holidaysBCToken">
						<xsl:call-template name="str:tokenize">
							<xsl:with-param name="string"
								select="$varyingNotionalFixingDates.HolidaysBC"/>
							<xsl:with-param name="delimiters" select="';'"/>
						</xsl:call-template>
					</xsl:variable>
					<xsl:variable name="holidaysBCToken.tokens"
