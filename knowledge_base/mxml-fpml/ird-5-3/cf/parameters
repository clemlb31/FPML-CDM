		<xsl:choose>
			<xsl:when test="string-length($result) &gt; 0">
				<xsl:value-of select="$result"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:call-template name="extract-indexation-indexCategory">
					<xsl:with-param name="legNb" select="$trdNb"/>
					<xsl:with-param name="stream" select="2"/>
				</xsl:call-template>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>
	
	<xsl:variable name="cfStream.extract-streamTemplate.paymentCurrency">
		<xsl:call-template name="extract-streamTemplate-paymentCurrency">
			<xsl:with-param name="legNb" select="$trdNb"/>
			<xsl:with-param name="stream" select="1"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="swapStream2.extract-streamTemplate.paymentCurrency">
		<xsl:call-template name="extract-streamTemplate-paymentCurrency">
			<xsl:with-param name="legNb" select="$trdNb"/>
			<xsl:with-param name="stream" select="2"/>
		</xsl:call-template>
	</xsl:variable>
	
	<xsl:variable name="cfStream.index.params" select="concat('index:', $leg1.floatingRateIndex)" />
	<xsl:variable name="cfStream.index.result" select="mx:execute-formula($mapIndex, $cfStream.index.params)" />
	<xsl:variable name="cfStream.inflationSwapIndexSourceInflation" select="mx:execute-formula('public.xml2xml.mapping.mxml2fpml.ird.inflationSwapIndexSource', concat('currency:', $cfStream.extract-streamTemplate.paymentCurrency, ',index:',  $cfStream.index.result//row[1]))"/>
	
	<xsl:variable name="cfStream.inflationSwapIndexSourceNotInflation" select="mx:execute-formula('public.xml2xml.mapping.mxml2fpml.ird.inflationSwapIndexSource', concat('currency:', $cfStream.extract-streamTemplate.paymentCurrency, ',index:', $cfStream_floatingRateIndex_FPML//row[1]))"/>
	
	<xsl:variable name="swapStream2.index.params" select="concat('index:', $leg2.floatingRateIndex)" />
	<xsl:variable name="swapStream2.index.result" select="mx:execute-formula($mapIndex, $swapStream2.index.params)" />
	<xsl:variable name="swapStream2.inflationSwapIndexSourceInflation" select="mx:execute-formula('public.xml2xml.mapping.mxml2fpml.ird.inflationSwapIndexSource', concat('currency:', $swapStream2.extract-streamTemplate.paymentCurrency, ',index:', $swapStream2.index.result//row[1]))"/>
	
	<xsl:variable name="swapStream2.inflationSwapIndexSourceNotInflation" select="mx:execute-formula('public.xml2xml.mapping.mxml2fpml.ird.inflationSwapIndexSource', concat('currency:', $swapStream2.extract-streamTemplate.paymentCurrency, ',index:', $swapStream2_floatingRateIndex_FPML//row[1]))"/>	
	
	<xsl:variable name="cfStream.inflationRate.indexSource">
		<xsl:choose>
			<xsl:when test="$indexCategory = 'inflationIndex'">
				<xsl:value-of select="$cfStream.inflationSwapIndexSourceInflation//row[1]"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:if	test="$cfStream_floatingRateIndex_FPML//row[1] != ''">
					<xsl:value-of select="$cfStream.inflationSwapIndexSourceNotInflation//row[1]"/>
				</xsl:if>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>
	<xsl:variable name="cfStream.inflationRate.rateSourcePageScheme">
		<xsl:choose>
			<xsl:when test="$indexCategory = 'inflationIndex'">
				<xsl:value-of select="$cfStream.inflationSwapIndexSourceInflation//row[2]"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:if	test="$cfStream_floatingRateIndex_FPML//row[1] != ''">
					<xsl:value-of select="$cfStream.inflationSwapIndexSourceNotInflation//row[2]"/>
				</xsl:if>				
			</xsl:otherwise>
		</xsl:choose>	
	</xsl:variable>
	
	<xsl:variable name="swapStream2.inflationRate.indexSource">
		<xsl:choose>
			<xsl:when test="$indexCategory = 'inflationIndex'">
				<xsl:value-of select="$swapStream2.inflationSwapIndexSourceInflation//row[1]"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:if	test="$swapStream2_floatingRateIndex_FPML//row[1] != ''">
					<xsl:value-of select="$swapStream2.inflationSwapIndexSourceNotInflation//row[1]"/>
				</xsl:if>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>
	<xsl:variable name="swapStream2.inflationRate.rateSourcePageScheme">
		<xsl:choose>
			<xsl:when test="$indexCategory = 'inflationIndex'">
				<xsl:value-of select="$swapStream2.inflationSwapIndexSourceInflation//row[2]"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:if	test="$swapStream2_floatingRateIndex_FPML//row[1] != ''">
					<xsl:value-of select="$swapStream2.inflationSwapIndexSourceNotInflation//row[2]"/>
				</xsl:if>				
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>
	
	<xsl:variable name="cfStream.inflationRate.period">
		<xsl:if	test="$indexCategory = 'inflationIndex' or $typology = 'Inflation Swap' or $Mxgroup = 'INFLS' or $cfStream.isInflationIndexed = 'true'">
			<xsl:variable name="tmp">
				<xsl:call-template name="extract-returnShifter-periodUnit">
					<xsl:with-param name="legNb" select="1"/>
					<xsl:with-param name="stream" select="1"/>
				</xsl:call-template>
			</xsl:variable>

			<xsl:variable name="result">
				<xsl:if test="string-length($tmp) &gt; 0">
					<xsl:value-of select="mx:execute-formula($mapPeriodUnit, concat('periodUnit:', $tmp))/row[1]" />
				</xsl:if>
			</xsl:variable>
			
			<xsl:call-template name="AssertNotMapped">
				<xsl:with-param name="value" select="$result"/>
				<xsl:with-param name="message" select="concat('Period Unit for Inflation Lag Shifter ', $tmp, ' not mapped')"/>
				<xsl:with-param name="formula" select="$mapPeriodUnit"/>
			</xsl:call-template>
			<xsl:value-of select="$result"/>
		</xsl:if>
	</xsl:variable>

	<xsl:variable name="cfStream.inflationRate.dayType">
		<xsl:if	test="$cfStream.inflationRate.period = 'D' and ($indexCategory = 'inflationIndex' or $typology = 'Inflation Swap' or $Mxgroup = 'INFLS' or $cfStream.isInflationIndexed = 'true')">
			<xsl:variable name="tmp">
				<xsl:call-template name="extract-returnShifter-periodUnit">
					<xsl:with-param name="legNb" select="1"/>
					<xsl:with-param name="stream" select="1"/>
				</xsl:call-template>
			</xsl:variable>
			<xsl:variable name="result">
				<xsl:if test="string-length($tmp) &gt; 0">
					<xsl:value-of select="mx:execute-formula($mapPeriodUnit, concat('periodUnit:', $tmp))/row[2]" />
				</xsl:if>
			</xsl:variable>
			<xsl:call-template name="AssertNotMapped">
				<xsl:with-param name="value" select="$result"/>
				<xsl:with-param name="message" select="concat('Period Unit for Inflation Lag Shifter ', $tmp, ' not mapped')"/>
				<xsl:with-param name="formula" select="$mapPeriodUnit"/>
			</xsl:call-template>
			<xsl:value-of select="$result"/>
		</xsl:if>
	</xsl:variable>

	<xsl:variable name="mapInterpolationMethod"	select="'public.xml2xml.mapping.mxml2fpml.interpolationMethod'"/>
	<xsl:variable name="cfStream.inflationRate.interpolationMethod">
		<xsl:if	test="$indexCategory = 'inflationIndex' or $typology = 'Inflation Swap' or $Mxgroup = 'INFLS' or $cfStream.isInflationIndexed = 'true'">
			<xsl:variable name="interpolationMethodMX">
				<xsl:call-template name="extract-return-interpolation">
					<xsl:with-param name="legNb" select="1"/>
					<xsl:with-param name="stream" select="1"/>
				</xsl:call-template>
			</xsl:variable>
			<xsl:if test="string-length($interpolationMethodMX) &gt; 0">
				<xsl:variable name="result"	select="mx:execute-formula($mapInterpolationMethod, concat('interpolation:', $interpolationMethodMX))"/>
				
				<xsl:call-template name="AssertNotMapped">
					<xsl:with-param name="value" select="$result"/>
					<xsl:with-param name="message"
						select="concat('Interpolation method ', $interpolationMethodMX, ' not mapped')"/>
					<xsl:with-param name="formula" select="$mapInterpolationMethod"/>
				</xsl:call-template>
				
				<xsl:value-of select="$result"/>
			</xsl:if>
		</xsl:if>
	</xsl:variable>

	<xsl:variable name="cfStream_extract-indexationIndexLabel">
		<xsl:call-template name="extract-indexationIndexLabel">
			<xsl:with-param name="legNb" select="1"/>
			<xsl:with-param name="stream" select="1"/>
		</xsl:call-template>
	</xsl:variable>

	<xsl:variable name="cfStream_floatingRateIndex_FPML" select="mx:execute-formula('public.ECN.import.FpML.mapping.outbound.index', concat('index:', $cfStream_extract-indexationIndexLabel))" />

	<xsl:variable name="cfStream.inflationRate.floatingRateIndex">
		<xsl:choose>
			<xsl:when test="$indexCategory = 'inflationIndex' or $typology = 'Inflation Swap' or $Mxgroup = 'INFLS'">
				<xsl:value-of select="$cfStream.floatingRateIndex"/>
			</xsl:when>
			<xsl:when test="$cfStream.isInflationIndexed = 'true'">
				<!--Deprecated implementation-->
				<!--<xsl:call-template name="extract-indexationIndexLabel">
					<xsl:with-param name="legNb" select="1"/>
					<xsl:with-param name="stream" select="1"/>
				</xsl:call-template>-->
				<xsl:value-of select="$cfStream_floatingRateIndex_FPML//row[1]"/>
			</xsl:when>
		</xsl:choose>
	</xsl:variable>
	<xsl:variable name="cfStream.inflationRate.floatingRateIndexScheme">
		<xsl:if	test="$indexCategory = 'inflationIndex' or $typology = 'Inflation Swap' or $Mxgroup = 'INFLS' or $cfStream.isInflationIndexed = 'true'">
			<xsl:value-of select="'http://www.fpml.org/coding-scheme/inflation-index-description'"/>
		</xsl:if>
	</xsl:variable>

	<xsl:variable name="cfStream.inflationRate.floatingRateMultiplierSchedule.nodes">
		<xsl:variable name="value">
			<xsl:call-template name="extract-inflationRateCalculation-floatingRateMultiplierSchedule-initialValue">
				<xsl:with-param name="stream" select="1"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:if test="string-length($value) &gt; 0">
			<xsl:element name="floatingRateMultiplierSchedule">
				<xsl:element name="initialValue">
					<xsl:value-of select="format-number($value div 100, '##.##########')"/>
				</xsl:element>
			</xsl:element>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="cfStream.initialStub.nodes">
		<xsl:variable name="firstFixing" select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[streamTemplate/leg = 1]/floatingRateStream/firstFixing"/>
		<xsl:variable name="initialStub" select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[streamTemplate/leg = 1]/stubPeriods/initialStub"/>
		<xsl:variable name="potentialStubs" select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[streamTemplate/leg = 1]/streamTemplate/potentialStubs"/>
		<xsl:variable name="firstFixingCustomized" select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[streamTemplate/leg = 1]/floatingRateStream/firstFixingCustomized"/>
		<xsl:choose>
				<!--MX generates misleading <stubPeriods><initialStub/></stubPeriods> elements for OIS with maturity<12M-->
				<xsl:when test="$typology = 'OIS' and $periodUnitOIS = 'T'"/>
				<!-- In case of a non regular stub with a first fixing customization -->
				<xsl:when test="(string-length($firstFixing) &gt; 0) and $initialStub and (string-length($potentialStubs) &gt; 0) and ($firstFixingCustomized = 'true')">
					<stubRate> 
						<xsl:value-of select="format-number($firstFixing div 100, '##.##########')"/>
					</stubRate>
				</xsl:when>
				<xsl:when test="$cfStream.initialStubCharacteristics.periodIndex = 'currentIndex'"/>
				<!--fpml.org: "If a stub period uses the same floating rate index, including tenor, as the regular calculation periods then this should not be specified again within this component, i.e. the stub calculation period amount component may not need to be specified even if there is an initial or final stub period"-->
				<xsl:otherwise>
					<xsl:if test="string-length($cfStream.initialStub.floatingRate.params) &gt; 0">
						<xsl:call-template name="create-floatingRate-floatingRate">
							<xsl:with-param name="floatingRateIndex" select="$cfStream.initialStub.floatingRate.floatingRateIndex"/>
							<xsl:with-param name="floatingRateIndexScheme" select="$cfStream.initialStub.floatingRate.floatingRateIndexScheme"/>
							<xsl:with-param name="period" select="$cfStream.initialStub.floatingRate.period"/>
							<xsl:with-param name="periodMultiplier" select="$cfStream.initialStub.floatingRate.periodMultiplier"/>
						</xsl:call-template>
					</xsl:if>
					<xsl:if test="string-length($cfStream.initialStub.floatingRate2.params) &gt; 0">
						<xsl:call-template name="create-floatingRate-floatingRate">
							<xsl:with-param name="floatingRateIndex" select="$cfStream.initialStub.floatingRate2.floatingRateIndex"/>
							<xsl:with-param name="floatingRateIndexScheme" select="$cfStream.initialStub.floatingRate2.floatingRateIndexScheme"/>
							<xsl:with-param name="period" select="$cfStream.initialStub.floatingRate2.period"/>
							<xsl:with-param name="periodMultiplier" select="$cfStream.initialStub.floatingRate2.periodMultiplier"/>
						</xsl:call-template>
					</xsl:if>
				</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>
		<!-- cfStream.finalStub.nodes -->
	<xsl:variable name="cfStream.finalStub.nodes">
		<xsl:choose>
				<!--MX generates misleading <stubPeriods><initialStub/></stubPeriods> elements for OIS with maturity<12M-->
				<xsl:when test="$typology = 'OIS' and $periodUnitOIS = 'T'"/>
				<xsl:when test="$cfStream.finalStubCharacteristics.periodIndex = 'currentIndex'"/>
				<!--fpml.org: "If a stub period uses the same floating rate index, including tenor, as the regular calculation periods then this should not be specified again within this component, i.e. the stub calculation period amount component may not need to be specified even if there is an initial or final stub period"-->
				<xsl:otherwise>
					<xsl:if test="string-length($cfStream.finalStub.floatingRate.params) &gt; 0">
						<xsl:call-template name="create-floatingRate-floatingRate">
							<xsl:with-param name="floatingRateIndex" select="$cfStream.finalStub.floatingRate.floatingRateIndex"/>
							<xsl:with-param name="floatingRateIndexScheme" select="$cfStream.finalStub.floatingRate.floatingRateIndexScheme"/>
							<xsl:with-param name="period" select="$cfStream.finalStub.floatingRate.period"/>
							<xsl:with-param name="periodMultiplier" select="$cfStream.finalStub.floatingRate.periodMultiplier"/>
						</xsl:call-template>
					</xsl:if>
					<xsl:if test="string-length($cfStream.finalStub.floatingRate2.params) &gt; 0">
						<xsl:call-template name="create-floatingRate-floatingRate">
							<xsl:with-param name="floatingRateIndex" select="$cfStream.finalStub.floatingRate2.floatingRateIndex"/>
							<xsl:with-param name="floatingRateIndexScheme" select="$cfStream.finalStub.floatingRate2.floatingRateIndexScheme"/>
							<xsl:with-param name="period" select="$cfStream.finalStub.floatingRate2.period"/>
							<xsl:with-param name="periodMultiplier" select="$cfStream.finalStub.floatingRate2.periodMultiplier"/>
						</xsl:call-template>
					</xsl:if>
				</xsl:otherwise>
			</xsl:choose>
		</xsl:variable>
		<xsl:variable name="cfStream.isDualStub">
			<xsl:variable name="cfStream.stubPeriodPosition" select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/structure/stubPeriodPosition"/>
			<xsl:choose>
				<xsl:when test="(string-length($cfStream.stubPeriodPosition) &gt; 0) and (contains($cfStream.stubPeriodPosition, 'bothSides')) and (string-length($cfStream.initialStub.nodes) &gt; 0) and (string-length($cfStream.finalStub.nodes) &gt; 0)">true</xsl:when>
				<xsl:otherwise>false</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

  	<!-- swapStream1.firstRegularPeriodStartDate -->
	<xsl:variable name="cfStream.firstRegularPeriodStartDate">
		<xsl:if 	test="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[1]/stubPeriods/initialStub">
			<xsl:variable name="cfStream.firstRegularPeriodStartDateTmp">
				<xsl:choose>
					<xsl:when 	test="$nbInterestPaymentPeriod1 = '1' and $nbCalculationPeriod1 &gt; 1">
						<xsl:choose>
							<xsl:when 	test="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[1]/cashFlows/interestFlows/interestPaymentPeriod/calculationPeriod[2]/unadjustedStartDate">
								<xsl:value-of	select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[1]/cashFlows/interestFlows/interestPaymentPeriod/calculationPeriod[2]/unadjustedStartDate"		/>
							</xsl:when>
							<xsl:otherwise>
								<xsl:value-of
									select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[1]/cashFlows/interestFlows/interestPaymentPeriod/calculationPeriod[2]/calculationStartDate"		/>
							</xsl:otherwise>
						</xsl:choose>
					</xsl:when>
					<xsl:otherwise>
						<xsl:choose>
							<xsl:when		test="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[1]/cashFlows/interestFlows/interestPaymentPeriod[2]/calculationPeriod/unadjustedStartDate">
								<xsl:value-of	select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[1]/cashFlows/interestFlows/interestPaymentPeriod[2]/calculationPeriod/unadjustedStartDate"		/>
							</xsl:when>
							<xsl:otherwise>
								<xsl:value-of	select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[1]/cashFlows/interestFlows/interestPaymentPeriod[2]/calculationPeriod/calculationStartDate"		/>
							</xsl:otherwise>
						</xsl:choose>
					</xsl:otherwise>
				</xsl:choose>
			</xsl:variable>
			<!-- In case there is only one period, ie the STUB is the whole period, there is no regularPeriod so the first regular period is set to NOTHING-->
			<xsl:choose>
				<xsl:when test="$cfStream.firstRegularPeriodStartDateTmp = ''">
					<xsl:value-of select="''"/>
				</xsl:when>
				<xsl:otherwise>
					<xsl:value-of	select="mx:execute-formula('mx.xml2xml.transform.mxml2fpml.utils.toFpMLDate', concat('mxmlDate:', $cfStream.firstRegularPeriodStartDateTmp))"	/>
				</xsl:otherwise>
			</xsl:choose>
		</xsl:if>
	</xsl:variable>
	<!-- swapStream1.lastRegularPeriodEndDate -->
	<xsl:variable name="cfStream.lastRegularPeriodEndDate">
		<xsl:if		test="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[1]/stubPeriods/finalStub">
			<xsl:variable name="cfStream.lastRegularPeriodEndDateTmp">
				<xsl:choose>
					<xsl:when 	test="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[1]/cashFlows/interestFlows/interestPaymentPeriod[number($nbInterestPaymentPeriod1) - 1]/calculationPeriod/unadjustedEndDate">
						<xsl:value-of	select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[1]/cashFlows/interestFlows/interestPaymentPeriod[number($nbInterestPaymentPeriod1) - 1]/calculationPeriod/unadjustedEndDate"	/>
					</xsl:when>
					<xsl:otherwise>
						<xsl:value-of	select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[1]/cashFlows/interestFlows/interestPaymentPeriod[number($nbInterestPaymentPeriod1) - 1]/calculationPeriod/calculationEndDate"	/>
					</xsl:otherwise>
				</xsl:choose>
			</xsl:variable>
			<!-- In case there is only one period, ie the STUB is the whole period, there is no regularPeriod so the first regular period is set to startDate-->
			<xsl:choose>
				<xsl:when test="$cfStream.lastRegularPeriodEndDateTmp = ''">
					<xsl:value-of select="$swapStream1.effectiveDate.unadjustedDate"/>
				</xsl:when>
				<xsl:otherwise>
					<xsl:value-of	select="mx:execute-formula('mx.xml2xml.transform.mxml2fpml.utils.toFpMLDate', concat('mxmlDate:', $cfStream.lastRegularPeriodEndDateTmp))"	/>
				</xsl:otherwise>
			</xsl:choose>
		</xsl:if>
	</xsl:variable>
</xsl:stylesheet>