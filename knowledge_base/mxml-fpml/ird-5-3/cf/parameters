<xsl:stylesheet	xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
				xmlns:mx="http://murex.com/xslt/common"
				xmlns:exslt="http://exslt.org/common"
				xmlns:dtcc="http://www.dtcc.com/ext"
				xmlns="http://www.fpml.org/FpML-5/confirmation"
				exclude-result-prefixes="mx exslt"
				version="1.0">
	
	<!-- ========================================================= -->
	<!-- This template contains variables needing mapping formulas -->
	<!-- ========================================================= -->
	<!-- Extraction templates -->
	<xsl:import href="mx.xml2xml.extract.mxml.products.common.templates"/>
	<xsl:import href="mx.xml2xml.extract.mxml.products.ird.swap.templates"/>
	
	<xsl:import href="mx.xml2xml.transform.mxml2fpml.5-3.products.ird.variables"/>
	<xsl:import	href="mx.xml2xml.transform.mxml2fpml.5-3.products.ird.utils.businessDayConventionsAndBusinessCenters"/>
	<xsl:import href="mx.xml2xml.transform.any2fpml.5-3.products.common.europeanExercise"/>
	<xsl:import href="mx.xml2xml.transform.any2fpml.5-3.products.common.americanExercise"/>
	<xsl:import href="mx.xml2xml.transform.any2fpml.5-3.products.common.bermudaExercise"/>
	<xsl:import href="mx.generic.errorHandling.assert"/>

	<!-- ============================= -->
	<!-- Readme:                       -->
	<!-- Mapping formulas (XSL invoke) -->
	<!-- Declare the mapping formulas in a seperate template and import it in the main transformation formula -->
	<!-- e.g: 	
		<xsl:import href="mx.xml2xml.transform.mxml2fpml.5-3.products.ird.swap.template" />
		<xsl:import href="mx.xml2xml.ECN.import.FpML.transform.mxml2fpml.common.5-3.parameters" />
		<xsl:import href="mx.xml2xml.transform.mxml2fpml.5-3.products.ird.swap.parameters" />-->
	<!-- ============================= -->
	<!-- FpMLDateFormula -->
	<xsl:variable name="FpMLDateFormula" select="'mx.xml2xml.ECN.common.utils.adaptDate'"/>
	<!-- Prepare necessary variables to calculate parameter values -->

	<!-- ============================ -->
	<!--           Common             -->
	<!-- ============================ -->
	<xsl:variable name="familyGroupType" select="mx:execute-formula('mx.postTrade.fields.trade.familyGroupType')"/>

	<xsl:variable name="trdNb">
		<xsl:variable name="nbTradeNode" select="count(/MxML/trades/trade)"/>
		<xsl:variable name="status1" select="/MxML/trades/trade[1]/tradeStatus/physicalStatus"/>
		<xsl:variable name="status2" select="/MxML/trades/trade[2]/tradeStatus/physicalStatus"/>
	
		<xsl:choose>
			<xsl:when test="$nbTradeNode = '2'">
				<xsl:choose>
					<xsl:when test="$status1 = $status2 and not($status1 = 'dead')">
						<xsl:value-of select="'1'"/>
					</xsl:when>
					<xsl:when test="$status1 = 'partiallyDead' and $status2 = 'dead'">
						<xsl:value-of select="'1'"/>
					</xsl:when>
					<xsl:otherwise>
						<xsl:for-each select="/MxML/trades/trade">
							<xsl:if test="not(tradeStatus/physicalStatus = 'dead')">
								<xsl:value-of select="position()"/>
							</xsl:if>
						</xsl:for-each>
					</xsl:otherwise>
				</xsl:choose>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="'1'"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<!-- ============================ -->
	<!-- financial data per stream    -->
	<!-- ============================ -->
	<!-- =========== -->
	<!-- cfStream -->
	<!-- =========== -->

	<!-- cfStream.calculationPeriodDatesAdjustments.businessDayConvention -->
	<xsl:variable name="cfStream.paramCalculationBusinessDayConvention" select="concat('businessDayConvention:', $leg1.calculation.businessDayConvention)"/>
	<xsl:variable name="cfStream.calculationPeriodDatesAdjustments.businessDayConvention" select="mx:execute-formula($mapBusinessDayConv, $cfStream.paramCalculationBusinessDayConvention)"/>

	<!-- cfStream.calculationPeriodDatesAdjustments.businessCenter.nodes -->
	<xsl:variable name="cfStream.calculationPeriodDatesAdjustments.businessCenter.nodes">
		<xsl:choose>
			<xsl:when
				test="/MxML/trades/trade[$trdNb]/tradeBody/*/stream[streamTemplate/leg = 1]/streamTemplate/streamSchedules/calculationEndSchedule/scheduleGenerator/standardScheduleGenerator/businessCenters/businessCenter">
				<xsl:value-of
					select="/MxML/trades/trade[$trdNb]/tradeBody/*/stream[streamTemplate/leg = 1]/streamTemplate/streamSchedules/calculationEndSchedule/scheduleGenerator/standardScheduleGenerator/businessCenters/businessCenter"
				/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:choose>
					<xsl:when
						test="$cfStream.calculationPeriodDatesAdjustments.businessDayConvention != 'NONE'">
						<xsl:call-template name="calculationPeriodDatesAdjustments.businessCenter">
							<xsl:with-param name="legNumber" select="'1'"/>
							<xsl:with-param name="nbTrade" select="$trdNb"/>
						</xsl:call-template>
					</xsl:when>
					<xsl:otherwise/>
				</xsl:choose>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<!-- paymentDatesAdjustments1.businessCenter.nodes -->
	<xsl:variable name="cfStream.paymentDatesAdjustments.businessCenter.nodes">
		<xsl:choose>
			<xsl:when
				test="/MxML/trades/trade/tradeBody/*/stream[streamTemplate/leg = 1]/streamTemplate/streamSchedules/paymentSchedule/scheduleGenerator/standardScheduleGenerator/businessCenters/businessCenter">
				<xsl:call-template name="paymentSchedule.businessCenter">
					<xsl:with-param name="legNumber" select="1"/>
					<xsl:with-param name="nbTrade" select="$trdNb"/>
				</xsl:call-template>
			</xsl:when>
			<xsl:otherwise>
				<xsl:call-template name="paymentDates.businessCenter">
					<xsl:with-param name="legNumber" select="1"/>
					<xsl:with-param name="nbTrade" select="$trdNb"/>
				</xsl:call-template>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<!-- cfStream.effectiveDate.dateAdjustments.businessDayConvention -->
	<xsl:variable name="cfStream.effectiveDate.unadjustedDate">
		<xsl:variable name="effectiveDateMx">
			<xsl:call-template name="extract-effectiveDate">
				<xsl:with-param name="legNb" select="1"/>
				<xsl:with-param name="stream" select="1"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:value-of
			select="mx:execute-formula($FpMLDateFormula, concat('date:', $effectiveDateMx, ',format:yyyymmdd,outputFormat:yyyy-mm-dd'))"
		/>
	</xsl:variable>
	<xsl:variable name="cfStream.effectiveDate.adjustedDate">

		<xsl:variable name="effectiveDateMx">
			<xsl:value-of
				select="/MxML/trades/trade[(not(tradeStatus/physicalStatus = 'dead') and count(../trade) &gt; 1) or (count(../trade) = 1)]/tradeBody/*/stream[streamTemplate/leg = 1]/adjustedEffectiveDate"
			/>
		</xsl:variable>
		<xsl:value-of
			select="mx:execute-formula($FpMLDateFormula, concat('date:', $effectiveDateMx, ',format:yyyymmdd,outputFormat:yyyy-mm-dd'))"
		/>
	</xsl:variable>
	<xsl:variable name="cfStream.paramEffectiveDateBusinessDayConvention"
		select="concat('businessDayConvention:', $leg1.effectiveDate.businessDayConvention)"/>
	<xsl:variable name="cfStream.effectiveDate.dateAdjustments.businessDayConvention">
		<xsl:choose>
			<xsl:when
				test="$cfStream.effectiveDate.unadjustedDate = $cfStream.effectiveDate.adjustedDate">
				<xsl:value-of select="'NONE'"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of
					select="mx:execute-formula($mapBusinessDayConv, $cfStream.paramEffectiveDateBusinessDayConvention)"
				/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<!-- cfStream.effectiveDate.dateAdjustments.businessCenter.nodes -->
	<xsl:variable name="cfStream.effectiveDate.dateAdjustments.businessCenter.nodes">
		<xsl:if test="$cfStream.effectiveDate.dateAdjustments.businessDayConvention != 'NONE'">
			<xsl:call-template name="makePaymentBusinessCenterNodes">
				<xsl:with-param name="legNumber" select="1"/>
			</xsl:call-template>
		</xsl:if>
	</xsl:variable>

	<!-- cfStream.terminationDate.dateAdjustments.businessDayConvention -->
	<xsl:variable name="cfStream.termination.unadjustedDate">
		<xsl:variable name="cfStream.paramMaturityDate"
			select="concat('date:', $leg1.maturity, ',format:yyyyMMdd,outputFormat:yyyy-MM-dd')"/>
		<xsl:value-of select="mx:execute-formula($FpMLDateFormula, $cfStream.paramMaturityDate)"
		/>
	</xsl:variable>
	<xsl:variable name="cfStream.terminationDate.adjustedDate">
		<xsl:variable name="terminationDateMx">
			<xsl:value-of
				select="/MxML/trades/trade[(not(tradeStatus/physicalStatus = 'dead') and count(../trade) &gt; 1) or (count(../trade) = 1)]/tradeBody/*/stream[streamTemplate/leg = 1]/adjustedMaturity"
			/>
		</xsl:variable>
		<xsl:value-of
			select="mx:execute-formula($FpMLDateFormula, concat('date:', $terminationDateMx, ',format:yyyymmdd,outputFormat:yyyy-mm-dd'))"
		/>
	</xsl:variable>
	<xsl:variable name="cfStream.terminationDate.dateAdjustments.businessDayConvention">
		<xsl:choose>
			<xsl:when
				test="$cfStream.termination.unadjustedDate = $cfStream.terminationDate.adjustedDate">
				<xsl:value-of select="'NONE'"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of
					select="mx:execute-formula($mapBusinessDayConv, $swapStream1.paramMaturityBusinessDayConvention)"
				/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<!-- cfStream.terminationDate.dateAdjustments.businessCenter.nodes -->
	<xsl:variable name="cfStream.terminationDate.dateAdjustments.businessCenter.nodes">
		<xsl:if test="$cfStream.terminationDate.dateAdjustments.businessDayConvention != 'NONE'">
			<xsl:call-template name="makePaymentBusinessCenterNodes">
				<xsl:with-param name="legNumber" select="1"/>
			</xsl:call-template>
		</xsl:if>
	</xsl:variable>

	<!-- cfStream.resetFrequency.period -->
	<xsl:variable name="cfStream.resetFrequency.period">
		<xsl:choose>
			<!-- DEF#731150 -->
			<xsl:when test="$typology = 'Asset Swap IRS'">
				<xsl:value-of select="'T'"/>
			</xsl:when>
			<xsl:when test="$leg1.calculation.periodMultiplier = '0'">
				<xsl:value-of select="'T'"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="mx:execute-formula($mapPeriodUnit, $swapStream1.paramResetFrequencyPeriodUnit)//row[1]" />
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<!-- cfStream.fixingDates.period -->
	<xsl:variable name="cfStream.fixingDates.period">
		<xsl:variable name="cfStream.fixingDates.periodTmp" select="mx:execute-formula($mapPeriodUnit, $swapStream1.paramFixingPeriodUnit)//row[1]"/>
		
		<xsl:choose>
			<!-- DEF#731150 -->
			<xsl:when test="$typology = 'Asset Swap IRS'">
				<xsl:value-of select="'D'"/>
			</xsl:when>
			<xsl:when test="$cfStream.isInflationIndexed = 'true'">
				<xsl:value-of select="$cfStream.inflationRate.period"/>
			</xsl:when>
			<xsl:when test="$cfStream.fixingDates.periodTmp = 'UNMAPPED'">
				<xsl:value-of select="'D'"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="$cfStream.fixingDates.periodTmp"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<!-- cfStream.initialFixingDate.periodMultiplier -->
	<xsl:variable name="cfStream.initialFixingDate.periodMultiplier">
		<xsl:variable name="fixingDate.customization">
			<xsl:call-template name="extract-fixingDate-customization">
				<xsl:with-param name="legNb" select="$trdNb"/>
				<xsl:with-param name="stream" select="1"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:variable name="fixingDate.customizedValue">
			<xsl:call-template name="extract-fixingDate-customizedValue">
				<xsl:with-param name="legNb" select="$trdNb"/>
				<xsl:with-param name="stream" select="1"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:variable name="fixingDate.calculationStartDate">
			<xsl:call-template name="extract-fixingDate-calculationStartDate">
				<xsl:with-param name="legNb" select="$trdNb"/>
				<xsl:with-param name="stream" select="1"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:choose>
			<xsl:when test="$cfStream.isInflationIndexed = 'true'">
				<xsl:value-of select="$swapStream1.inflationRate.periodMultiplier"/>
			</xsl:when>
			<xsl:when test="string-length($fixingDate.customization) &gt; 0">
				<xsl:variable name="fixingDate.custom.julian">
					<xsl:call-template name="julianday-from-gregorian">
						<xsl:with-param name="date" select="$fixingDate.customizedValue"/>
					</xsl:call-template>
				</xsl:variable>
				<xsl:variable name="fixingDate.calc.julian">
					<xsl:call-template name="julianday-from-gregorian">
						<xsl:with-param name="date" select="$fixingDate.calculationStartDate"/>
					</xsl:call-template>
				</xsl:variable>
				<xsl:value-of select="$fixingDate.custom.julian - $fixingDate.calc.julian"/>
			</xsl:when>
			<xsl:otherwise/>
		</xsl:choose>
	</xsl:variable>

	<!-- When the initial fixing date is customised, the dayType is set to Calendar -->
	<xsl:variable name="cfStream.initialFixingDate.dayType">
		<xsl:if test="string-length($cfStream.initialFixingDate.periodMultiplier) &gt; 0">
			<xsl:value-of select="'Calendar'"/>
		</xsl:if>
	</xsl:variable>

	<!-- When the initial fixing date is customised, the period is D -->
	<xsl:variable name="cfStream.initialFixingDate.period">
		<xsl:if	test="string-length($cfStream.initialFixingDate.periodMultiplier) &gt; 0 and not($cfStream.isInflationIndexed = 'true')">
			<xsl:value-of select="'D'"/>
		</xsl:if>
	</xsl:variable>

	<!-- When the initial fixing date is customised, the bdc is NONE -->
	<xsl:variable name="cfStream.initialFixingDate.businessDayConvention">
		<xsl:if test="string-length($cfStream.initialFixingDate.periodMultiplier) &gt; 0">
			<xsl:value-of select="'NONE'"/>
		</xsl:if>
	</xsl:variable>

	<!-- When the initial fixing date is customised, business center for initial fixing date is blank -->
	<xsl:variable name="cfStream.initialFixingDate.businessCenter.nodes"/>

	<!-- cfStream.fixingDates.businessDayConvention -->
	<xsl:variable name="cfStream.fixingDates.businessDayConvention">
		<xsl:choose>
			<!-- businessDayConvention must equal 'PRECEDING' if periodMultiplier is '0' and period is 'D' -->
			<xsl:when
				test="$swapStream1.fixingDates.periodMultiplier = '0' and ($swapStream1.fixingDates.period = 'D' or string-length($swapStream1.fixingDates.period) = 0)">
				<xsl:value-of select="'PRECEDING'"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="'NONE'"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<!-- cfStream.resetDatesAdjustments.businessDayConvention -->
	<xsl:variable name="cfStream.resetDatesAdjustments.businessDayConvention">
		<xsl:choose>
			<xsl:when test="$cfStream.isInflationIndexed = 'true'">
				<xsl:value-of select="'NONE'"/>
			</xsl:when>
			<xsl:when
				test="$leg1.reset.shifter.periodMultiplier = '0' and $cfStream.fixingDates.period = 'businessDay'">
				<xsl:choose>
					<xsl:when test="$dateShifterDirection = 'forward'">FOLLOWING</xsl:when>
					<xsl:otherwise>PRECEDING</xsl:otherwise>
				</xsl:choose>
			</xsl:when>
			<xsl:otherwise>
				<xsl:choose>
					<xsl:when test="$leg1.reset.businessDayConvention = 'none'">
						<xsl:choose>
							<xsl:when
								test="/MxML/trades/trade[(not(tradeStatus/physicalStatus = 'dead') and count(../trade) &gt; 1) or (count(../trade) = 1)]/tradeBody/*/stream[1]/streamTemplate/streamSchedules/resetSchedule/shifter/dateShifterDirection = 'backward'">
								<xsl:value-of select="'PRECEDING'"/>
							</xsl:when>
							<xsl:otherwise>
								<xsl:value-of select="'FOLLOWING'"/>
							</xsl:otherwise>
						</xsl:choose>
					</xsl:when>
					<xsl:otherwise>
						<xsl:value-of
							select="mx:execute-formula($mapBusinessDayConv, $swapStream1.paramResetDatesAdjustmentsBusinessDayConvention)"
						/>
					</xsl:otherwise>
				</xsl:choose>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<!-- cfStream.resetDatesAdjustments.businessCenter.nodes -->
	<xsl:variable name="cfStream.resetDatesAdjustments.businessCenter.nodes">
		<xsl:choose>
			<xsl:when test="$cfStream.isInflationIndexed = 'true'">
				<xsl:value-of select="''"/>
			</xsl:when>
			<xsl:when
				test="string-length(/MxML/trades/trade[(not(tradeStatus/physicalStatus = 'dead') and count(../trade) &gt; 1) or (count(../trade) = 1)]/tradeBody/*/stream[streamTemplate/leg = 1]/streamTemplate/streamSchedules/resetSchedule/scheduleGenerator/standardScheduleGenerator/businessCenters/businessCenter) &gt; 0 and $cfStream.resetDatesAdjustments.businessDayConvention != 'NONE'">
				<xsl:call-template name="resetSchedule.businessCenter">
					<xsl:with-param name="legNumber" select="1"/>
				</xsl:call-template>
			</xsl:when>
			<xsl:otherwise>
				<xsl:choose>
					<xsl:when
						test="$cfStream.resetDatesAdjustments.businessDayConvention != 'NONE'">
						<xsl:call-template name="resetDates.businessCenter">
							<xsl:with-param name="legNumber" select="1"/>
						</xsl:call-template>
					</xsl:when>
					<xsl:otherwise/>
				</xsl:choose>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<!-- cfStream floatingIndex -->
	<xsl:variable name="cfStream.params" select="concat('index:', $leg1.floatingRateIndex)"/>
	<xsl:variable name="cfStream.params.details">
		<xsl:if test="$leg1.payoutType != 'fixedRate'">
			<xsl:copy-of select="mx:execute-formula($mapIndex, $cfStream.params)"/>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="cfStream.floatingRateIndex">
		<xsl:if test="$leg1.payoutType != 'fixedRate'">
			<xsl:variable name="cfStream.index.resultPre" select="exslt:node-set($cfStream.params.details)/table/row[1]"/>
			
			<xsl:choose>
				<xsl:when test="$cfStream.index.resultPre = 'UNMAPPED'">
					<xsl:value-of select="mx:execute-formula('mx.xml2xml.ECN.common.errorHandling.throwException', concat('errorMessage: Unmapped index (first leg)-', concat($mapIndex, translate($cfStream.params, ',', '|'))))" />
				</xsl:when>
				<xsl:otherwise>
					<xsl:value-of select="$cfStream.index.resultPre"/>
				</xsl:otherwise>
			</xsl:choose>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="cfStream.floatingRateIndexScheme">
		<xsl:if test="$leg1.payoutType != 'fixedRate'">
			<xsl:value-of select="exslt:node-set($cfStream.params.details)/table/row[4]"/>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="cfStream.calculationPeriodAmount.periodMultiplier">
		<xsl:if test="$leg1.payoutType != 'fixedRate'">
			<xsl:value-of select="exslt:node-set($cfStream.params.details)/table/row[3]"/>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="cfStream.calculationPeriodAmount.period">
		<xsl:if test="$leg1.payoutType != 'fixedRate'">
			<xsl:value-of select="exslt:node-set($cfStream.params.details)/table/row[2]"/>
		</xsl:if>
	</xsl:variable>

	<!-- cfStream.dayCountFraction -->
	<xsl:variable name="leg1.dayCountFractionLabel">
		<xsl:call-template name="extract-dayCountFractionLabel">
			<xsl:with-param name="legNb" select="1"/>
			<xsl:with-param name="stream" select="1"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="leg1.paramDayCountFraction"
		select="concat('rateConventionLabel:', $leg1.dayCountFractionLabel)"/>
	<xsl:variable name="cfStream.dayCountFraction">
		<xsl:variable name="cfStream.dayCountFractionPre"
			select="mx:execute-formula($mapDayCountBasis, $leg1.paramDayCountFraction)"/>
		<xsl:choose>
			<xsl:when test="$cfStream.dayCountFractionPre = 'UNMAPPED'">
				<xsl:value-of
					select="mx:execute-formula('mx.xml2xml.ECN.common.errorHandling.throwException', concat('errorMessage: Unmapped dayCountFraction (first leg)-', concat($mapDayCountBasis, translate($leg1.paramDayCountFraction, ',', '|'))))"
				/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="$cfStream.dayCountFractionPre"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<!-- cfStream.calculationPeriodFrequency.period -->
	<xsl:variable name="cfStream.calculationPeriodFrequency.period">
		<xsl:choose>
			<xsl:when test="$leg1.singlePeriod = 'true' and $cfStream.dayCountFraction = '1/1'">
				<xsl:choose>
					<xsl:when
						test="($indexCategory = 'inflationIndex' or $typology = 'Inflation Swap' or $Mxgroup = 'INFLS')">
						<xsl:choose>
							<xsl:when test="$leg1.payoutType = 'fixedRate'">
								<xsl:value-of select="'Y'"/>
							</xsl:when>
							<xsl:otherwise>
								<xsl:value-of select="'T'"/>
							</xsl:otherwise>
						</xsl:choose>
					</xsl:when>
					<xsl:otherwise>
						<xsl:value-of select="'Y'"/>
					</xsl:otherwise>
				</xsl:choose>
			</xsl:when>
			<xsl:when test="$leg1.calculation.periodMultiplier = '0'">
				<xsl:value-of select="'T'"/>
			</xsl:when>
			<xsl:when
				test="$swapStream1.paymentSchedule.zeroCouponMode = 'true' and $leg1.payoutType = 'fixedRate'">
				<xsl:value-of select="'T'"/>
			</xsl:when>
			<xsl:when test="$leg1.singlePeriod = 'true' and $leg1.payoutType = 'fixedRate'">
				<xsl:value-of select="'T'"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of
					select="mx:execute-formula($mapPeriodUnit, $swapStream1.paramCalculationPeriodUnit)//row[1]"
				/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<xsl:variable name="leg1.singlePeriod.periodDayCountFactor"
		select="number(/MxML/trades/trade[1]/tradeBody/*/stream[./streamTemplate/streamSchedules/singlePeriod = 'true' and ./streamTemplate/leg = 1]/cashFlows/interestFlows/interestPaymentPeriod/calculationPeriod/periodDayCountFactor)"/>
	<!-- cfStream.frequency.period -->
	<xsl:variable name="cfStream.frequency.period">
		<xsl:choose>
			<xsl:when test="$swapStream1.paymentSchedule.zeroCouponMode = 'true'">
				<xsl:value-of select="'T'"/>
			</xsl:when>
			<xsl:when test="$leg1.singlePeriod = 'true'">T</xsl:when>
			<xsl:otherwise>
				<xsl:value-of
					select="mx:execute-formula($mapPeriodUnit, $swapStream1.paramFrequencyPeriodUnit)//row[1]"
				/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

	<!-- cfStream.businessDayConvention -->
	<xsl:variable name="zeroCouponMode"
		select="/MxML/trades/trade/tradeBody/*/stream[streamTemplate/leg = 1]/streamTemplate/streamSchedules/paymentSchedule/zeroCouponMode"/>
	<xsl:variable name="leg1.periodMultiplier">
		<xsl:call-template name="extract-shifter-payment-periodMultiplier">
			<xsl:with-param name="legNb" select="1"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="leg1.periodUnit">
