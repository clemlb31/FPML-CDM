	<!-- cfStream.calculationPeriodFrequency.rollConvention -->
	<xsl:variable name="leg1.calculationSchedule.scheduleGeneratorLabel">
		<xsl:call-template name="extract-scheduleGenerationLabel">
			<xsl:with-param name="legNb" select="1"/>
			<xsl:with-param name="stream" select="1"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="cfStream.calculationPeriodFrequency.rollConvention">
		<xsl:variable name="calculationPeriodFrequency.rollConvention1"
			select="mx:execute-formula($mapRollConvention, concat('rollConventionLabel:', $leg1.calculationSchedule.scheduleGeneratorLabel))"/>
		<xsl:choose>
			<!-- ZC - Fixed Leg -->
			<!-- ZC control had been removed because 'NONE' is not the correct value according to the specs (case 2135) -->
			<!-- Reactivated: because values should be 1T for calc pay freq and NONE for Roll convention -->
			<xsl:when test="$leg1.singlePeriod = 'true' and $cfStream.dayCountFraction = '1/1'">
				<xsl:choose>
					<xsl:when
						test="($indexCategory = 'inflationIndex' or $typology = 'Inflation Swap' or $Mxgroup = 'INFLS')">
						<xsl:choose>
							<xsl:when test="$leg1.payoutType = 'fixedRate'">
								<!-- When calculation frequency period is Y -->
								<xsl:choose>
									<xsl:when
										test="$calculationPeriodFrequency.rollConvention1 = $leg1.calculationSchedule.scheduleGeneratorLabel or $calculationPeriodFrequency.rollConvention1 = ''">
										<xsl:call-template name="getRollConvention">
											<xsl:with-param name="stream"
												select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[streamTemplate/leg = 1]"
											/>
										</xsl:call-template>
									</xsl:when>
									<xsl:otherwise>
										<xsl:value-of
											select="$calculationPeriodFrequency.rollConvention1"/>
									</xsl:otherwise>
								</xsl:choose>
							</xsl:when>
							<!-- When calculation frequency period is T -->
							<xsl:otherwise>
								<xsl:value-of select="'NONE'"/>
							</xsl:otherwise>
						</xsl:choose>
					</xsl:when>
					<xsl:otherwise>
						<xsl:choose>
							<!-- When calculation frequency period is Y -->
							<xsl:when
								test="$calculationPeriodFrequency.rollConvention1 = $leg1.calculationSchedule.scheduleGeneratorLabel or $calculationPeriodFrequency.rollConvention1 = ''">
								<xsl:call-template name="getRollConvention">
									<xsl:with-param name="stream"
										select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[streamTemplate/leg = 1]"
									/>
								</xsl:call-template>
							</xsl:when>
							<xsl:otherwise>
								<xsl:value-of select="$calculationPeriodFrequency.rollConvention1"/>
							</xsl:otherwise>
						</xsl:choose>
					</xsl:otherwise>
				</xsl:choose>
			</xsl:when>

			<xsl:when
				test="$swapStream1.paymentSchedule.zeroCouponMode = 'true' and $leg1.payoutType = 'fixedRate'">
				<xsl:value-of select="'NONE'"/>
			</xsl:when>
			<xsl:when test="$leg1.singlePeriod = 'true' and $leg1.payoutType = 'fixedRate'">
				<xsl:value-of select="'NONE'"/>
			</xsl:when>
			<xsl:when
				test="($swapStream1.calculationPeriodFrequency.endOfMonthTreatment = 'stickIfEndOfMonth' or $swapStream1.calculationPeriodFrequency.endOfMonthTreatment = 'stickIfUsualEndOfMonth') and (substring($leg1.maturityDate, 5, 4) = '0131' or substring($leg1.maturityDate, 5, 4) = '0228' or substring($leg1.maturityDate, 5, 4) = '0229' or substring($leg1.maturityDate, 5, 4) = '0331' or substring($leg1.maturityDate, 5, 4) = '0430' or substring($leg1.maturityDate, 5, 4) = '0531' or substring($leg1.maturityDate, 5, 4) = '0630' or substring($leg1.maturityDate, 5, 4) = '3101' or substring($leg1.maturityDate, 5, 4) = '0731' or substring($leg1.maturityDate, 5, 4) = '0831' or substring($leg1.maturityDate, 5, 4) = '0930' or substring($leg1.maturityDate, 5, 4) = '1031' or substring($leg1.maturityDate, 5, 4) = '1130' or substring($leg1.maturityDate, 5, 4) = '1231')">
				<xsl:value-of select="'EOM'"/>
			</xsl:when>
			<!--OIS and compound Term -->
			<xsl:when test="$leg1.calculation.periodUnit = 'term'">
				<xsl:value-of select="'NONE'"/>
			</xsl:when>
			<xsl:when test="$leg1.calculation.periodMultiplier = '0'">
				<xsl:value-of select="'NONE'"/>
			</xsl:when>
			<xsl:when
				test="$calculationPeriodFrequency.rollConvention1 = $leg1.calculationSchedule.scheduleGeneratorLabel or $calculationPeriodFrequency.rollConvention1 = ''">
				<xsl:call-template name="getRollConvention">
					<xsl:with-param name="stream"
						select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[streamTemplate/leg = 1]"
					/>
				</xsl:call-template>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="$calculationPeriodFrequency.rollConvention1"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>

