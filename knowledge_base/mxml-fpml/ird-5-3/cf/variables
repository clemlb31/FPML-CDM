	<xsl:template name="createNotionalAmount-cf">
		<xsl:param name="streamNumber"/>
		<xsl:param name="observationDate"/>
		<xsl:param name="mxmlObservationDate"/>
		<xsl:param name="isFxLinked"/>
		<xsl:param name="indexationIndex"/>
		<xsl:choose>
			<xsl:when test="$isFxLinked = 'true'">
				<fxLinkedNotionalAmount>
					<xsl:variable name="systemDate">
						<xsl:value-of select="/MxML/trades/trade[@id = $contractRef]/tradeInputConditions/systemDate"/>
					</xsl:variable>
					<xsl:variable name="fixingValue" select="/MxML/trades/trade[@id = $contractRef]/tradeImpacts/tradeImpact[@mefClass = 'mxContractEventIIMPACT_FIXING']/contractEventImpactBody/fixingImpact[./streamFixingReference/periodFixingDescription[./fixingDate = $mxmlObservationDate and ./indexLabel = $indexationIndex and contains(./archiving, 'FIXINGS')]]/fixingValue"/>
					<xsl:variable name="indexationObservedRate">
						<xsl:choose>
							<xsl:when test="number($fixingValue) &gt; 0">
								<xsl:value-of select="$fixingValue"/>
							</xsl:when>
							<xsl:otherwise>
								<xsl:choose>
									<xsl:when test="number($mxmlObservationDate) &lt; number($systemDate)">
										<xsl:choose>
											<xsl:when test="string-length(/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[1]/indexationLists/indexationList) &gt; 0">
												<xsl:value-of select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[1]/indexationLists/indexationList[./indexedObjectNature = 'outstandingCapital']/indexationSchedules/indexationSchedule/indexations/indexation[date=$mxmlObservationDate]/observedRate"/>
											</xsl:when>
											<xsl:otherwise>
												<xsl:value-of select="/MxML/trades/trade[@id = $contractRef]/tradeBody/*/stream[2]/indexationLists/indexationList[./indexedObjectNature = 'outstandingCapital']/indexationSchedules/indexationSchedule/indexations/indexation[date=$mxmlObservationDate]/observedRate"/>
											</xsl:otherwise>
										</xsl:choose>
									</xsl:when>
									<xsl:otherwise/>
								</xsl:choose>
							</xsl:otherwise>
						</xsl:choose>
					</xsl:variable>
					<xsl:variable name="isIndexationFixingDone" select="my:isObservationFixed($mxmlObservationDate, $indexationIndex)"/>
					<xsl:call-template name="create-fxLinkedNotionalAmount">
						<xsl:with-param name="resetDate">
							<xsl:value-of select="mx:execute-formula($FpMLDateFormula, concat('date:',calculationStartDate,',format:yyyymmdd,outputFormat:yyyy-mm-dd'))"/>
						</xsl:with-param>
						<xsl:with-param name="adjustedFxSpotFixingDate" select="$observationDate"/>
						<xsl:with-param name="observedFxSpotRate">
							<xsl:if test="$isIndexationFixingDone = 'true'">
								<xsl:value-of select="format-number($indexationObservedRate, '##.##########')"/>
							</xsl:if>
						</xsl:with-param>
						<xsl:with-param name="notionalAmount">
							<xsl:if test="$isIndexationFixingDone = 'true'">
								<xsl:value-of select="format-number(notionalAmount, '##.########')"/>
							</xsl:if>
						</xsl:with-param>
					</xsl:call-template>
				</fxLinkedNotionalAmount>
			</xsl:when>
			<xsl:otherwise>
				<notionalAmount>
					<xsl:value-of select="format-number(notionalAmount, '##.########')"/>
				</notionalAmount>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:template>
