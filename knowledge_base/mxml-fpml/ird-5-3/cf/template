<xsl:stylesheet xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns="http://www.fpml.org/FpML-5/confirmation" xmlns:exsl="http://exslt.org/common" xmlns:exslt="http://exslt.org/common" xmlns:mx="http://murex.com/xslt/common" version="1.0" exclude-result-prefixes="mx">
