          <xsl:with-param name="mandatoryEarlyTerminationModel.dateAdjustments.businessDayConvention" select="$mandatoryEarlyTerminationModel.dateAdjustments.businessDayConvention" />
          <xsl:with-param name="mandatoryEarlyTerminationModel.dateAdjustments.businessCenter.nodes" select="$businessCenter.nodes" />
          <xsl:with-param name="mandatoryEarlyTerminationModel.unadjustedDate" select="$mandatoryEarlyTerminationModel.unadjustedDate" />
