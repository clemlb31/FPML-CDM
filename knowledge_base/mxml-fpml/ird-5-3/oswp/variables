<xsl:stylesheet xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
    xmlns:dyn="http://exslt.org/dynamic" xmlns="http://www.fpml.org/FpML-5/confirmation"
    xmlns:mx="http://murex.com/xslt/common" version="1.0" exclude-result-prefixes="mx">
    
    <xsl:import href="mx.generic.errorHandling.assert"/>
    <xsl:import href="mx.xml2xml.extract.mxml.products.ird.templates"/>
    <xsl:import href="mx.xml2xml.extract.mxml.products.common.templates"/>
    <xsl:variable name="adaptDateFormula" select="'mx.xml2xml.ECN.common.utils.adaptDate'"/>
    <xsl:variable name="format" select="'yyyyMMdd'"/>
    <xsl:variable name="outputFormat" select="'yyyy-MM-dd'"/>
    
    <xsl:variable name="bermudaExerciseDates.unadjustedDate.nodes">
        <xsl:for-each
            select="/MxML/trades/trade/tradeBody/*/payout/option/exercizeSchedule/exercizeEvents/exercizeEvent/exercizeDate">
            <xsl:variable name="exercizeDate">
                <xsl:value-of select="."/>
            </xsl:variable>
            <unadjustedDate>
                <xsl:value-of
                    select="mx:execute-formula($adaptDateFormula, concat('date:', $exercizeDate,',format:', $format,',outputFormat:', $outputFormat))"
                />
            </unadjustedDate>
        </xsl:for-each>
    </xsl:variable>
    
    <xsl:variable name="swaptionStraddle">
        <xsl:variable name="optionPackageType">
            <xsl:call-template name="extract-optionPackageType">
                <xsl:with-param name="legNb" select="1"/>
            </xsl:call-template>
        </xsl:variable>
        <xsl:choose>
            <xsl:when test="$optionPackageType = 'straddle'">
                <xsl:value-of select="'true'"/>
            </xsl:when>
            <xsl:when test="$optionPackageType = 'call'">
                <xsl:value-of select="'false'"/>
            </xsl:when>
            <xsl:otherwise>NaN</xsl:otherwise>
        </xsl:choose>
    </xsl:variable>
    
    
    <xsl:variable name="notificationEffectiveCalendar">
        <xsl:call-template name="extract-notificationEffectiveCalendar">
            <xsl:with-param name="legNb" select="'1'"/>
        </xsl:call-template>
    </xsl:variable>
    <xsl:variable name="notificationEffectiveCalendar.paramBusinessCenter"
        select="concat('businessCenter:', $notificationEffectiveCalendar)"/>
    
    <!-- buy or sell -->
    <xsl:variable name="buyOrSell">
        <xsl:call-template name="extract-buy-or-sell-option"/>
    </xsl:variable>
    
    <xsl:variable name="swapStream1.inflationRate.interpolationMethod">
        <xsl:value-of select="'None'"/>
    </xsl:variable>
    
    <xsl:variable name="swapStream2.inflationRate.interpolationMethod">
        <xsl:value-of select="'None'"/>
    </xsl:variable>
    
    <xsl:variable name="premium.nodes">
        <xsl:variable name="periodicSettlementFlowPath">
            <xsl:choose>
                <xsl:when
                    test="/MxML/trades/trade/tradeBody/swaption/settlement/settlementSchedule/periodicSettlementFlows/periodicSettlementFlow">
                    <xsl:value-of
                        select="'/MxML/trades/trade/tradeBody/swaption/settlement/settlementSchedule/periodicSettlementFlows/periodicSettlementFlow'"
                    />
                </xsl:when>
                <xsl:otherwise>
                    <xsl:value-of select="''"/>
                </xsl:otherwise>
            </xsl:choose>
        </xsl:variable>
        
        <xsl:choose>
            <xsl:when
                test="string-length($periodicSettlementFlowPath)&gt;0 and count(dyn:evaluate($periodicSettlementFlowPath))&gt;1">
                
                <!-- settlementSchedule payer/receiver -->
                <xsl:variable name="payerPartyReference.href.tmp">
                    <xsl:call-template name="extract-settlementSchedule-payerPartyReference"/>
                </xsl:variable>
                <xsl:variable name="receiverPartyReference.href.tmp">
                    <xsl:call-template name="extract-settlementSchedule-receiverPartyReference"/>
                </xsl:variable>
                
                <xsl:variable name="payerPartyReference.href">
                    <xsl:variable name="payerPartyReference.href.pre">
                        <xsl:value-of   select="mx:execute-formula($mapCounterparty, concat('partyLabel:', $payerPartyReference.href.tmp))" />
                    </xsl:variable>
                    <xsl:choose>
                        <xsl:when test="$payerPartyReference.href.pre = 'UNMAPPED' ">
                            <xsl:value-of
                                select="mx:execute-formula('mx.xml2xml.ECN.common.errorHandling.throwException', concat('errorMessage: Unmapped party -',$payerPartyReference.href.pre))"
                            />
                        </xsl:when>
                        <xsl:when test="string-length($payerPartyReference.href.pre) = 0">
                            <xsl:value-of
                                select="mx:execute-formula('mx.xml2xml.ECN.common.errorHandling.throwException', concat('errorMessage: Unmapped party -',$payerPartyReference.href.pre))"
                            />
                        </xsl:when>
                        <xsl:otherwise>
                            <xsl:value-of select="$payerPartyReference.href.pre"/>
                        </xsl:otherwise>
                    </xsl:choose>
                </xsl:variable>
                <xsl:variable name="receiverPartyReference.href">
                    <xsl:variable name="receiverPartyReference.href.pre">
                        <xsl:value-of select="mx:execute-formula($mapCounterparty, concat('partyLabel:', $receiverPartyReference.href.tmp))" />
                    </xsl:variable>
                    <xsl:choose>
                        <xsl:when test="$receiverPartyReference.href.pre = 'UNMAPPED' ">
                            <xsl:value-of
                                select="mx:execute-formula('mx.xml2xml.ECN.common.errorHandling.throwException', concat('errorMessage: Unmapped party -',$receiverPartyReference.href.pre))"
                            />
                        </xsl:when>
                        <xsl:when test="string-length($receiverPartyReference.href.pre) = 0">
                            <xsl:value-of
                                select="mx:execute-formula('mx.xml2xml.ECN.common.errorHandling.throwException', concat('errorMessage: Unmapped party -',$receiverPartyReference.href.pre))"
                            />
                        </xsl:when>
                        <xsl:otherwise>
                            <xsl:value-of select="$receiverPartyReference.href.pre"/>
                        </xsl:otherwise>
                    </xsl:choose>
                </xsl:variable>
                
                <xsl:variable name="premiumAmount.currency">
                    <xsl:call-template name="extract-settlementSchedule-currency"/>
                </xsl:variable>
                
                <xsl:for-each select="dyn:evaluate($periodicSettlementFlowPath)">
                    <xsl:variable name="premiumAmount.amount"
                        select="dyn:evaluate(concat($periodicSettlementFlowPath,'[',position(),']/interestFlow'))"/>
                    <xsl:variable name="unadjustedDate">
                        <xsl:variable name="dateMx"
                            select="dyn:evaluate(concat($periodicSettlementFlowPath,'[',position(),']/paymentDate'))"/>
                        <xsl:value-of
                            select="mx:execute-formula($adaptDateFormula, concat('date:',$dateMx,',format:yyyymmdd,outputFormat:yyyy-mm-dd'))"
                        />
                    </xsl:variable>
                    
                    <premium>
                        <payerPartyReference href="{$payerPartyReference.href}"/>
                        <receiverPartyReference href="{$receiverPartyReference.href}"/>
                        <paymentAmount>
                            <currency currencyScheme="{'http://www.fpml.org/ext/iso4217'}">
                                <xsl:value-of select="$premiumAmount.currency"/>
                            </currency>
                            <amount>
                                <xsl:choose>
                                    <xsl:when test="string-length($premiumAmount.amount) &gt;0 and number($premiumAmount.amount)=number($premiumAmount.amount) ">
                                        <!--verifying amount is a number-->
                                        <xsl:value-of select="$premiumAmount.amount"/>
                                    </xsl:when>
                                    <xsl:otherwise>
                                        <xsl:value-of select="'0'"/>
                                    </xsl:otherwise>
                                </xsl:choose>
                            </amount>
                        </paymentAmount>
                        <paymentDate>
                            <unadjustedDate>
                                <xsl:value-of select="$unadjustedDate"/>
                            </unadjustedDate>
                            <dateAdjustments>
                                <businessDayConvention>NONE</businessDayConvention>
                            </dateAdjustments>
                        </paymentDate>
                    </premium>
                </xsl:for-each>
            </xsl:when>
            <xsl:otherwise>
                <xsl:value-of select="''"/>
            </xsl:otherwise>
        </xsl:choose>
    </xsl:variable>
 
    <xsl:variable name="leg1.periodUnit">
      <xsl:call-template name="extract-shifter-payment-periodUnit">
        <xsl:with-param name="legNb" select="1"/>
        <xsl:with-param name="tradeNb" select="$trdNb"/>
      </xsl:call-template>
    </xsl:variable>

    <xsl:variable name="swapStream1.paymentDaysOffset.period">
      <xsl:choose>
        <xsl:when test="$leg1.periodUnit = 'businessDay'">D</xsl:when>
        <xsl:when test="$leg1.periodUnit = 'day'">D</xsl:when>
        <xsl:when test="$leg1.periodUnit = 'week'">W</xsl:when>
        <xsl:when test="$leg1.periodUnit = 'month'">M</xsl:when>
        <xsl:when test="$leg1.periodUnit = 'year'">Y</xsl:when>
        <xsl:otherwise>Business</xsl:otherwise>
      </xsl:choose>
    </xsl:variable>
	
    <xsl:variable name="swapStream1.paymentDaysOffset.periodMultiplier">
      <xsl:value-of
        select="/MxML/trades/trade[$trdNb]/tradeBody//stream[1]/streamTemplate/streamSchedules/paymentSchedule/shifter/shift/periodMultiplier"/>
    </xsl:variable>
	
    <xsl:variable name="swapStream1.paymentDaysOffset.dayType">
      <xsl:choose>
        <xsl:when
          test="$swapStream1.paymentDaysOffset.periodMultiplier = '0' and $leg1.periodUnit = 'businessDay'">Business</xsl:when>
        <xsl:otherwise>
          <xsl:choose>
            <xsl:when test="$leg1.periodUnit = 'day'">Calendar</xsl:when>
            <xsl:otherwise>Business</xsl:otherwise>
          </xsl:choose>
        </xsl:otherwise> 
      </xsl:choose>
    </xsl:variable> 
	
    <xsl:variable name="leg2.periodUnit">
      <xsl:call-template name="extract-shifter-payment-periodUnit">
        <xsl:with-param name="legNb" select="2"/>
        <xsl:with-param name="tradeNb" select="$trdNb"/>
      </xsl:call-template>
    </xsl:variable>

    <xsl:variable name="swapStream2.paymentDaysOffset.period">
      <xsl:choose>
        <xsl:when test="$leg1.periodUnit = 'businessDay'">D</xsl:when>
        <xsl:when test="$leg1.periodUnit = 'day'">D</xsl:when>
        <xsl:when test="$leg1.periodUnit = 'week'">W</xsl:when>
        <xsl:when test="$leg1.periodUnit = 'month'">M</xsl:when>
        <xsl:when test="$leg1.periodUnit = 'year'">Y</xsl:when>
        <xsl:otherwise>Business</xsl:otherwise>
      </xsl:choose>
    </xsl:variable>

    <xsl:variable name="swapStream2.paymentDaysOffset.periodMultiplier">
      <xsl:value-of
        select="/MxML/trades/trade[$trdNb]/tradeBody//stream[2]/streamTemplate/streamSchedules/paymentSchedule/shifter/shift/periodMultiplier"/>
    </xsl:variable>

    <xsl:variable name="swapStream1.paymentDaysOffset.dayType">
      <xsl:choose>
        <xsl:when
          test="$swapStream1.paymentDaysOffset.periodMultiplier = '0' and $leg1.periodUnit = 'businessDay'">Business</xsl:when>
        <xsl:otherwise>
          <xsl:choose>
            <xsl:when test="$leg2.periodUnit = 'day'">Calendar</xsl:when>
            <xsl:otherwise>Business</xsl:otherwise>
          </xsl:choose>
        </xsl:otherwise>
      </xsl:choose>
    </xsl:variable>
 
</xsl:stylesheet>
