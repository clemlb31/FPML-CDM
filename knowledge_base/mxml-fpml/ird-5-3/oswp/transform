<!--xsl:stylesheet xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:dyn="http://exslt.org/dynamic" xmlns:mx="http://murex.com/xslt/common" xmlns:exslt="http://exslt.org/common" version="1.0" exclude-result-prefixes="mx exslt dyn xsl"-->
<xsl:stylesheet xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
    xmlns:dyn="http://exslt.org/dynamic" xmlns="http://www.fpml.org/FpML-5/confirmation"
    xmlns:exslt="http://exslt.org/common" xmlns:mx="http://murex.com/xslt/common" version="1.0"
    exclude-result-prefixes="mx">
    <xsl:import href="mx.xml2xml.transform.mxml2fpml.5-3.products.common.correctableRequestMessage"/>
    <xsl:import href="mx.xml2xml.transform.any2fpml.5-3.msg.requestMessageHeader"/>
    <xsl:import href="mx.xml2xml.transform.any2fpml.5-3.products.common.party"/>
    <xsl:import href="mx.generic.errorHandling.assert"/>
    <xsl:import href="mx.xml2xml.transform.any2fpml.5-3.products.ird.oswp.tradeNode"/>
    <xsl:import href="mx.generic.exslt.date.difference"/>
    <xsl:import href="mx.xml2xml.transform.mxml2fpml.5-3.events.variables"/>
    <xsl:import href="mx.xml2xml.transform.mxml2fpml.5-3.products.ird.swap.variables"/>
    <xsl:import href="mx.xml2xml.transform.mxml2fpml.5-3.products.common.addNamespace"/>
    <xsl:import href="mx.xml2xml.transform.any2fpml.5-3.products.common.bermudaExercise"/>
    <xsl:import href="mx.xml2xml.transform.any2fpml.5-3.events.tradeNotionalChange"/>
    <xsl:include href="mx.xml2xml.transform.mxml2fpml.5-3.products.variables"/>
    <xsl:include href="mx.xml2xml.transform.mxml2fpml.5-3.products.ird.variables"/>
    <xsl:include href="mx.xml2xml.transform.mxml2fpml.5-3.products.ird.oswp.variables"/>
    <xsl:template name="generate-fpml-ird-swaption" match="/">

        <!--==========================-->
        <!-- Mandatory mapping tables -->
        <!--==========================-->
        <xsl:param name="mapBusinessCenters"/>
        <xsl:param name="mapBusinessDayConv"/>
        <xsl:param name="mapDayCountBasis"/>
        <xsl:param name="mapIndex"/>
        <xsl:param name="mapCounterparty"/>
        <xsl:param name="mapPeriodUnit"/>
        <xsl:param name="mapOurPartyLabel"/>
        <xsl:param name="mapPaymentType"/>

        <!--==========================-->
        <!-- Mandatory parameters     -->
        <!--==========================-->
        <xsl:param name="tradeId2.scheme"/>
        <xsl:param name="tradeId2"/>
        <!-- parties -->
        <xsl:param name="party.partyId1"/>
        <xsl:param name="party.partyId2"/>
        <xsl:param name="party.partyIdScheme1"/>
        <xsl:param name="party.partyIdScheme2"/>
        <!-- specific amendment -->
        <xsl:param name="isCorrection"/>
        <xsl:param name="sequenceNumber"/>
        <xsl:param name="correlationId"/>
        <xsl:param name="correlationIdScheme"/>

        <!--==========================-->
        <!-- Optional parameters      -->
        <!--==========================-->
        <!-- optional parameters -->
        <xsl:param name="messageId"/>
        <xsl:param name="messageIdScheme"/>
        <xsl:param name="sendBy.partyIdScheme"/>
        <xsl:param name="sendTo.partyIdScheme"/>
        <xsl:param name="contractID"/>
        <xsl:param name="party.partyId1Scheme"/>
        <xsl:param name="party.partyId2Scheme"/>
        <xsl:param name="earliestExerciseTime.hourMinuteTime"/>
        <xsl:param name="earliestExerciseTime.businessCenter.businessCenterScheme"
            select="$businessCenterScheme"/>
        <xsl:param name="expirationTime.hourMinuteTime"/>
        <xsl:param name="expirationTime.businessCenter.businessCenterScheme"
            select="$businessCenterScheme"/>
        <xsl:param name="bermudaExercise.id"/>
        <xsl:param name="initialValue"/>
        <xsl:param name="swapStream1.businessCenter.businessCenterScheme"/>
        <xsl:param name="swapStream1.notionalSchedule.id"/>
        <xsl:param name="swapStream1.notionalSchedule.notionalStepSchedule.currency.currencyScheme"/>
        <xsl:param name="swapStream1.floatingRateIndexScheme"/>
        <xsl:param name="swapStream2.businessCenter.businessCenterScheme"/>
        <xsl:param name="swapStream2.notionalSchedule.id"/>
        <xsl:param name="swapStream2.notionalSchedule.notionalStepSchedule.currency.currencyScheme"/>
        <xsl:param name="swapStream2.floatingRateIndexScheme"/>
        <xsl:param name="exerciseProcedure.fallbackExercise" select="'false'"/>
        <xsl:param name="exerciseProcedure.followUpConfirmation" select="'false'"/>
        <xsl:param name="swapStream2.effectiveDate.dateAdjustments.businessCenter.id"/>
        <xsl:param name="swapStream1.effectiveDate.dateAdjustments.businessCenter.id"/>
        <xsl:param name="swapStream2.terminationDate.dateAdjustments.businessCenter.id"/>
        <xsl:param name="swapStream1.terminationDate.dateAdjustments.businessCenter.id"/>
		<xsl:param name="productId.nodes"/>
        <!--fpml message type-->
        <xsl:param name="fpmlType" select="'DataDocument'"/>

        <!-- Parameter used to change the direction of the deal -->
        <xsl:param name="reversePayReceive"/>

        <!-- counterpartId -->
        <xsl:variable name="counterpartId">
            <xsl:variable name="counterpartIdPre">
                <xsl:value-of
                    select="mx:execute-formula($mapCounterparty, concat('partyLabel:', $ctpName))"/>
            </xsl:variable>
            <xsl:choose>
                <xsl:when test="$counterpartIdPre = 'UNMAPPED' ">
                    <xsl:value-of
                        select="mx:execute-formula('mx.xml2xml.ECN.common.errorHandling.throwException', concat('errorMessage: Unmapped party -',$counterpartIdPre))"
                    />
                </xsl:when>
                <xsl:when test="string-length($counterpartIdPre) = 0">
                    <xsl:value-of
                        select="mx:execute-formula('mx.xml2xml.ECN.common.errorHandling.throwException', concat('errorMessage: Unmapped party -',$counterpartIdPre))"
                    />
                </xsl:when>
                <xsl:otherwise>
                    <xsl:value-of select="$counterpartIdPre"/>
                </xsl:otherwise>
            </xsl:choose>
        </xsl:variable>

        <!-- originatorId -->
        <xsl:variable name="originatorId">
            <xsl:variable name="originatorIdPre">
                <xsl:value-of
                    select="mx:execute-formula($mapCounterparty, concat('partyLabel:', $legalEntity))"
                />
            </xsl:variable>
            <xsl:choose>
                <xsl:when test="$originatorIdPre = 'UNMAPPED' ">
                    <xsl:value-of
                        select="mx:execute-formula('mx.xml2xml.ECN.common.errorHandling.throwException', concat('errorMessage: Unmapped party -',$originatorIdPre))"
                    />
                </xsl:when>
                <xsl:when test="string-length($originatorIdPre) = 0">
                    <xsl:value-of
                        select="mx:execute-formula('mx.xml2xml.ECN.common.errorHandling.throwException', concat('errorMessage: Unmapped party -',$originatorIdPre))"
                    />
                </xsl:when>
                <xsl:otherwise>
                    <xsl:value-of select="$originatorIdPre"/>
                </xsl:otherwise>
            </xsl:choose>
        </xsl:variable>

        <!-- buyerPartyReference.href -->
        <xsl:variable name="buyerPartyReference.href">
            <xsl:choose>
                <xsl:when test="$buyOrSell='buy'">
                    <xsl:value-of select="$originatorId"/>
                </xsl:when>
                <xsl:otherwise>
                    <xsl:value-of select="$counterpartId"/>
                </xsl:otherwise>
            </xsl:choose>
        </xsl:variable>

        <!-- sellerPartyReference.href -->
        <xsl:variable name="sellerPartyReference.href">
            <xsl:choose>
                <xsl:when test="$buyOrSell='buy'">
                    <xsl:value-of select="$counterpartId"/>
                </xsl:when>
                <xsl:otherwise>
                    <xsl:value-of select="$originatorId"/>
                </xsl:otherwise>
            </xsl:choose>
        </xsl:variable>

        <xsl:variable name="swapStream1.payerPartyReference.href">
            <xsl:choose>
                <xsl:when test="$s1PayOrReceive = 'pay'">
                    <xsl:choose>
                        <xsl:when test="$reversePayReceive = 'true'">
                            <xsl:value-of select="$counterpartId"/>
                        </xsl:when>
                        <xsl:otherwise>
                            <xsl:value-of select="$originatorId"/>
                        </xsl:otherwise>
                    </xsl:choose>
                </xsl:when>
                <xsl:when test="$s1PayOrReceive = 'receive'">
                    <xsl:choose>
                        <xsl:when test="$reversePayReceive = 'true'">
                            <xsl:value-of select="$originatorId"/>
                        </xsl:when>
                        <xsl:otherwise>
                            <xsl:value-of select="$counterpartId"/>
                        </xsl:otherwise>
                    </xsl:choose>
                </xsl:when>
            </xsl:choose>
        </xsl:variable>

        <xsl:variable name="swapStream1.receiverPartyReference.href">
            <xsl:choose>
                <xsl:when test="$swapStream1.payerPartyReference.href = $counterpartId">
                    <xsl:value-of select="$originatorId"/>
                </xsl:when>
                <xsl:otherwise>
                    <xsl:value-of select="$counterpartId"/>
                </xsl:otherwise>
            </xsl:choose>
        </xsl:variable>

        <xsl:variable name="leg1.maturity.businessDayConvention">
            <xsl:call-template name="extract-streamSchedules-businessDayConvention">
                <xsl:with-param name="legNb" select="1"/>
                <xsl:with-param name="stream" select="1"/>
            </xsl:call-template>
        </xsl:variable>
        <xsl:variable name="swapStream1.terminationDate.dateAdjustments.businessDayConvention"
            select="mx:execute-formula($mapBusinessDayConv, $swapStream1.paramMaturityBusinessDayConvention)"/>

        <!--terminationDate.businessCenter-->
        <xsl:variable name="swapStream1.calculationPeriodFrequency.period">
            <xsl:value-of
                select="mx:execute-formula($mapPeriodUnit, $swapStream1.paramCalculationPeriodUnit)//row[1]"
            />
        </xsl:variable>
        <xsl:variable name="swapStream1.businessCenter"
            select="mx:execute-formula($mapBusinessCenters, $swapStream1.paramBusinessCenter)"/>
        <xsl:variable name="notificationEffectiveCalendar.businessCenter"
            select="mx:execute-formula($mapBusinessCenters,$notificationEffectiveCalendar.paramBusinessCenter)"/>
        <xsl:variable name="swapStream1.frequency.period">
            <xsl:value-of
                select="mx:execute-formula($mapPeriodUnit, $swapStream1.paramFrequencyPeriodUnit)//row[1]"
            />
        </xsl:variable>
        <xsl:variable name="swapStream1.fixingDates.period">
            <xsl:value-of
                select="mx:execute-formula($mapPeriodUnit, $swapStream1.paramFixingPeriodUnit)//row[1]"
            />
        </xsl:variable>
        <xsl:variable name="swapStream1.fixingDates.dayType">
            <xsl:value-of
                select="mx:execute-formula($mapPeriodUnit, $swapStream1.paramFixingPeriodUnit)//row[2]"
            />
        </xsl:variable>
        <xsl:variable name="swapStream1.resetFrequency.period">
            <xsl:value-of
                select="mx:execute-formula($mapPeriodUnit, $swapStream1.paramResetFrequencyPeriodUnit)//row[1]"
            />
        </xsl:variable>

        <!-- swapStream1.fixingDates.businessDayConvention -->
        <xsl:variable name="swapStream1.fixingDates.businessDayConvention">
            <xsl:choose>
                <!-- businessDayConvention must equal 'PRECEDING' if periodMultiplier is '0' and period is 'D' -->
                <xsl:when
                    test="$swapStream1.fixingDates.periodMultiplier = '0' and ($swapStream1.fixingDates.period = 'D' or string-length($swapStream1.fixingDates.period) = 0)">
                    <xsl:value-of select="'PRECEDING'"/>
                </xsl:when>
                <xsl:otherwise>
                    <xsl:value-of select="'NONE'"/>
                </xsl:otherwise>
            </xsl:choose>
        </xsl:variable>


        <!--streamSchedules.businessCenter-->
        <xsl:variable name="s1.streamSchedules.businessDayConvention"
            select="mx:execute-formula($mapBusinessDayConv, $s1.streamSchedules.businessDayConvention.param)"/>
        <xsl:variable name="swapStream1.terminationDate.dateAdjustments.businessDayConvention"
            select="mx:execute-formula($mapBusinessDayConv, $swapStream1.paramMaturityBusinessDayConvention)"/>
        <xsl:variable name="swapStream1.calculationPeriodDatesAdjustments.businessDayConvention"
            select="mx:execute-formula($mapBusinessDayConv, $swapStream1.paramCalculationBusinessDayConvention)"/>
        <xsl:variable name="swapStream1.dayCountFraction"
            select="mx:execute-formula($mapDayCountBasis, $swapStream1.paramDayCountFraction)"/>
        <xsl:variable name="swapStream1.businessDayConvention"
            select="mx:execute-formula($mapBusinessDayConv, $swapStream1.paramBusinessDayConvention)"/>
        <xsl:variable name="swapStream1.resetDatesAdjustments.businessDayConvention"
            select="mx:execute-formula($mapBusinessDayConv, $swapStream1.paramResetDatesAdjustmentsBusinessDayConvention)"/>
        <xsl:variable name="swapStream1.spreadSchedule.nodes">
            <xsl:call-template name="create-spreadSchedule">
                <xsl:with-param name="initialValue" select="$initialValue"/>
            </xsl:call-template>
        </xsl:variable>

        <!-- floating leg -->
        <xsl:variable name="swapStream1.params" select="concat('index:', $leg1.floatingRateIndex)"/>
        <xsl:variable name="swapStream1.result"
            select="mx:execute-formula($mapIndex, $swapStream1.params)"/>
        <xsl:variable name="swapStream1.resultPre" select="$swapStream1.result//row[1]"/>
        <xsl:variable name="swapStream1.floatingRateIndex">
            <xsl:choose>
                <xsl:when test="$leg1.payoutType = 'floatingRate'">
                    <xsl:value-of select="$swapStream1.result//row[1]"/>
                </xsl:when>
                <xsl:when test="$leg1.payoutType = 'fixedRate'">
                    <xsl:value-of select="''"/>
                </xsl:when>
                <xsl:when test="string-length($swapStream1.resultPre) = 'UNMAPPED' ">
                    <xsl:value-of
                        select="mx:execute-formula('mx.xml2xml.ECN.common.errorHandling.throwException', concat('errorMessage: Unmapped party -',$swapStream1.resultPre))"
                    />
                </xsl:when>
                <xsl:otherwise>
                    <xsl:value-of
                        select="mx:execute-formula('mx.xml2xml.ECN.common.errorHandling.throwException',concat('errorMessage: payment type for stream 2 is incorrect. Returned value is: ', $leg1.payoutType))"
                    />
                </xsl:otherwise>
            </xsl:choose>
        </xsl:variable>
        <xsl:variable name="swapStream1.calculationPeriodAmount.period"/>
        <xsl:variable name="swapStream1.calculationPeriodAmount.periodMultiplier">
            <xsl:value-of select="$swapStream1.result//row[3]"/>
        </xsl:variable>
        <xsl:variable name="swapStream1.paymentDates.period" select="$swapStream1.frequency.period"/>
        <xsl:variable name="swapStream1.paymentDates.periodMultiplier"
            select="$swapStream1.frequency.periodMultiplier"/>
        <xsl:variable name="swapStream1.effectiveDate.dateAdjustments.businessCenter"
            select="$swapStream1.businessCenter"/>
        <xsl:variable name="swapStream1.terminationDate.dateAdjustments.businessCenter"
            select="$swapStream1.businessCenter"/>
        <xsl:variable name="swapStream1.calculationPeriodDatesAdjustments.businessCenter"
            select="$swapStream1.businessCenter"/>
        <xsl:variable name="swapStream1.resetDatesAdjustments.businessCenter"
            select="$swapStream1.businessCenter"/>
        <xsl:variable name="swapStream2.payerPartyReference.href">
            <xsl:choose>
                <xsl:when test="$s1PayOrReceive = 'pay'">
                    <xsl:choose>
                        <xsl:when test="$reversePayReceive = 'true'">
                            <xsl:value-of select="$counterpartId"/>
                        </xsl:when>
                        <xsl:otherwise>
                            <xsl:value-of select="$originatorId"/>
                        </xsl:otherwise>
                    </xsl:choose>
                </xsl:when>
                <xsl:otherwise>
                    <xsl:choose>
                        <xsl:when test="$reversePayReceive = 'true'">
                            <xsl:value-of select="$originatorId"/>
                        </xsl:when>
                        <xsl:otherwise>
                            <xsl:value-of select="$counterpartId"/>
                        </xsl:otherwise>
                    </xsl:choose>
                </xsl:otherwise>
            </xsl:choose>
        </xsl:variable>
        <xsl:variable name="swapStream2.receiverPartyReference.href">
            <xsl:choose>
                <xsl:when test="$s1PayOrReceive = 'pay'">
                    <xsl:choose>
                        <xsl:when test="$reversePayReceive = 'true'">
                            <xsl:value-of select="$originatorId"/>
                        </xsl:when>
                        <xsl:otherwise>
                            <xsl:value-of select="$counterpartId"/>
                        </xsl:otherwise>
                    </xsl:choose>
                </xsl:when>
                <xsl:otherwise>
                    <xsl:choose>
                        <xsl:when test="$reversePayReceive = 'true'">
                            <xsl:value-of select="$counterpartId"/>
                        </xsl:when>
                        <xsl:otherwise>
                            <xsl:value-of select="$originatorId"/>
                        </xsl:otherwise>
                    </xsl:choose>
                </xsl:otherwise>
            </xsl:choose>
        </xsl:variable>
        <xsl:variable name="partyTradeIdentifier.tradeId2" select="$tradeId"/>
        <xsl:variable name="leg2.maturity.businessDayConvention">
            <xsl:call-template name="extract-streamSchedules-businessDayConvention">
                <xsl:with-param name="legNb" select="1"/>
                <xsl:with-param name="stream" select="2"/>
            </xsl:call-template>
        </xsl:variable>
        <xsl:variable name="swapStream2.terminationDate.dateAdjustments.businessDayConvention"
            select="mx:execute-formula($mapBusinessDayConv, $swapStream2.paramMaturityBusinessDayConvention)"/>
        <!--terminationDate.businessCenter-->
        <xsl:variable name="swapStream2.calculationPeriodFrequency.period">
            <xsl:value-of
                select="mx:execute-formula($mapPeriodUnit, $swapStream2.paramCalculationPeriodUnit)//row[1]"
            />
        </xsl:variable>
        <xsl:variable name="swapStream2.businessCenter"
            select="mx:execute-formula($mapBusinessCenters, $swapStream2.paramBusinessCenter)"/>
        <xsl:variable name="swapStream2.frequency.period">
            <xsl:value-of
                select="mx:execute-formula($mapPeriodUnit, $swapStream2.paramFrequencyPeriodUnit)//row[1]"
            />
        </xsl:variable>
        <xsl:variable name="swapStream2.fixingDates.period">
            <xsl:value-of
                select="mx:execute-formula($mapPeriodUnit, $swapStream2.paramFixingPeriodUnit)//row[1]"
            />
        </xsl:variable>
        <xsl:variable name="swapStream2.fixingDates.dayType">
            <xsl:value-of
                select="mx:execute-formula($mapPeriodUnit, $swapStream2.paramFixingPeriodUnit)//row[2]"
            />
        </xsl:variable>
        <xsl:variable name="swapStream2.resetFrequency.period">
            <xsl:value-of
                select="mx:execute-formula($mapPeriodUnit, $swapStream2.paramResetFrequencyPeriodUnit)//row[1]"
            />
        </xsl:variable>
        <!-- swapStream2.fixingDates.businessDayConvention -->
        <xsl:variable name="swapStream2.fixingDates.businessDayConvention">
            <xsl:choose>
                <!-- businessDayConvention must equal 'PRECEDING' if periodMultiplier is '0' and period is 'D' -->
                <xsl:when
                    test="$swapStream2.fixingDates.periodMultiplier = '0' and ($swapStream2.fixingDates.period = 'D' or string-length($swapStream2.fixingDates.period) = 0)">
                    <xsl:value-of select="'PRECEDING'"/>
                </xsl:when>
                <xsl:otherwise>
                    <xsl:value-of select="'NONE'"/>
                </xsl:otherwise>
            </xsl:choose>
        </xsl:variable>

        <xsl:variable name="s2.streamSchedules.businessDayConvention"
            select="mx:execute-formula($mapBusinessDayConv, $s2.streamSchedules.businessDayConvention.param)"/>
        <xsl:variable name="swapStream2.terminationDate.dateAdjustments.businessDayConvention"
            select="mx:execute-formula($mapBusinessDayConv, $swapStream2.paramMaturityBusinessDayConvention)"/>
        <xsl:variable name="swapStream2.calculationPeriodDatesAdjustments.businessDayConvention"
            select="mx:execute-formula($mapBusinessDayConv, $swapStream2.paramCalculationBusinessDayConvention)"/>
        <xsl:variable name="swapStream2.dayCountFraction"
            select="mx:execute-formula($mapDayCountBasis, $swapStream2.paramDayCountFraction)"/>
        <xsl:variable name="swapStream2.businessDayConvention"
            select="mx:execute-formula($mapBusinessDayConv, $swapStream2.paramBusinessDayConvention)"/>
        <xsl:variable name="swapStream2.resetDatesAdjustments.businessDayConvention"
            select="mx:execute-formula($mapBusinessDayConv, $swapStream2.paramResetDatesAdjustmentsBusinessDayConvention)"/>
        <xsl:variable name="swapStream2.spreadSchedule.nodes">
            <xsl:call-template name="create-spreadSchedule">
                <xsl:with-param name="initialValue" select="$initialValue"/>
            </xsl:call-template>
        </xsl:variable>

        <!-- floating leg -->
        <xsl:variable name="swapStream2.params" select="concat('index:', $leg2.floatingRateIndex)"/>
        <xsl:variable name="swapStream2.result"
            select="mx:execute-formula($mapIndex, $swapStream2.params)"/>
        <xsl:variable name="swapStream2.resultPre" select="$swapStream2.result//row[1]"/>
        <xsl:variable name="swapStream2.floatingRateIndex">
            <xsl:choose>
                <xsl:when test="$leg2.payoutType = 'floatingRate'">
                    <xsl:value-of select="$swapStream2.result//row[1]"/>
                </xsl:when>
                <xsl:when test="$leg2.payoutType = 'fixedRate'">
                    <xsl:value-of select="''"/>
                </xsl:when>
                <xsl:when test="string-length($swapStream2.resultPre) = 'UNMAPPED' ">
                    <xsl:value-of
                        select="mx:execute-formula('mx.xml2xml.ECN.common.errorHandling.throwException', concat('errorMessage: Unmapped party -',$swapStream2.resultPre))"
                    />
                </xsl:when>
                <xsl:otherwise>
                    <xsl:value-of
                        select="mx:execute-formula('mx.xml2xml.ECN.common.errorHandling.throwException',concat('errorMessage: payment type for stream 2 is incorrect. Returned value is: ', $leg1.payoutType))"
                    />
                </xsl:otherwise>
            </xsl:choose>
        </xsl:variable>
        <xsl:variable name="swapStream2.calculationPeriodAmount.period"/>
        <xsl:variable name="swapStream2.calculationPeriodAmount.period">
            <xsl:value-of select="$swapStream2.result//row[2]"/>
        </xsl:variable>
        <xsl:variable name="swapStream2.calculationPeriodAmount.periodMultiplier">
            <xsl:value-of select="$swapStream2.result//row[3]"/>
        </xsl:variable>
        <xsl:variable name="swapStream2.paymentDates.period" select="$swapStream2.frequency.period"/>
        <xsl:variable name="swapStream2.paymentDates.periodMultiplier"
            select="$swapStream2.frequency.periodMultiplier"/>
        <xsl:variable name="swapStream2.effectiveDate.dateAdjustments.businessCenter"
            select="$swapStream2.businessCenter"/>
        <xsl:variable name="swapStream2.terminationDate.dateAdjustments.businessCenter"
            select="$swapStream2.businessCenter"/>
        <xsl:variable name="swapStream2.calculationPeriodDatesAdjustments.businessCenter"
            select="$swapStream2.businessCenter"/>
        <xsl:variable name="swapStream2.resetDatesAdjustments.businessCenter"
            select="$swapStream2.businessCenter"/>

        <!-- ===================== -->
        <!-- Payers and receivers  -->
        <!-- ===================== -->
        <xsl:variable name="premium.payerPartyReference">
            <xsl:choose>
                <xsl:when test="$premium.pay.or.receive='pay'">
                    <xsl:value-of select="$originatorId"/>
                </xsl:when>
                <xsl:otherwise>
                    <xsl:value-of select="$counterpartId"/>
                </xsl:otherwise>
            </xsl:choose>
        </xsl:variable>
        <xsl:variable name="premium.receiverPartyReference">
            <xsl:choose>
                <xsl:when test="$premium.pay.or.receive='pay'">
                    <xsl:value-of select="$counterpartId"/>
                </xsl:when>
                <xsl:otherwise>
                    <xsl:value-of select="$originatorId"/>
                </xsl:otherwise>
            </xsl:choose>
        </xsl:variable>
        <!-- receiverPartyReference.href -->
        <xsl:variable name="receiverPartyReference.href">
            <xsl:variable name="receiver">
                <xsl:call-template name="extract-eventCashFlow-receiverPartyID"/>
            </xsl:variable>
            <xsl:value-of select="substring-after($receiver, '#')"/>
        </xsl:variable>
        <!-- payerPartyReference.href -->
        <xsl:variable name="payerPartyReference.href">
            <xsl:variable name="payer">
                <xsl:call-template name="extract-payPartyID"/>
            </xsl:variable>
            <xsl:value-of select="substring-after($payer, '#')"/>
        </xsl:variable>
        <!--partyTradeIdentifier.nodes-->
        <xsl:variable name="party.id1" select="$counterpartId"/>
        <xsl:variable name="party.id2" select="mx:execute-formula($mapOurPartyLabel)"/>
        <xsl:variable name="partyTradeIdentifier.nodes">
            <xsl:call-template name="create-partyTradeIdentifier-partyTradeIdentifier">
                <xsl:with-param name="partyReference.href" select="$party.id2"/>
                <xsl:with-param name="tradeId" select="$partyTradeIdentifier.tradeId2"/>
                <xsl:with-param name="tradeId.tradeIdScheme" select="$tradeId2.scheme"/>
            </xsl:call-template>
        </xsl:variable>
        <!--<xsl:variable name="exerciseNode">
			<xsl:call-template name="create-bermudaExercise">
				<xsl:with-param name="id" select="$bermudaExercise.id" />
				<xsl:with-param name="bermudaExerciseDates.unadjustedDate.nodes" select="$bermudaExerciseDates.unadjustedDate.nodes"/>
				<xsl:with-param name="bermudaExerciseDates.dateAdjustments.businessDayConvention" select="$s1.streamSchedules.businessDayConvention"/>
				<xsl:with-param name="bermudaExerciseDates.dateAdjustments.businessCenter"  select="$notificationEffectiveCalendar.businessCenter" />
				<xsl:with-param name="earliestExerciseTime.hourMinuteTime" select="$earliestExerciseTime.hourMinuteTime" />
				<xsl:with-param name="earliestExerciseTime.businessCenter.name" select="$notificationEffectiveCalendar.businessCenter" />
