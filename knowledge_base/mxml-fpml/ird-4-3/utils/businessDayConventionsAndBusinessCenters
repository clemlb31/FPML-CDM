	<xsl:template name="terminationDate.businessDayConvention">
		<xsl:param name="legNumber" />
		<xsl:param name="nbTrade"  select="number($tradePos)" />
		<xsl:choose>
			<!-- drivingSchedule -->
			<xsl:when test="/MxML/trades/trade[position() = $nbTrade]/tradeBody/*/stream[streamTemplate/leg = $legNumber]/streamTemplate/streamSchedules/calculationEndSchedule/scheduleNature= 'drivingSchedule'">
				<xsl:choose>
					<xsl:when test="/MxML/trades/trade[position() = $nbTrade]/tradeBody/*/stream[streamTemplate/leg = $legNumber]/streamTemplate/streamSchedules/calculationEndSchedule/scheduleGenerator/standardScheduleGenerator/businessDayConvention">
						<xsl:value-of select="mx:execute-formula($mapBusinessDayConv,concat('businessDayConvention:',/MxML/trades/trade[position() = $nbTrade]/tradeBody/*/stream[streamTemplate/leg = $legNumber]/streamTemplate/streamSchedules/calculationEndSchedule/scheduleGenerator/standardScheduleGenerator/businessDayConvention))" />
					</xsl:when>
					<xsl:otherwise>
						<xsl:value-of select="'FOLLOWING'" />
					</xsl:otherwise>
				</xsl:choose>
			</xsl:when>
			<xsl:otherwise>
				<xsl:choose>
					<!-- businessDayConvention exists under the shifter node -->
					<xsl:when test="/MxML/trades/trade[position() = $nbTrade]/tradeBody/*/stream[streamTemplate/leg = $legNumber]/streamTemplate/streamSchedules/calculationEndSchedule/shifter/businessDayConvention">
						<xsl:value-of select="mx:execute-formula($mapBusinessDayConv,concat('businessDayConvention:',/MxML/trades/trade[position() = $nbTrade]/tradeBody/*/stream[streamTemplate/leg = $legNumber]/streamTemplate/streamSchedules/calculationEndSchedule/shifter/businessDayConvention))" />
					</xsl:when>
					<!-- deduceFrom or equal to-->
					<xsl:otherwise>
						<xsl:choose>
							<!-- payment schedule -->
							<xsl:when test="/MxML/trades/trade[position() = $nbTrade]/tradeBody/*/stream[streamTemplate/leg = $legNumber]/streamTemplate/streamSchedules/calculationEndSchedule/underlyingSchedule = 'paymentSchedule' ">
								<xsl:choose>
									<xsl:when test="/MxML/trades/trade[position() = $nbTrade]/tradeBody/*/stream[streamTemplate/leg = $legNumber]/streamTemplate/streamSchedules/paymentSchedule/scheduleNature='drivingSchedule'">
