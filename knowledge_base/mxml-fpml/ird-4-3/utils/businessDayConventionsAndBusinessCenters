												<xsl:value-of select="mx:execute-formula($mapBusinessDayConv,concat('businessDayConvention:',/MxML/trades/trade[position() = $nbTrade]/tradeBody/*/stream[streamTemplate/leg = $legNumber]/streamTemplate/streamSchedules/paymentSchedule/shifter/businessDayConvention))" />
											</xsl:when>
											<xsl:when test="/MxML/trades/trade[position() = $nbTrade]/tradeBody/*/stream[streamTemplate/leg = $legNumber]/streamTemplate/streamSchedules/paymentSchedule/scheduleGenerator/standardScheduleGenerator/businessDayConvention">
												<xsl:value-of select="mx:execute-formula($mapBusinessDayConv,concat('businessDayConvention:',/MxML/trades/trade[position() = $nbTrade]/tradeBody/*/stream[streamTemplate/leg = $legNumber]/streamTemplate/streamSchedules/paymentSchedule/scheduleGenerator/standardScheduleGenerator/businessDayConvention))" />
											</xsl:when>
											<xsl:otherwise>
												<xsl:value-of select="'FOLLOWING'" />
											</xsl:otherwise>
										</xsl:choose>
									</xsl:when>
									<xsl:otherwise>
										<xsl:choose>
											<xsl:when test="/MxML/trades/trade[position() = $nbTrade]/tradeBody/*/stream[streamTemplate/leg = $legNumber]/streamTemplate/streamSchedules/paymentSchedule/underlyingSchedule='calculationSchedule'">
												<xsl:choose>
													<xsl:when test="/MxML/trades/trade[position() = $nbTrade]/tradeBody/*/stream[streamTemplate/leg = $legNumber]/streamTemplate/streamSchedules/calculationSchedule/scheduleNature= 'drivingSchedule'">
														<xsl:choose>
															<xsl:when test="/MxML/trades/trade[position() = $nbTrade]/tradeBody/*/stream[streamTemplate/leg = $legNumber]/streamTemplate/streamSchedules/calculationSchedule/scheduleGenerator/standardScheduleGenerator/businessDayConvention">
																<xsl:value-of select="mx:execute-formula($mapBusinessDayConv,concat('businessDayConvention:',/MxML/trades/trade[position() = $nbTrade]/tradeBody/*/stream[streamTemplate/leg = $legNumber]/streamTemplate/streamSchedules/calculationSchedule/scheduleGenerator/standardScheduleGenerator/businessDayConvention))" />
															</xsl:when>
															<xsl:otherwise>
																<xsl:value-of select="'FOLLOWING'" />
															</xsl:otherwise>
