<xsl:stylesheet xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:str="http://exslt.org/strings" xmlns:exsl="http://exslt.org/common" xmlns="http://www.fpml.org/2007/FpML-4-3" xmlns:mx="http://murex.com/xslt/common" version="1.0" exclude-result-prefixes="mx exsl str">
	<xsl:import href="mx.generic.errorHandling.assert"/>
	<xsl:import href="mx.xml2xml.transform.mxml2fpml.4-3.products.ird.variables"/>
	<xsl:import href="mx.xml2xml.extract.mxml.products.ird.templates"/>
	<xsl:import href="mx.xml2xml.extract.mxml.products.common.templates"/>
	<xsl:import href="mx.generic.exslt.str.split"/>
	<xsl:import href="mx.generic.exslt.str.tokenize"/>
	<!--Param User Defined Field Label For Internal Counterparty-->
	<xsl:param name="internalUdfLabel" select="''"/>
	<xsl:variable name="adaptDateFormula" select="'mx.xml2xml.ECN.common.utils.adaptDate'"/>
	<xsl:variable name="format" select="'yyyyMMdd'"/>
	<xsl:variable name="outputFormat" select="'yyyy-MM-dd'"/>
	<xsl:variable name="bermudaExerciseDates.unadjustedDate.nodes">
		<xsl:for-each select="/MxML/trades/trade[(not(tradeHeader/tradeUserDefinedFields/userDefinedField[fieldLabel=$internalUdfLabel]/fieldValue=&quot;true&quot;) and not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeBody/*/payout/option/exercizeSchedule/exercizeEvents/exercizeEvent/exercizeDate">
			<xsl:variable name="exercizeDate">
				<xsl:value-of select="."/>
			</xsl:variable>
			<unadjustedDate>
				<xsl:value-of select="mx:execute-formula($adaptDateFormula, concat('date:', $exercizeDate,',format:', $format,',outputFormat:', $outputFormat))"/>
			</unadjustedDate>
		</xsl:for-each>
	</xsl:variable>
	<xsl:variable name="swaptionStraddle">
		<xsl:variable name="optionPackageType">
			<xsl:call-template name="extract-optionPackageType">
				<xsl:with-param name="legNb" select="1"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:choose>
			<xsl:when test="$optionPackageType = 'straddle'">
				<xsl:value-of select="'true'"/>
			</xsl:when>
			<xsl:when test="$optionPackageType = 'call'">
				<xsl:value-of select="'false'"/>
			</xsl:when>
			<xsl:otherwise>NaN</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>
	<xsl:variable name="notificationEffectiveCalendar">
		<xsl:call-template name="extract-notificationEffectiveCalendar">
			<xsl:with-param name="legNb" select="'1'"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="notificationEffectiveCalendar.paramBusinessCenter" select="concat('businessCenter:', $notificationEffectiveCalendar)"/>
	<!-- option style -->
	<xsl:variable name="optionStyle">
		<xsl:call-template name="extract-optionStyle"/>
	</xsl:variable>
	<!-- option holder -->
	<xsl:variable name="optionHolderReference">
		<xsl:call-template name="extract-optionHolderReference"/>
	</xsl:variable>
	<!-- option writer -->
	<xsl:variable name="optionWriterReference">
		<xsl:call-template name="extract-optionWriterReference"/>
	</xsl:variable>
	<!-- buy or sell -->
	<xsl:variable name="buyOrSell">
		<xsl:call-template name="extract-buy-or-sell-option"/>
	</xsl:variable>
	<!-- settlementNature -->
	<xsl:variable name="settlementNature">
		<xsl:call-template name="extract-settlementNature"/>
	</xsl:variable>
	<xsl:variable name="MxML.MutuallyAgreedClearinghouse">
		<xsl:variable name="MutuallyAgreedClearinghouseUDFLabel" select="mx:execute-formula($mapUdfLabel,'udfContent:SwaptionMutuallyAgreedClearingHouse')"/>
		<xsl:variable name="MxML.MutuallyAgreedClearinghouseTmp">
			<xsl:call-template name="extract-udf">
				<xsl:with-param name="label" select="$MutuallyAgreedClearinghouseUDFLabel"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:variable name="MxML.MappedMutuallyAgreedClearinghouse">
			<xsl:if test="string-length($MxML.MutuallyAgreedClearinghouseTmp) &gt; 0">
				<xsl:value-of select="mx:execute-formula($mapCounterparty, concat('partyLabel:',$MxML.MutuallyAgreedClearinghouseTmp))"/>
			</xsl:if>
		</xsl:variable>
		<xsl:if test="string-length($MxML.MutuallyAgreedClearinghouseTmp) &gt; 0">
			<xsl:call-template name="AssertNotMapped">
				<xsl:with-param name="value" select="$MxML.MappedMutuallyAgreedClearinghouse"/>
				<xsl:with-param name="message" select="concat('Mutually Agreed Clearing House: ',$MxML.MappedMutuallyAgreedClearinghouse, ' not mapped. Please check formula: ', $mapCounterparty)"/>
				<xsl:with-param name="formula" select="$mapCounterparty"/>
			</xsl:call-template>
		</xsl:if>
		<xsl:value-of select="$MxML.MappedMutuallyAgreedClearinghouse"/>
	</xsl:variable>
		
	<!-- =================== -->
	<!-- cashSettlement Node -->
	<!-- =================== -->
	<!-- cashSettlementValuationTime node -->
	<xsl:variable name="swaptionSettlementMatrix" select="mx:execute-formula('public.xml2xml.mapping.mxml2fpml.ird.swaptionSettlementMatrix',concat('currency:',$swapStream1.notionalSchedule.notionalStepSchedule.currency,',indexFamily:',$indexFamily,',isdaDocumentation:',$contractualDefinitions.overriding))"/>
	<xsl:variable name="cashSettlement.cashSettlementValuationTime.hourMinuteTime" select="$swaptionSettlementMatrix//row[10]"/>
	<xsl:variable name="cashSettlement.cashSettlementValuationTime.businessCenter.name">
		<xsl:variable name="businessCenters">
			<xsl:value-of select="exsl:node-set($swaptionSettlementMatrix)//row[11]"/>
		</xsl:variable>
		<xsl:variable name="holidaysBCToken">
			<xsl:call-template name="str:tokenize">
				<xsl:with-param name="string" select="$businessCenters"/>
				<xsl:with-param name="delimiters" select="';'"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:variable name="holidaysBCToken.tokens" select="exsl:node-set($holidaysBCToken)/token"/>
		<xsl:for-each select="$holidaysBCToken.tokens">
			<xsl:variable name="pos" select="position()"/>
			<businessCenter>
				<xsl:value-of select="$holidaysBCToken.tokens[$pos]"/>
			</businessCenter>
		</xsl:for-each>
	</xsl:variable>
	<!-- cashSettlementValuationDate node -->
	<xsl:variable name="cashSettlement.cashSettlementValuationDate.dateRelativeTo.href">
		<xsl:value-of select="'exercisePeriod'"/>
	</xsl:variable>
	<xsl:variable name="cashSettlement.cashSettlementValuationDate.periodMultiplier">
		<xsl:value-of select="'0'"/>
	</xsl:variable>
	<xsl:variable name="cashSettlement.cashSettlementValuationDate.period">
		<xsl:value-of select="'D'"/>
	</xsl:variable>
	<xsl:variable name="cashSettlement.cashSettlementValuationDate.businessDayConvention">
		<xsl:value-of select="'NONE'"/>
	</xsl:variable>
	<!-- cashSettlementPaymentDate node -->
	<xsl:variable name="cashSettlement.relativeDate.businessDayConvention">
		<xsl:variable name="businessDayConvention" select="/MxML/trades/trade[1]/tradeBody/*/stream[./streamTemplate/payoutType='floatingRate']/streamTemplate/streamSchedules/calculationSchedule/scheduleGenerator/standardScheduleGenerator/businessDayConvention"/>
		<xsl:value-of select="mx:execute-formula('public.xml2xml.mapping.mxml2fpml.common.businessDayConvention', concat('businessDayConvention:', $businessDayConvention))"/>
	</xsl:variable>
	<xsl:variable name="cashSettlement.cashSettlementPaymentDate.dateRelativeTo.href">
		<xsl:value-of select="'exercisePeriod'"/>
	</xsl:variable>
	<xsl:variable name="cashSettlement.cashSettlementPaymentDate.businessCenter.nodes">
		<xsl:variable name="businessCenters">
			<xsl:value-of select="exsl:node-set($swaptionSettlementMatrix)//row[4]"/>
		</xsl:variable>
		<xsl:variable name="holidaysBCToken">
			<xsl:call-template name="str:tokenize">
				<xsl:with-param name="string" select="$businessCenters"/>
				<xsl:with-param name="delimiters" select="';'"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:variable name="holidaysBCToken.tokens" select="exsl:node-set($holidaysBCToken)/token"/>
		<xsl:for-each select="$holidaysBCToken.tokens">
			<xsl:variable name="pos" select="position()"/>
			<businessCenter>
				<xsl:value-of select="$holidaysBCToken.tokens[$pos]"/>
			</businessCenter>
		</xsl:for-each>
	</xsl:variable>
	<!-- cashSettlementPaymentDate node -->
	<xsl:variable name="cashSettlement.cashSettlementPaymentDate.dateShifterLabel">
		<xsl:value-of select="exsl:node-set($swaptionSettlementMatrix)//row[5]"/>
	</xsl:variable>
	<xsl:variable name="cashSettlement.cashSettlementPaymentDate.period">
		<xsl:value-of select="mx:execute-formula($mapShifterLabel, concat('shifterLabel:',$cashSettlement.cashSettlementPaymentDate.dateShifterLabel))//row[2]"/>
	</xsl:variable>
	<xsl:variable name="cashSettlement.cashSettlementPaymentDate.periodMultiplier">
		<xsl:value-of select="mx:execute-formula('public.xml2xml.mapping.mxml2fpml.common.shifterLabel', concat('shifterLabel:',$cashSettlement.cashSettlementPaymentDate.dateShifterLabel))//row[3]"/>
	</xsl:variable>
	<xsl:variable name="cashSettlement.cashSettlementPaymentDate.dayType">
		<xsl:choose>
			<xsl:when test="number($cashSettlement.cashSettlementPaymentDate.periodMultiplier) = 0 ">
				<xsl:value-of select="''"/> 
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="mx:execute-formula($mapShifterLabel, concat('shifterLabel:',$cashSettlement.cashSettlementPaymentDate.dateShifterLabel))//row[1]"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>
	<xsl:variable name="cashSettlement.relativeDate.businessDayConvention">
		<xsl:choose>
			<xsl:when test="number($cashSettlement.cashSettlementPaymentDate.periodMultiplier) = 0 ">
				<xsl:value-of select="'NONE'"/> 
			</xsl:when>
			<xsl:otherwise>
				<xsl:variable name="businessDayConvention" select="/MxML/trades/trade[1]/tradeBody/*/stream[./streamTemplate/payoutType='floatingRate']/streamTemplate/streamSchedules/calculationSchedule/scheduleGenerator/standardScheduleGenerator/businessDayConvention"/>
				<xsl:value-of select="mx:execute-formula('public.xml2xml.mapping.mxml2fpml.common.businessDayConvention', concat('businessDayConvention:', $businessDayConvention))"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>
	<xsl:variable name="cashSettlementMethod" select="exsl:node-set($swaptionSettlementMatrix)//row[1]"/>
	<xsl:variable name="cashSettlementMethod.tokens">
		<xsl:call-template name="str:_tokenize-delimiters">
			<xsl:with-param name="string" select="$cashSettlementMethod"/>
			<xsl:with-param name="delimiters" select="';'"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="cashSettlementMethod.token" select="exsl:node-set($cashSettlementMethod.tokens)/token"/>
	<xsl:variable name="cashSettlementMethod.token1" select="string($cashSettlementMethod.token[1])"/>
	<xsl:variable name="optionExercizeMethod">
		<xsl:call-template name="extract-optionExercizeMethod"/>
	</xsl:variable>
	<xsl:variable name="optionExercizeSettlement">
		<xsl:call-template name="extract-optionExercizeSettlement"/>
	</xsl:variable>
	<xsl:variable name="default.reference.banks">
		<xsl:variable name="reference.banks.udf">
			<xsl:if test="$contractualDefinitions.overriding = 'ISDA2021'">
				<xsl:call-template name="extract-swaption-cash-settlement-reference-banks-udf">
					<xsl:with-param name="mapUdfLabel" select="$mapUdfLabel"/>
					<xsl:with-param name="mapReferenceBank" select="$mapUdfLabel"/>
				</xsl:call-template>
			</xsl:if>
		</xsl:variable>
		<xsl:choose>
			<xsl:when test="contains(translate($reference.banks.udf,'abcdefghijklmnopqrstuvwxyz','ABCDEFGHIJKLMNOPQRSTUVWXYZ'), 'AGREED ON EXERCISE')">
				<xsl:value-of select="'True'"/>
			</xsl:when>
			<xsl:when test="string-length($reference.banks.udf) &gt; 0 ">
				<xsl:value-of select="'NotDefault'"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="'NoBanks'"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>
	<xsl:variable name="swaptionMappedCashSettlementMethod" select="mx:execute-formula('mx.xml2xml.transform.mxml2fpml.4-3.products.ird.oswp.swaptionCashSettlementMethod',concat('method:',$optionExercizeMethod,',isdaDefinitions:',$contractualDefinitions.overriding,',informationSourcePopulated:',$default.reference.banks))"/>
	<xsl:variable name="exercizeMethod">
		<xsl:choose>
			<xsl:when test="$optionExercizeSettlement = 'physical'"/>
			<xsl:when test="string-length($swaptionMappedCashSettlementMethod) &gt; 0"><xsl:value-of select="$swaptionMappedCashSettlementMethod"></xsl:value-of></xsl:when>					 
			<xsl:when test="$optionExercizeMethod = 'parYieldCurveUnadjusted'">ParYieldCurve-Unadjusted</xsl:when>
			<!-- ParYieldCurve-Adjusted not used -->
			<xsl:when test="$optionExercizeMethod = 'parYieldCurveAdjusted'">ParYieldCurve-Adjusted</xsl:when>
			<xsl:when test="$optionExercizeMethod = 'cashPriceAlternate'">CashPriceAlternateMethod</xsl:when>
			<xsl:when test="$optionExercizeMethod = 'zeroCouponYieldAdjusted'">ZeroCouponYield-Adjusted</xsl:when>
			<!-- Done outside of FpML layer trasnformation -->
			<xsl:when test="$optionExercizeMethod = 'collateralizedCashPrice'">CollateralizedCashPrice</xsl:when>
			<!-- xsl:when test="$optionExercizeMethod = 'standard'">CashPrice</xsl:when -->
			<xsl:when test="$optionExercizeMethod = 'cashPrice'">CashPrice</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="$cashSettlementMethod.token1"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>				
	<xsl:variable name="cashSettlement.referenceBanks">
		<xsl:if test="$contractualDefinitions.overriding = 'ISDA2021'">
			<xsl:call-template name="extract-swaption-cash-settlement-reference-banks-node">
				<xsl:with-param name="mapUdfLabel" select="$mapUdfLabel"/>
				<xsl:with-param name="mapReferenceBank" select="$mapReferenceBank"/>
			</xsl:call-template>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="swaption.rateSource.udf">
		<xsl:if test="$contractualDefinitions.overriding = 'ISDA2021'">
			<xsl:call-template name="extract-swaption-cash-settlement-rate-source">
				<xsl:with-param name="mapUdfLabel" select="$mapUdfLabel"/>
				<xsl:with-param name="mapReferenceBank" select="$mapReferenceBank"/>
			</xsl:call-template>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="cashSettlement.rateSource">
		<xsl:choose>
			<xsl:when test="string-length($swaption.rateSource.udf) &gt; 0">
				<xsl:value-of select="mx:execute-formula($mapInformationSource, concat('informationSource:',$swaption.rateSource.udf))"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="$cashSettlementMethod.token[2]"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>
	<xsl:variable name="cashSettlement.rateType">
		<xsl:value-of select="$cashSettlementMethod.token[4]"/>
	</xsl:variable>
	<xsl:variable name="cashSettlement.applicableCSA">
		<xsl:value-of select="$cashSettlementMethod.token[3]"/>
	</xsl:variable>
	<xsl:variable name="cashSettlementISDA2021.nodes">
		<xsl:if test="$contractualDefinitions.overriding = 'ISDA2021'">
			<xsl:choose>
				<xsl:when test="$exercizeMethod = 'ParYieldCurveUnadjusted'">
					<xsl:element name="parYieldCurveUnadjustedMethod">
						<xsl:if test=" string-length($cashSettlement.referenceBanks) &gt; 0 or string-length($cashSettlement.rateSource) &gt; 0   ">
							<settlementRateSource>
								<xsl:choose>
									<xsl:when test="string-length($cashSettlement.referenceBanks) &gt; 0">
										<cashSettlementReferenceBanks>
											<xsl:copy-of select="$cashSettlement.referenceBanks"/>
										</cashSettlementReferenceBanks>
									</xsl:when>
									<xsl:otherwise>
										<informationSource>
											<rateSource>
												<xsl:value-of select="$cashSettlement.rateSource"/>
											</rateSource>
										</informationSource>
									</xsl:otherwise>
								</xsl:choose>
							</settlementRateSource>
						</xsl:if>
						<xsl:if test="string-length($cashSettlement.rateType) &gt; 0 ">
							<quotationRateType>
								<xsl:value-of select="$cashSettlement.rateType"/>
							</quotationRateType>
						</xsl:if>
					</xsl:element>
				</xsl:when>
				<xsl:when test="$exercizeMethod = 'CollateralizedCashPrice'">
					<xsl:element name="collateralizedCashPriceMethod">
						<xsl:if test="string-length($swapStream1.notionalSchedule.notionalStepSchedule.currency) &gt; 0 ">
							<cashSettlementCurrency>
								<xsl:value-of select="$swapStream1.notionalSchedule.notionalStepSchedule.currency"/>
							</cashSettlementCurrency>
						</xsl:if>
						<xsl:if test=" string-length($cashSettlement.referenceBanks) &gt; 0 or string-length($cashSettlement.rateSource) &gt; 0  ">
							<settlementRateSource>
								<xsl:choose>
									<xsl:when test="string-length($cashSettlement.referenceBanks) &gt; 0">
										<cashSettlementReferenceBanks>
											<xsl:copy-of select="$cashSettlement.referenceBanks"/>
										</cashSettlementReferenceBanks>
									</xsl:when>
									<xsl:otherwise>
										<informationSource>
											<rateSource>
												<xsl:value-of select="$cashSettlement.rateSource"/>
											</rateSource>
										</informationSource>
									</xsl:otherwise>
								</xsl:choose>
							</settlementRateSource>
						</xsl:if>
						<xsl:if test="string-length($cashSettlement.rateType) &gt; 0 ">
							<quotationRateType>
								<xsl:value-of select="$cashSettlement.rateType"/>
							</quotationRateType>
						</xsl:if>
						<xsl:if test="string-length($MxML.MutuallyAgreedClearinghouse) &gt; 0">
							<mutuallyAgreedClearinghouse>
								<identifier>
									<xsl:attribute name="idScheme">
										<xsl:value-of select="'http://www.fpml.org/coding-scheme/external/iso9362'" />
									</xsl:attribute>
									<xsl:value-of select="$MxML.MutuallyAgreedClearinghouse" />
								</identifier>
							</mutuallyAgreedClearinghouse>
						</xsl:if>
						<xsl:variable name="underlyingCSA">
							<xsl:call-template name="extract-swaption-payout-underlyingcsa">
								</xsl:call-template>
						</xsl:variable>
						<xsl:if test="string-length($underlyingCSA) &gt; 0">
							<agreedDiscountRate>
								<xsl:value-of select="mx:execute-formula('public.xml2xml.mapping.mxml2fpml.ird.oswp.agreedDiscountRate',concat('underlyingCSA:',$underlyingCSA,',currency:',$swapStream1.notionalSchedule.notionalStepSchedule.currency))"/>
							</agreedDiscountRate>
						</xsl:if>
					</xsl:element>
				</xsl:when>
				<xsl:when test="$exercizeMethod = 'MidMarketValuation-IndicativeQuotations'">
					<xsl:element name="midMarketValuation">
						<xsl:element name="indicativeQuotations">
							<xsl:if test="string-length($swapStream1.notionalSchedule.notionalStepSchedule.currency) &gt; 0 ">
								<cashSettlementCurrency>
									<xsl:value-of select="$swapStream1.notionalSchedule.notionalStepSchedule.currency"/>
								</cashSettlementCurrency>
							</xsl:if>
							<xsl:if test="string-length($cashSettlement.applicableCSA) &gt; 0 ">
								<applicabelCsa>
									<xsl:value-of select="$cashSettlement.applicableCSA"/>
								</applicabelCsa>
							</xsl:if>
							<xsl:if test="string-length($cashSettlement.referenceBanks) &gt; 0 ">
								<cashSettlementReferenceBanks>
									<xsl:copy-of select="$cashSettlement.referenceBanks"/>
								</cashSettlementReferenceBanks>
							</xsl:if>
						</xsl:element>
					</xsl:element>
				</xsl:when>
				<xsl:when test="$exercizeMethod = 'MidMarketValuation-IndicativeQuotationsAlternate'">
					<xsl:element name="midMarketValuation">
						<xsl:element name="indicativeQuotationsAlternate">
							<xsl:if test="string-length($swapStream1.notionalSchedule.notionalStepSchedule.currency) &gt; 0 ">
								<cashSettlementCurrency>
									<xsl:value-of select="$swapStream1.notionalSchedule.notionalStepSchedule.currency"/>
								</cashSettlementCurrency>
							</xsl:if>
							<xsl:if test="string-length($cashSettlement.applicableCSA) &gt; 0 ">
								<applicabelCsa>
									<xsl:value-of select="$cashSettlement.applicableCSA"/>
								</applicabelCsa>
							</xsl:if>
							<xsl:if test="string-length($cashSettlement.referenceBanks) &gt; 0 ">
								<cashSettlementReferenceBanks>
									<xsl:copy-of select="$cashSettlement.referenceBanks"/>
								</cashSettlementReferenceBanks>
							</xsl:if>
						</xsl:element>
					</xsl:element>
				</xsl:when>
				<xsl:when test="$exercizeMethod = 'MidMarketValuation-CalculationAgentDetermination'">
					<xsl:element name="midMarketValuation">
						<xsl:element name="calculationAgentDetermination">
							<xsl:if test="string-length($swapStream1.notionalSchedule.notionalStepSchedule.currency) &gt; 0 ">
								<cashSettlementCurrency>
									<xsl:value-of select="$swapStream1.notionalSchedule.notionalStepSchedule.currency"/>
								</cashSettlementCurrency>
							</xsl:if>
							<xsl:if test="string-length($cashSettlement.applicableCSA) &gt; 0 ">
								<applicabelCsa>
									<xsl:value-of select="$cashSettlement.applicableCSA"/>
								</applicabelCsa>
							</xsl:if>
						</xsl:element>
					</xsl:element>
				</xsl:when>
			</xsl:choose>
		</xsl:if>
	</xsl:variable>		
	
	<!-- cashPriceMethod node -->
	<xsl:variable name="cashSettlement.cashPriceMethod.currency">
		<xsl:if test="$exercizeMethod = 'CashPrice' ">
			<xsl:value-of select="$swapStream1.notionalSchedule.notionalStepSchedule.currency"/>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="cashSettlement.cashPriceMethod.quotationRateType">
		<xsl:if test="$exercizeMethod = 'CashPrice' ">
			<xsl:value-of select="'Mid'"/>
		</xsl:if>
	</xsl:variable>
	<!-- cashPriceAlternateMethod node -->
	<xsl:variable name="cashSettlement.cashPriceAlternateMethod.currency">
		<xsl:if test="$exercizeMethod = 'CashPriceAlternateMethod' ">
			<xsl:value-of select="$swapStream1.notionalSchedule.notionalStepSchedule.currency"/>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="cashSettlement.cashPriceAlternateMethod.quotationRateType">
		<xsl:if test="$exercizeMethod = 'CashPriceAlternateMethod' ">
			<xsl:value-of select="'Mid'"/>
		</xsl:if>
	</xsl:variable>
	<!-- parYieldCurveUnadjustedMethod node -->
	<xsl:variable name="cashSettlement.parYieldCurveUnadjustedMethod.rateSource">
		<xsl:if test="$exercizeMethod = 'ParYieldCurve-Unadjusted' ">
			<xsl:value-of select="string($cashSettlementMethod.token[2])"/>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="cashSettlement.parYieldCurveUnadjustedMethod.quotationRateType">
		<xsl:if test="$exercizeMethod = 'ParYieldCurve-Unadjusted' ">
			<xsl:value-of select="string($cashSettlementMethod.token[4])"/>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="cashSettlement.parYieldCurveUnadjustedMethod.rateSource.informationProviderScheme">
		<xsl:if test="$exercizeMethod = 'ParYieldCurve-Unadjusted' ">
			<xsl:value-of select="'http://www.fpml.org/coding-scheme/information-provider-2-0'"/>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="cashSettlement.parYieldCurveUnadjustedMethod.rateSourcePage"/>
	<!-- zeroCouponYieldAdjustedMethod node -->
	<xsl:variable name="cashSettlement.zeroCouponYieldAdjustedMethod.rateSource">
		<xsl:if test="$exercizeMethod = 'ZeroCouponYield-Adjusted' ">
			<xsl:value-of select="string($cashSettlementMethod.token[2])"/>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="cashSettlement.zeroCouponYieldAdjustedMethod.rateSource.informationProviderScheme">
		<xsl:if test="$exercizeMethod = 'ZeroCouponYield-Adjusted' ">
			<xsl:value-of select="'http://www.fpml.org/coding-scheme/information-provider-2-0'"/>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="cashSettlement.zeroCouponYieldAdjustedMethod.rateSourcePage"/>
	<xsl:variable name="cashSettlement.zeroCouponYieldAdjustedMethod.quotationRateType">
		<xsl:if test="$exercizeMethod = 'ZeroCouponYield-Adjusted' ">
			<xsl:value-of select="string($cashSettlementMethod.token[4])"/>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="cashSettlement.zeroCouponYieldAdjustedMethod.nodes">
		<settlementRateSource>
			<informationSource>
				<xsl:if test="string-length($cashSettlement.zeroCouponYieldAdjustedMethod.rateSource)&gt;0">
					<rateSource>
						<xsl:if test="string-length($cashSettlement.zeroCouponYieldAdjustedMethod.rateSource.informationProviderScheme)&gt;0">
							<xsl:attribute name="informationProviderScheme">
								<xsl:value-of select="$cashSettlement.zeroCouponYieldAdjustedMethod.rateSource.informationProviderScheme"/>
							</xsl:attribute>
						</xsl:if>
						<xsl:value-of select="$cashSettlement.zeroCouponYieldAdjustedMethod.rateSource"/>
					</rateSource>
				</xsl:if>
				<xsl:if test="string-length($cashSettlement.zeroCouponYieldAdjustedMethod.rateSourcePage)&gt;0">
					<rateSourcePage>
						<xsl:value-of select="$cashSettlement.zeroCouponYieldAdjustedMethod.rateSourcePage"/>
					</rateSourcePage>
				</xsl:if>
			</informationSource>
		</settlementRateSource>
		<quotationRateType>
			<xsl:value-of select="$cashSettlement.zeroCouponYieldAdjustedMethod.quotationRateType"/>
		</quotationRateType>
	</xsl:variable>
	<!-- collateralizedCashPriceMethod -->
	<xsl:variable name="cashSettlement.collateralizedCashPriceMethod.quotationRateType">
		<xsl:if test="$exercizeMethod = 'CollateralizedCashPrice' ">
			<xsl:value-of select="string($cashSettlementMethod.token[4])"/>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="cashSettlement.collateralizedCashPriceMethod.quotationRateSource">
		<xsl:if test="$exercizeMethod = 'CollateralizedCashPrice' ">
			<xsl:value-of select="string($cashSettlementMethod.token[2])"/>
		</xsl:if>
	</xsl:variable>

 	<xsl:variable name="cashSettlement.collateralizedCashPriceMethod.nodes"/>

	<xsl:variable name="physicalSettlement.nodes">
		<xsl:if test="$optionExercizeSettlement = 'physical'">
			<xsl:variable name="udf.referenceBanks" select="mx:execute-formula($mapUdfLabel,'udfContent:SwaptionCashReferenceBanks')"/>
			<xsl:variable name="MxML.referenceBanksPacked">
				<xsl:call-template name="extract-udf-vector">
					<xsl:with-param name="label" select="$udf.referenceBanks"/>
				</xsl:call-template>
			</xsl:variable>
			
			<xsl:variable name="optionExercizeSettlement" select="/MxML/trades/trade/tradeBody/swaption/payout/option/optionExercizeSettlement"/>
			<xsl:variable name="optionExercizeMethod" select="/MxML/trades/trade/tradeBody/swaption/payout/option/optionExercizeMethod"/>
			<xsl:variable name="udf.rateSource" select="mx:execute-formula($mapUdfLabel,'udfContent:RateSource')"/>
			<xsl:variable name="MxML.rateSource">
				<xsl:call-template name="extract-udf">
					<xsl:with-param name="label" select="$udf.rateSource"/>
				</xsl:call-template>
			</xsl:variable>
			<xsl:variable name="udf.rateType" select="mx:execute-formula($mapUdfLabel,'udfContent:QuotationRateType')"/>
			<xsl:variable name="MxML.rateType">
				<xsl:call-template name="extract-udf">
					<xsl:with-param name="label" select="$udf.rateType"/>
				</xsl:call-template>
			</xsl:variable>
			<xsl:if test="(string-length( $MxML.MutuallyAgreedClearinghouse ) &gt; 0 ) or (string-length( $MxML.referenceBanksPacked ) &gt; 0 ) or ($optionExercizeMethod = 'clearedPhysicalSettlement') or (string-length($MxML.rateSource) &gt; 0) or (string-length($MxML.rateType) &gt; 0)">
				<physicalSettlement>
					<xsl:if test="$optionExercizeMethod = 'clearedPhysicalSettlement'">
						<clearedPhysicalSettlement>true</clearedPhysicalSettlement>
					</xsl:if>
					<xsl:if test="$optionExercizeMethod = 'standard' and $optionExercizeSettlement = 'physical' and string-length($MxML.MutuallyAgreedClearinghouse) &gt; 0">
						<clearedPhysicalSettlement>false</clearedPhysicalSettlement>
					</xsl:if>
					<xsl:if test="string-length($MxML.MutuallyAgreedClearinghouse) &gt; 0">
						<mutuallyAgreedClearinghouse>
							<identifier>
								<xsl:attribute name="idScheme">
									<xsl:value-of select="'http://www.fpml.org/coding-scheme/external/iso9362'" />
								</xsl:attribute>
								<xsl:value-of select="$MxML.MutuallyAgreedClearinghouse" />
							</identifier>
						</mutuallyAgreedClearinghouse>
					</xsl:if>
					<xsl:variable name="underlyingCSA">
						<xsl:call-template name="extract-swaption-payout-underlyingcsa">
							</xsl:call-template>
					</xsl:variable>
					<xsl:if test="string-length($underlyingCSA) &gt; 0 and $contractualDefinitions.overriding = 'ISDA2021'">
						<agreedDiscountRate>
							<xsl:value-of select="mx:execute-formula('public.xml2xml.mapping.mxml2fpml.ird.oswp.agreedDiscountRate',concat('underlyingCSA:',$underlyingCSA,',currency:',$swapStream1.notionalSchedule.notionalStepSchedule.currency))"/>
						</agreedDiscountRate>
					</xsl:if>
					<xsl:if test="(string-length( $MxML.referenceBanksPacked ) &gt; 0) or (string-length($MxML.rateSource) &gt; 0)">
						<settlementRateSource>
							<xsl:choose>
								<xsl:when test="string-length( $MxML.referenceBanksPacked ) &gt; 0">
									<cashSettlementReferenceBanks>
										<xsl:variable name="referenceBanksToken">
											<xsl:call-template name="str:tokenize">
												<xsl:with-param name="string" select="$MxML.referenceBanksPacked"/>
												<xsl:with-param name="delimiters" select="';'"/>
											</xsl:call-template>
										</xsl:variable>
										<xsl:variable name="referenceBanksToken.tokens" select="exsl:node-set($referenceBanksToken)/token"/>
										<xsl:for-each select="$referenceBanksToken.tokens">
											<xsl:variable name="pos" select="position()"/>
											<referenceBank>
												<referenceBankId>
													<xsl:value-of select="mx:execute-formula($mapReferenceBank, concat('referenceBank:', $referenceBanksToken.tokens[$pos]))"/>
												</referenceBankId>
											</referenceBank>
										</xsl:for-each>
									</cashSettlementReferenceBanks>
								</xsl:when>
								<xsl:when test="string-length($MxML.rateSource) &gt; 0">
									<informationSource>
										<rateSource>
											<xsl:value-of select="mx:execute-formula($mapInformationSource, concat('informationSource:', $MxML.rateSource))"/>
										</rateSource>
									</informationSource>
								</xsl:when>
							</xsl:choose>
						</settlementRateSource>
					</xsl:if>
					<xsl:if test="string-length($MxML.rateType) &gt; 0">
						<quotationRateType>
							<xsl:value-of select="$MxML.rateType"/>
						</quotationRateType>
					</xsl:if>
				</physicalSettlement>
			</xsl:if>
		</xsl:if>
	</xsl:variable>

	<xsl:variable name="exerciseProcedure.followUpConfirmation">
		<xsl:variable name="label" select="mx:execute-formula('public.ECN.common.mappings.udfLabels', 'fieldName:SwaptionExerciseConfirmation')"/>
		<xsl:value-of select="/MxML/trades/trade[(not(tradeHeader/tradeUserDefinedFields/userDefinedField[fieldLabel=$internalUdfLabel]/fieldValue=&quot;true&quot;) and not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeHeader/tradeUserDefinedFields/userDefinedField[fieldLabel = $label]/fieldValue"/>
	</xsl:variable>

	<xsl:variable name="exerciseProcedure.thresholdRate">
		<xsl:variable name="label" select="mx:execute-formula('public.ECN.common.mappings.udfLabels', 'fieldName:ExecutionThresholdRate')"/>
		<xsl:value-of select="/MxML/trades/trade[(not(tradeHeader/tradeUserDefinedFields/userDefinedField[fieldLabel=$internalUdfLabel]/fieldValue=&quot;true&quot;) and not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeHeader/tradeUserDefinedFields/userDefinedField[fieldLabel = $label]/fieldValue"/>
	</xsl:variable>

	<xsl:variable name="exerciseProcedure.autoExercize">
		<xsl:variable name="label" select="mx:execute-formula('public.ECN.common.mappings.udfLabels', 'fieldName:AutoExercise')"/>
		<xsl:value-of select="/MxML/trades/trade[(not(tradeHeader/tradeUserDefinedFields/userDefinedField[fieldLabel=$internalUdfLabel]/fieldValue=&quot;true&quot;) and not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeHeader/tradeUserDefinedFields/userDefinedField[fieldLabel = $label]/fieldValue"/>
	</xsl:variable>
	
</xsl:stylesheet>