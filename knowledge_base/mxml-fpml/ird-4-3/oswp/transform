			</xsl:if>
		</xsl:variable>
		<xsl:variable name="bermudaRelativeDatesPeriodMultiplier">
			<xsl:if test="string-length($exercizeScheduleShifter) &gt; 0">
				<xsl:value-of select="exsl:node-set($exercizeScheduleShifter)/table/row[1]" />
			</xsl:if>
		</xsl:variable>
		<xsl:variable name="bermudaRelativeDatesPeriodUnit">
			<xsl:if test="string-length($exercizeScheduleShifter) &gt; 0">
				<xsl:value-of select="exsl:node-set($exercizeScheduleShifter)/table/row[2]" />
			</xsl:if>
		</xsl:variable>
		<xsl:variable name="bermudaRelativeDatesBDC">
			<xsl:if test="string-length($exercizeScheduleShifter) &gt; 0">
				<xsl:value-of select="exsl:node-set($exercizeScheduleShifter)/table/row[3]" />
			</xsl:if>
		</xsl:variable>
		<xsl:variable name="bermudaRelativeDatesDayType">
			<xsl:if test="string-length($exercizeScheduleShifter) &gt; 0">
				<xsl:value-of select="exsl:node-set($exercizeScheduleShifter)/table/row[4]" />
			</xsl:if>
		</xsl:variable>
		<xsl:variable name="bermudaRelativeDatesBusinessCenterNodes">
			<xsl:if test="$optionStyle = 'bermudan'">
				<xsl:copy-of select="$swapStream1.businessCenter.nodes" />
			</xsl:if>
		</xsl:variable>

		<!-- exercize schedule leg nature -->
		<xsl:variable name="exercizeLegNature">
			<!--xsl:call-template name="extract-exercizeScheduleBuilder-exercizeLegNature" /-->
		</xsl:variable>



		<!-- relevantUnderlyingDate:relativeDates/periodMultiplier -->
		<xsl:variable name="relevantUnderlyingDate.periodMultiplier">
			<xsl:if test="$optionStyle = 'bermudan'">
				<xsl:variable name="fixedLegNum">
					<xsl:call-template name="extract-fixedLegNum" />
				</xsl:variable>
				<xsl:variable name="floatingLegNum">
					<xsl:choose>
						<xsl:when test="$fixedLegNum = '1' ">
							<xsl:value-of select="'2'" />
						</xsl:when>
						<xsl:when test="$fixedLegNum = '2' ">
							<xsl:value-of select="'1'" />
						</xsl:when>
					</xsl:choose>
				</xsl:variable>
				<xsl:choose>
					<xsl:when test="$exercizeLegNature = 'fixed' and $fixedLegNum = '1' ">
						<xsl:value-of select="$swapStream1.calculationPeriodFrequency.periodMultiplier" />
					</xsl:when>
					<xsl:when test="$exercizeLegNature = 'floating' and $floatingLegNum = '1' ">
						<xsl:value-of select="$swapStream1.calculationPeriodFrequency.periodMultiplier" />
					</xsl:when>
					<xsl:when test="$exercizeLegNature = 'fixed' and $fixedLegNum = '2' ">
						<xsl:value-of select="$swapStream2.calculationPeriodFrequency.periodMultiplier" />
					</xsl:when>
					<xsl:when test="$exercizeLegNature = 'floating' and $floatingLegNum = '2' ">
						<xsl:value-of select="$swapStream2.calculationPeriodFrequency.periodMultiplier" />
					</xsl:when>
					<!-- basis swap underlying not handled as based On information (first/second) is not exported -->
					<xsl:otherwise />
				</xsl:choose>
			</xsl:if>
		</xsl:variable>

		<!-- relevantUnderlyingDate:relativeDates/<period -->
		<xsl:variable name="relevantUnderlyingDate.period">
			<xsl:if test="$optionStyle = 'bermudan'">
				<xsl:variable name="fixedLegNum">
					<xsl:call-template name="extract-fixedLegNum" />
				</xsl:variable>
				<xsl:variable name="floatingLegNum">
					<xsl:choose>
						<xsl:when test="$fixedLegNum = '1' ">
							<xsl:value-of select="'2'" />
						</xsl:when>
						<xsl:when test="$fixedLegNum = '2' ">
							<xsl:value-of select="'1'" />
						</xsl:when>
					</xsl:choose>
				</xsl:variable>
				<xsl:choose>
					<xsl:when test="$exercizeLegNature = 'fixed' and $fixedLegNum = '1' ">
						<xsl:value-of select="$swapStream1.calculationPeriodFrequency.period" />
					</xsl:when>
					<xsl:when test="$exercizeLegNature = 'floating' and $floatingLegNum = '1' ">
						<xsl:value-of select="$swapStream1.calculationPeriodFrequency.period" />
					</xsl:when>
					<xsl:when test="$exercizeLegNature = 'fixed' and $floatingLegNum = '2'">
						<xsl:value-of select="$swapStream2.calculationPeriodFrequency.period" />
					</xsl:when>
					<xsl:when test="$exercizeLegNature = 'floating' and $floatingLegNum = '2'">
						<xsl:value-of select="$swapStream2.calculationPeriodFrequency.period" />
					</xsl:when>
					<!-- basis swap underlying not handled as based On information (first/second) is not exported -->
					<xsl:otherwise />
				</xsl:choose>
			</xsl:if>
		</xsl:variable>

		<!-- relevantUnderlyingDate:relativeDates/businessDayConvention -->
		<xsl:variable name="relevantUnderlyingDate.businessDayConvention">
			<xsl:if test="$optionStyle = 'bermudan'">
				<xsl:variable name="fixedLegNum">
					<xsl:call-template name="extract-fixedLegNum" />
				</xsl:variable>
				<xsl:variable name="floatingLegNum">
					<xsl:choose>
						<xsl:when test="$fixedLegNum = '1' ">
							<xsl:value-of select="'2'" />
						</xsl:when>
						<xsl:when test="$fixedLegNum = '2' ">
							<xsl:value-of select="'1'" />
						</xsl:when>
					</xsl:choose>
				</xsl:variable>
				<xsl:choose>
					<xsl:when test="$exercizeLegNature = 'fixed' and $fixedLegNum = '1' ">
						<xsl:value-of select="$swapStream1.businessDayConvention" />
					</xsl:when>
					<xsl:when test="$exercizeLegNature = 'floating' and $floatingLegNum = '1' ">
						<xsl:value-of select="$swapStream1.businessDayConvention" />
					</xsl:when>
					<xsl:when test="$exercizeLegNature = 'fixed' and $floatingLegNum = '2' ">
						<xsl:value-of select="$swapStream2.businessDayConvention" />
					</xsl:when>
					<xsl:when test="$exercizeLegNature = 'floating' and $floatingLegNum = '2' ">
						<xsl:value-of select="$swapStream2.businessDayConvention" />
					</xsl:when>
					<!-- basis swap underlying not handled as based On information (first/second) is not exported -->
					<xsl:otherwise />
				</xsl:choose>
			</xsl:if>
		</xsl:variable>

		<!-- relevantUnderlyingDate:relativeDates/businessCenters -->
		<xsl:variable name="relevantUnderlyingDate.businessCenterNodes">
			<xsl:if test="$optionStyle = 'bermudan'">
				<xsl:variable name="fixedLegNum">
					<xsl:call-template name="extract-fixedLegNum" />
				</xsl:variable>
				<xsl:variable name="floatingLegNum">
					<xsl:choose>
						<xsl:when test="$fixedLegNum = '1' ">
							<xsl:value-of select="'2'" />
						</xsl:when>
						<xsl:when test="$fixedLegNum = '2' ">
							<xsl:value-of select="'1'" />
						</xsl:when>
					</xsl:choose>
				</xsl:variable>
				<xsl:choose>
					<xsl:when test="$exercizeLegNature = 'fixed' and $fixedLegNum = '1' ">
						<xsl:copy-of select="$swapStream1.businessCenter.nodes" />
					</xsl:when>
					<xsl:when test="$exercizeLegNature = 'floating' and $floatingLegNum = '1' ">
						<xsl:copy-of select="$swapStream1.businessCenter.nodes" />
					</xsl:when>
					<xsl:when test="$exercizeLegNature = 'fixed' and $fixedLegNum = '2' ">
						<xsl:copy-of select="$swapStream2.businessCenter.nodes" />
					</xsl:when>
					<xsl:when test="$exercizeLegNature = 'floating' and $floatingLegNum = '2' ">
						<xsl:copy-of select="$swapStream2.businessCenter.nodes" />
					</xsl:when>
					<!-- basis swap underlying not handled as based On information (first/second) is not exported -->
					<xsl:otherwise />
				</xsl:choose>
			</xsl:if>
		</xsl:variable>
		<!-- relevantUnderlyingDate:scheduleBounds/unadjustedFirstDate -->
		<xsl:variable name="relevantUnderlyingDate.scheduleBounds.unadjustedFirstDate">
			<xsl:if test="$optionStyle = 'bermudan'">
				<xsl:variable name="relevantUnderlyingDate.scheduleBounds.unadjustedFirstDateMx">
					<xsl:call-template name="extract-exercizeScheduleBuilder-exercizeStartDate" />
				</xsl:variable>
				<xsl:value-of select="mx:execute-formula('mx.xml2xml.ECN.common.utils.adaptDate', concat('date:', $relevantUnderlyingDate.scheduleBounds.unadjustedFirstDateMx, ',format:yyyymmdd,outputFormat:yyyy-mm-dd'))" />
			</xsl:if>
		</xsl:variable>
		<!-- relevantUnderlyingDate:scheduleBounds/unadjustedLastDate -->
		<xsl:variable name="relevantUnderlyingDate.scheduleBounds.unadjustedLastDate">
			<xsl:if test="$optionStyle = 'bermudan'">
				<xsl:variable name="relevantUnderlyingDate.scheduleBounds.unadjustedLastDateMx">
					<xsl:call-template name="extract-exercizeScheduleBuilder-exercizeEndDate" />
				</xsl:variable>
				<xsl:value-of select="mx:execute-formula('mx.xml2xml.ECN.common.utils.adaptDate', concat('date:', $relevantUnderlyingDate.scheduleBounds.unadjustedLastDateMx, ',format:yyyymmdd,outputFormat:yyyy-mm-dd'))" />
			</xsl:if>
		</xsl:variable>
		<xsl:variable name="swaption.exersice.streamSchedules.businessDayConvention">
			<xsl:choose>
				<!-- Market convention -->
				<xsl:when test="$premium.currency='USD'">
					<xsl:value-of select="'PRECEDING'" />
				</xsl:when>
				<xsl:otherwise>
					<xsl:value-of select="'FOLLOWING'" />
				</xsl:otherwise>
			</xsl:choose>
		</xsl:variable>


		<xsl:variable name="exersiceNode">
			<!-- Values are initiliazed from a mapping formula based on 2006 ISDA Definitions Settlement Matrix for Early Termination and Swaptions (the ISDA Settlement Matrix) document -->
			<xsl:variable name="indexFamily">
				<xsl:if test="contains($swapStream1.floatingRateIndex ,'EURIBOR')  or contains($swapStream2.floatingRateIndex,'EURIBOR')">
					<xsl:value-of select="'EURIBOR'"/>
				</xsl:if>
				<xsl:if test="contains($swapStream1.floatingRateIndex ,'LIBOR')  or contains($swapStream2.floatingRateIndex,'LIBOR')">
					<xsl:value-of select="'LIBOR'"/>
				</xsl:if>
				<xsl:if test="contains($swapStream1.floatingRateIndex ,'SOFR')  or contains($swapStream2.floatingRateIndex,'SOFR')">
					<xsl:value-of select="'SOFR'"/>
				</xsl:if>
				<xsl:if test="contains($swapStream1.floatingRateIndex ,'SARON')  or contains($swapStream2.floatingRateIndex,'SARON')">
					<xsl:value-of select="'SARON'"/>
				</xsl:if>
			</xsl:variable>            
			<xsl:variable name="swaptionSettlementMatrix" select="mx:execute-formula('public.xml2xml.mapping.mxml2fpml.ird.swaptionSettlementMatrix',concat('currency:',$swapStream1.notionalSchedule.notionalStepSchedule.currency,',indexFamily:',$indexFamily,',isdaDocumentation:',$contractualDefinitions.overriding))"/>

			<xsl:variable name="swaption.earliestExerciseTime.hourMinuteTime" 	select="exsl:node-set($swaptionSettlementMatrix)//row[8]" />
			<xsl:variable name="swaption.earliestExerciseTime.businessCenter.nodes">
				<xsl:variable name="businessCenters">
					<xsl:value-of select="exsl:node-set($swaptionSettlementMatrix)//row[9]" />
				</xsl:variable>
				<xsl:variable name="holidaysBCToken">
					<xsl:call-template name="str:tokenize">
						<xsl:with-param name="string" select="$businessCenters" />
						<xsl:with-param name="delimiters" select="';'" />
					</xsl:call-template>
				</xsl:variable>
				<xsl:variable name="holidaysBCToken.tokens" select="exsl:node-set($holidaysBCToken)/token" />
				<xsl:for-each select="$holidaysBCToken.tokens">
					<xsl:variable name="pos" select="position()" />
					<businessCenter>
						<xsl:value-of select="$holidaysBCToken.tokens[$pos]" />
					</businessCenter>
				</xsl:for-each>
			</xsl:variable>

			<xsl:variable name="swaption.latestExerciseTime.hourMinuteTime" 		select="exsl:node-set($swaptionSettlementMatrix)//row[10]" />
			<xsl:variable name="swaption.latestExerciseTime.businessCenter.nodes">
				<xsl:variable name="businessCenters">
					<xsl:value-of select="exsl:node-set($swaptionSettlementMatrix)//row[11]" />
				</xsl:variable>
				<xsl:variable name="holidaysBCToken">
					<xsl:call-template name="str:tokenize">
						<xsl:with-param name="string" select="$businessCenters" />
						<xsl:with-param name="delimiters" select="';'" />
					</xsl:call-template>
				</xsl:variable>
				<xsl:variable name="holidaysBCToken.tokens" select="exsl:node-set($holidaysBCToken)/token" />
				<xsl:for-each select="$holidaysBCToken.tokens">
					<xsl:variable name="pos" select="position()" />
					<businessCenter>
						<xsl:value-of select="$holidaysBCToken.tokens[$pos]" />
					</businessCenter>
				</xsl:for-each>
			</xsl:variable>

			<xsl:variable name="swaption.expirationTime.hourMinuteTime" 		select="exsl:node-set($swaptionSettlementMatrix)//row[12]" />
			<xsl:variable name="swaption.expirationTime.businessCenter.nodes">
				<xsl:variable name="businessCenters">
					<xsl:value-of select="exsl:node-set($swaptionSettlementMatrix)//row[13]" />
				</xsl:variable>
				<xsl:variable name="holidaysBCToken">
					<xsl:call-template name="str:tokenize">
						<xsl:with-param name="string" select="$businessCenters" />
						<xsl:with-param name="delimiters" select="';'" />
					</xsl:call-template>
				</xsl:variable>
				<xsl:variable name="holidaysBCToken.tokens" select="exsl:node-set($holidaysBCToken)/token" />
				<xsl:for-each select="$holidaysBCToken.tokens">
					<xsl:variable name="pos" select="position()" />
					<businessCenter>
						<xsl:value-of select="$holidaysBCToken.tokens[$pos]" />
					</businessCenter>
				</xsl:for-each>
			</xsl:variable>

			<xsl:variable name="swaption.exerciseDate.businessCenter.nodes">
				<xsl:choose>
					<xsl:when test="$use.default.exercise.calendar = 'true'">
						<xsl:variable name="businessCenters">
							<xsl:value-of select="exsl:node-set($swaptionSettlementMatrix)//row[2]"/>
						</xsl:variable>
						<xsl:variable name="holidaysBCToken">
							<xsl:call-template name="str:tokenize">
								<xsl:with-param name="string" select="$businessCenters"/>
								<xsl:with-param name="delimiters" select="';'"/>
							</xsl:call-template>
						</xsl:variable>
						<xsl:variable name="holidaysBCToken.tokens" select="exsl:node-set($holidaysBCToken)/token"/>
						<xsl:for-each select="$holidaysBCToken.tokens">
							<xsl:variable name="pos" select="position()"/>
							<businessCenter>
								<xsl:if test="string-length($swaption.exerciseDate.businessCenter.scheme)&gt;0">
								  <xsl:attribute name="businessCenterScheme">
									<xsl:value-of select="$businessCenterScheme" />
								  </xsl:attribute>
								</xsl:if>
								<xsl:value-of select="$holidaysBCToken.tokens[$pos]"/>
							</businessCenter>
						</xsl:for-each>
					</xsl:when>
					<xsl:otherwise>
						<xsl:call-template name="extract-paymentBusinessCenterNodes2">
							<xsl:with-param name="legNb" select="1"/>
							<xsl:with-param name="stream" select="1"/>
							<xsl:with-param name="businessCenterScheme" select="$swaption.exerciseDate.businessCenter.scheme"/>
						</xsl:call-template>
					</xsl:otherwise>
				</xsl:choose>
			</xsl:variable>		
			
			<xsl:variable name="swaption.exerciseDate.businessCenter.bdc">
				<xsl:choose>
					<xsl:when test="$use.default.exercise.calendar = 'true' and string-length(exsl:node-set($swaptionSettlementMatrix)//row[14]) &gt; 0 ">
						<xsl:value-of select="exsl:node-set($swaptionSettlementMatrix)//row[14]"/>
					</xsl:when>
					<xsl:otherwise>
						<xsl:value-of select="$swaption.exersice.streamSchedules.businessDayConvention"/>
					</xsl:otherwise>
				</xsl:choose>
			</xsl:variable>

			<xsl:call-template name="create-exercise-node">
				<xsl:with-param name="optionStyle" select="$optionStyle" />

				<xsl:with-param name="exercise.id">
					<xsl:choose>
						<xsl:when test="$optionStyle = 'european' and contains($settlementNature, 'cash')" >
							<xsl:value-of select="'exercisePeriod'"/>
						</xsl:when>
						<xsl:when test="$optionStyle != 'european' " >
							<xsl:value-of select="'swaptionExerciseDate'" />
						</xsl:when>
					</xsl:choose>
				</xsl:with-param> 
				<!-- commencementDate element if American -->
				<xsl:with-param name="commencementDate.unadjustedDate" select="$tradeDate" />
				<xsl:with-param name="commencementDate.dateAdjustments.businessDayConvention" select="$swapStream1.businessDayConvention" />
				<xsl:with-param name="commencementDate.dateAdjustments.businessCenter.nodes" select="$swapStream1.businessCenter.nodes" />
				<xsl:with-param name="commencementDate.dateAdjustments.businessCenter.businessCenterScheme" select="$businessCenterScheme" />
				<!-- bermudaExerciseDates -->
				<xsl:with-param name="bermudaExerciseDates.dateRelativeTo.href" select="'swapEffectiveDates'" />
				<xsl:with-param name="bermudaExerciseDates.period" select="$bermudaRelativeDatesPeriodUnit" />
				<xsl:with-param name="bermudaExerciseDates.periodMultiplier" select="$bermudaRelativeDatesPeriodMultiplier" />
				<xsl:with-param name="bermudaExerciseDates.dayType">
					<xsl:choose>
						<xsl:when test="$bermudaRelativeDatesPeriodUnit != 'D' " />
						<xsl:otherwise>
							<xsl:value-of select="$bermudaRelativeDatesDayType" />
						</xsl:otherwise>
					</xsl:choose>
				</xsl:with-param>
				<xsl:with-param name="bermudaExerciseDates.businessDayConvention">
					<xsl:choose>
						<xsl:when test="$bermudaRelativeDatesPeriodUnit = 'D' ">
							<xsl:value-of select="'NONE'" />
						</xsl:when>
						<xsl:otherwise>
							<xsl:value-of select="$bermudaRelativeDatesBDC" />
						</xsl:otherwise>
					</xsl:choose>
				</xsl:with-param>
				<xsl:with-param name="bermudaExerciseDates.businessCenter.nodes" select="$bermudaRelativeDatesBusinessCenterNodes" />
				<xsl:with-param name="bermudaExerciseDates.businessCenter.businessCenterScheme" select="$businessCenterScheme" />
				<!-- relevantUnderlyingDate -->
				<xsl:with-param name="relevantUnderlyingDate.id" select="'swapEffectiveDates'" />
				<xsl:with-param name="relevantUnderlyingDate.period" select="$relevantUnderlyingDate.period" />
				<xsl:with-param name="relevantUnderlyingDate.periodMultiplier" select="$relevantUnderlyingDate.periodMultiplier" />
				<xsl:with-param name="relevantUnderlyingDate.businessDayConvention" select="$relevantUnderlyingDate.businessDayConvention" />
				<xsl:with-param name="relevantUnderlyingDate.businessCenter.nodes" select="$relevantUnderlyingDate.businessCenterNodes" />
				<xsl:with-param name="relevantUnderlyingDate.businessCenter.businessCenterScheme" select="$businessCenterScheme" />
				<xsl:with-param name="relevantUnderlyingDate.dateRelativeTo.href" select="'swapEffectiveDates'" />
				<xsl:with-param name="relevantUnderlyingDate.scheduleBounds.unadjustedFirstDate" select="$relevantUnderlyingDate.scheduleBounds.unadjustedFirstDate" />
				<xsl:with-param name="relevantUnderlyingDate.scheduleBounds.unadjustedLastDate" select="$relevantUnderlyingDate.scheduleBounds.unadjustedLastDate" />
				<!-- expiration date element-->
				<xsl:with-param name="expirationDate.id" select="$expirationDate.id" />
				<xsl:with-param name="expirationDate.unadjustedDate" select="$expirationDate.unadjustedDate" />
				<xsl:with-param name="expirationDate.dateAdjustments.businessDayConvention" select="$swaption.exerciseDate.businessCenter.bdc" />
				<xsl:with-param name="expirationDate.dateAdjustments.businessCenter.nodes" select="$swaption.exerciseDate.businessCenter.nodes" />
				<xsl:with-param name="expirationDate.dateAdjustments.businessCenter.businessCenterScheme" select="$businessCenterScheme" />
				<xsl:with-param name="earliestExerciseTime.businessCenter.businessCenterScheme"  select="$earliestExerciseTime.businessCenter.businessCenterScheme" />
				<xsl:with-param name="earliestExerciseTime.hourMinuteTime" select="$swaption.earliestExerciseTime.hourMinuteTime" />
				<xsl:with-param name="earliestExerciseTime.businessCenter.name" select="$swaption.earliestExerciseTime.businessCenter.nodes" />
				<xsl:with-param name="expirationTime.businessCenter.businessCenterScheme"  select="$expirationTime.businessCenter.businessCenterScheme" />
				<xsl:with-param name="expirationTime.hourMinuteTime" select="$swaption.expirationTime.hourMinuteTime" />
				<xsl:with-param name="expirationTime.businessCenter.name" select="$swaption.expirationTime.businessCenter.nodes" />
				<xsl:with-param name="latestExerciseTime.businessCenter.businessCenterScheme" select="$latestExerciseTime.businessCenter.businessCenterScheme" />
				<xsl:with-param name="latestExerciseTime.hourMinuteTime" select="$swaption.latestExerciseTime.hourMinuteTime" />
				<xsl:with-param name="latestExerciseTime.businessCenter.name" select="$swaption.latestExerciseTime.businessCenter.nodes" />
				<xsl:with-param name="swapStream1.effectiveDate.businessDayConvention" select="$swapStream1.effectiveDate.businessDayConvention" />
				<xsl:with-param name="swapStream2.effectiveDate.businessDayConvention" select="$swapStream2.effectiveDate.businessDayConvention" />
				<xsl:with-param name="swapStream1.effectiveDate.dateAdjustments.businessCenter.nodes" select="$swapStream1.effectiveDate.dateAdjustments.businessCenter.nodes" />
			</xsl:call-template>
		</xsl:variable>
		<xsl:variable name="earlyTerminationProvision.nodes">
			<xsl:if test="$optionForm='optionToCancel' and ($bermudaExerciseDates.period != '' or $isMandatoryEarlyTermination='true' )">
				<xsl:call-template name="create-earlyTerminationProvision">
					<!-- earlyTerminationProvision -->
					<xsl:with-param name="optionForm" select="$optionForm" />
					<xsl:with-param name="bermudaExerciseDates.period"  select="$bermudaExerciseDates.period"/> 
					<xsl:with-param name="bermudaExerciseDates.periodMultiplier" select="$bermudaExerciseDates.periodMultiplier"/>
					<xsl:with-param name="bermudaExerciseDates.dayType" select="$bermudaExerciseDates.dayType"/>
					<xsl:with-param name="bermudaExerciseDates.businessDayConvention" select="$bermudaExerciseDates.businessDayConvention"/>
					<xsl:with-param name="bermudaExerciseDates.dateRelativeTo.href" select="$bermudaExerciseDates.dateRelativeTo.href"/>
					<xsl:with-param name="bermudaExerciseDates.dateRelativeTo" select="$bermudaExerciseDates.dateRelativeTo"/>
					<xsl:with-param name="bermudaExerciseDates.businessCenter"  select="$bermudaExerciseDates.businessCenter" />
					<xsl:with-param name="bermudaExerciseDates.businessCenter.nodes" select="$bermudaExerciseDates.businessCenter.nodes" />
					<xsl:with-param name="bermudaExerciseDates.businessCenter.businessCenterScheme"  select="$bermudaExerciseDates.businessCenter.businessCenterScheme" />
					<xsl:with-param name="followUpConfirmation" select="$followUpConfirmation" />

					<xsl:with-param name="earliestExerciseTime.hourMinuteTime"    select="$earliestExerciseTime.hourMinuteTime" />  
					<xsl:with-param name="earliestExerciseTime.businessCenter.name"  select="$earliestExerciseTime.businessCenter.name" />

					<xsl:with-param name="latestExerciseTime.hourMinuteTime" select="$latestExerciseTime.hourMinuteTime" />
					<xsl:with-param name="latestExerciseTime.businessCenter.name" select="$latestExerciseTime.businessCenter.name" />

					<xsl:with-param name="expirationTime.hourMinuteTime"   select="$expirationTime.hourMinuteTime" /> 
					<xsl:with-param name="expirationTime.businessCenter.name"        select="$expirationTime.businessCenter.name" />      
