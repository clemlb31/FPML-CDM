<xsl:stylesheet xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:str="http://exslt.org/strings" 
	xmlns="http://www.fpml.org/2007/FpML-4-3" 
	xmlns:exsl="http://exslt.org/common" 
	xmlns:mx="http://murex.com/xslt/common" 
	version="1.0" exclude-result-prefixes="mx exsl str">

	<xsl:import href="mx.xml2xml.transform.any2fpml.4-3.products.common.notificationMessageHeader" />
	<xsl:import href="mx.xml2xml.transform.any2fpml.4-3.products.common.tradeHeader" />
	<xsl:import href="mx.xml2xml.transform.any2fpml.4-3.products.ird.oswp.tradeNode" />
	<xsl:import href="mx.xml2xml.transform.any2fpml.4-3.products.ird.common.earlyTerminationProvision" />
	<xsl:import href="mx.generic.exslt.date.difference" />
	<xsl:import href="mx.xml2xml.transform.any2fpml.4-3.products.common.exercise" />
	<xsl:import href="mx.xml2xml.transform.any2fpml.4-3.products.common.americanExercise" />
	<xsl:import href="mx.xml2xml.transform.any2fpml.4-3.products.common.bermudaExercise" />
	<xsl:import href="mx.xml2xml.transform.any2fpml.4-3.products.common.europeanExercise" />
	<xsl:include href="mx.xml2xml.transform.mxml2fpml.4-3.products.ird.oswp.variables" />
	<xsl:include href="mx.xml2xml.transform.mxml2fpml.4-3.products.ird.variables" />
	<xsl:include href="mx.xml2xml.transform.mxml2fpml.4-3.products.variables" />	

	<!--Param User Defined Field Label For Internal Counterparty-->
	<xsl:param name="internalUdfLabel" select="''"/>
	
	<!-- ================================================= -->
	<!-- This template will generate a FpML message v 4.3  --> 
	<!-- of SWAPTION product                               -->  
	<!-- ================================================= --> 
	<xsl:template name="generate-fpml-ird-swaption">
		<xsl:param name="fpmlType" select="'RequestTradeConfirmation'" />
		<!--==========================-->  
		<!-- Mandatory mapping tables -->
		<!--==========================-->
		<xsl:param name="mapCounterparty" />
		<xsl:param name="mapOurPartyLabel" />
		<xsl:param name="mapBusinessCenter" />

		<xsl:param name="partyAlternateSystem" />
		<!-- mandatory parameters (refers to our tradeId) -->
		<xsl:param name="tradeId2" />
		<xsl:param name="tradeId2.scheme" />

		<!-- optional parameters -->
		<xsl:param name="swapStream1.id" select="$swapStream1.id" />
		<xsl:param name="swapStream2.id" select="$swapStream2.id" />
		<xsl:param name="messageId" />
		<xsl:param name="messageIdScheme" />
		<xsl:param name="sendBy.partyIdScheme" />
		<xsl:param name="sendTo.partyIdScheme" />
		<xsl:param name="tradeId1" />
		<xsl:param name="tradeId1.scheme" />
		<xsl:param name="mapScheduleLabel" />
		<xsl:param name="calculationAgentPartyReference.nodes" />
		<xsl:param name="tradeIdSupplement2" />
		<xsl:param name="tradeIdSupplement.tradeIdScheme2" />
		<!--==========================-->
		<!-- Optional parameters      -->
		<!--==========================-->
		<xsl:param name="additionalParties.nodes" />
		<xsl:param name="earliestExerciseTime.hourMinuteTime" />
		<xsl:param name="earliestExerciseTime.businessCenter.businessCenterScheme" select="'http://www.fpml.org/coding-scheme/business-center-6-4'" />
		<xsl:param name="expirationTime.hourMinuteTime" />
		<xsl:param name="expirationTime.businessCenter.businessCenterScheme" select="'http://www.fpml.org/coding-scheme/business-center-6-4'" />
		<xsl:param name="bermudaExercise.id" />
		<xsl:param name="initialValue" />
		<xsl:param name="swapStream1.businessCenter.businessCenterScheme" />
		<xsl:param name="swapStream1.notionalSchedule.id" />
		<xsl:param name="swapStream1.notionalSchedule.notionalStepSchedule.currency.currencyScheme" />
		<xsl:param name="swapStream1.floatingRateIndexScheme" />
		<xsl:param name="swapStream2.businessCenter.businessCenterScheme" />
		<xsl:param name="swapStream2.notionalSchedule.id" />
		<xsl:param name="swapStream2.notionalSchedule.notionalStepSchedule.currency.currencyScheme" />
		<xsl:param name="swapStream2.floatingRateIndexScheme" />
		<xsl:param name="exerciseProcedure.fallbackExercise" select="'false'" />
		<xsl:param name="exerciseProcedure.followUpConfirmation" select="'false'" />
		<xsl:param name="exerciseProcedure.autoExercize" select="'false'" />
		<xsl:param name="swapStream2.effectiveDate.dateAdjustments.businessCenter.id" />
		<xsl:param name="swapStream1.effectiveDate.dateAdjustments.businessCenter.id" />
		<xsl:param name="swapStream2.terminationDate.dateAdjustments.businessCenter.id" />
		<xsl:param name="swapStream1.terminationDate.dateAdjustments.businessCenter.id" />
		<xsl:param name="swapStream1.dayCountFraction.dayCountFractionScheme" />
		<xsl:param name="swapStream1.effectiveDate.businessDayConvention" select="''" />
		<xsl:param name="swapStream2.effectiveDate.businessDayConvention" select="''" />
		<xsl:param name="swapStream1.effectiveDate.dateAdjustments.businessCenter.nodes" select="$swapStream2.businessCenter.nodes" />
		<xsl:param name="swapStream1.effectiveDate.unadjustedDate" select="$swapStream1.effectiveDate.unadjustedDate" />
		<xsl:param name="swapStream1.effectiveDate.dateAdjustments.businessDayConvention" select="$swapStream1.effectiveDate.dateAdjustments.businessDayConvention" />
		<xsl:param name="swapStream2.effectiveDate.unadjustedDate" select="$swapStream2.effectiveDate.unadjustedDate" />
		<xsl:param name="swapStream2.effectiveDate.dateAdjustments.businessDayConvention" select="$swapStream2.effectiveDate.dateAdjustments.businessDayConvention" />
		<xsl:param name="swapStream1.fixingDates.businessDayConvention" select="$swapStream1.fixingDates.businessDayConvention" />
		<xsl:param name="swapStream2.fixingDates.businessDayConvention" select="$swapStream2.fixingDates.businessDayConvention" />
		<xsl:param name="swapStream1.resetDatesAdjustments.businessCenter.nodes" select="$swapStream1.businessCenter.nodes" />
		<xsl:param name="swapStream2.resetDatesAdjustments.businessCenter.nodes" select="$swapStream2.businessCenter.nodes" />
		<xsl:param name="stream1.spreadSchedule.nodes" select="$stream1.spreadSchedule.nodes" />
		<xsl:param name="stream2.spreadSchedule.nodes" select="$stream2.spreadSchedule.nodes" />
		<xsl:param name="calculationAgentParty" />
		<xsl:param name="swapStream1.businessDayConvention.overriding" />
		<xsl:param name="swapStream2.businessDayConvention.overriding" />
		<xsl:param name="swapStream1.payerPartyReference.href.overriding" />
		<xsl:param name="swapStream1.receiverPartyReference.href.overriding" />
		<xsl:param name="swapStream2.payerPartyReference.href.overriding" />
		<xsl:param name="swapStream2.receiverPartyReference.href.overriding" />
		<xsl:param name="swapStream1.fixingDates.dayType.overriding"/>
		<xsl:param name="swapStream2.fixingDates.dayType.overriding"/>
		<!-- Documentation -->
		<xsl:param name="masterAgreementDate" />
		<xsl:param name="contractualDefinitions" />
		<xsl:param name="contractualDefinitionsScheme" />
		<xsl:param name="party1.id" />
		<xsl:param name="party2.id" />
		<!-- Overriding used by MTM module to generate mtm parties -->
		<xsl:param name="party.partyId1.overriding" />
		<xsl:param name="party.partyId2.overriding" />
		<xsl:param name="party.partyIdScheme1" />
		<xsl:param name="party.partyIdScheme2" />

		<!-- Parameter used to change the direction of the deal -->
		<xsl:param name="reversePayReceive"/>

		<!-- Overriding used by MTM module to generate the tag initialFixingDate for IRS product without customizations-->
		<xsl:param name="swapStream1.initialFixingDate.periodMultiplier.overriding" />
		<xsl:param name="swapStream1.initialFixingDate.period.overriding" />
		<xsl:param name="swapStream1.initialFixingDate.dayType.overriding" />
		<xsl:param name="swapStream1.initialFixingDate.businessDayConvention.overriding" />
		<xsl:param name="swapStream1.initialFixingDate.businessCenter.nodes.overriding" />
		<xsl:param name="swapStream1.initialFixingDate.dateRelativeTo.href.overriding" />
		<xsl:param name="swapStream1.initialFixingDate.paymentCalendar.overriding" />
		<xsl:param name="swapStream2.initialFixingDate.periodMultiplier.overriding" />
		<xsl:param name="swapStream2.initialFixingDate.period.overriding" />
		<xsl:param name="swapStream2.initialFixingDate.dayType.overriding" />
		<xsl:param name="swapStream2.initialFixingDate.businessDayConvention.overriding" />
		<xsl:param name="swapStream2.initialFixingDate.businessCenter.nodes.overriding" />
		<xsl:param name="swapStream2.initialFixingDate.dateRelativeTo.href.overriding" />
		<xsl:param name="swapStream2.initialFixingDate.paymentCalendar.overriding" />

		<!-- relativeEffectiveDate required if american or bermudan swaption -->
		<xsl:param name="swapStream1.relativeEffectiveDate.id" />
		<xsl:param name="swapStream1.relativeEffectiveDate.period" />
		<xsl:param name="swapStream1.relativeEffectiveDate.periodMultiplier" />
		<xsl:param name="swapStream1.relativeEffectiveDate.dayType" />
		<xsl:param name="swapStream1.relativeEffectiveDate.businessDayConvention" />
		<xsl:param name="swapStream1.relativeEffectiveDate.dateRelativeTo.href" />
		<xsl:param name="swapStream2.relativeEffectiveDate.id" />
		<xsl:param name="swapStream2.relativeEffectiveDate.period" />
		<xsl:param name="swapStream2.relativeEffectiveDate.periodMultiplier" />
		<xsl:param name="swapStream2.relativeEffectiveDate.dayType" />
		<xsl:param name="swapStream2.relativeEffectiveDate.businessDayConvention" />
		<xsl:param name="swapStream2.relativeEffectiveDate.dateRelativeTo.href" />
		<!-- =================== -->
		<!-- cashSettlement Node -->
		<!-- =================== -->  
		<!-- businessCenterTime - create-businessCenterTime-cashSettlementValuationTime -->
		<xsl:param name="cashSettlement.hourMinuteTime" />
		<xsl:param name="cashSettlement.businessCenter.name" />
		<xsl:param name="cashSettlement.cashSettlementValuationDate.period" />
		<xsl:param name="cashSettlement.cashSettlementValuationDate.periodMultiplier" />
		<xsl:param name="cashSettlement.cashSettlementValuationDate.dayType" />
		<xsl:param name="cashSettlement.businessDayConvention" />
		<xsl:param name="cashSettlement.cashSettlementValuationDate.businessCenter.nodes" />
		<xsl:param name="cashSettlement.cashSettlementValuationDate.businessCenter" />
		<xsl:param name="cashSettlement.cashSettlementValuationDate.businessCenter.id" />
		<xsl:param name="cashSettlement.cashSettlementValuationDate.businessCenter.businessCenterScheme" />
		<xsl:param name="cashSettlement.cashSettlementValuationDate.dateRelativeTo.href" />
		<xsl:param name="cashSettlement.cashSettlementValuationDate.dateRelativeTo" />
		<!-- cashSettlementPaymentDate - create-cashSettlementPaymentDate-->
		<xsl:param name="cashSettlement.cashSettlementPaymentDate.period" />
		<xsl:param name="cashSettlement.cashSettlementPaymentDate.periodMultiplier" />
		<xsl:param name="cashSettlement.cashSettlementPaymentDate.dayType" />
		<xsl:param name="cashSettlement.relativeDate.businessDayConvention" />
		<xsl:param name="cashSettlement.cashSettlementPaymentDate.dateRelativeTo.href" />
		<xsl:param name="cashSettlement.cashSettlementPaymentDate.dateRelativeTo" />
		<xsl:param name="cashSettlement.cashSettlementPaymentDate.businessCenter.nodes" />
		<xsl:param name="cashSettlement.cashSettlementPaymentDate.businessCenter" />
		<xsl:param name="cashSettlement.cashSettlementPaymentDate.businessCenter.id" />
		<xsl:param name="cashSettlement.cashSettlementPaymentDate.businessCenter.businessCenterScheme" />
		<!-- yieldCurveMethod - parYieldCurveUnadjustedMethod -->
		<xsl:param name="cashSettlement.parYieldCurveUnadjustedMethod.rateSource" />
		<xsl:param name="cashSettlement.parYieldCurveUnadjustedMethod.quotationRateType" />
		<xsl:param name="cashSettlementISDA2021.nodes"/>												  

		<!-- ============================== -->
		<!-- earlyTerminationProvision node -->
		<!-- ============================== -->
		<xsl:param name="earliestExerciseTime.hourMinuteTime" />  
		<xsl:param name="earliestExerciseTime.businessCenter.name" />

		<xsl:param name="latestExerciseTime.hourMinuteTime" />
		<xsl:param name="latestExerciseTime.businessCenter.name" />
		<xsl:param name="latestExerciseTime.businessCenter.businessCenterScheme" />

		<xsl:param name="expirationTime.hourMinuteTime" /> 
		<xsl:param name="expirationTime.businessCenter.name" />   

		<xsl:param name="expirationDate.id" />      
		<xsl:param name="premium.adjustedPaymentDate" />
		<xsl:param name="additionalPayment.nodes" />
		<xsl:param name="additionalParties.nodes" />

		<xsl:param name="earlyTerminationProvision.calculationAgentParty" />
		<xsl:param name="earlyTerminationProvision.calculationAgentParty.nodes" />

		<xsl:param name="earlyTerminationProvision.hourMinuteTime" />
		<xsl:param name="earlyTerminationProvision.businessCenter.name" /> 

		<xsl:param name="earlyTerminationProvision.cashSettlementValuationDate.businessCenter.businessCenterScheme" />

		<xsl:param name="earlyTerminationProvision.zeroCouponYieldAdjustedMethod.rateSource"/>
		<xsl:param name="earlyTerminationProvision.zeroCouponYieldAdjustedMethod.rateSourcePage"/>
		<xsl:param name="earlyTerminationProvision.zeroCouponYieldAdjustedMethod.quotationRateType"/>
		<xsl:param name="earlyTerminationProvision.zeroCouponYieldAdjustedMethod.referenceBank.node"/>

		<xsl:param name="earlyTerminationProvision.cashPriceMethod.currency"/>
		<xsl:param name="earlyTerminationProvision.cashPriceMethod.quotationRateType"/>
		<xsl:param name="earlyTerminationProvision.cashPriceMethod.referenceBank.node"/>

		<xsl:param name="earlyTerminationProvision.cashPriceAlternateMethod.currency"/>
		<xsl:param name="earlyTerminationProvision.cashPriceAlternateMethod.quotationRateType"/>
		<xsl:param name="earlyTerminationProvision.cashPriceAlternateMethod.referenceBank.node"/>

		<!--overriding used by Markitwire for stub nodes -->
		<xsl:param name="swapStream1.initialStub.nodes.overriding" />
		<xsl:param name="swapStream1.finalStub.nodes.overriding" />
		<xsl:param name="swapStream2.initialStub.nodes.overriding" />
		<xsl:param name="swapStream2.finalStub.nodes.overriding" />
		<xsl:param name="swapStream1.stubCalculationPeriodAmount.calculationPeriodDatesReference.href.overriding"/>
		<xsl:param name="swapStream2.stubCalculationPeriodAmount.calculationPeriodDatesReference.href.overriding"/>
		<!-- ============================== -->
		<xsl:param name="collateral.nodes" />
		<xsl:param name="contractualDefinitions.nodes" />
		<xsl:param name="use.default.exercise.calendar" select="''"/>
		<xsl:param name="swaption.exerciseDate.businessCenter.scheme" select="'http://www.fpml.org/coding-scheme/business-center-6-4'" />
		
		<xsl:param name="swapStream1.notionalSchedule.notionalStepSchedule.initialValue.overriding"/>
		<xsl:param name="swapStream2.notionalSchedule.notionalStepSchedule.initialValue.overriding"/>
		
		<FpML xmlns:dsig="http://www.w3.org/2000/09/xmldsig#" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:fpml="http://www.fpml.org/2007/FpML-4-3" xsi:schemaLocation="http://www.fpml.org/2007/FpML-4-3                                           /xmls/OTC/fpml-main-4-3.xsd                                                               http://www.w3.org/2000/09/xmldsig#                                                               /xmls/OTC/xmldsig-core-schema.xsd" xsi:type="{$fpmlType}" version="4-3">
			<xsl:variable name="entity" select="/MxML/trades/trade[(not(tradeHeader/tradeUserDefinedFields/userDefinedField[fieldLabel=$internalUdfLabel]/fieldValue=&quot;true&quot;) and not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeHeader/tradeViews/tradeView/entity" />
			<xsl:variable name="legalEntity" select="/MxML/trades/trade[(not(tradeHeader/tradeUserDefinedFields/userDefinedField[fieldLabel=$internalUdfLabel]/fieldValue=&quot;true&quot;) and not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeHeader/tradeViews/tradeView/legalEntity" />
			<xsl:variable name="paramCtpLabel" select="concat('partyLabel:', $ctpName)" />
			<xsl:variable name="paramOurLabel" select="concat('partyLabel:', $ourName,',userName:',$ourUserName, ',entity:', $entity, ',legalEntity:', $legalEntity)" />

			<!-- counterparty identifier-->
			<xsl:variable name="party.partyId1">
				<xsl:variable name="ctpAltIdFromDisplayLabel">
					<xsl:if test="string-length($partyAlternateSystem)&gt;0">
						<xsl:value-of select="mx:execute-formula('mx.xml2xml.ECN.common.sql.ctpAltIdFromDisplayLabel',concat('displayLabel:',$ctpName,',altSys:',$partyAlternateSystem))" />
					</xsl:if>
				</xsl:variable>
				<xsl:choose>
					<xsl:when test="string-length($party.partyId1.overriding)&gt;0">
						<xsl:value-of select="$party.partyId1.overriding" />
					</xsl:when>
					<xsl:when test="string-length($ctpAltIdFromDisplayLabel)&gt;0">
						<xsl:value-of select="$ctpAltIdFromDisplayLabel" />
					</xsl:when>
					<xsl:otherwise>
						<xsl:value-of select="mx:execute-formula($mapCounterparty, $paramCtpLabel)" />
					</xsl:otherwise>
				</xsl:choose>
			</xsl:variable>
			<xsl:call-template name="AssertNotMapped">
				<xsl:with-param name="value" select="$party.partyId1" />
				<xsl:with-param name="message" select="concat('Party ', $ctpName,' not mapped')" />
				<xsl:with-param name="formula" select="$mapCounterparty" />
			</xsl:call-template>

			<xsl:variable name="party.partyName1">
				<xsl:choose>
					<xsl:when test="string-length($party.partyId1.overriding) &gt; 0">
						<xsl:value-of select="$party.partyId1.overriding" />
					</xsl:when>
					<xsl:otherwise>
						<xsl:value-of select="$party.partyId1" />
					</xsl:otherwise>
				</xsl:choose>
			</xsl:variable>
			<xsl:variable name="party.id1">
				<xsl:choose>
					<xsl:when test="string-length($party1.id) &gt; 0">
						<xsl:value-of select="$party1.id" />
					</xsl:when>
					<xsl:otherwise>
						<xsl:choose>
							<xsl:when test="string-length($party.partyId1.overriding) &gt; 0">
								<xsl:value-of select="$party.partyId1.overriding" />
							</xsl:when>
							<xsl:otherwise>
								<xsl:value-of select="$party.partyId1" />
							</xsl:otherwise>
						</xsl:choose>
					</xsl:otherwise>
				</xsl:choose>
			</xsl:variable>
			<!-- our party identifier-->
			<xsl:variable name="party.partyId2">
				<xsl:variable name="ctpAltIdFromDisplayLabel">
					<xsl:if test="string-length($partyAlternateSystem)&gt;0">
						<xsl:value-of select="mx:execute-formula('mx.xml2xml.ECN.common.sql.ctpAltIdFromDisplayLabel',concat('displayLabel:',$ourName,',altSys:',$partyAlternateSystem))" />
					</xsl:if>
				</xsl:variable>
				<xsl:choose>
					<xsl:when test="string-length($party.partyId2.overriding)&gt;0">
						<xsl:value-of select="$party.partyId2.overriding" />
					</xsl:when>
					<xsl:when test="string-length($ctpAltIdFromDisplayLabel)&gt;0">
						<xsl:value-of select="$ctpAltIdFromDisplayLabel" />
					</xsl:when>
					<xsl:otherwise>
						<xsl:value-of select="mx:execute-formula($mapCounterparty, $paramOurLabel)" />
					</xsl:otherwise>
				</xsl:choose>
			</xsl:variable>
			<xsl:call-template name="AssertNotMapped">
				<xsl:with-param name="value" select="$party.partyId1" />
				<xsl:with-param name="message" select="concat('Party ', $ourName,' not mapped')" />
				<xsl:with-param name="formula" select="$mapCounterparty" />
			</xsl:call-template>

			<xsl:variable name="party.partyName2">
				<xsl:choose>
					<xsl:when test="string-length($party.partyId2.overriding) &gt; 0">
						<xsl:value-of select="$party.partyId2.overriding" />
					</xsl:when>
					<xsl:otherwise>
						<xsl:value-of select="$party.partyId2" />
					</xsl:otherwise>
				</xsl:choose>
			</xsl:variable>
			<xsl:variable name="party.id2">
				<xsl:choose>
					<xsl:when test="string-length($party2.id) &gt; 0">
						<xsl:value-of select="$party2.id" />
					</xsl:when>
					<xsl:otherwise>
						<xsl:choose>
							<xsl:when test="string-length($party.partyId2.overriding) &gt; 0">
								<xsl:value-of select="$party.partyId2.overriding" />
							</xsl:when>
							<xsl:otherwise>
								<xsl:value-of select="$party.partyId2" />
							</xsl:otherwise>
						</xsl:choose>
					</xsl:otherwise>
				</xsl:choose>
			</xsl:variable>

			<!-- specific novation -->
			<xsl:variable name="paramPartyNameEvent" select="concat('partyLabel:', $partyNameEvent)" />
			<xsl:variable name="party.partyNameEventId" select="$partyNameEventId" />
			<xsl:variable name="party.partyNameEvent">
				<xsl:if test="string-length($partyNameEventId) &gt; 0">
					<xsl:value-of select="mx:execute-formula($mapCounterparty, $paramPartyNameEvent)" />
				</xsl:if>
			</xsl:variable>
			<xsl:if test="string-length($partyNameEventId) &gt; 0">
				<xsl:call-template name="AssertNotMapped">
					<xsl:with-param name="value" select="$party.partyNameEvent" />
					<xsl:with-param name="message" select="concat('Party ', $partyNameEvent,' not mapped')" />
					<xsl:with-param name="formula" select="$mapCounterparty" />
				</xsl:call-template>
			</xsl:if>

			<!-- specific novation -->
			<xsl:variable name="paramPartyNameEvent" select="concat('partyLabel:', $partyNameEvent)" />
			<xsl:variable name="party.partyNameEventId" select="$partyNameEventId" />
			<xsl:variable name="party.partyNameEvent">
				<xsl:if test="string-length($partyNameEventId) &gt; 0">
					<xsl:value-of select="mx:execute-formula($mapCounterparty, $paramPartyNameEvent)" />
				</xsl:if>
			</xsl:variable>
			<xsl:if test="string-length($partyNameEventId) &gt; 0">
				<xsl:call-template name="AssertNotMapped">
					<xsl:with-param name="value" select="$party.partyNameEvent" />
					<xsl:with-param name="message" select="concat('Party ', $partyNameEvent,' not mapped')" />
					<xsl:with-param name="formula" select="$mapCounterparty" />
				</xsl:call-template>
			</xsl:if>
			<!-- ================================================================== -->

			<xsl:if test="string-length($messageId) or string-length($messageIdScheme)&gt;0">
				<xsl:call-template name="create-notificationMessageHeader">
					<xsl:with-param name="messageId" select="$messageId" />
					<xsl:with-param name="messageIdScheme" select="$messageIdScheme" />
					<xsl:with-param name="sentBy" select="$party.partyName2" />
					<xsl:with-param name="sendTo" select="$party.partyName1" />
					<xsl:with-param name="sentBy.partyIdScheme" select="$sendBy.partyIdScheme" />
					<xsl:with-param name="sendTo.partyIdScheme" select="$sendTo.partyIdScheme" />
					<xsl:with-param name="creationTimestamp" select="$creationTimestamp" />
				</xsl:call-template>
			</xsl:if>

			<xsl:call-template name="generate-fpml-ird-swaption-trade">
				<xsl:with-param name="additionalParties.nodes" select="$additionalParties.nodes" />
				<xsl:with-param name="tradeIdSupplement2" select="$tradeIdSupplement2" />
				<xsl:with-param name="tradeIdSupplement.tradeIdScheme2" select="$tradeIdSupplement.tradeIdScheme2" />
