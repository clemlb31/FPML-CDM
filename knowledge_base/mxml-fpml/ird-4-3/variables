						<xsl:choose>
							<xsl:when test="string-length(normalize-space($notificationEffectiveShifterPeriod.tmp)) &gt; 0 and string-length(normalize-space($notificationEffectiveShifterPeriodUnit.tmp)) &gt; 0">
								<xsl:call-template name="AssertNotMapped">
									<xsl:with-param name="value" select="$notificationEffectiveShifterPeriod.tmp"/>
									<xsl:with-param name="message" select="concat('Period Unit ','X',$notificationEffectiveShifterPeriod.tmp,'X', $notificationEffectiveShifterPeriodUnit, ' not mapped')"/>
