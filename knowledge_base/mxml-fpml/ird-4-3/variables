						<xsl:variable name="notificationEffectiveShifterPeriodUnit.tmp">
							<xsl:value-of select="mx:execute-formula($mapPeriodUnit, concat('periodUnit:',$notificationEffectiveShifterPeriodUnit))//row[2]"/>
