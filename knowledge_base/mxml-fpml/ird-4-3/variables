	<!-- ================================================================== -->
	<xsl:variable name="mapCompounding" select="'public.xml2xml.mapping.mxml2fpml.bmfcompounding'"/>
	<!-- swapStream1.compoundingMethod -->
	<xsl:variable name="swapStream1.compoundingFormula">
