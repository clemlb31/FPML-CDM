		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="swapStream1.fixingDates.periodMultiplier">
		<xsl:choose>
			<xsl:when test="$swapStream1.indexFormula.indexFormulaType = 'compounding'">
				<xsl:choose>
					<xsl:when test="string-length($swapStream1.compoundedIndex.periodMultiplier) &gt; 0">
						<xsl:value-of select="$swapStream1.compoundedIndex.periodMultiplier"/>
					</xsl:when>
					<xsl:otherwise>
						<xsl:value-of select="'0'"/>
					</xsl:otherwise>
				</xsl:choose>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="$leg1.reset.shifter.periodMultiplier"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>
	<xsl:variable name="leg1.fixingDates.businessDayConvention">
		<xsl:choose>
			<!-- We assume that the drivingScheule is the Calculation schedule -->
			<xsl:when test="$leg1.reset.scheduleNature = 'equalTo'">
				<xsl:value-of select="$leg1.calculation.businessDayConvention"/>
			</xsl:when>
			<xsl:when test="$leg1.reset.scheduleNature = 'deducedFrom' and string-length($leg1.resetSchedule.businessDayConvention) = 0">
				<xsl:value-of select="$leg1.calculation.businessDayConvention"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="$leg1.resetSchedule.businessDayConvention"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>
	<xsl:variable name="swapStream1.paramMFixingDatesBusinessDayConvention" select="concat('interface:', $interface, ',businessDayConvention:', $leg1.fixingDates.businessDayConvention)"/>
	<xsl:variable name="swapStream1.fixingDates.dayType">
		<xsl:choose>
			<xsl:when test="$swapStream1.indexFormula.indexFormulaType = 'compounding' and string-length($swapStream1.fixingDates.periodMultiplier) &gt; 0">
				<!-- value is hardcoded because in the current time it is alwasys Business in Markitwire -->
				<xsl:value-of select="'Business'"/>
			</xsl:when>
			<xsl:when test="$swapStream1.fixingDates.periodMultiplier = '0' and ($swapStream1.fixingDates.period = 'D' or string-length($swapStream1.fixingDates.period) = 0)">
			</xsl:when>
			<xsl:otherwise>
				<xsl:variable name="swapStream1.fixingDates.dayType.tmp">
					<xsl:value-of select="mx:execute-formula($mapPeriodUnit, $swapStream1.paramFixingPeriodUnit)//row[2]"/>
				</xsl:variable>
				<xsl:call-template name="AssertNotMapped">
					<xsl:with-param name="value" select="$swapStream1.fixingDates.dayType.tmp"/>
					<xsl:with-param name="message" select="concat('dayType ', $swapStream1.paramFixingPeriodUnit, ' not mapped')"/>
					<xsl:with-param name="formula" select="$mapPeriodUnit"/>
				</xsl:call-template>
				<xsl:value-of select="$swapStream1.fixingDates.dayType.tmp"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>
	<xsl:variable name="swapStream1.fixingDates.businessDayConvention">
		<xsl:choose>
			<xsl:when test="$swapStream1.fixingDates.periodMultiplier = '0' and ($swapStream1.fixingDates.period = 'D' or string-length($swapStream1.fixingDates.period) = 0)">
				<xsl:value-of select="'PRECEDING'"/>
			</xsl:when>
			<xsl:when test="string-length($leg1.fixingDates.businessDayConvention) &gt; 0 and $swapStream1.fixingDates.dayType != 'Business'">
				<xsl:value-of select="mx:execute-formula($mapBusinessDayConv, $swapStream1.paramMFixingDatesBusinessDayConvention)"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="'NONE'"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>
	<xsl:variable name="swapStream1.fixingDates.dateRelativeTo.href" select="$leg1.resetDate.id"/>
	<xsl:variable name="swapStream1.paramResetFrequencyPeriodUnit" select="concat('interface:', $interface, ',periodUnit:', $leg1.reset.periodUnit)"/>
	<xsl:variable name="swapStream1.resetFrequency.periodMultiplier">
		<xsl:value-of select="$leg1.reset.periodMultiplier"/>
	</xsl:variable>
	<xsl:variable name="swapStream1.paramResetDatesAdjustmentsBusinessDayConvention" select="concat('interface:', $interface, ',businessDayConvention:', $leg1.reset.businessDayConvention)"/>
	<xsl:variable name="eventName">
		<xsl:value-of select="name(/MxML/contractEvents/contractEvent/contractEventBody/*[1])"/>
	</xsl:variable>
	<xsl:variable name="swapStream1.notionalSchedule.notionalStepSchedule.pastInitialValue">
		<xsl:if test="$eventName='stepOut'">
			<xsl:value-of select="format-number(/MxML/trades/trade[(not(tradeHeader/tradeUserDefinedFields/userDefinedField[fieldLabel=$internalUdfLabel]/fieldValue=&quot;true&quot;) and not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeBody/*/stream/capital/initialCapitalAmount,'##.##') "/>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="swapStream1.notionalSchedule.notionalStepSchedule.initialValue">
		<xsl:choose>
			<xsl:when test="string-length($swapStream1.notionalSchedule.notionalStepSchedule.pastInitialValue) &gt; 0">
				<xsl:value-of select="format-number($swapStream1.notionalSchedule.notionalStepSchedule.pastInitialValue, '##.##')"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:variable name="swapStream1.notionalSchedule.notionalStepSchedule.initialValue.tmp">
					<xsl:call-template name="extract-floatRate">
						<xsl:with-param name="legNb" select="1"/>
						<xsl:with-param name="stream" select="1"/>
					</xsl:call-template>
				</xsl:variable>
				<xsl:if test="string-length($swapStream1.notionalSchedule.notionalStepSchedule.initialValue.tmp) &gt; 0 and $swapStream1.notionalSchedule.notionalStepSchedule.initialValue.tmp &gt; 0">
					<xsl:value-of select="format-number($swapStream1.notionalSchedule.notionalStepSchedule.initialValue.tmp, '##.##')"/>
				</xsl:if>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>
	<xsl:variable name="swapStream1.notionalSchedule.notionalStepSchedule.currency">
		<xsl:call-template name="extract-initialCapitalCurrency">
			<xsl:with-param name="legNb" select="number($tradePos)"/>
			<xsl:with-param name="stream" select="1"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="swapStream1.paramDayCountFraction" select="concat('interface:', $interface, ',rateConventionLabel:', $leg1.rateConventionLabel)"/>
	<xsl:variable name="swapStream1.dayCountFraction.dayCountFractionScheme" select="'http://www.fpml.org/coding-scheme/day-count-fraction-2-1'"/>
