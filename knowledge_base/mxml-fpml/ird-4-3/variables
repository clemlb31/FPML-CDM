<xsl:stylesheet xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:str="http://exslt.org/strings" xmlns:exsl="http://exslt.org/common" xmlns="http://www.fpml.org/2007/FpML-4-3" xmlns:mx="http://murex.com/xslt/common" xmlns:date="http://exslt.org/dates-and-times" xmlns:exslt="http://exslt.org/common" exclude-result-prefixes="mx exslt date str" version="1.0">
	<xsl:import href="mx.xml2xml.extract.mxml.products.ird.swap.templates"/>
	<xsl:import href="mx.xml2xml.extract.mxml.products.ird.templates"/>
	<xsl:import href="mx.xml2xml.transform.mxml2fpml.4-3.products.common.common"/>
	<xsl:import href="mx.xml2xml.transform.any2fpml.4-3.products.common.partyTradeIdentifier"/>
	<xsl:import href="mx.xml2xml.transform.any2fpml.4-3.products.common.spreadSchedule"/>
	<xsl:import href="mx.generic.exslt.date.difference"/>
	<xsl:import href="mx.generic.exslt.date.day-name"/>
	<xsl:import href="mx.generic.exslt.date.add"/>
	<xsl:import href="mx.generic.exslt.str.tokenize"/>
	<xsl:import href="mx.generic.errorHandling.assert"/>
	<xsl:import href="mx.generic.errorHandling.paramsToString"/>
	<xsl:import href="mx.xml2xml.transform.any2fpml.4-3.products.common.party"/>
	<xsl:import href="mx.xml2xml.transform.mxml2fpml.utils.schedule"/>
	<xsl:include href="mx.xml2xml.transform.mxml2fpml.4-3.products.variables"/>
	<xsl:include href="mx.xml2xml.transform.mxml2fpml.4-3.products.ird.common.documentation"/>
	<xsl:include href="mx.xml2xml.transform.mxml2fpml.4-3.products.ird.common.index"/>
	<xsl:include href="mx.xml2xml.transform.mxml2fpml.4-3.products.ird.common.stub"/>
	<xsl:param name="execContextMW"/>
	<xsl:param name="initFixingPM1"/>
	<xsl:param name="initFixingPM2"/>
	<xsl:param name="extended.numeric.format"/>
	<xsl:param name="messageType"/>
	<!--Param User Defined Field Label For Internal Counterparty-->
	<xsl:param name="internalUdfLabel" select="''"/>
	<xsl:variable name="tradeIdScheme1" select="'TradeRefNbr'"/>
	<xsl:variable name="FpMLDateFormula" select="'mx.xml2xml.ECN.common.utils.adaptDate'"/>
	<xsl:variable name="upper.case" select="'ABCDEFGHIJKLMNOPQRSTUVWXYZ'"/>
	<xsl:variable name="lower.case" select="'abcdefghijklmnopqrstuvwxyz'"/>
	<!-- ==================================================== -->
	<!-- Global variables - Can be defined at interface level -->
	<xsl:variable name="mapBusinessDayConv" select="'public.xml2xml.mapping.mxml2fpml.common.businessDayConvention'"/>
	<xsl:variable name="mapDayCountBasis" select="'public.xml2xml.mapping.mxml2fpml.common.dayCountBasis'"/>
	<xsl:variable name="mapPeriodUnit" select="'public.xml2xml.mapping.mxml2fpml.common.periodUnit'"/>
	<xsl:variable name="mapShifterLabel" select="'public.xml2xml.mapping.mxml2fpml.common.shifterLabel'"/>
	<xsl:variable name="mapIndex" select="'public.xml2xml.mapping.mxml2fpml.ird.index'"/>
	<xsl:variable name="mapFrequency" select="'mx.xml2xml.transform.mxml2fpml.mapping.frequency'"/>
	<xsl:variable name="mapToFpMLDate" select="'mx.xml2xml.transform.mxml2fpml.utils.toFpMLDate'"/>
	<xsl:variable name="mapBusinessCenter"/>
	<xsl:variable name="udfPostProcessingFormula"/>
	<!-- Master Agreement - FpML documentation -->
	<xsl:variable name="MAmethod"/>
	<xsl:variable name="mapMasterAgreement"/>
	<xsl:variable name="mapUdfLabel"/>
	<xsl:variable name="mapReferenceBank"/>
	<xsl:variable name="mapInformationSource"/>
	<xsl:variable name="mapMaConfirmationType"/>
	<xsl:variable name="masterAgreementTypeScheme" select="'http://www.fpml.org/coding-scheme/master-agreement-type-1-0'"/>
	<xsl:variable name="isFixedAmount"/>
	<xsl:variable name="numeric.format" select="'##.########'"/>
	<xsl:variable name="numeric.format.10dp" select="'##.##########'"/>
	<xsl:variable name="numeric.format.12dp" select="'##.############'"/>
	<xsl:variable name="swapStream1.effectiveDate.dateAdjustments.businessDayConvention.overriding"/>
	<xsl:variable name="swapStream2.effectiveDate.dateAdjustments.businessDayConvention.overriding"/>
	<xsl:variable name="swapStream1.businessDayConvention.overriding"/>
	<xsl:variable name="swapStream2.businessDayConvention.overriding"/>
	<xsl:variable name="swapStream1.initialFixingDate.periodMultiplier.overriding"/>
	<xsl:variable name="swapStream2.initialFixingDate.periodMultiplier.overriding"/>
	<xsl:variable name="contractualDefinitions.overriding"/>
	<!--weekly Roll Convention -->
	<xsl:variable name="swapStream1.resetFrequency.weeklyRollConvention">
		<xsl:variable name="weeklyRollDay1">
			<xsl:call-template name="extract-averageUnderlyingIndex-adjustmentSubPeriod-weekDay">
				<xsl:with-param name="stream" select="'1'"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:value-of select="translate(substring($weeklyRollDay1,1,3), $lower.case, $upper.case)"/>
	</xsl:variable>
	<xsl:variable name="swapStream2.resetFrequency.weeklyRollConvention">
		<xsl:variable name="weeklyRollDay2">
			<xsl:call-template name="extract-averageUnderlyingIndex-adjustmentSubPeriod-weekDay">
				<xsl:with-param name="stream" select="'2'"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:value-of select="translate(substring($weeklyRollDay2,1,3), $lower.case, $upper.case)"/>
	</xsl:variable>
	<!-- End of Global variables -->
	<!-- ==================================================== -->
	<!-- businessCenterScheme-->
	<xsl:variable name="businessCenterScheme" select="'http://www.fpml.org/coding-scheme/business-center-6-4'"/>
	<!--floatingRateIndexScheme-->
	<xsl:variable name="floatingRateIndexScheme" select="'http://www.fpml.org/coding-scheme/floating-rate-index-2-0'"/>
	<!--dayCountFractionScheme-->
	<xsl:variable name="dayCountFractionScheme" select="'http://www.fpml.org/coding-scheme/day-count-fraction-2-1'"/>
	<!--currencyScheme-->
	<xsl:variable name="currencyScheme" select="'http://www.fpml.org/ext/iso4217'"/>
	<xsl:variable name="settlementPayOrReceive">
		<xsl:call-template name="extract-settlementSign">
			<xsl:with-param name="legNb" select="1"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="creationTimestamp" select="mx:execute-formula('mx.xml2xml.transform.mxml2fpml.4-3.products.common.time.releaseTime')"/>
	<!-- ============================================================================= -->
	<!-- EXTRACT FROM MXML -->
	<!-- ============================================================================= -->
	<xsl:variable name="tradeDate">
		<xsl:variable name="tradeDateMx">
			<xsl:call-template name="extract-tradeDate">
				<xsl:with-param name="legNb" select="number($tradePos)"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:value-of select="mx:execute-formula('mx.xml2xml.ECN.common.utils.adaptDate', concat('date:', $tradeDateMx, ',format:yyyymmdd,outputFormat:yyyy-mm-dd'))"/>
	</xsl:variable>
	<xsl:variable name="tradeIdOld1">
		<xsl:call-template name="extract-tradeID">
			<xsl:with-param name="legNb" select="1"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="tradeIdOld2">
		<xsl:call-template name="extract-tradeID">
			<xsl:with-param name="legNb" select="2"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="tradeId.scheme" select="'TradeRefNbr'"/>
	<!-- Trade typology specific for each leg -->
	<!-- An OIS deal can be fixed/floating or floating/floating -->
	<xsl:variable name="leg1.payoutType">
		<xsl:call-template name="extract-streamPayoutType">
			<xsl:with-param name="legNb" select="number($tradePos)"/>
			<xsl:with-param name="stream" select="1"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="leg2.payoutType">
		<xsl:call-template name="extract-streamPayoutType">
			<xsl:with-param name="legNb" select="number($tradePos)"/>
			<xsl:with-param name="stream" select="2"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="swapStream1.singlePeriod">
		<xsl:call-template name="extract-singlePeriod">
			<xsl:with-param name="legNb" select="1"/>
			<xsl:with-param name="stream" select="1"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="swapStream2.singlePeriod">
		<xsl:call-template name="extract-singlePeriod">
			<xsl:with-param name="legNb" select="1"/>
			<xsl:with-param name="stream" select="2"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="swapStream1.singlePeriod.startDateAdjustment">
		<xsl:call-template name="extract-streamSchedules-adjustStartDate">
			<xsl:with-param name="legNb" select="1"/>
			<xsl:with-param name="stream" select="1"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="swapStream2.singlePeriod.startDateAdjustment">
		<xsl:call-template name="extract-streamSchedules-adjustStartDate">
			<xsl:with-param name="legNb" select="1"/>
			<xsl:with-param name="stream" select="2"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="usage">
		<xsl:call-template name="extract-usage"/>
	</xsl:variable>
	<xsl:variable name="leg1.typology">
		<xsl:choose>
			<xsl:when test="contains($typology , 'OIS') and $leg2.payoutType = 'floatingRate' and $leg1.payoutType = 'floatingRate' and /MxML/trades/trade[(not(tradeHeader/tradeUserDefinedFields/userDefinedField[fieldLabel=$internalUdfLabel]/fieldValue=&quot;true&quot;) and not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeBody/*/stream[2]/streamTemplate/floatingRateStreamTemplate/index/indexFormula/indexFormulaType = 'compounding'">
				<xsl:value-of select="'OIS_IRS'"/>
			</xsl:when>
			<!-- Basis Swap -->
			<xsl:when test="$tradeGroup = 'IRS' and $leg2.payoutType = 'floatingRate' and $leg1.payoutType = 'floatingRate'">
				<xsl:value-of select="'BS_IRS'"/>
			</xsl:when>
			<!-- ZC Swap, zeroCouponMode=true -->
			<xsl:when test="$tradeGroup = 'IRS' and $leg1.payoutType = 'floatingRate' and $swapStream1.paymentSchedule.zeroCouponMode = 'true'">
				<xsl:value-of select="'ZC_IRS'"/>
			</xsl:when>
			<!-- ZC Swap, singlePeriod=true -->
			<xsl:when test="$tradeGroup = 'IRS' and $leg1.payoutType = 'floatingRate' and $swapStream1.singlePeriod = 'true'">
				<xsl:value-of select="'ZC_IRS'"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="$typology"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>
	<xsl:variable name="leg2.typology">
		<xsl:choose>
			<xsl:when test="contains($typology , 'OIS') and $leg2.payoutType = 'floatingRate' and $leg1.payoutType = 'floatingRate' and /MxML/trades/trade[(not(tradeHeader/tradeUserDefinedFields/userDefinedField[fieldLabel=$internalUdfLabel]/fieldValue=&quot;true&quot;) and not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeBody/*/stream[1]/streamTemplate/floatingRateStreamTemplate/index/indexFormula/indexFormulaType = 'compounding'">
				<xsl:value-of select="'OIS_IRS'"/>
			</xsl:when>
			<!-- Basis Swap -->
			<xsl:when test="$tradeGroup = 'IRS' and $leg2.payoutType = 'floatingRate' and $leg1.payoutType = 'floatingRate'">
				<xsl:value-of select="'BS_IRS'"/>
			</xsl:when>
			<!-- ZC Swap, zeroCouponMode=true -->
			<xsl:when test="$tradeGroup = 'IRS' and $leg2.payoutType = 'floatingRate' and $swapStream2.paymentSchedule.zeroCouponMode = 'true'">
				<xsl:value-of select="'ZC_IRS'"/>
			</xsl:when>
			<!-- ZC Swap, singlePeriod=true -->
			<xsl:when test="$tradeGroup = 'IRS' and $leg2.payoutType = 'floatingRate' and $swapStream2.singlePeriod = 'true'">
				<xsl:value-of select="'ZC_IRS'"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="$typology"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>
	<!-- ===================== -->
	<!--  Premium if any  -->
	<!-- ===================== -->
	<xsl:variable name="premium.amount">
		<xsl:call-template name="extract-settlementFlow-amount">
			<xsl:with-param name="legNb" select="number($tradePos)"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="premium.currency">
		<xsl:call-template name="extract-settlementCurrency">
			<xsl:with-param name="legNb" select="number($tradePos)"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="premium.date">
		<xsl:variable name="premiumDateMx">
			<xsl:call-template name="extract-settlementFlow-date">
				<xsl:with-param name="legNb" select="number($tradePos)"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:value-of select="mx:execute-formula('mx.xml2xml.ECN.common.utils.adaptDate', concat('date:', $premiumDateMx, ',format:yyyymmdd,outputFormat:yyyy-mm-dd'))"/>
	</xsl:variable>
	<xsl:variable name="premium.pay.or.receive">
		<xsl:call-template name="extract-settlementFlow-payOrReceive">
			<xsl:with-param name="legNb" select="number($tradePos)"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="premium.convertedDate">
		<xsl:choose>
			<xsl:when test="string-length($premium.date) &gt; 0">
				<xsl:variable name="paramPremiumDate" select="concat('date:', $premium.date, ',format:yyyyMMdd,outputFormat:yyyy-MM-dd')"/>
				<xsl:value-of select="mx:execute-formula('mx.xml2xml.ECN.common.utils.adaptDate', $paramPremiumDate)"/>
			</xsl:when>
		</xsl:choose>
	</xsl:variable>
	<xsl:variable name="premium.businessDayConvention" select="'NONE'"/>
	<!-- ======================== -->
	<!-- additionalPayment if any -->
	<!-- ======================== -->
	<xsl:variable name="additionalPayment.amount">
		<xsl:call-template name="extract-additionalFlow-amount">
			<xsl:with-param name="legNb" select="number($tradePos)"/>
			<xsl:with-param name="flow" select="1"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="additionalPayment.date">
		<xsl:variable name="additionalPaymentDateMx">
			<xsl:call-template name="extract-additionalFlow-date">
				<xsl:with-param name="legNb" select="number($tradePos)"/>
				<xsl:with-param name="flow" select="1"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:value-of select="mx:execute-formula('mx.xml2xml.ECN.common.utils.adaptDate', concat('date:', $additionalPaymentDateMx, ',format:yyyymmdd,outputFormat:yyyy-mm-dd'))"/>
	</xsl:variable>
	<xsl:variable name="additionalPayment.currency">
		<xsl:call-template name="extract-additionalFlow-currency">
			<xsl:with-param name="legNb" select="number($tradePos)"/>
			<xsl:with-param name="flow" select="1"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="additionalPayment.payOrReceive">
		<xsl:call-template name="extract-additionalFlow-payOrReceive">
			<xsl:with-param name="legNb" select="number($tradePos)"/>
			<xsl:with-param name="flow" select="1"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="expirationDate.unadjustedDate">
		<xsl:variable name="optionMaturityDate">
			<xsl:call-template name="extract-optionMaturityDate">
				<xsl:with-param name="legNb" select="number($tradePos)"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:value-of select="mx:execute-formula('mx.xml2xml.ECN.common.utils.adaptDate', concat('date:', $optionMaturityDate, ',format:yyyymmdd,outputFormat:yyyy-mm-dd'))"/>
	</xsl:variable>
	<!-- ===================== -->
	<!-- LEG 1                 -->
	<!-- ===================== -->
	<xsl:variable name="leg1.pay.or.receive">
		<xsl:call-template name="extract-pay-or-receive">
			<xsl:with-param name="legNb" select="1"/>
			<xsl:with-param name="stream" select="1"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="leg1.effectiveDate">
		<xsl:variable name="effectiveDateMx">
			<xsl:call-template name="extract-effectiveDate">
				<xsl:with-param name="legNb" select="number($tradePos)"/>
				<xsl:with-param name="stream" select="1"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:value-of select="mx:execute-formula('mx.xml2xml.ECN.common.utils.adaptDate', concat('date:', $effectiveDateMx, ',format:yyyymmdd,outputFormat:yyyy-mm-dd'))"/>
	</xsl:variable>
	<xsl:variable name="leg1.adjustedMaturityDate">
		<xsl:call-template name="extract-adjustedMaturityDate">
			<xsl:with-param name="stream" select="1"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="leg1.startDelayLength">
		<xsl:call-template name="extract-startDelayLength">
			<xsl:with-param name="legNb" select="number($tradePos)"/>
			<xsl:with-param name="stream" select="1"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="leg1.startDateTreatment.dateTreatment">
		<xsl:call-template name="extract-startDateTreatment-dateTreatment">
			<xsl:with-param name="legNb" select="number($tradePos)"/>
			<xsl:with-param name="stream" select="1"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="leg1.endDateTreatment.dateTreatment">
		<xsl:call-template name="extract-endDateTreatment-dateTreatment">
			<xsl:with-param name="legNb" select="number($tradePos)"/>
			<xsl:with-param name="stream" select="1"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="leg1.paymentBusinessCenterName">
		<xsl:call-template name="extract-paymentBusinessCenterName">
			<xsl:with-param name="legNb" select="number($tradePos)"/>
			<xsl:with-param name="stream" select="1"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="leg1.calculationtBusinessCenterName">
		<xsl:call-template name="extract-calculationBusinessCenterName">
			<xsl:with-param name="legNb" select="number($tradePos)"/>
			<xsl:with-param name="stream" select="1"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="leg1.resetBusinessCenterName">
		<xsl:call-template name="extract-resetBusinessCenterName">
			<xsl:with-param name="legNb" select="number($tradePos)"/>
			<xsl:with-param name="stream" select="1"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="leg1.paymentBusinessCenters">
		<xsl:call-template name="extract-businessCenterLabel">
			<xsl:with-param name="legNb" select="1"/>
			<xsl:with-param name="stream" select="1"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="leg1.calculationBusinessCenters">
		<xsl:call-template name="extract-calculationBusinessCenterLabel">
			<xsl:with-param name="legNb" select="1"/>
			<xsl:with-param name="stream" select="1"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="leg1.scheduleGeneratorLabel">
		<xsl:call-template name="extract-scheduleGenerationLabel">
			<xsl:with-param name="legNb" select="number($tradePos)"/>
			<xsl:with-param name="stream" select="1"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="leg1.calculation.periodMultiplier.tmp">
		<xsl:choose>
			<xsl:when test="$tradeGroup = 'FRA'">
				<xsl:call-template name="extract-indexPeriodMultiplierFixFloat"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:call-template name="extract-periodMultiplier">
					<xsl:with-param name="legNb" select="number($tradePos)"/>
					<xsl:with-param name="stream" select="1"/>
				</xsl:call-template>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>
	<xsl:variable name="leg1.calculation.periodUnit.tmp">
		<xsl:choose>
			<xsl:when test="$tradeGroup = 'FRA'">
				<xsl:call-template name="extract-indexPeriodUnitFixFloat"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:call-template name="extract-periodUnit">
					<xsl:with-param name="legNb" select="number($tradePos)"/>
					<xsl:with-param name="stream" select="1"/>
				</xsl:call-template>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>
	<xsl:variable name="leg1.calculation.periodUnit.FixFloat">
		<xsl:variable name="periodUnit1">
			<xsl:call-template name="extract-indexPeriodUnitFloat">
				<xsl:with-param name="stream" select="'1'"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:choose>
			<xsl:when test="string-length($periodUnit1) &gt; 0 ">
				<xsl:value-of select="$periodUnit1"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="$leg1.calculation.periodUnit.tmp"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>
	<xsl:variable name="leg1.calculation.periodMultiplier.FixFloat">
		<xsl:variable name="periodMultiplier1">
			<xsl:call-template name="extract-indexPeriodMultiplierFloat">
				<xsl:with-param name="stream" select="'1'"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:choose>
			<xsl:when test="$periodMultiplier1 &gt; 0 ">
				<xsl:value-of select="$periodMultiplier1"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="$leg1.calculation.periodMultiplier.tmp"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>
	<xsl:variable name="leg2.calculation.periodUnit.FixFloat">
		<xsl:variable name="periodUnit2">
			<xsl:call-template name="extract-indexPeriodUnitFloat">
				<xsl:with-param name="stream" select="'2'"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:choose>
			<xsl:when test="string-length($periodUnit2) &gt; 0 ">
				<xsl:value-of select="$periodUnit2"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="$leg2.calculation.periodUnit.tmp"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>
	<xsl:variable name="leg2.calculation.periodMultiplier.FixFloat">
		<xsl:variable name="periodMultiplier2">
			<xsl:call-template name="extract-indexPeriodMultiplierFloat">
				<xsl:with-param name="stream" select="'2'"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:choose>
			<xsl:when test="$periodMultiplier2 &gt; 0 ">
				<xsl:value-of select="$periodMultiplier2"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="$leg2.calculation.periodMultiplier.tmp"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>
	<xsl:variable name="leg1.calculation.periodMultiplier">
