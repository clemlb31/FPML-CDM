				<xsl:variable name="swBusinessDayConvention">
					<xsl:choose>
						<xsl:when test="string-length(/MxML/trades/trade[(not(tradeHeader/tradeUserDefinedFields/userDefinedField[fieldLabel=$internalUdfLabel]/fieldValue=&quot;true&quot;) and not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeBody/interestRateSwap/payout/option/exercizeSchedule/exercizeScheduleBuilder/exercizeStreamSchedule/scheduleGenerator/standardScheduleGenerator/businessDayConvention) &gt; 0">
							<xsl:variable name="businessDayConvention" select="/MxML/trades/trade[(not(tradeHeader/tradeUserDefinedFields/userDefinedField[fieldLabel=$internalUdfLabel]/fieldValue=&quot;true&quot;) and not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeBody/interestRateSwap/payout/option/exercizeSchedule/exercizeScheduleBuilder/exercizeStreamSchedule/scheduleGenerator/standardScheduleGenerator/businessDayConvention"/>
							<xsl:value-of select="mx:execute-formula($mapBusinessDayConv,concat('businessDayConvention:',$businessDayConvention))"/>
						</xsl:when>
						<xsl:otherwise>
							<xsl:value-of select="'FOLLOWING'"/>
						</xsl:otherwise>
					</xsl:choose>
				</xsl:variable>
				<!-- print  relevantUnderlyingDate -->
				<relevantUnderlyingDate id="CNCTerminationDates">
					<relativeDates>
						<periodMultiplier>
							<xsl:value-of select="$periodMultiplier"/>
						</periodMultiplier>
						<period>
							<xsl:value-of select="$swPeriodUnit"/>
						</period>
						<businessDayConvention>
							<xsl:value-of select="$swBusinessDayConvention"/>
						</businessDayConvention>
						<xsl:copy-of select="$exercise.businessCenters.node"/>
						<dateRelativeTo href="CNCTerminationDates"/>
						<scheduleBounds>
							<unadjustedFirstDate>
								<xsl:value-of select="mx:execute-formula($mapToFpMLDate, concat('mxmlDate:',/MxML/trades/trade[(not(tradeHeader/tradeUserDefinedFields/userDefinedField[fieldLabel=$internalUdfLabel]/fieldValue=&quot;true&quot;) and not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeBody/interestRateSwap/payout/option/exercizeSchedule/exercizeEvents/exercizeEvent/exercizeEffectiveDate))"/>
							</unadjustedFirstDate>
							<unadjustedLastDate>
								<xsl:value-of select="mx:execute-formula($mapToFpMLDate, concat('mxmlDate:',/MxML/trades/trade[(not(tradeHeader/tradeUserDefinedFields/userDefinedField[fieldLabel=$internalUdfLabel]/fieldValue=&quot;true&quot;) and not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeBody/interestRateSwap/stream/maturity))"/>
							</unadjustedLastDate>
						</scheduleBounds>
					</relativeDates>
				</relevantUnderlyingDate>
			</xsl:if>
			<xsl:if test="$optionStyle = 'american'">
				<relevantUnderlyingDate id="CNCTerminationDates">
					<relativeDates>
						<periodMultiplier>1</periodMultiplier>
						<period>D</period>
						<businessDayConvention>FOLLOWING</businessDayConvention>
						<xsl:copy-of select="$exercise.businessCenters.node"/>
						<dateRelativeTo href="CNCTerminationDates"/>
						<scheduleBounds>
							<unadjustedFirstDate>
								<xsl:value-of select="mx:execute-formula($mapToFpMLDate, concat('mxmlDate:',/MxML/trades/trade[(not(tradeHeader/tradeUserDefinedFields/userDefinedField[fieldLabel=$internalUdfLabel]/fieldValue=&quot;true&quot;) and not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeBody/*/payout/option/optionMaturity/date))"/>
							</unadjustedFirstDate>
							<unadjustedLastDate>
								<xsl:value-of select="mx:execute-formula($mapToFpMLDate, concat('mxmlDate:',/MxML/trades/trade[(not(tradeHeader/tradeUserDefinedFields/userDefinedField[fieldLabel=$internalUdfLabel]/fieldValue=&quot;true&quot;) and not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeBody/interestRateSwap/stream/maturity))"/>
							</unadjustedLastDate>
						</scheduleBounds>
					</relativeDates>
				</relevantUnderlyingDate>
			</xsl:if>
			<xsl:if test="$optionStyle = 'european'">
				<xsl:variable name="optionMaturity.unadjustedEffectiveExercizeDate" select="/MxML/trades/trade[(not(tradeHeader/tradeUserDefinedFields/userDefinedField[fieldLabel=$internalUdfLabel]/fieldValue=&quot;true&quot;) and not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeBody/*/payout/option/optionMaturity/unadjustedEffectiveExercizeDate"/>
				<xsl:variable name="optionMaturity.effectiveExercizeDate" select="/MxML/trades/trade[(not(tradeHeader/tradeUserDefinedFields/userDefinedField[fieldLabel=$internalUdfLabel]/fieldValue=&quot;true&quot;) and not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeBody/*/payout/option/optionMaturity/effectiveExercizeDate"/>
				<xsl:variable name="optionMaturity.date" select="/MxML/trades/trade[(not(tradeHeader/tradeUserDefinedFields/userDefinedField[fieldLabel=$internalUdfLabel]/fieldValue=&quot;true&quot;) and not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeBody/*/payout/option/optionMaturity/date"/>
				<xsl:variable name="optionMaturity.effectiveDateShifter" select="/MxML/trades/trade[(not(tradeHeader/tradeUserDefinedFields/userDefinedField[fieldLabel=$internalUdfLabel]/fieldValue=&quot;true&quot;) and not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeBody/*/payout/option/optionMaturity/effectiveDateShifter"/>

				<relevantUnderlyingDate id="CNCTerminationDates">
					<adjustableDates>
						<unadjustedDate>
							<xsl:choose>
								<xsl:when test="$optionMaturity.unadjustedEffectiveExercizeDate">
									<xsl:value-of select="mx:execute-formula($mapToFpMLDate, concat('mxmlDate:',$optionMaturity.unadjustedEffectiveExercizeDate))"/>
								</xsl:when>						
								<xsl:when test="$optionMaturity.date">
									<xsl:value-of select="mx:execute-formula($mapToFpMLDate, concat('mxmlDate:',$optionMaturity.date))"/>
								</xsl:when>					
								<xsl:otherwise>
									<xsl:value-of select="mx:execute-formula($mapToFpMLDate, concat('mxmlDate:',$optionMaturity.effectiveExercizeDate))"/>
								</xsl:otherwise>						
							</xsl:choose>
						</unadjustedDate>
						<dateAdjustments>
							<xsl:choose>
								<xsl:when test="string-length($optionMaturity.effectiveDateShifter) = 0 ">
									<businessDayConvention>NONE</businessDayConvention>
								</xsl:when>				
								<xsl:otherwise>
									<businessDayConvention>MODFOLLOWING</businessDayConvention>
									<xsl:copy-of select="$exercise.businessCenters.node"/>
								</xsl:otherwise>
							</xsl:choose>
						</dateAdjustments>
					</adjustableDates>
				</relevantUnderlyingDate>
			</xsl:if>
			<earliestExerciseTime>
				<hourMinuteTime>
					<xsl:value-of select="$earliestExerciseTime.hourMinuteTime"/>
				</hourMinuteTime>
				<businessCenter>
					<xsl:value-of select="$earliestExerciseTime.businessCenter.name"/>
				</businessCenter>
			</earliestExerciseTime>
			<xsl:if test="$optionStyle != 'european'">
				<latestExerciseTime>
					<hourMinuteTime>
						<xsl:value-of select="$latestExerciseTime.hourMinuteTime"/>
					</hourMinuteTime>
					<businessCenter>
						<xsl:value-of select="$latestExerciseTime.businessCenter.name"/>
					</businessCenter>
				</latestExerciseTime>
			</xsl:if>
			<expirationTime>
				<hourMinuteTime>
					<xsl:value-of select="$expirationTime.hourMinuteTime"/>
				</hourMinuteTime>
				<businessCenter>
					<xsl:value-of select="$expirationTime.businessCenter.name"/>
				</businessCenter>
			</expirationTime>
		</xsl:element>
		<!-- All option type -->
		<followUpConfirmation>false</followUpConfirmation>
	</xsl:variable>
	<xsl:template name="businessCenterNodes">
		<xsl:param name="calendars"/>
		<xsl:choose>
			<xsl:when test="contains($calendars, '|')">
				<businessCenter>
					<xsl:value-of select="substring-before($calendars, '|')"/>
				</businessCenter>
				<xsl:variable name="calendars" select="substring-after($calendars, '|')"/>
				<xsl:call-template name="businessCenterNodes">
					<xsl:with-param name="calendars" select="$calendars"/>
				</xsl:call-template>
			</xsl:when>
			<xsl:when test="string-length($calendars) = 4">
				<businessCenter>
					<xsl:value-of select="$calendars"/>
				</businessCenter>
			</xsl:when>
		</xsl:choose>
	</xsl:template>
	<xsl:variable name="swapStream1.fro.calculationParameter.nodes">
		<xsl:variable name="tmpValue">
			<xsl:call-template name="extract-isda2021FROModifierType">
				<xsl:with-param name="froLabel" select="$swapStream1.ISDA2021FROLabel"/>
				<xsl:with-param name="index.formula.type" select="$swapStream1.indexFormula.indexFormulaType"/>
				<xsl:with-param name="stream" select="1"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:if test="string-length($tmpValue) &gt; 0">
			<xsl:variable name="modifierType" select="substring-before($tmpValue,':')"/>
			<xsl:variable name="shift" select="substring-after($tmpValue,':')"/>
			<xsl:element name="calculationParameters">
				<xsl:element name="calculationMethod">
					<xsl:choose>
						<xsl:when test="$swapStream1.indexFormula.indexFormulaType ='average'">
							<xsl:value-of select="'Averaging'"/>
						</xsl:when>
						<xsl:when test="$swapStream1.indexFormula.indexFormulaType ='compounding'">
							<xsl:value-of select="'Compounding'"/>
						</xsl:when>
					</xsl:choose>
				</xsl:element>
				<xsl:element name="applicableBusinessDays">
					<xsl:element name="businessCenters">
						<xsl:copy-of select="$swapStream1.archiving.businessCenter.nodes"/>
					</xsl:element>
				</xsl:element>
				<xsl:choose>
					<xsl:when test="$modifierType='ObsShift'">
						<xsl:element name="observationShift">
							<xsl:element name="offsetDays">
								<xsl:value-of select="$shift"/>
							</xsl:element>
							<xsl:element name="observationPeriodDates">
								<xsl:value-of select="'Standard'"/>
							</xsl:element>
						</xsl:element>
					</xsl:when>
					<xsl:when test="$modifierType='Lookback'">
						<xsl:element name="lookback">
							<xsl:element name="offsetDays">
								<xsl:value-of select="$shift"/>
							</xsl:element>
						</xsl:element>
					</xsl:when>
					<xsl:when test="$modifierType='Lockout'">
						<xsl:element name="lockout">
							<xsl:element name="offsetDays">
								<xsl:value-of select="$shift"/>
							</xsl:element>
						</xsl:element>
					</xsl:when>
				</xsl:choose>
			</xsl:element>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="swapStream2.fro.calculationParameter.nodes">
		<xsl:variable name="tmpValue">
			<xsl:call-template name="extract-isda2021FROModifierType">
				<xsl:with-param name="froLabel" select="$swapStream2.ISDA2021FROLabel"/>
				<xsl:with-param name="index.formula.type" select="$swapStream2.indexFormula.indexFormulaType"/>
				<xsl:with-param name="stream" select="2"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:if test="string-length($tmpValue) &gt; 0">
			<xsl:variable name="modifierType" select="substring-before($tmpValue,':')"/>
			<xsl:variable name="shift" select="substring-after($tmpValue,':')"/>
			<xsl:element name="calculationParameters">
				<xsl:element name="calculationMethod">
					<xsl:choose>
						<xsl:when test="$swapStream2.indexFormula.indexFormulaType ='average'">
							<xsl:value-of select="'Averaging'"/>
						</xsl:when>
						<xsl:when test="$swapStream2.indexFormula.indexFormulaType ='compounding'">
							<xsl:value-of select="'Compounding'"/>
						</xsl:when>
					</xsl:choose>
				</xsl:element>
				<xsl:element name="applicableBusinessDays">
					<xsl:element name="businessCenters">
						<xsl:copy-of select="$swapStream2.archiving.businessCenter.nodes"/>
					</xsl:element>
				</xsl:element>
				<xsl:choose>
					<xsl:when test="$modifierType='ObsShift'">
						<xsl:element name="observationShift">
							<xsl:element name="offsetDays">
								<xsl:value-of select="$shift"/>
							</xsl:element>
							<xsl:element name="observationPeriodDates">
								<xsl:value-of select="'Standard'"/>
							</xsl:element>
						</xsl:element>
					</xsl:when>
					<xsl:when test="$modifierType='Lookback'">
						<xsl:element name="lookback">
							<xsl:element name="offsetDays">
								<xsl:value-of select="$shift"/>
							</xsl:element>
						</xsl:element>
					</xsl:when>
					<xsl:when test="$modifierType='Lockout'">
						<xsl:element name="lockout">
							<xsl:element name="offsetDays">
								<xsl:value-of select="$shift"/>
							</xsl:element>
						</xsl:element>
					</xsl:when>
				</xsl:choose>
			</xsl:element>
		</xsl:if>
	</xsl:variable>
</xsl:stylesheet>