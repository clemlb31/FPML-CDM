				<xsl:variable name="swPeriodUnit">
					<xsl:choose>
						<xsl:when test="string-length(/MxML/trades/trade[(not(tradeHeader/tradeUserDefinedFields/userDefinedField[fieldLabel=$internalUdfLabel]/fieldValue=&quot;true&quot;) and not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeBody/interestRateSwap/payout/option/exercizeSchedule/exercizeScheduleBuilder/exercizeStreamSchedule/scheduleGenerator/standardScheduleGenerator/defaultFrequency/periodUnit) &gt; 0">
							<xsl:variable name="periodUnit" select="/MxML/trades/trade[(not(tradeHeader/tradeUserDefinedFields/userDefinedField[fieldLabel=$internalUdfLabel]/fieldValue=&quot;true&quot;) and not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeBody/interestRateSwap/payout/option/exercizeSchedule/exercizeScheduleBuilder/exercizeStreamSchedule/scheduleGenerator/standardScheduleGenerator/defaultFrequency/periodUnit"/>
