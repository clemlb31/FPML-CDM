			<xsl:when test="$tradeGroup = 'ASWP'">
				<xsl:choose>
					<xsl:when test="$leg2.payoutType = 'fixedRate' and $isIndexedOnBondLeg2 != '' and $isIndexedOnBondLeg2 = 'inflation'">
						<xsl:value-of select="'floatingRateCalculationPeriodDates1'"/>
					</xsl:when>
					<xsl:otherwise>
						<xsl:value-of select="'fixedRateCalculationPeriodDates1'"/>
					</xsl:otherwise>
				</xsl:choose>
			</xsl:when>
			<!--Basis swap-->
			<xsl:when test="$leg2.payoutType = 'floatingRate' and $leg1.payoutType = 'floatingRate'">
				<xsl:value-of select="'floatingRateCalculationPeriodDates2'"/>
			</xsl:when>
			<xsl:when test="$leg2.payoutType = 'floatingRate'">
				<xsl:value-of select="'floatingRateCalculationPeriodDates1'"/>
			</xsl:when>
			<xsl:when test="$leg2.payoutType = 'fixedRate' and $leg1.payoutType = 'fixedRate'">
				<xsl:value-of select="'fixedRateCalculationPeriodDates2'"/>
			</xsl:when>
			<xsl:when test="$leg2.payoutType = 'fixedRate'">
				<xsl:value-of select="'fixedRateCalculationPeriodDates1'"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="mx:execute-formula('mx.xml2xml.ECN.common.errorHandling.throwException', concat('errorMessage: payment type for stream 2 is incorrect. Returned value is: ', $leg1.payoutType))"/>
