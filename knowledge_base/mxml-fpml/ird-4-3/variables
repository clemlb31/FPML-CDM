			<xsl:variable name="tmp">
				<xsl:call-template name="extract-returnShifter-periodMultiplier">
					<xsl:with-param name="legNb" select="1"/>
					<xsl:with-param name="stream" select="1"/>
				</xsl:call-template>
			</xsl:variable>
			<xsl:choose>
				<xsl:when test="string(number($tmp)) != 'NaN' and number($tmp) &lt; 0">
					<xsl:value-of select="-1.0 * number($tmp)"/>
				</xsl:when>
				<xsl:otherwise>
					<xsl:value-of select="number($tmp)"/>
				</xsl:otherwise>
			</xsl:choose>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="swapStream2.inflationRate.periodMultiplier">
		<xsl:if test="$indexCategory = 'inflationIndex' or contains($leg2.typology,'Inflation') or $Mxgroup = 'INFLS' or contains($typology,'Asset Swap IRS') or $Mxgroup = 'ASWP'">
			<xsl:variable name="tmp">
				<xsl:call-template name="extract-returnShifter-periodMultiplier">
					<xsl:with-param name="legNb" select="1"/>
					<xsl:with-param name="stream" select="2"/>
				</xsl:call-template>
			</xsl:variable>
			<xsl:choose>
				<xsl:when test="string(number($tmp)) != 'NaN' and number($tmp) &lt; 0">
					<xsl:value-of select="-1.0 * number($tmp)"/>
				</xsl:when>
				<xsl:otherwise>
					<xsl:value-of select="number($tmp)"/>
				</xsl:otherwise>
