	<xsl:variable name="swapStream1.inflationRate.interpolationMethodScheme" select="'http://www.fpml.org/coding-scheme/interpolation-method-1-0'"/>
	<xsl:variable name="swapStream1.inflationRate.interpolationMethod">
		<xsl:if test="$indexCategory = 'inflationIndex' or contains($leg1.typology,'Inflation') or $tradeGroup = 'ASWP'">
			<xsl:variable name="interpolationMethodMX">
				<xsl:call-template name="extract-return-interpolation">
					<xsl:with-param name="legNb" select="1"/>
					<xsl:with-param name="stream" select="1"/>
				</xsl:call-template>
			</xsl:variable>
			<xsl:if test="string-length($interpolationMethodMX) &gt; 0">
				<xsl:variable name="result" select="mx:execute-formula($mapInterpolationMethod, concat('interface:', $interface, ',interpolation:', $interpolationMethodMX))"/>
				<xsl:call-template name="AssertNotMapped">
					<xsl:with-param name="value" select="$result"/>
					<xsl:with-param name="message" select="concat('Interpolation method ', $interpolationMethodMX, ' not mapped')"/>
					<xsl:with-param name="formula" select="$mapInterpolationMethod"/>
				</xsl:call-template>
				<xsl:value-of select="$result"/>
			</xsl:if>
		</xsl:if>
