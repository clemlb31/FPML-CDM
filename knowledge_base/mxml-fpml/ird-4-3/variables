	<xsl:variable name="swapStream2.paramCalculationBusinessDayConvention" select="concat('interface:', $interface, ',businessDayConvention:', $leg2.calculation.businessDayConvention)"/>
	<xsl:variable name="swapStream2.paramCalculationPeriodUnit" select="concat('interface:', $interface, ',periodUnit:', $leg2.calculation.periodUnit)"/>
	<xsl:variable name="swapStream2.paramMaturityBusinessDayConvention" select="concat('interface:', $interface, ',businessDayConvention:', $leg2.maturity.businessDayConvention)"/>
	<xsl:variable name="swapStream2.calculationPeriodFrequency.periodMultiplier">
		<xsl:choose>
			<xsl:when test="$leg2.calculation.periodMultiplier = '0'">
				<xsl:value-of select="'1'"/>
			</xsl:when>
			<xsl:when test="($leg2.payoutType = 'fixedRate') and ($isFixedAmount = 'Y' or $isFixedAmount = 'y')">
				<xsl:value-of select="'1'"/>
