	</xsl:variable>
	<!-- Start usage OIS leg1 -->
	<xsl:variable name="leg1.periodUnit.OIS">
		<xsl:call-template name="extract-shifter-payment-periodUnit">
			<xsl:with-param name="legNb" select="1"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="swapStream1.paymentDaysOffset.period.OIS">
		<xsl:choose>
			<xsl:when test="$leg1.periodUnit.OIS = 'businessDay'">
				<xsl:value-of select="'D'"/>
			</xsl:when>
			<xsl:when test="$leg1.periodUnit.OIS = 'day'">
				<xsl:value-of select="'D'"/>
			</xsl:when>
			<xsl:when test="$leg1.periodUnit.OIS = 'week'">
				<xsl:value-of select="'W'"/>
			</xsl:when>
			<xsl:when test="$leg1.periodUnit.OIS = 'month'">
				<xsl:value-of select="'M'"/>
			</xsl:when>
			<xsl:when test="$leg1.periodUnit.OIS = 'year'">
				<xsl:value-of select="'Y'"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="'Business'"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>
	<xsl:variable name="swapStream1.paymentDaysOffset.periodMultiplier.OIS">
		<xsl:value-of select="/MxML/trades/trade[(not(tradeHeader/tradeUserDefinedFields/userDefinedField[fieldLabel=$internalUdfLabel]/fieldValue=&quot;true&quot;) and not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeBody/*/stream[1]/streamTemplate/streamSchedules/paymentSchedule/shifter/shift/periodMultiplier"/>
	</xsl:variable>
	<xsl:variable name="swapStream1.paymentDaysOffset.dayType.OIS">
		<xsl:choose>
			<xsl:when test="$swapStream1.paymentDaysOffset.periodMultiplier.OIS = '0' and $leg1.periodUnit.OIS = 'businessDay'">
				<xsl:value-of select="'Business'"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:choose>
					<xsl:when test="$leg1.periodUnit.OIS = 'day'">
						<xsl:value-of select="'Calendar'"/>
					</xsl:when>
					<xsl:otherwise>
						<xsl:value-of select="'Business'"/>
					</xsl:otherwise>
				</xsl:choose>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>
	<!-- End usage OIS leg1 -->
	<xsl:variable name="swapStream1.paymentDaysOffset.periodMultiplier">
		<xsl:value-of select="/MxML/trades/trade[(not(tradeHeader/tradeUserDefinedFields/userDefinedField[fieldLabel=$internalUdfLabel]/fieldValue=&quot;true&quot;) and not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeBody/*/stream[1]/streamTemplate/streamSchedules/paymentSchedule/shifter/shift/periodMultiplier"/>
	</xsl:variable>
	<xsl:variable name="leg1.periodUnit">
		<xsl:if test="contains($typology , 'OIS') or contains($typology , 'Xccy') or (string-length($swapStream1.paymentDaysOffset.periodMultiplier) &gt; 0 and $swapStream1.paymentDaysOffset.periodMultiplier != 0 )">
			<xsl:call-template name="extract-shifter-payment-periodUnit">
				<xsl:with-param name="legNb" select="1"/>
			</xsl:call-template>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="swapStream1.paymentDaysOffset.period">
		<xsl:if test="contains($typology , 'OIS') or contains($typology , 'Xccy') or (string-length($swapStream1.paymentDaysOffset.periodMultiplier) &gt; 0 and $swapStream1.paymentDaysOffset.periodMultiplier != 0 )">
			<xsl:choose>
				<xsl:when test="$leg1.periodUnit = 'businessDay'">
					<xsl:value-of select="'D'"/>
				</xsl:when>
				<xsl:when test="$leg1.periodUnit = 'day'">
					<xsl:value-of select="'D'"/>
				</xsl:when>
				<xsl:when test="$leg1.periodUnit = 'week'">
					<xsl:value-of select="'W'"/>
				</xsl:when>
				<xsl:when test="$leg1.periodUnit = 'month'">
					<xsl:value-of select="'M'"/>
				</xsl:when>
				<xsl:when test="$leg1.periodUnit = 'year'">
					<xsl:value-of select="'Y'"/>
				</xsl:when>
				<xsl:otherwise>
					<xsl:value-of select="'Business'"/>
				</xsl:otherwise>
			</xsl:choose>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="swapStream1.paymentDaysOffset.dayType">
		<xsl:if test="contains($typology , 'OIS')  or contains($typology , 'Xccy') or (string-length($swapStream1.paymentDaysOffset.periodMultiplier) &gt; 0 and $swapStream1.paymentDaysOffset.periodMultiplier != 0 )">
			<xsl:choose>
				<xsl:when test="$swapStream1.paymentDaysOffset.periodMultiplier = '0' and $leg1.periodUnit = 'businessDay'">
					<xsl:value-of select="'Business'"/>
				</xsl:when>
				<xsl:otherwise>
					<xsl:choose>
						<xsl:when test="$leg1.periodUnit = 'day'">
							<xsl:value-of select="'Calendar'"/>
						</xsl:when>
						<xsl:otherwise>
							<xsl:value-of select="'Business'"/>
						</xsl:otherwise>
					</xsl:choose>
				</xsl:otherwise>
			</xsl:choose>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="swapStream1.calculationPeriodFrequency.period">
		<xsl:choose>
			<xsl:when test="$leg1.calculation.periodMultiplier = '0'">
				<xsl:value-of select="'T'"/>
			</xsl:when>
			<xsl:when test="($leg1.payoutType = 'fixedRate') and ($isFixedAmount = 'Y' or $isFixedAmount = 'y')">
				<xsl:value-of select="'T'"/>
			</xsl:when>
			<xsl:when test="$swapStream1.paymentSchedule.zeroCouponMode = 'true' and $leg1.payoutType = 'fixedRate'">
				<xsl:value-of select="'T'"/>
			</xsl:when>
			<xsl:when test="$swapStream1.singlePeriod = 'true' and $leg1.payoutType = 'fixedRate'">
				<xsl:value-of select="'T'"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="mx:execute-formula($mapPeriodUnit, $swapStream1.paramCalculationPeriodUnit)//row[1]"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>
	<xsl:variable name="swapStream1.paymentDates.calculationPeriodDatesReference.href">
		<xsl:choose>
			<!--Asset swap-->
			<xsl:when test="$tradeGroup = 'ASWP'">
				<xsl:choose>
					<xsl:when test="$leg1.payoutType = 'fixedRate' and $isIndexedOnBondLeg1 != '' and $isIndexedOnBondLeg1 = 'inflation'">
						<xsl:value-of select="'floatingRateCalculationPeriodDates1'"/>
					</xsl:when>
					<xsl:otherwise>
						<xsl:value-of select="'fixedRateCalculationPeriodDates1'"/>
					</xsl:otherwise>
				</xsl:choose>
			</xsl:when>
			<xsl:when test="$leg1.payoutType = 'floatingRate'">
				<xsl:value-of select="'floatingRateCalculationPeriodDates1'"/>
			</xsl:when>
			<xsl:when test="$leg1.payoutType = 'fixedRate'">
				<xsl:value-of select="'fixedRateCalculationPeriodDates1'"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="mx:execute-formula('mx.xml2xml.ECN.common.errorHandling.throwException', concat('errorMessage: payment type for stream 1 is incorrect. Returned value is: ', $leg1.payoutType))"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>
	<xsl:variable name="swapStream1.frequency.periodMultiplier">
		<xsl:choose>
			<xsl:when test="$swapStream1.paymentSchedule.zeroCouponMode = 'true'">
				<xsl:value-of select="'1'"/>
			</xsl:when>
			<xsl:when test="$swapStream1.singlePeriod = 'true'">
				<xsl:value-of select="'1'"/>
			</xsl:when>
			<xsl:when test="$leg1.payment.periodMultiplier = '0'">
				<xsl:value-of select="'1'"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="$leg1.payment.periodMultiplier"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>
	<xsl:variable name="swapStream1.paramFrequencyPeriodUnit" select="concat('interface:', $interface, ',periodUnit:', $leg1.payment.periodUnit)"/>
	<xsl:variable name="calculationPeriodNumberOfDaysTmp">
		<xsl:call-template name="date:difference">
			<xsl:with-param name="start" select="$effective.date.yyyymmdd"/>
			<xsl:with-param name="end" select="$leg1.adjustedMaturityDate"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="calculationPeriodNumberOfDays" select="substring-before(substring-after($calculationPeriodNumberOfDaysTmp, 'P'), 'D')"/>
	<xsl:variable name="swapStream1.payRelativeTo">
		<xsl:variable name="paymentPosition">
			<xsl:call-template name="extract-paymentPosition">
				<xsl:with-param name="legNb" select="1"/>
				<xsl:with-param name="stream" select="1"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:choose>
			<xsl:when test="$paymentPosition = 'upFront'">
				<xsl:value-of select="'CalculationPeriodStartDate'"/>
			</xsl:when>
			<xsl:when test="$paymentPosition = 'upFrontDisc'">
				<xsl:value-of select="'CalculationPeriodStartDate'"/>
			</xsl:when>
			<xsl:when test="$paymentPosition = 'inArrears'">
				<xsl:value-of select="'CalculationPeriodEndDate'"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="'UNKNOWN'"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>
	<xsl:variable name="swapStream1.paramBusinessDayConvention" select="concat('interface:', $interface, ',businessDayConvention:', $leg1.payment.businessDayConvention)"/>
	<xsl:variable name="swapStream1.resetDates.id">
		<xsl:choose>
			<xsl:when test="$swapStream1.ISDA2021FROLabel='true'">
				<xsl:value-of select="''"/>
			</xsl:when>
			<xsl:when test="$leg1.payoutType = 'floatingRate'">
				<xsl:value-of select="$leg1.resetDate.id"/>
			</xsl:when>
			<xsl:when test="$leg1.payoutType = 'fixedRate'">
				<xsl:value-of select="''"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="'NaN'"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>
	<xsl:variable name="swapStream1.calculationPeriodDatesReference.href">
		<xsl:choose>
			<xsl:when test="$leg1.payoutType = 'floatingRate'">
				<xsl:value-of select="'floatingRateCalculationPeriodDates1'"/>
			</xsl:when>
			<xsl:when test="$leg1.payoutType = 'fixedRate'">
				<xsl:value-of select="'fixedRateCalculationPeriodDates1'"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="'NaN'"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>
	<xsl:variable name="swapStream1.paramFixingPeriodUnit" select="concat('interface:', $interface, ',periodUnit:', $leg1.reset.shifter.periodUnit)"/>
	<!-- OIS Compounded Indexes -->
	<xsl:variable name="swapStream1.indexFormula.indexFormulaType">
		<xsl:call-template name="extract-indexFormula-indexFormulaType">
			<xsl:with-param name="stream" select="'1'"/>
