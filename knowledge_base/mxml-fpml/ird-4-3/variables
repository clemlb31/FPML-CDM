								<xsl:when test="$dateDiff &gt; 9089 and $dateDiff &lt; 9102">
									<xsl:value-of select="'3'"/>
								</xsl:when>
								<xsl:when test="$dateDiff &gt; 9398 and $dateDiff &lt; 9402">
