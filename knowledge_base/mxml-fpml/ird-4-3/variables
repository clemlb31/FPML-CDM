			<xsl:with-param name="legNb" select="number($tradePos)"/>
			<xsl:with-param name="stream" select="1"/>
			<xsl:with-param name="schedule" select="'calculationSchedule'"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="s1.streamSchedules.businessDayConvention.param" select="concat('interface:', $interface, ',businessDayConvention:', $s1.streamSchedules.businessDayConventionMx)"/>
	<!-- ===================== -->
	<!-- SWAP STREAM 2 -->
	<!-- ===================== -->
	<xsl:variable name="swapStream2.effectiveDate.unadjustedDate">
		<xsl:variable name="tmp">
			<xsl:choose>
				<xsl:when test="/MxML/trades/trade[1]/tradeBody/*/stream[2]/streamTemplate/potentialStubs/initialStubCharacteristics/couponLength = 'fullCoupon'">
					<xsl:call-template name="extract-adjustedEffectiveDate">
						<xsl:with-param name="legNb" select="number($tradePos)"/>
						<xsl:with-param name="stream" select="2"/>
					</xsl:call-template>
				</xsl:when>
				<xsl:otherwise>
					<xsl:call-template name="extract-streamEffectiveDate">
						<xsl:with-param name="legNb" select="number($tradePos)"/>
						<xsl:with-param name="stream" select="2"/>
					</xsl:call-template>
				</xsl:otherwise>
			</xsl:choose>
		</xsl:variable>
		<xsl:value-of select="mx:execute-formula('mx.xml2xml.ECN.common.utils.adaptDate', concat('date:', $tmp, ',format:yyyymmdd,outputFormat:yyyy-mm-dd'))"/>
