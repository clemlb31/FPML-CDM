					<xsl:variable name="optionalBreakClause" select="optionalBreakClause"/>
					<xsl:if test="$optionalBreakClause = 'Optional'">
						<xsl:value-of select="'1'"/>
					</xsl:if>
				</xsl:for-each>
			</xsl:variable>
			<xsl:choose>
				<xsl:when test="string-length($nbOpt) &gt; 0">
					<xsl:value-of select="'false'"/>
				</xsl:when>
				<xsl:when test="(/MxML/trades/trade[(not(tradeHeader/tradeUserDefinedFields/userDefinedField[fieldLabel=$internalUdfLabel]/fieldValue=&quot;true&quot;) and not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))])[1]/tradeBody/*/payout/option/mutualBreakSchedule/exercizeEvents/exercizeEvent[optionalBreakClause = 'Mandatory']">
					<xsl:value-of select="'true'"/>
