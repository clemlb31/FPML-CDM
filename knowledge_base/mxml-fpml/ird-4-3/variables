				</xsl:variable>
				<xsl:choose>
					<xsl:when test="$tmpValue != '' and $tmpValue != 'NaN' and string-length($local.numeric.format) &gt; 0 and $leg2.isLegIndexTransitionSpread = 'true'">
						<xsl:value-of select="format-number($tmpValue div 100, $local.numeric.format)"/>
