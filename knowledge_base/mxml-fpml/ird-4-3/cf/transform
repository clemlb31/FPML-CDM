<xsl:stylesheet xmlns:xsl="http://www.w3.org/1999/XSL/Transform" 
				xmlns:mx="http://murex.com/xslt/common" 
				xmlns:exslt="http://exslt.org/common" 
				xmlns="http://www.fpml.org/2010/FpML-4-3"
				exclude-result-prefixes="mx exslt"
				version="1.0">
	
	<xsl:import href="mx.xml2xml.transform.any2fpml.4-3.products.common.notificationMessageHeader" />
	<xsl:import href="mx.xml2xml.transform.any2fpml.4-3.products.ird.cf.tradeNode" />
	<xsl:import href="mx.xml2xml.transform.any2fpml.4-3.products.common.party" />
	<xsl:import href="mx.generic.errorHandling.assert" />

	<xsl:include href="mx.xml2xml.transform.mxml2fpml.4-3.products.ird.cf.variables" />
	<xsl:include href="mx.xml2xml.transform.mxml2fpml.4-3.products.ird.variables" />
	<xsl:include href="mx.xml2xml.transform.mxml2fpml.4-3.products.variables" />
	<xsl:include href="mx.xml2xml.transform.mxml2fpml.4-3.products.ird.utils.businessDayConventionsAndBusinessCenters" />

	<!--Param User Defined Field Label For Internal Counterparty-->
	<xsl:param name="internalUdfLabel" select="''"/>

	<!-- ================================================= -->
	<!-- This template will generate a FpML message v 4.3  -->
	<!-- of a cross currency swap product                  -->
	<!-- Mark To Market is not supported.                  -->
	<!-- ================================================= -->
	<xsl:template name="create-fpml-node-ird-capFloor">

		<!-- mandatory mapping table-->
		<xsl:param name="mapCounterparty" />
		<xsl:param name="mapOurPartyLabel" />

		<xsl:param name="partyNameRef" select="'N'" /> 
		<xsl:param name="mapBusinessCenter" />

		<!-- mandatory parameters (refers to our tradeId) -->
		<xsl:param name="tradeId2" />
		<xsl:param name="tradeId2.scheme" />

		<!-- optional parameters -->
		<xsl:param name="messageId" />
		<xsl:param name="messageIdScheme" />
		<xsl:param name="sendBy.partyIdScheme" />
		<xsl:param name="sendTo.partyIdScheme" />
		<xsl:param name="tradeId1" />
		<xsl:param name="tradeId1.scheme" />

		<!--fpml message type-->
		<xsl:param name="fpmlType" select="''" />

		<!-- optional parameters -->
		<xsl:param name="calculationPeriodDate.id" select="''" />
		<xsl:param name="paymentDate.calculationPeriodDatesReference" select="''" />
		<xsl:param name="paymentDate.payRelativeTo" select="''" />
		<xsl:param name="resetDate.calculationPeriodDatesReference" select="''" />
		<xsl:param name="resetDate.resetRelativeTo" select="''" />
		<xsl:param name="businessCenterScheme" select="$businessCenterScheme" />
		<xsl:param name="currencyScheme" select="$currencyScheme" />
		<xsl:param name="dayCountFractionScheme" select="$dayCountFractionScheme" />
		<xsl:param name="floatingRateIndexScheme" select="$floatingRateIndexScheme" />
		<xsl:param name="party.partyIdScheme1" />
		<xsl:param name="party.partyIdScheme2" />
		<xsl:param name="partyAlternateSystem" />
		<xsl:param name="contractualDefinitionsScheme" select="''" />
		<xsl:param name="calculationPeriodDatesReference" select="''" />
		<xsl:param name="calculationAgentParty" select="''" />
		<xsl:param name="notionalSchedule.id" select="''" />
		<xsl:param name="paymentDates.id" select="''" />
		<xsl:param name="calculationPeriodDates.id" select="''" />
		<xsl:param name="effectiveDate.dateAdjustments.businessCenter.nodes" select="$swapStream1.businessCenter.nodes" />
		<xsl:param name="terminationDate.dateAdjustments.businessCenter.nodes" select="$swapStream1.businessCenter.nodes" />
		<xsl:param name="fixingDates.businessDayConvention" select="$swapStream1.fixingDates.businessDayConvention" />
		<xsl:param name="fixingDates.businessDayConvention.overriding" />
		<xsl:param name="fixingDates.dateRelativeTo" select="''" />
		<xsl:param name="notionalSchedule.notionalStepSchedule.steps" select="''" />
		<xsl:param name="effectiveDate.dateAdjustments.businessDayConvention.overriding"/>
		<xsl:param name="party1.id" />
		<xsl:param name="party2.id" />
		<xsl:param name="side1" />
		<xsl:param name="side2" />

		<!-- Parameter used to change the direction of the deal -->
		<xsl:param name="reversePayReceive"/>

		<!-- ============================== -->
		<!-- earlyTerminationProvision node -->
		<!-- ============================== -->
		<xsl:param name="earliestExerciseTime.hourMinuteTime" />  
		<xsl:param name="earliestExerciseTime.businessCenter.name" />

		<xsl:param name="latestExerciseTime.hourMinuteTime" />
		<xsl:param name="latestExerciseTime.businessCenter.name" />

		<xsl:param name="expirationTime.hourMinuteTime" /> 
		<xsl:param name="expirationTime.businessCenter.name" />      

		<xsl:param name="earlyTerminationProvision.calculationAgentParty" />
		<xsl:param name="earlyTerminationProvision.calculationAgentParty.nodes" />

		<xsl:param name="earlyTerminationProvision.hourMinuteTime" />
		<xsl:param name="earlyTerminationProvision.businessCenter.name" />

		<xsl:param name="earlyTerminationProvision.cashSettlementValuationDate.businessCenter.businessCenterScheme" />

		<xsl:param name="earlyTerminationProvision.zeroCouponYieldAdjustedMethod.rateSource"/>
		<xsl:param name="earlyTerminationProvision.zeroCouponYieldAdjustedMethod.rateSourcePage"/>
		<xsl:param name="earlyTerminationProvision.zeroCouponYieldAdjustedMethod.quotationRateType"/>
		<xsl:param name="earlyTerminationProvision.zeroCouponYieldAdjustedMethod.referenceBank.node"/>

		<xsl:param name="earlyTerminationProvision.cashPriceMethod.currency"/>
		<xsl:param name="earlyTerminationProvision.cashPriceMethod.quotationRateType"/>
		<xsl:param name="earlyTerminationProvision.cashPriceMethod.referenceBank.node"/>

		<xsl:param name="earlyTerminationProvision.cashPriceAlternateMethod.currency"/>
		<xsl:param name="earlyTerminationProvision.cashPriceAlternateMethod.quotationRateType"/>
		<xsl:param name="earlyTerminationProvision.cashPriceAlternateMethod.referenceBank.node"/>
		<xsl:param name="earlyTerminationProvision.cashSettlementISDA20XX.nodes"/>																			

		<xsl:param name="collateral.nodes" />
		<xsl:param name="contractualDefinitions.nodes" />
		<xsl:param name="additionalPayment.nodes" />
		<xsl:param name="additionalParties.nodes" />
		<xsl:param name="adjustableDate.id" />
		<xsl:param name="paymentDaysOffset.dayType.overriding" />


		<!--FpML Node -->
		<FpML xmlns:fpml="http://www.fpml.org/2007/FpML-4-3" 
			  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
			  xmlns="http://www.fpml.org/2007/FpML-4-3"
			  xsi:schemaLocation="http://www.fpml.org/2007/FpML-4-3         ../fpml-main-4-3.xsd         http://www.w3.org/2000/09/xmldsig#         ../xmldsig-core-schema.xsd" 
			  xsi:type="{$fpmlType}"
			  version="4-3">

			<xsl:variable name="entity" select="/MxML/trades/trade[(not(tradeHeader/tradeUserDefinedFields/userDefinedField[fieldLabel=$internalUdfLabel]/fieldValue=&quot;true&quot;) and not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeHeader/tradeViews/tradeView/entity" />
			<xsl:variable name="legalEntity" select="/MxML/trades/trade[(not(tradeHeader/tradeUserDefinedFields/userDefinedField[fieldLabel=$internalUdfLabel]/fieldValue=&quot;true&quot;) and not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeHeader/tradeViews/tradeView/legalEntity" />
			<xsl:variable name="paramCtpLabel" select="concat('partyLabel:', $ctpName)" />
			<xsl:variable name="paramOurLabel" select="concat('partyLabel:', $ourName,',userName:',$ourUserName, ',entity:', $entity, ',legalEntity:', $legalEntity)" />

			<!-- counterparty identifier-->
			<xsl:variable name="party.partyId1">
				<xsl:variable name="ctpAltIdFromDisplayLabel">
					<xsl:if test="string-length($partyAlternateSystem)&gt;0">
						<xsl:value-of select="mx:execute-formula('mx.xml2xml.ECN.common.sql.ctpAltIdFromDisplayLabel',concat('displayLabel:',$ctpName,',altSys:',$partyAlternateSystem))" />
					</xsl:if>
				</xsl:variable>
				<xsl:choose>
					<xsl:when test="string-length($ctpAltIdFromDisplayLabel)&gt;0">
						<xsl:value-of select="$ctpAltIdFromDisplayLabel" />
					</xsl:when>
					<xsl:otherwise>
						<xsl:value-of select="mx:execute-formula($mapCounterparty, $paramCtpLabel)" />
					</xsl:otherwise>
				</xsl:choose>
			</xsl:variable>
			<xsl:call-template name="AssertNotMapped">
				<xsl:with-param name="value" select="$party.partyId1" />
				<xsl:with-param name="message" select="concat('Party ', $ctpName,' not mapped')" />
				<xsl:with-param name="formula" select="$mapCounterparty" />
			</xsl:call-template>
			<xsl:variable name="party.partyName1" select="$party.partyId1" />
			<xsl:variable name="party.id1">
				<xsl:choose>
					<xsl:when test="string-length($party1.id) &gt; 0">
						<xsl:value-of select="$party1.id" />
					</xsl:when>
					<xsl:otherwise>
						<xsl:value-of select="$party.partyId1" />
					</xsl:otherwise>
				</xsl:choose>
			</xsl:variable>

			<!-- our party identifier-->
			<xsl:variable name="party.partyId2">
				<xsl:choose>
					<!-- default behaviour: use mapOurPartyLabel formula-->
					<xsl:when test="$mapOurPartyLabel != ''">
						<xsl:value-of select="mx:execute-formula($mapOurPartyLabel, $paramOurLabel)" />
					</xsl:when>
					<xsl:otherwise>
						<!-- Else: use mapCounterparty formula-->
						<xsl:variable name="party.partyId2">
							<xsl:variable name="ctpAltIdFromDisplayLabel">
								<xsl:if test="string-length($partyAlternateSystem)&gt;0">
									<xsl:value-of select="mx:execute-formula('mx.xml2xml.ECN.common.sql.ctpAltIdFromDisplayLabel',concat('displayLabel:',$ourName,',altSys:',$partyAlternateSystem))" />
								</xsl:if>
							</xsl:variable>
							<xsl:choose>
								<xsl:when test="string-length($ctpAltIdFromDisplayLabel)&gt;0">
									<xsl:value-of select="$ctpAltIdFromDisplayLabel" />
								</xsl:when>
								<xsl:otherwise>
									<xsl:value-of select="mx:execute-formula($mapCounterparty, $paramOurLabel)" />
								</xsl:otherwise>
							</xsl:choose>
						</xsl:variable>
						<xsl:value-of select="$party.partyId2" />
					</xsl:otherwise>
				</xsl:choose>
			</xsl:variable>
			<xsl:call-template name="AssertNotMapped">
				<xsl:with-param name="value" select="$party.partyId2" />
				<xsl:with-param name="message" select="concat('Party ', $ourName,' not mapped')" />
				<xsl:with-param name="formula" select="$mapCounterparty" />
			</xsl:call-template>
			<xsl:variable name="party.partyName2" select="$party.partyId2" />
			<xsl:variable name="party.id2">
				<xsl:choose>
					<xsl:when test="string-length($party2.id) &gt; 0">
						<xsl:value-of select="$party2.id" />
					</xsl:when>
					<xsl:otherwise>
						<xsl:value-of select="$party.partyId2" />
					</xsl:otherwise>
				</xsl:choose>
			</xsl:variable>

			<!-- ================================================================== -->

			<xsl:if test="string-length($messageId) or string-length($messageIdScheme)&gt;0">
				<xsl:call-template name="create-notificationMessageHeader">
					<xsl:with-param name="messageId" select="$messageId" />
					<xsl:with-param name="messageIdScheme" select="$messageIdScheme" />
					<xsl:with-param name="sentBy" select="$party.partyName2" />
					<xsl:with-param name="sendTo" select="$party.partyName1" />
					<xsl:with-param name="sentBy.messageAddressScheme" select="$sendBy.partyIdScheme" />
					<xsl:with-param name="sentTo.messageAddressScheme" select="$sendTo.partyIdScheme" />
					<xsl:with-param name="creationTimestamp" select="$creationTimestamp" />
				</xsl:call-template>
			</xsl:if>
			<xsl:call-template name="create-fpml-trade-node-ird-capFloor">
				<xsl:with-param name="mapCounterparty" select="$mapCounterparty" />
				<xsl:with-param name="mapOurPartyLabel" select="$mapOurPartyLabel" />
				<xsl:with-param name="partyAlternateSystem" select="$partyAlternateSystem" />
				<xsl:with-param name="partyNameRef" select="$partyNameRef" />

				<xsl:with-param name="party1.id" select="$party.id1" />
				<xsl:with-param name="party2.id" select="$party.id2" />

				<!-- mandatory  parameters (refers to our tradeId) -->
				<xsl:with-param name="tradeId2" select="$tradeId2" />
				<xsl:with-param name="tradeId2.scheme" select="$tradeId2.scheme" />
				<xsl:with-param name="calculationPeriodDate.id" select="$calculationPeriodDate.id" />
				<xsl:with-param name="paymentDate.calculationPeriodDatesReference" select="$paymentDate.calculationPeriodDatesReference" />
				<xsl:with-param name="paymentDate.payRelativeTo" select="$swapStream1.payRelativeTo" />
				<xsl:with-param name="resetDate.calculationPeriodDatesReference" select="$resetDate.calculationPeriodDatesReference" />
				<xsl:with-param name="resetDate.resetRelativeTo" select="$resetDate.resetRelativeTo" />
				<xsl:with-param name="businessCenterScheme" select="$businessCenterScheme" />
				<xsl:with-param name="currencyScheme" select="$currencyScheme" />
				<xsl:with-param name="swapStream1.dayCountFraction.dayCountFractionScheme" select="$dayCountFractionScheme" />
				<xsl:with-param name="floatingRateIndexScheme" select="$floatingRateIndexScheme" />
				<xsl:with-param name="masterAgreementTypeScheme" select="$masterAgreementTypeScheme" />
				<xsl:with-param name="contractualDefinitionsScheme" select="$contractualDefinitionsScheme" />
				<xsl:with-param name="calculationPeriodDatesReference" select="$calculationPeriodDatesReference" />
				<xsl:with-param name="calculationAgentParty" select="$calculationAgentParty" />
				<xsl:with-param name="notionalSchedule.id" select="$notionalSchedule.id" />
				<xsl:with-param name="paymentDates.id" select="$paymentDates.id" />
				<xsl:with-param name="calculationPeriodDates.id" select="$calculationPeriodDates.id" />
				<xsl:with-param name="effectiveDate.dateAdjustments.businessDayConvention.overriding" select="$effectiveDate.dateAdjustments.businessDayConvention.overriding" />
				<xsl:with-param name="effectiveDate.dateAdjustments.businessCenter.nodes" select="$effectiveDate.dateAdjustments.businessCenter.nodes" />
				<xsl:with-param name="terminationDate.dateAdjustments.businessCenter.nodes" select="$terminationDate.dateAdjustments.businessCenter.nodes" />
				<xsl:with-param name="fixingDates.businessDayConvention" select="$fixingDates.businessDayConvention" />
				<xsl:with-param name="fixingDates.businessDayConvention.overriding" select="$fixingDates.businessDayConvention.overriding"/>
				<xsl:with-param name="fixingDates.dateRelativeTo" select="$fixingDates.dateRelativeTo" />
				<xsl:with-param name="notionalSchedule.notionalStepSchedule.steps" select="$notionalSchedule.notionalStepSchedule.steps" />

				<!-- trade side node -->
				<xsl:with-param name="side1" select="$side1" />
				<xsl:with-param name="side2" select="$side2" />
				<xsl:with-param name="reversePayReceive" select="$reversePayReceive"/>

				<!-- earlyTerminationProvision -->
				<xsl:with-param name="optionForm" select="$optionForm" />
				<xsl:with-param name="bermudaExerciseDates.period"  select="$bermudaExerciseDates.period"/> 
				<xsl:with-param name="bermudaExerciseDates.periodMultiplier" select="$bermudaExerciseDates.periodMultiplier"/>
				<xsl:with-param name="bermudaExerciseDates.dayType" select="$bermudaExerciseDates.dayType"/>
				<xsl:with-param name="bermudaExerciseDates.businessDayConvention" select="$bermudaExerciseDates.businessDayConvention"/>
				<xsl:with-param name="bermudaExerciseDates.dateRelativeTo.href" select="$bermudaExerciseDates.dateRelativeTo.href"/>
				<xsl:with-param name="bermudaExerciseDates.businessCenter.nodes" select="$bermudaExerciseDates.businessCenter.nodes" />

				<xsl:with-param name="earliestExerciseTime.hourMinuteTime"    select="$earliestExerciseTime.hourMinuteTime" />  
				<xsl:with-param name="earliestExerciseTime.businessCenter.name"  select="$earliestExerciseTime.businessCenter.name" />

				<xsl:with-param name="latestExerciseTime.hourMinuteTime" select="$latestExerciseTime.hourMinuteTime" />
				<xsl:with-param name="latestExerciseTime.businessCenter.name" select="$latestExerciseTime.businessCenter.name" />

				<xsl:with-param name="expirationTime.hourMinuteTime"   select="$expirationTime.hourMinuteTime" /> 
				<xsl:with-param name="expirationTime.businessCenter.name"        select="$expirationTime.businessCenter.name" />      

				<xsl:with-param name="earlyTerminationProvision.calculationAgentParty"  select="$earlyTerminationProvision.calculationAgentParty" />
				<xsl:with-param name="earlyTerminationProvision.calculationAgentParty.nodes"  select="$earlyTerminationProvision.calculationAgentParty.nodes" />

				<xsl:with-param name="earlyTerminationProvision.hourMinuteTime"  select="$earlyTerminationProvision.hourMinuteTime" />
				<xsl:with-param name="earlyTerminationProvision.businessCenter.name"   select="$earlyTerminationProvision.businessCenter.name" /> 

				<xsl:with-param name="earlyTerminationProvision.dateAdjustments.businessDayConvention" select="$earlyTerminationProvision.dateAdjustments.businessDayConvention" />
				<xsl:with-param name="earlyTerminationProvision.cashSettlementValuationDate.businessCenter.businessCenterScheme"  select="$earlyTerminationProvision.cashSettlementValuationDate.businessCenter.businessCenterScheme" />

				<xsl:with-param name="earlyTerminationProvision.zeroCouponYieldAdjustedMethod.rateSource" select="$earlyTerminationProvision.zeroCouponYieldAdjustedMethod.rateSource"/>
				<xsl:with-param name="earlyTerminationProvision.zeroCouponYieldAdjustedMethod.rateSourcePage" select="$earlyTerminationProvision.zeroCouponYieldAdjustedMethod.rateSourcePage"/>
				<xsl:with-param name="earlyTerminationProvision.zeroCouponYieldAdjustedMethod.quotationRateType" select="$earlyTerminationProvision.zeroCouponYieldAdjustedMethod.quotationRateType"/>
				<xsl:with-param name="earlyTerminationProvision.zeroCouponYieldAdjustedMethod.referenceBank.node" select="$earlyTerminationProvision.zeroCouponYieldAdjustedMethod.referenceBank.node"/>

				<xsl:with-param name="earlyTerminationProvision.cashPriceMethod.currency" select="$earlyTerminationProvision.cashPriceMethod.currency"/>
				<xsl:with-param name="earlyTerminationProvision.cashPriceMethod.quotationRateType" select="$earlyTerminationProvision.cashPriceMethod.quotationRateType"/>
				<xsl:with-param name="earlyTerminationProvision.cashPriceMethod.referenceBank.node" select="$earlyTerminationProvision.cashPriceMethod.referenceBank.node"/>

				<xsl:with-param name="earlyTerminationProvision.cashPriceAlternateMethod.currency" select="$earlyTerminationProvision.cashPriceAlternateMethod.currency"/>
				<xsl:with-param name="earlyTerminationProvision.cashPriceAlternateMethod.quotationRateType" select="$earlyTerminationProvision.cashPriceAlternateMethod.quotationRateType"/>
				<xsl:with-param name="earlyTerminationProvision.cashPriceAlternateMethod.referenceBank.node" select="$earlyTerminationProvision.cashPriceAlternateMethod.referenceBank.node"/>
				<xsl:with-param name="earlyTerminationProvision.cashSettlementISDA20XX.nodes" select="$earlyTerminationProvision.cashSettlementISDA20XX.nodes"/>																																					
				<xsl:with-param name="collateral.nodes" select="$collateral.nodes" />

				<xsl:with-param name="contractualDefinitions.nodes" select="$contractualDefinitions.nodes" />
				<xsl:with-param name="additionalPayment.nodes" select="$additionalPayment.nodes" />
				<xsl:with-param name="additionalParties.nodes" />
				<xsl:with-param name="adjustableDate.id">
					<xsl:choose>
						<xsl:when test="$isMandatoryEarlyTermination = 'true' and string-length($adjustableDate.id) = 0">
							<xsl:value-of select="$earlyTerminationProvision.cashSettlementValuationDate.dateRelativeTo.href"></xsl:value-of>
						</xsl:when>
						<xsl:otherwise>
							<xsl:value-of select="$adjustableDate.id"></xsl:value-of>
						</xsl:otherwise>
					</xsl:choose>
				</xsl:with-param>					  						   
				<xsl:with-param name="paymentDaysOffset.dayType.overriding" select="$paymentDaysOffset.dayType.overriding" />
			</xsl:call-template>
			<!-- Create the first party tag -->
			<xsl:call-template name="create-trade-party">
				<xsl:with-param name="party.id" select="$party.id1" />
				<xsl:with-param name="party.partyId" select="$party.partyId1" />
				<xsl:with-param name="party.partyIdScheme" select="$party.partyIdScheme1" />
			</xsl:call-template>
			<!-- Create the second party tag -->
			<xsl:call-template name="create-trade-party">
				<xsl:with-param name="party.id" select="$party.id2" />
				<xsl:with-param name="party.partyId" select="$party.partyId2" />
				<xsl:with-param name="party.partyIdScheme" select="$party.partyIdScheme2" />
			</xsl:call-template>
			<!-- Create the event party tag if needed -->
			<xsl:variable name="paramPartyNameEvent" select="concat('partyLabel:', $partyNameEvent)" />
			<xsl:variable name="party.partyNameEventId" select="$partyNameEventId" />
			<xsl:variable name="party.partyNameEvent">
				<xsl:if test="string-length($partyNameEventId) &gt; 0">
					<xsl:value-of select="mx:execute-formula($mapCounterparty, $paramPartyNameEvent)" />
				</xsl:if>
			</xsl:variable>
			<xsl:if test="string-length($partyNameEventId) &gt; 0">
				<xsl:call-template name="AssertNotMapped">
					<xsl:with-param name="value" select="$party.partyNameEvent" />
					<xsl:with-param name="message" select="concat('Party ', $partyNameEvent,' not mapped')" />
					<xsl:with-param name="formula" select="$mapCounterparty" />
				</xsl:call-template>
			</xsl:if>
			<xsl:choose>
				<xsl:when test="string-length($additionalParties.nodes)&gt;0">
					<xsl:copy-of select="$additionalParties.nodes" />
				</xsl:when>
				<xsl:when test="string-length($party.partyNameEventId)">
					<xsl:call-template name="create-trade-party">
						<xsl:with-param name="party.id" select="$party.partyNameEventId" />
						<xsl:with-param name="party.partyId" select="$party.partyNameEvent" />
					</xsl:call-template>
				</xsl:when>
			</xsl:choose>
		</FpML>
	</xsl:template>
	<xsl:template name="create-fpml-trade-node-ird-capFloor">

		<!-- mandatory mapping table-->
		<xsl:param name="mapCounterparty" />
		<xsl:param name="mapOurPartyLabel" />
		<xsl:param name="partyNameRef" select="'N'" />
		<xsl:param name="tradeId1" />
		<xsl:param name="tradeIdScheme1" />

		<!-- mandatory parameters (refers to our tradeId) -->
		<xsl:param name="tradeId2" />
		<xsl:param name="tradeId2.scheme" />

		<!-- optional parameters -->
		<xsl:param name="calculationPeriodDate.id" select="''" />
		<xsl:param name="paymentDate.calculationPeriodDatesReference" select="''" />
		<xsl:param name="paymentDate.payRelativeTo" select="''" />
		<xsl:param name="resetDate.calculationPeriodDatesReference" select="''" />
		<xsl:param name="resetDate.resetRelativeTo" select="''" />
		<xsl:param name="businessCenterScheme" select="''" />
		<xsl:param name="currencyScheme" select="''" />
		<xsl:param name="swapStream1.dayCountFraction.dayCountFractionScheme" select="''" />
		<xsl:param name="floatingRateIndexScheme" select="''" />
		<xsl:param name="masterAgreementTypeScheme" select="''" />
		<xsl:param name="contractualDefinitionsScheme" select="''" />
		<xsl:param name="calculationPeriodDatesReference" select="''" />
		<xsl:param name="calculationAgentParty" select="''" />
		<xsl:param name="notionalSchedule.id" select="''" />
		<xsl:param name="paymentDates.id" select="''" />
		<xsl:param name="partyAlternateSystem" />
		<xsl:param name="calculationPeriodDates.id" select="''" />
		<xsl:param name="contractualDefinitions2" />
		<xsl:param name="contractualDefinitions2Scheme" />
		<xsl:param name="effectiveDate.dateAdjustments.businessCenter.nodes" />
		<xsl:param name="effectiveDate.dateAdjustments.businessDayConvention.overriding" />
