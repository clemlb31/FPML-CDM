					<xsl:with-param name="stream" select="1" />
				</xsl:call-template>
			</xsl:variable>
			<xsl:choose>
				<!-- ZC (Fixed Amount on fixed leg) - Customized flow  -->
				<xsl:when test="$leg1.payoutType = 'fixedRate' and string-length($customPaymentAmount1) &gt; 0 and ($swapStream1.paymentSchedule.zeroCouponMode = 'true'  or $swapStream1.singlePeriod = 'true')">
					<xsl:choose>
						<xsl:when test="( number($customPaymentAmount1) &lt; 0 and leg1.pay.or.receive = 'pay' ) or (number($customPaymentAmount1) &gt; 0 and not(leg1.pay.or.receive = 'pay'))">
							<xsl:value-of select="format-number(number($customPaymentAmount1)*-1, '##.##')"/>
