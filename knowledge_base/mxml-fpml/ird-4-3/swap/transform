<xsl:stylesheet xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns="http://www.fpml.org/2007/FpML-4-3" xmlns:mx="http://murex.com/xslt/common" xmlns:exslt="http://exslt.org/common" version="1.0" exclude-result-prefixes="mx exslt">
	<xsl:import href="mx.xml2xml.transform.any2fpml.4-3.products.common.notificationMessageHeader" />
	<xsl:import href="mx.xml2xml.transform.any2fpml.4-3.products.common.tradeHeader" />
	<xsl:import href="mx.xml2xml.transform.any2fpml.4-3.products.ird.swap.tradeNode" />
	<xsl:import href="mx.generic.exslt.date.difference" />
	<xsl:import href="mx.generic.errorHandling.assert" />
	<xsl:import href="mx.xml2xml.transform.any2fpml.4-3.products.common.bermudaExercise" />
	<xsl:import href="mx.xml2xml.transform.any2fpml.4-3.products.common.floatingRate"/>
	<xsl:include href="mx.xml2xml.transform.mxml2fpml.4-3.products.ird.swap.variables" />
	<xsl:include href="mx.xml2xml.transform.mxml2fpml.4-3.products.ird.variables" />
	<xsl:include href="mx.xml2xml.transform.mxml2fpml.4-3.products.variables" />

	<!--Param User Defined Field Label For Internal Counterparty-->
	<xsl:param name="internalUdfLabel" select="''"/>
	<xsl:param name="initFixingPM1"/>
	<xsl:param name="initFixingPM2"/>

	<!-- ================================================= -->
	<!-- This template will generate a FpML message v 4.3  -->
	<!-- of IRD SWAP product                               -->
	<!-- ================================================= -->
	<xsl:template name="create-fpml-node-ird-irs">
		<xsl:param name="fpmlType" select="'RequestTradeConfirmation'" />

		<!--==========================-->
		<!-- Mandatory mapping tables -->
		<!--==========================-->
		<xsl:param name="mapCounterparty" />
		<xsl:param name="mapOurPartyLabel" />
		<xsl:param name="mapBusinessCenter" />
		<xsl:param name="partyAlternateSystem" />

		<!-- mandatory parameters (refers to our tradeId) -->
		<xsl:param name="tradeId2" />
		<xsl:param name="tradeId2.scheme" />

		<!-- optional parameters -->
		<xsl:param name="messageId" />
		<xsl:param name="messageIdScheme" />
		<xsl:param name="sendBy.partyIdScheme" />
		<xsl:param name="sendTo.partyIdScheme" />
		<xsl:param name="tradeId1" />
		<xsl:param name="tradeId1.scheme" />
		<xsl:param name="businessCenter.nodes.exist" />
		<xsl:param name="swapStream1.id" />
		<xsl:param name="party1.id" />
		<xsl:param name="party2.id" />
		<xsl:param name="party.partyIdScheme1" />
		<xsl:param name="party.partyIdScheme2" />
		<xsl:param name="side1" />
		<xsl:param name="side2" />
		<xsl:param name="tradeIdSupplement2" />
		<xsl:param name="tradeIdSupplement.tradeIdScheme2" />

		<!--==========================-->
		<!-- Optional parameters      -->
		<!--==========================-->
		<xsl:param name="earliestExerciseTime.hourMinuteTime" />
		<xsl:param name="earliestExerciseTime.businessCenter.name" />
		<xsl:param name="earliestExerciseTime.businessCenter.businessCenterScheme" select="'http://www.fpml.org/coding-scheme/business-center-6-4'" />
		<xsl:param name="expirationTime.hourMinuteTime" />
		<xsl:param name="expirationTime.businessCenter.businessCenterScheme" select="'http://www.fpml.org/coding-scheme/business-center-6-4'" />
		<xsl:param name="initialValue" />
		<xsl:param name="swapStream1.businessCenter.businessCenterScheme" />
		<xsl:param name="swapStream1.notionalSchedule.id" />
		<xsl:param name="swapStream1.notionalSchedule.notionalStepSchedule.currency.currencyScheme" />
		<xsl:param name="swapStream1.floatingRateIndexScheme" />
		<xsl:param name="swapStream1.effectiveDate.dateAdjustments.businessCenter.id" />
		<xsl:param name="swapStream1.terminationDate.dateAdjustments.businessCenter.id" />
		<xsl:param name="swapStream1.dayCountFraction.dayCountFractionScheme" />
		<xsl:param name="swapStream1.paymentDates.id" />
		<xsl:param name="swapStream1.calculationPeriodDates.id" select="$swapStream1.calculationPeriodDates.id" />
		<xsl:param name="swapStream1.paymentDates.calculationPeriodDatesReference.href" select="$swapStream1.paymentDates.calculationPeriodDatesReference.href" />
		<xsl:param name="swapStream1.calculationPeriodDatesReference.href" select="$swapStream1.calculationPeriodDatesReference.href" />
		<xsl:param name="swapStream1.resetDates.id" select="$swapStream1.resetDates.id" />
		<xsl:param name="swapStream1.fixingDates.dateRelativeTo.href" select="$swapStream1.fixingDates.dateRelativeTo.href" />
		<xsl:param name="swapStream1.fixingDates.dateRelativeTo" />
		<xsl:param name="swapStream1.resetDatesAdjustments.businessCenter.nodes" select="$swapStream1.resetDatesAdjustments.businessCenter.nodes" />
		<xsl:param name="swapStream1.resetDatesAdjustments.businessCenter.nodes" select="$swapStream1.resetDatesAdjustments.businessCenter.nodes" />
		<xsl:param name="swapStream1.resetDatesAdjustments.businessCenter.nodes.overriding" />
		<xsl:param name="swapStream1.calculationPeriodFrequency.rollConvention.overriding" />		
		<xsl:param name="swapStream2.calculationPeriodFrequency.rollConvention.overriding" />
		<xsl:param name="swapStream1.fixingDates.businessCenter.nodes.overriding" />
		<xsl:param name="swapStream2.fixingDates.businessCenter.nodes.overriding" />
		<xsl:param name="swapStream1.resetDatesAdjustments.businessDayConvention.overriding" />
		<xsl:param name="swapStream2.resetDatesAdjustments.businessDayConvention.overriding" />		
		<xsl:param name="swapStream1.businessDayConvention.overriding" />
		<xsl:param name="swapStream2.businessDayConvention.overriding" />
		<xsl:param name="swapStream2.businessCenter.businessCenterScheme" />
		<xsl:param name="swapStream2.notionalSchedule.id" />
		<xsl:param name="swapStream2.notionalSchedule.notionalStepSchedule.currency.currencyScheme" />
		<xsl:param name="swapStream2.floatingRateIndexScheme" />
		<xsl:param name="exerciseProcedure.fallbackExercise" select="'false'" />
		<xsl:param name="followUpConfirmation" select="'false'" />
		<xsl:param name="swapStream2.effectiveDate.dateAdjustments.businessCenter.id" />
		<xsl:param name="swapStream2.terminationDate.dateAdjustments.businessCenter.id" />
		<xsl:param name="swapStream2.dayCountFraction.dayCountFractionScheme" select="$swapStream2.dayCountFraction.dayCountFractionScheme" />
		<xsl:param name="additionalParties.nodes" />
		<xsl:param name="swapStream2.id" />
		<xsl:param name="swapStream2.paymentDates.id" />
		<xsl:param name="swapStream2.calculationPeriodDates.id" select="$swapStream2.calculationPeriodDates.id" />
		<xsl:param name="swapStream2.paymentDates.calculationPeriodDatesReference.href" select="$swapStream2.paymentDates.calculationPeriodDatesReference.href" />
		<xsl:param name="swapStream2.calculationPeriodDatesReference.href" select="$swapStream2.calculationPeriodDatesReference.href" />
		<xsl:param name="swapStream2.resetDates.id" select="$swapStream2.resetDates.id" />
		<xsl:param name="swapStream2.fixingDates.dateRelativeTo.href" select="$swapStream2.fixingDates.dateRelativeTo.href" />
		<xsl:param name="swapStream2.fixingDates.dateRelativeTo" />
		<xsl:param name="swapStream2.resetDatesAdjustments.businessCenter.nodes" select="$swapStream2.resetDatesAdjustments.businessCenter.nodes" />
		<xsl:param name="swapStream2.resetDatesAdjustments.businessCenter.nodes.overriding" />
		<xsl:param name="additionalPayment.nodes" />
		<xsl:param name="contractualDefinitions.nodes" />
		<xsl:param name="swapStream1.formulaDescription" />
		<xsl:param name="swapStream2.formulaDescription" />

		<!-- paymentDaysOffset -->
		<xsl:param name="swapStream1.paymentDaysOffset.period" />
		<xsl:param name="swapStream1.paymentDaysOffset.periodMultiplier" />
		<xsl:param name="swapStream1.paymentDaysOffset.dayType" />
		<xsl:param name="swapStream2.paymentDaysOffset.period" />
		<xsl:param name="swapStream2.paymentDaysOffset.periodMultiplier" />
		<xsl:param name="swapStream2.paymentDaysOffset.dayType" />

		<!-- paymentDaysOffset overriding -->
		<xsl:param name="swapStream1.paymentDaysOffset.period.overriding" />
		<xsl:param name="swapStream1.paymentDaysOffset.periodMultiplier.overriding" />
		<xsl:param name="swapStream1.paymentDaysOffset.dayType.overriding" />
		<xsl:param name="swapStream2.paymentDaysOffset.period.overriding" />
		<xsl:param name="swapStream2.paymentDaysOffset.periodMultiplier.overriding" />
		<xsl:param name="swapStream2.paymentDaysOffset.dayType.overriding" />

		<!-- Overriding used by MTM module to generate mtm parties-->
		<xsl:param name="swapStream1.payerPartyReference.href.overriding" />
		<xsl:param name="swapStream1.receiverPartyReference.href.overriding" />
		<xsl:param name="swapStream2.payerPartyReference.href.overriding" />
		<xsl:param name="swapStream2.receiverPartyReference.href.overriding" />

		<!-- Overriding used by MTM module to generate the tag fixingDates for INFLS product-->
		<xsl:param name="swapStream1.fixingDates.period.overriding" />
		<xsl:param name="swapStream1.fixingDates.periodMultiplier.overriding" />
		<xsl:param name="swapStream1.fixingDates.dayType.overriding" />
		<xsl:param name="swapStream1.fixingDates.businessDayConvention.overriding" />
		<xsl:param name="swapStream1.fixingDates.businessCenter.overriding" />
		<xsl:param name="swapStream2.fixingDates.period.overriding" />
		<xsl:param name="swapStream2.fixingDates.periodMultiplier.overriding" />
		<xsl:param name="swapStream2.fixingDates.dayType.overriding" />
		<xsl:param name="swapStream2.fixingDates.businessDayConvention.overriding" />
		<xsl:param name="swapStream2.fixingDates.businessCenter.overriding" />

		<!-- Overriding used by MTM module to generate the tag initialFixingDate for IRS product without customizations-->
		<xsl:param name="swapStream1.initialFixingDate.periodMultiplier.overriding" />
		<xsl:param name="swapStream1.initialFixingDate.period.overriding" />
		<xsl:param name="swapStream1.initialFixingDate.dayType.overriding" />
		<xsl:param name="swapStream1.initialFixingDate.businessDayConvention.overriding" />
		<xsl:param name="swapStream1.initialFixingDate.businessCenter.nodes.overriding" />
		<xsl:param name="swapStream1.initialFixingDate.dateRelativeTo.href.overriding" />
		<xsl:param name="swapStream1.initialFixingDate.paymentCalendar.overriding" />
		<xsl:param name="swapStream1.initialFixingDate.customized.overriding" />
		<xsl:param name="swapStream2.initialFixingDate.periodMultiplier.overriding" />
		<xsl:param name="swapStream2.initialFixingDate.period.overriding" />
		<xsl:param name="swapStream2.initialFixingDate.dayType.overriding" />
		<xsl:param name="swapStream2.initialFixingDate.businessDayConvention.overriding" />
		<xsl:param name="swapStream2.initialFixingDate.businessCenter.nodes.overriding" />
		<xsl:param name="swapStream2.initialFixingDate.dateRelativeTo.href.overriding" />
		<xsl:param name="swapStream2.initialFixingDate.paymentCalendar.overriding" />
		<xsl:param name="swapStream2.initialFixingDate.customized.overriding" />

		<!-- Inflation Rate calculation -->
		<!-- Overriding of scheme used by MTM module -->
		<xsl:param name="swapStream1.inflationRate.floatingRateIndexScheme.overriding" />
		<xsl:param name="swapStream1.inflationRate.mainPublication" />
		<xsl:param name="swapStream1.inflationRate.mainPublicationScheme" />
		<xsl:param name="swapStream1.inflationRate.interpolationMethod" />
		<xsl:param name="swapStream1.inflationRate.interpolationMethodScheme" />
		<xsl:param name="swapStream2.inflationRate.floatingRateIndexScheme.overriding" />
		<xsl:param name="swapStream2.inflationRate.mainPublication" />
		<xsl:param name="swapStream2.inflationRate.mainPublicationScheme" />
		<xsl:param name="swapStream2.inflationRate.interpolationMethod" />
		<xsl:param name="swapStream2.inflationRate.interpolationMethodScheme" />

		<!-- Parameter used to change the direction of the deal -->
		<xsl:param name="reversePayReceive"/>

		<!-- ============================== -->
		<!-- earlyTerminationProvision node -->
		<!-- ============================== -->
		<xsl:param name="latestExerciseTime.hourMinuteTime" />
		<xsl:param name="latestExerciseTime.businessCenter.name" />
		<xsl:param name="latestExerciseTime.businessCenter.businessCenterScheme" />
		<xsl:param name="expirationTime.hourMinuteTime" /> 
		<xsl:param name="expirationTime.businessCenter.name" />
		<xsl:param name="earlyTerminationProvision.calculationAgentParty" />
		<xsl:param name="earlyTerminationProvision.calculationAgentParty.nodes" />
		<xsl:param name="earlyTerminationProvision.hourMinuteTime" />
		<xsl:param name="earlyTerminationProvision.businessCenter.name" /> 
		<xsl:param name="earlyTerminationProvision.businessCenter.businessCenterScheme" /> 
		<xsl:param name="earlyTerminationProvision.dateAdjustments.businessCenter" />
		<xsl:param name="earlyTerminationProvision.dateAdjustments.businessCenter.businessCenterScheme" />
		<xsl:param name="earlyTerminationProvision.cashSettlementValuationDate.businessCenter" />
		<xsl:param name="earlyTerminationProvision.cashSettlementValuationDate.businessCenter.businessCenterScheme" />
		<xsl:param name="earlyTerminationProvision.zeroCouponYieldAdjustedMethod.rateSource"/>
		<xsl:param name="earlyTerminationProvision.zeroCouponYieldAdjustedMethod.rateSourcePage"/>
		<xsl:param name="earlyTerminationProvision.zeroCouponYieldAdjustedMethod.quotationRateType"/>
		<xsl:param name="earlyTerminationProvision.zeroCouponYieldAdjustedMethod.referenceBank.node"/>
		<xsl:param name="earlyTerminationProvision.zeroCouponYieldAdjustedMethod.node"/>
		<xsl:param name="earlyTerminationProvision.cashPriceMethod.currency"/>
		<xsl:param name="earlyTerminationProvision.cashPriceMethod.quotationRateType"/>
		<xsl:param name="earlyTerminationProvision.cashPriceMethod.referenceBank.node"/>
		<xsl:param name="earlyTerminationProvision.cashPriceAlternateMethod.currency"/>
		<xsl:param name="earlyTerminationProvision.cashPriceAlternateMethod.quotationRateType"/>
		<xsl:param name="earlyTerminationProvision.cashPriceAlternateMethod.referenceBank.node"/>
		<xsl:param name="earlyTerminationProvision.mandatoryEarlyTerminationDate.id" select="'mandatoryEarlyTerminationDate'"/>
		<xsl:param name="earlyTerminationProvision.cashSettlementISDA20XX.nodes"/>																			

		<!-- ============================== -->
		<xsl:param name="collateral.nodes" />

		<!-- Overriding used by MTM module to generate the tag optionalEarlyTermination/bermudaExercise for IRS BEMUDAN product-->
		<xsl:param name="bermudaExerciseDates.period.overriding" />
		<xsl:param name="bermudaExerciseDates.periodMultiplier.overriding" />
		<xsl:param name="bermudaExerciseDates.dayType.overriding" />
		<xsl:param name="bermudaExerciseDates.businessDayConvention.overriding" />
		<xsl:param name="bermudaExerciseDates.unadjustedDate.nodes.overriding" />        
		<xsl:param name="bermudaExerciseDates.businessCenter.overriding" />
		<xsl:param name="bermudaExerciseDates.businessCenter.businessCenterScheme.overriding" />
		<xsl:param name="bermudaExerciseDates.dateRelativeTo.href.overriding" />

		<!-- Cash flows For Inflation Swaps -->
		<xsl:param name="swapStream1.cashflowsMatchParameters" />
		<xsl:param name="swapStream1.paymentCalculationPeriod.nodes"/>
		<xsl:param name="swapStream1.principalExchange.nodes"/>
		<xsl:param name="swapStream2.cashflowsMatchParameters" />
		<xsl:param name="swapStream2.paymentCalculationPeriod.nodes"/>
		<xsl:param name="swapStream2.principalExchange.nodes"/>

		<!-- overriding used by Markitwire For Inflation Swap Trades-->
		<xsl:param name="swapStream1.calculationPeriodFrequency.period.overriding" />
		<xsl:param name="swapStream2.calculationPeriodFrequency.period.overriding"/>
		<xsl:param name="swapStream1.calculationPeriodFrequency.periodMultiplier.overriding"/>
		<xsl:param name="swapStream2.calculationPeriodFrequency.periodMultiplier.overriding"/>
		<xsl:param name="swapStream1.frequency.periodMultiplier.overriding"/>
		<xsl:param name="swapStream2.frequency.periodMultiplier.overriding"/>
		<xsl:param name="swapStream1.frequency.period.overriding"/>
		<xsl:param name="swapStream2.frequency.period.overriding"/>
		<xsl:param name="swapStream1.resetDate.id.overriding" />
		<xsl:param name="swapStream2.resetDate.id.overriding" />

		<!--overriding used by Markitwire for stub nodes -->
		<xsl:param name="swapStream1.initialStub.nodes.overriding" />
		<xsl:param name="swapStream1.finalStub.nodes.overriding" />
		<xsl:param name="swapStream2.initialStub.nodes.overriding" />
		<xsl:param name="swapStream2.finalStub.nodes.overriding" />
		<xsl:param name="swapStream1.stubCalculationPeriodAmount.calculationPeriodDatesReference.href.overriding"/>
		<xsl:param name="swapStream2.stubCalculationPeriodAmount.calculationPeriodDatesReference.href.overriding"/>
		<xsl:param name="linkId1" />
		<xsl:param name="linkId.id1" />
		<xsl:param name="linkId.linkIdScheme1" />
		<xsl:param name="linkId2" />
		<xsl:param name="linkId.id2" />
		<xsl:param name="linkId.linkIdScheme2" />
		
		<!-- overriding used for markitwire submit novation where there is a check in the markitwire api for novated amount less than trade amount - causes an error if step out ratio greater than 50 % -->
		<xsl:param name="swapStream1.notionalSchedule.notionalStepSchedule.initialValue.overriding"/>
		<xsl:param name="swapStream2.notionalSchedule.notionalStepSchedule.initialValue.overriding"/>

		<!-- usage -->
		<xsl:param name="usage" />

		<!-- indexTransitionEvent swapStream1.spreadScheduleInitialValue and swapStream2.spreadScheduleInitialValue 
		     are calculated in mx.xml2xml.transform.mxml2fpml.4-3.products.ird.variables 
		-->

		<xsl:param name="swapStream1.rateCutOffDaysOffset.periodMultiplier.Overriding"/>
		<xsl:param name="swapStream2.rateCutOffDaysOffset.periodMultiplier.Overriding"/>

		<xsl:param name="swapStream1.suppressFirstFixing"/>
		<xsl:param name="swapStream2.suppressFirstFixing"/>
		<xsl:param name="swapStream1.suppressAveragingMethod"/>
		<xsl:param name="swapStream2.suppressAveragingMethod"/>
		<FpML xmlns:dsig="http://www.w3.org/2000/09/xmldsig#" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:fpml="http://www.fpml.org/2007/FpML-4-3" version="4-3" xsi:schemaLocation="http://www.fpml.org/2007/FpML-4-3 ../fpml-main-4-3.xsd http://www.w3.org/2000/09/xmldsig# ../xmldsig-core-schema.xsd" xsi:type="{$fpmlType}">

			<xsl:variable name="entity" select="/MxML/trades/trade[(not(tradeHeader/tradeUserDefinedFields/userDefinedField[fieldLabel=$internalUdfLabel]/fieldValue=&quot;true&quot;) and not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeHeader/tradeViews/tradeView/entity" />
			<xsl:variable name="legalEntity" select="/MxML/trades/trade[(not(tradeHeader/tradeUserDefinedFields/userDefinedField[fieldLabel=$internalUdfLabel]/fieldValue=&quot;true&quot;) and not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeHeader/tradeViews/tradeView/legalEntity" />
			<xsl:variable name="paramCtpLabel" select="concat('partyLabel:', $ctpName)" />
			<xsl:variable name="paramOurLabel" select="concat('partyLabel:', $ourName,',userName:',$ourUserName, ',entity:', $entity, ',legalEntity:', $legalEntity)" />

			<!-- counterparty identifier-->
			<xsl:variable name="party.partyId1">
				<xsl:variable name="ctpAltIdFromDisplayLabel">
					<xsl:if test="string-length($partyAlternateSystem)&gt;0">
						<xsl:value-of select="mx:execute-formula('mx.xml2xml.ECN.common.sql.ctpAltIdFromDisplayLabel',concat('displayLabel:',$ctpName,',altSys:',$partyAlternateSystem))" />
					</xsl:if>
				</xsl:variable>
				<xsl:choose>
					<xsl:when test="string-length($ctpAltIdFromDisplayLabel)&gt;0">
						<xsl:value-of select="$ctpAltIdFromDisplayLabel" />
					</xsl:when>
					<xsl:otherwise>
						<xsl:value-of select="mx:execute-formula($mapCounterparty, $paramCtpLabel)" />
					</xsl:otherwise>
				</xsl:choose>
			</xsl:variable>
			<xsl:call-template name="AssertNotMapped">
				<xsl:with-param name="value" select="$party.partyId1" />
				<xsl:with-param name="message" select="concat('Party ', $ctpName,' not mapped')" />
				<xsl:with-param name="formula" select="$mapCounterparty" />
			</xsl:call-template>
			<xsl:variable name="party.partyName1" select="$party.partyId1" />
			<xsl:variable name="party.id1">
				<xsl:choose>
					<xsl:when test="string-length($party1.id) &gt; 0">
						<xsl:value-of select="$party1.id" />
					</xsl:when>
					<xsl:otherwise>
						<xsl:value-of select="$party.partyId1" />
					</xsl:otherwise>
				</xsl:choose>
			</xsl:variable>

			<!-- our party identifier-->
			<xsl:variable name="party.partyId2">
				<xsl:variable name="ctpAltIdFromDisplayLabel">
					<xsl:if test="string-length($partyAlternateSystem)&gt;0">
						<xsl:value-of select="mx:execute-formula('mx.xml2xml.ECN.common.sql.ctpAltIdFromDisplayLabel',concat('displayLabel:',$ourName,',altSys:',$partyAlternateSystem))" />
					</xsl:if>
				</xsl:variable>
				<xsl:choose>
					<xsl:when test="string-length($ctpAltIdFromDisplayLabel)&gt;0">
						<xsl:value-of select="$ctpAltIdFromDisplayLabel" />
					</xsl:when>
					<xsl:when test="string-length($mapOurPartyLabel) &gt; 0">
						<xsl:value-of select="mx:execute-formula($mapOurPartyLabel)" />
					</xsl:when>
					<xsl:otherwise>
						<xsl:value-of select="mx:execute-formula($mapCounterparty, $paramOurLabel)" />
					</xsl:otherwise>
				</xsl:choose>
			</xsl:variable>
			<xsl:call-template name="AssertNotMapped">
				<xsl:with-param name="value" select="$party.partyId2" />
				<xsl:with-param name="message" select="concat('Party ', $ourName,' not mapped')" />
				<xsl:with-param name="formula" select="$mapCounterparty" />
			</xsl:call-template>
			<xsl:variable name="party.partyName2" select="$party.partyId2" />
			<xsl:variable name="party.id2">
				<xsl:choose>
					<xsl:when test="string-length($party2.id) &gt; 0">
						<xsl:value-of select="$party2.id" />
					</xsl:when>
					<xsl:otherwise>
						<xsl:value-of select="$party.partyId2" />
					</xsl:otherwise>
				</xsl:choose>
			</xsl:variable>

			<!-- specific novation -->
			<xsl:variable name="paramPartyNameEvent" select="concat('partyLabel:', $partyNameEvent)" />
			<xsl:variable name="party.partyNameEventId" select="$partyNameEventId" />
			<xsl:variable name="party.partyNameEvent">
				<xsl:if test="string-length($partyNameEventId) &gt; 0">
					<xsl:value-of select="mx:execute-formula($mapCounterparty, $paramPartyNameEvent)" />
				</xsl:if>
			</xsl:variable>
			<xsl:if test="string-length($partyNameEventId) &gt; 0">
				<xsl:call-template name="AssertNotMapped">
					<xsl:with-param name="value" select="$party.partyNameEvent" />
					<xsl:with-param name="message" select="concat('Party ', $partyNameEvent,' not mapped')" />
					<xsl:with-param name="formula" select="$mapCounterparty" />
				</xsl:call-template>
			</xsl:if>
			<xsl:if test="string-length($messageId) or string-length($messageIdScheme)&gt;0">
				<xsl:call-template name="create-notificationMessageHeader">
