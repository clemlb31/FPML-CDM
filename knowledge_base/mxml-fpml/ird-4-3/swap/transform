		<xsl:variable name="swapStream2.inflationSwapIndexSource"  select="mx:execute-formula('public.xml2xml.mapping.mxml2fpml.ird.inflationSwapIndexSource',concat('currency:',/MxML/trades/trade[(not(tradeHeader/tradeUserDefinedFields/userDefinedField[fieldLabel=$internalUdfLabel]/fieldValue=&quot;true&quot;) and not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeBody/*/stream[2]/streamTemplate/paymentCurrency, ',index:', $swapStream2.floatingRateIndex))" />

