<xsl:stylesheet xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:str="http://exslt.org/strings" xmlns:exsl="http://exslt.org/common" xmlns="http://www.fpml.org/2007/FpML-4-3" xmlns:mx="http://murex.com/xslt/common" xmlns:date="http://exslt.org/dates-and-times" xmlns:exslt="http://exslt.org/common" exclude-result-prefixes="mx exslt date str" version="1.0">
	<!--Param User Defined Field Label For Internal Counterparty-->
	<xsl:param name="internalUdfLabel" select="''"/>	
	<xsl:param name="extended.numeric.format"/> 

	<xsl:variable name="numeric.format" select="'##.########'"/>
	<xsl:variable name="numeric.format.10dp" select="'##.##########'"/>
	<xsl:variable name="numeric.format.12dp" select="'##.############'"/>
	<xsl:variable name="contractualDefinitions.overriding"/>
	<xsl:variable name="swapStream1.inflationRate.period">
		<xsl:if test="contains($typology,'Inflation')  or $Mxgroup = 'INFLS'">
			<xsl:variable name="tmp">
				<xsl:call-template name="extract-returnShifter-periodUnit">
					<xsl:with-param name="legNb" select="1" />
					<xsl:with-param name="stream" select="1" />
				</xsl:call-template>
			</xsl:variable>
			<xsl:variable name="result">
				<xsl:if test="string-length ($tmp) &gt; 0">
					<xsl:value-of select="mx:execute-formula($mapPeriodUnit,concat('periodUnit:',$tmp))/row[1]" />
				</xsl:if>
			</xsl:variable>
			<xsl:call-template name="AssertNotMapped">
				<xsl:with-param name="value" select="$result" />
				<xsl:with-param name="message" select="concat('Period Unit for Inflation Lag Shifter ', $tmp,' not mapped')" />
				<xsl:with-param name="formula" select="$mapPeriodUnit" />
			</xsl:call-template>
			<xsl:value-of select="$result" />
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="swapStream2.inflationRate.period">
		<xsl:if test="contains($typology,'Inflation')  or $Mxgroup = 'INFLS'">
			<xsl:variable name="tmp">
				<xsl:call-template name="extract-returnShifter-periodUnit">
					<xsl:with-param name="legNb" select="1" />
					<xsl:with-param name="stream" select="2" />
				</xsl:call-template>
			</xsl:variable>
			<xsl:variable name="result">
				<xsl:if test="string-length ($tmp) &gt; 0">
					<xsl:value-of select="mx:execute-formula($mapPeriodUnit,concat('periodUnit:',$tmp))/row[1]" />
				</xsl:if>
			</xsl:variable>
			<xsl:call-template name="AssertNotMapped">
				<xsl:with-param name="value" select="$result" />
				<xsl:with-param name="message" select="concat('Period Unit for Inflation Lag Shifter ', $tmp,' not mapped')" />
				<xsl:with-param name="formula" select="$mapPeriodUnit" />
			</xsl:call-template>
			<xsl:value-of select="$result" />
		</xsl:if>
	</xsl:variable>
	<!-- spreadSchedule.nodes stream1-->
	<xsl:variable name="swapStream1.spreadSchedule.nodes">
		<xsl:variable name="local.numeric.format">
			<xsl:choose>
				<xsl:when test="$extended.numeric.format='true'">
					<xsl:value-of select="$numeric.format.10dp"/>
				</xsl:when>
				<xsl:otherwise>
					<xsl:value-of select="$numeric.format"/>
				</xsl:otherwise>
			</xsl:choose>
		</xsl:variable>
		<xsl:choose>
			<xsl:when test="string-length($swapStream1.spreadSchedule.initialValue) &gt; 0 and $swapStream1.spreadSchedule.initialValue != '0.'">
				<xsl:call-template name="create-spreadSchedule">
					<xsl:with-param name="initialValue" select="$swapStream1.spreadSchedule.initialValue" />
					<xsl:with-param name="local.numeric.format" select="$local.numeric.format" />
				</xsl:call-template>
			</xsl:when>
			<xsl:when test="string-length($stream1.margin) &gt; 0 and $stream1.margin != '0.'">
				<xsl:call-template name="create-spreadSchedule">
					<xsl:with-param name="initialValue" select="format-number($stream1.margin div 100, $local.numeric.format)" />
					<xsl:with-param name="local.numeric.format" select="$local.numeric.format" />
				</xsl:call-template>
			</xsl:when>
			<xsl:when test="string-length($swapStream1.spreadSchedule.initialValue) &gt; 0 and $swapStream1.spreadSchedule.initialValue != '0.'">
				<xsl:call-template name="create-spreadSchedule">
					<xsl:with-param name="initialValue" select="$swapStream1.spreadSchedule.initialValue" />
					<xsl:with-param name="local.numeric.format" select="$local.numeric.format" />
					<xsl:with-param name="step.nodes" select="$swapStream1.spreadSchedule.step.nodes" />
				</xsl:call-template>
			</xsl:when>
		</xsl:choose>
	</xsl:variable>
	<!-- spreadSchedule.nodes stream2 -->
	<xsl:variable name="swapStream2.spreadSchedule.nodes">
		<xsl:variable name="local.numeric.format">
			<xsl:choose>
				<xsl:when test="$extended.numeric.format='true'">
					<xsl:value-of select="$numeric.format.10dp"/>
				</xsl:when>
				<xsl:otherwise>
					<xsl:value-of select="$numeric.format"/>
				</xsl:otherwise>
			</xsl:choose>
		</xsl:variable>
		<xsl:choose>
			<xsl:when test="string-length($swapStream2.spreadSchedule.initialValue) &gt; 0 and $swapStream2.spreadSchedule.initialValue != '0.'">
				<xsl:call-template name="create-spreadSchedule">
					<xsl:with-param name="initialValue" select="$swapStream2.spreadSchedule.initialValue" />
					<xsl:with-param name="local.numeric.format" select="$local.numeric.format" />
				</xsl:call-template>
			</xsl:when>
			<xsl:when test="string-length($stream2.margin) &gt; 0 and $stream2.margin != '0.'">
				<xsl:call-template name="create-spreadSchedule">
					<xsl:with-param name="initialValue" select="format-number($stream2.margin div 100, $local.numeric.format)" />
					<xsl:with-param name="local.numeric.format" select="$local.numeric.format" />
				</xsl:call-template>
			</xsl:when>
			<xsl:when test="string-length($swapStream2.spreadSchedule.initialValue) &gt; 0 and $swapStream2.spreadSchedule.initialValue != '0.'">
				<xsl:call-template name="create-spreadSchedule">
					<xsl:with-param name="initialValue" select="$swapStream2.spreadSchedule.initialValue" />
					<xsl:with-param name="local.numeric.format" select="$local.numeric.format" />
					<xsl:with-param name="step.nodes" select="$swapStream2.spreadSchedule.step.nodes" />
				</xsl:call-template>
			</xsl:when>
		</xsl:choose>
	</xsl:variable>

</xsl:stylesheet>