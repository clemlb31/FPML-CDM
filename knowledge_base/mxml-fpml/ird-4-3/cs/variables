				<xsl:when test="/MxML/trades/trade[(not(tradeHeader/tradeUserDefinedFields/userDefinedField[fieldLabel=$internalUdfLabel]/fieldValue=&quot;true&quot;) and not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeBody/currencySwap/stream[2]/streamTemplate/indexationRulesLists/indexationRulesList/indexedObjectNature = 'initialCapital' "/>
				<xsl:when test="$event = 'restructure' or ($event = 'unwind' and $unwoundRatio &lt; 1 )">
					<xsl:variable name="swapStream2.fxLinkedNotionalSchedule.initialValue.tmp">
						<xsl:call-template name="extract-initialCapitalAmount">
							<xsl:with-param name="legNb" select="1"/>
