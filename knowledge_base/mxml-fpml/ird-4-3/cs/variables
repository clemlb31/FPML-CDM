			<xsl:variable name="indexationRulesLists-periodMultiplier">
				<xsl:call-template name="extract-indexationRulesLists-periodMultiplier">
					<xsl:with-param name="stream" select="1"/>
				</xsl:call-template>
			</xsl:variable>
			<xsl:choose>
				<xsl:when test="string-length($indexationRulesLists-periodMultiplier) &gt; 0">
					<xsl:value-of select="$indexationRulesLists-periodMultiplier"/>
				</xsl:when>
				<xsl:otherwise>
					<xsl:value-of select="$swapStream1.fixingDates.periodMultiplier"/>
				</xsl:otherwise>
			</xsl:choose>
		</xsl:if>
