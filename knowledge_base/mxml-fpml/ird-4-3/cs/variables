				<xsl:with-param name="message" select="concat('periodUnit ', $swapStream2.indexationRulesLists.periodUnit.value, ' not mapped')"/>
				<xsl:with-param name="formula" select="$mapPeriodUnit"/>
			</xsl:call-template>
			<xsl:value-of select="$swapStream2.dayType.tmp"/>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="swapStream2.settlementProvision.businessDayConvention">
		<xsl:if test="string-length($swapStream2.indexationRulesLists.dateShifterDirection.value) &gt; 0">
			<xsl:variable name="swapStream2.settlementProvision.businessDayConvention.tmp">
				<xsl:value-of select="mx:execute-formula($mapBusinessDayConv, concat('businessDayConvention:', $swapStream2.indexationRulesLists.dateShifterDirection.value))"/>
			</xsl:variable>
			<xsl:call-template name="AssertNotMapped">
				<xsl:with-param name="value" select="$swapStream2.settlementProvision.businessDayConvention.tmp"/>
				<xsl:with-param name="message" select="concat('businessDayConvention ', $swapStream2.indexationRulesLists.dateShifterDirection.value, ' not mapped')"/>
				<xsl:with-param name="formula" select="$mapBusinessDayConv"/>
			</xsl:call-template>
			<xsl:value-of select="$swapStream2.settlementProvision.businessDayConvention.tmp"/>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="swapStream2.settlementProvision.businessCenter.nodes">
		<xsl:call-template name="extract-indexationRulesLists-businessCenter-Nodes">
			<xsl:with-param name="stream" select="2"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="swapStream2.settlementRateOption">
		<xsl:if test="string-length($swapStream2.settlementRateOption.value) &gt; 0 and string-length($swapStream2.indexationRulesLists.periodUnit.value) &gt; 0 and string-length($swapStream2.settlementProvision.periodMultiplier) &gt; 0 ">
			<xsl:variable name="swapStream2.settlementRateOption.tmp">
				<xsl:value-of select="mx:execute-formula($mapSettlementRateOption, concat('indexLabel:', $swapStream2.settlementRateOption.value))"/>
			</xsl:variable>
			<xsl:call-template name="AssertNotMapped">
				<xsl:with-param name="value" select="$swapStream2.settlementRateOption.tmp"/>
				<xsl:with-param name="message" select="concat('settlementRateOption [', $swapStream2.settlementRateOption.value, '] not mapped | LEG 2 | Period Unit [', $swapStream2.indexationRulesLists.periodUnit.value,'] Period Multiplier [',$swapStream2.settlementProvision.periodMultiplier,'] Date Shifter Direction [',$swapStream2.indexationRulesLists.dateShifterDirection.value,']')"/>
				<xsl:with-param name="formula" select="$mapSettlementRateOption"/>
			</xsl:call-template>
			<xsl:value-of select="$swapStream2.settlementRateOption.tmp"/>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="swapStream2.settlementRateOption.settlementRateOptionScheme">
		<xsl:value-of select="'http://www.fpml.org/coding-scheme/settlement-rate-option-1-0'"/>
	</xsl:variable>
	<!-- Condition to identify the NDS deal based on intial capital currency and final capital currency -->
	<!-- If condition is not applied the IRD CS deal will be consider as NONE NDS -->
	<xsl:variable name="swapStream2.settlementCurrency.currency">
		<xsl:if test="$swapStream2.initialCapitalCurrency != $swapStream2.finalCapitalCurrency and string-length($swapStream2.currency) &gt; 0 and string-length($swapStream2.settlementProvision.period) &gt; 0 and string-length($swapStream2.settlementProvision.periodMultiplier) &gt; 0 and string-length($swapStream2.dayType) &gt; 0 ">
			<xsl:call-template name="extract-streamPaymentCurrency">
				<xsl:with-param name="stream" select="2"></xsl:with-param>
			</xsl:call-template>
		</xsl:if>
	</xsl:variable>

	<xsl:variable name="swapstream1.nonDeliverable">
		<xsl:variable name="tmpPayCurrency">
			<xsl:call-template name="extract-streamPaymentCurrency">
				<xsl:with-param name="stream" select="1"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:variable name="tmpCapCurrency">
			<xsl:call-template name="extract-initialCapitalCurrency">
				<xsl:with-param name="stream" select="1"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:choose>
			<xsl:when test="not($tmpCapCurrency = $tmpPayCurrency)">
				<xsl:value-of select="'true'"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="'false'"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>
	<xsl:variable name="swapstream2.nonDeliverable">
		<xsl:variable name="tmpPayCurrency">
			<xsl:call-template name="extract-streamPaymentCurrency">
				<xsl:with-param name="stream" select="2"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:variable name="tmpCapCurrency">
			<xsl:call-template name="extract-initialCapitalCurrency">
				<xsl:with-param name="stream" select="2"/>
			</xsl:call-template>
		</xsl:variable>
		<xsl:choose>
			<xsl:when test="not($tmpCapCurrency = $tmpPayCurrency)">
				<xsl:value-of select="'true'"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="'false'"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>
 
 </xsl:stylesheet>
