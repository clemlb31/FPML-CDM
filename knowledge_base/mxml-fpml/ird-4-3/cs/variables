<xsl:stylesheet xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:str="http://exslt.org/strings" xmlns:exsl="http://exslt.org/common" xmlns="http://www.fpml.org/2007/FpML-4-3" xmlns:mx="http://murex.com/xslt/common" xmlns:date="http://exslt.org/dates-and-times" xmlns:exslt="http://exslt.org/common" exclude-result-prefixes="mx exslt date str" version="1.0">
	<xsl:import href="mx.xml2xml.extract.mxml.products.ird.swap.templates"/>
	<xsl:import href="mx.xml2xml.extract.mxml.products.ird.templates"/>
	<xsl:import href="mx.xml2xml.extract.mxml.products.common.templates"/>
	<xsl:import href="mx.xml2xml.transform.mxml2fpml.4-3.products.variables"/>
	<xsl:import href="mx.xml2xml.transform.any2fpml.4-3.products.common.spreadSchedule"/>
	<xsl:import href="mx.xml2xml.transform.mxml2fpml.4-3.products.ird.variables"/>
	<!--Param User Defined Field Label For Internal Counterparty-->
	<xsl:param name="internalUdfLabel" select="''"/>
	<xsl:param name="extended.numeric.format"/>
	<xsl:variable name="numeric.format" select="'##.########'"/>
	<xsl:variable name="numeric.format.12dp" select="'##.############'"/>
	<xsl:variable name="cs-local.numeric.format">
		<xsl:choose>
			<xsl:when test="$extended.numeric.format='true'">
				<xsl:value-of select="$numeric.format.12dp"/>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="$numeric.format"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:variable>
	<!-- specific MTM -->
	<xsl:variable name="mapFXRateSource" select="'public.xml2xml.mapping.mxml2fpml.common.fxRateSource'"/>
	<!-- specific to settlement provision -->
	<xsl:variable name="mapSettlementRateOption" select="'public.xml2xml.mapping.mxml2fpml.ird.settlementRateOption'"/>
	<!--margin stream1-->
	<xsl:variable name="swapStream1.margin">
		<xsl:call-template name="extract-margin">
			<xsl:with-param name="stream" select="1"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="swapStream1.spreadSchedule.nodes">
		<xsl:if test="string-length($swapStream1.margin) &gt; 0 and $swapStream1.margin != '0.'">
			<xsl:call-template name="create-spreadSchedule">
				<xsl:with-param name="initialValue" select="format-number($swapStream1.margin div 100, cs-local.numeric.format)"/>
				<xsl:with-param name="local.numeric.format" select="$cs-local.numeric.format"/>
			</xsl:call-template>
		</xsl:if>
	</xsl:variable>
	<!--stream1 initialCapitalExchange-->
	<xsl:variable name="swapStream1.initialExchange">
		<xsl:call-template name="extract-initialCapitalExchange">
			<xsl:with-param name="stream" select="1"/>
		</xsl:call-template>
	</xsl:variable>
	<!--stream1 finalCapitalExchange-->
	<xsl:variable name="swapStream1.finalExchange">
		<xsl:call-template name="extract-finalCapitalExchange">
			<xsl:with-param name="stream" select="1"/>
		</xsl:call-template>
	</xsl:variable>
	<!--stream1 intermediateCapitalExchange-->
	<xsl:variable name="swapStream1.intermediateExchange">
		<xsl:call-template name="extract-intermediateCapitalExchange">
			<xsl:with-param name="stream" select="1"/>
		</xsl:call-template>
	</xsl:variable>
	<!--margin stream2-->
	<xsl:variable name="swapStream2.margin">
		<xsl:call-template name="extract-margin">
			<xsl:with-param name="stream" select="2"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="swapStream2.spreadSchedule.nodes">
		<xsl:if test="string-length($swapStream2.margin) &gt; 0 and $swapStream2.margin != '0.'">
			<xsl:call-template name="create-spreadSchedule">
				<xsl:with-param name="initialValue" select="format-number($swapStream2.margin div 100, cs-local.numeric.format)"/>
				<xsl:with-param name="local.numeric.format" select="$cs-local.numeric.format"/>
			</xsl:call-template>
		</xsl:if>
	</xsl:variable>
	<!--stream2 initialCapitalExchange-->
	<xsl:variable name="swapStream2.initialExchange">
		<xsl:call-template name="extract-initialCapitalExchange">
			<xsl:with-param name="stream" select="2"/>
		</xsl:call-template>
	</xsl:variable>
	<!--stream2 finalCapitalExchange-->
	<xsl:variable name="swapStream2.finalExchange">
		<xsl:call-template name="extract-finalCapitalExchange">
			<xsl:with-param name="stream" select="2"/>
		</xsl:call-template>
	</xsl:variable>
	<!--stream2 intermediateCapitalExchange-->
	<xsl:variable name="swapStream2.intermediateExchange">
		<xsl:call-template name="extract-intermediateCapitalExchange">
			<xsl:with-param name="stream" select="2"/>
		</xsl:call-template>
	</xsl:variable>
	<!-- Mark To Market -->
	<xsl:variable name="swapStream1.indexed">
		<xsl:call-template name="extract-indexed">
			<xsl:with-param name="stream" select="1"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="swapStream2.indexed">
		<xsl:call-template name="extract-indexed">
			<xsl:with-param name="stream" select="2"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="swapStream1.indexed.indexLabel">
		<xsl:call-template name="extract-indexationRulesLists-indexLabel">
			<xsl:with-param name="stream" select="1"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="swapStream2.indexed.indexLabel">
		<xsl:call-template name="extract-indexationRulesLists-indexLabel">
			<xsl:with-param name="stream" select="2"/>
		</xsl:call-template>
	</xsl:variable>
	<xsl:variable name="swapStream1.notionalSchedule.id">
		<xsl:choose>
			<xsl:when test="$swapStream1.indexed = 'true' and string-length(/MxML/trades/trade/tradeBody/currencySwap/stream[1]/streamTemplate/indexationRulesLists/indexationRulesList[indexedObjectNature = 'outstandingCapital']) &gt; 0"/>
			<xsl:when test="$swapStream2.indexed = 'true' and string-length(/MxML/trades/trade/tradeBody/currencySwap/stream[2]/streamTemplate/indexationRulesLists/indexationRulesList[indexedObjectNature = 'outstandingCapital']) &gt; 0">
				<xsl:value-of select="'notionalScheduleConstant'"/>
			</xsl:when>
		</xsl:choose>
	</xsl:variable>
	<xsl:variable name="swapStream2.notionalSchedule.id">
		<xsl:choose>
			<xsl:when test="$swapStream1.indexed = 'true' and string-length(/MxML/trades/trade/tradeBody/currencySwap/stream[1]/streamTemplate/indexationRulesLists/indexationRulesList[indexedObjectNature = 'outstandingCapital']) &gt; 0">
				<xsl:value-of select="'notionalScheduleConstant'"/>
			</xsl:when>
			<xsl:when test="$swapStream2.indexed = 'true' and string-length(/MxML/trades/trade/tradeBody/currencySwap/stream[2]/streamTemplate/indexationRulesLists/indexationRulesList[indexedObjectNature = 'outstandingCapital']) &gt; 0"/>
		</xsl:choose>
	</xsl:variable>
	<xsl:variable name="swapStream1.fxLinkedNotionalSchedule.constantNotionalScheduleReference.href">
		<xsl:if test="$swapStream1.indexed = 'true' and string-length(/MxML/trades/trade/tradeBody/currencySwap/stream[1]/streamTemplate/indexationRulesLists/indexationRulesList[indexedObjectNature = 'outstandingCapital']) &gt; 0">
			<xsl:value-of select="$swapStream2.notionalSchedule.id"/>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="swapStream2.fxLinkedNotionalSchedule.constantNotionalScheduleReference.href">
		<xsl:if test="$swapStream2.indexed = 'true' and string-length(/MxML/trades/trade/tradeBody/currencySwap/stream[2]/streamTemplate/indexationRulesLists/indexationRulesList[indexedObjectNature = 'outstandingCapital']) &gt; 0">
			<xsl:value-of select="$swapStream1.notionalSchedule.id"/>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="swapStream1.fxLinkedNotionalSchedule.varyingNotionalInterimExchangePaymentDates.periodMultiplier">
		<xsl:if test="$swapStream1.indexed = 'true' and string-length(/MxML/trades/trade/tradeBody/currencySwap/stream[1]/streamTemplate/indexationRulesLists/indexationRulesList[indexedObjectNature = 'outstandingCapital']) &gt; 0">
			<xsl:value-of select="'0'"/>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="swapStream2.fxLinkedNotionalSchedule.varyingNotionalInterimExchangePaymentDates.periodMultiplier">
		<xsl:if test="$swapStream2.indexed = 'true' and string-length(/MxML/trades/trade/tradeBody/currencySwap/stream[2]/streamTemplate/indexationRulesLists/indexationRulesList[indexedObjectNature = 'outstandingCapital']) &gt; 0">
			<xsl:value-of select="'0'"/>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="swapStream1.fxLinkedNotionalSchedule.varyingNotionalInterimExchangePaymentDates.period">
		<xsl:if test="$swapStream1.indexed = 'true' and string-length(/MxML/trades/trade/tradeBody/currencySwap/stream[1]/streamTemplate/indexationRulesLists/indexationRulesList[indexedObjectNature = 'outstandingCapital']) &gt; 0">
			<xsl:value-of select="'D'"/>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="swapStream2.fxLinkedNotionalSchedule.varyingNotionalInterimExchangePaymentDates.period">
		<xsl:if test="$swapStream2.indexed = 'true' and string-length(/MxML/trades/trade/tradeBody/currencySwap/stream[2]/streamTemplate/indexationRulesLists/indexationRulesList[indexedObjectNature = 'outstandingCapital']) &gt; 0">
			<xsl:value-of select="'D'"/>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="swapStream1.fxLinkedNotionalSchedule.varyingNotionalInterimExchangePaymentDates.businessDayConvention">
		<xsl:if test="$swapStream1.indexed = 'true' and string-length(/MxML/trades/trade/tradeBody/currencySwap/stream[1]/streamTemplate/indexationRulesLists/indexationRulesList[indexedObjectNature = 'outstandingCapital']) &gt; 0">
			<xsl:value-of select="'NONE'"/>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="swapStream2.fxLinkedNotionalSchedule.varyingNotionalInterimExchangePaymentDates.businessDayConvention">
		<xsl:if test="$swapStream2.indexed = 'true' and string-length(/MxML/trades/trade/tradeBody/currencySwap/stream[2]/streamTemplate/indexationRulesLists/indexationRulesList[indexedObjectNature = 'outstandingCapital']) &gt; 0">
			<xsl:value-of select="'NONE'"/>
		</xsl:if>
	</xsl:variable>
	<!-- ==================================================== -->
