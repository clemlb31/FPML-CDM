				<xsl:when
					test="/MxML/trades/trade[(not(tradeHeader/tradeUserDefinedFields/userDefinedField[fieldLabel=$internalUdfLabel]/fieldValue=&quot;true&quot;) and not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeBody/currencySwap/stream[1]/streamTemplate/indexationRulesLists/indexationRulesList/indexedObjectNature = 'initialCapital' and /MxML/trades/trade[(not(tradeHeader/tradeUserDefinedFields/userDefinedField[fieldLabel=$internalUdfLabel]/fieldValue=&quot;true&quot;) and not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeBody/currencySwap/stream[1]/indexationLists/indexationList[indexedObjectNature = 'initialCapital']/indexationSchedules/indexationSchedule/indexations/indexation/date = /MxML/trades/trade[(not(tradeHeader/tradeUserDefinedFields/userDefinedField[fieldLabel=$internalUdfLabel]/fieldValue=&quot;true&quot;) and not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeInputConditions/systemDate"/>-->
				<xsl:when test="/MxML/trades/trade[(not(tradeHeader/tradeUserDefinedFields/userDefinedField[fieldLabel=$internalUdfLabel]/fieldValue=&quot;true&quot;) and not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeBody/currencySwap/stream[1]/streamTemplate/indexationRulesLists/indexationRulesList/indexedObjectNature = 'initialCapital'"/>
				<xsl:when test="$event = 'restructure' or ($event = 'unwind' and $unwoundRatio &lt; 1 )">
					<xsl:variable name="swapStream1.fxLinkedNotionalSchedule.initialValue.tmp">
						<xsl:call-template name="extract-initialCapitalAmount">
							<xsl:with-param name="legNb" select="1"/>
							<xsl:with-param name="stream" select="1"/>
						</xsl:call-template>
					</xsl:variable>
					<xsl:value-of select="format-number($swapStream1.fxLinkedNotionalSchedule.initialValue.tmp, '#.##')"/>
				</xsl:when>
				<xsl:otherwise>
					<xsl:value-of select="format-number($swapStream1.notionalSchedule.notionalStepSchedule.initialValue, '#.##')"/>
				</xsl:otherwise>
			</xsl:choose>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="swapStream2.fxLinkedNotionalSchedule.initialValue">
		<xsl:if test="$swapStream2.indexed = 'true' and string-length(/MxML/trades/trade/tradeBody/currencySwap/stream[2]/streamTemplate/indexationRulesLists/indexationRulesList[indexedObjectNature = 'outstandingCapital']) &gt; 0">
			<xsl:choose>
				<xsl:when test="$event = 'fixingEvent'">
					<xsl:value-of select="format-number($swapStream2.notionalSchedule.notionalStepSchedule.initialValue, '#.##')"/>
				</xsl:when>
				<!-- In case of forward start and fixing referenceDate is greater than systemDate or equal, the intial amount is not fixed -->
				<!--	<xsl:when
					test="/MxML/trades/trade[(not(tradeHeader/tradeUserDefinedFields/userDefinedField[fieldLabel=$internalUdfLabel]/fieldValue=&quot;true&quot;) and not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeBody/currencySwap/stream[2]/streamTemplate/indexationRulesLists/indexationRulesList/indexedObjectNature = 'initialCapital' and /MxML/trades/trade[(not(tradeHeader/tradeUserDefinedFields/userDefinedField[fieldLabel=$internalUdfLabel]/fieldValue=&quot;true&quot;) and not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeBody/currencySwap/stream[2]/indexationLists/indexationList[indexedObjectNature = 'initialCapital']/indexationSchedules/indexationSchedule/indexations/indexation/date &gt; /MxML/trades/trade[(not(tradeHeader/tradeUserDefinedFields/userDefinedField[fieldLabel=$internalUdfLabel]/fieldValue=&quot;true&quot;) and not(tradeHeader/tradeCategory/tradeDestination = &quot;internal&quot;) and ((not(tradeStatus/physicalStatus = &quot;dead&quot;) and count(../trade) &gt; 1) or (count(../trade) = 1) or (count(../trade) = count(../trade/tradeStatus[physicalStatus = &quot;dead&quot;]))))]/tradeInputConditions/systemDate"/>
				<xsl:when
