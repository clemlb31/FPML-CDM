		</xsl:if>
	</xsl:variable>
	<xsl:variable name="swapStream1.fxLinkedNotionalSchedule.varyingNotionalCurrency">
		<xsl:if test="$swapStream1.indexed = 'true' and string-length(/MxML/trades/trade/tradeBody/currencySwap/stream[1]/streamTemplate/indexationRulesLists/indexationRulesList[indexedObjectNature = 'outstandingCapital']) &gt; 0">
			<xsl:value-of select="$swapStream1.notionalSchedule.notionalStepSchedule.currency"/>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="swapStream2.fxLinkedNotionalSchedule.varyingNotionalCurrency">
		<xsl:if test="$swapStream2.indexed = 'true' and string-length(/MxML/trades/trade/tradeBody/currencySwap/stream[2]/streamTemplate/indexationRulesLists/indexationRulesList[indexedObjectNature = 'outstandingCapital']) &gt; 0">
			<xsl:value-of select="$swapStream2.notionalSchedule.notionalStepSchedule.currency"/>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="swapStream1.fxLinkedNotionalSchedule.varyingNotionalInterimExchangePaymentDates.dateRelativeTo.href">
		<xsl:if test="$swapStream1.indexed = 'true' and string-length(/MxML/trades/trade/tradeBody/currencySwap/stream[1]/streamTemplate/indexationRulesLists/indexationRulesList[indexedObjectNature = 'outstandingCapital']) &gt; 0">
			<xsl:value-of select="$swapStream1.paymentDates.id"/>
		</xsl:if>
	</xsl:variable>
	<xsl:variable name="swapStream2.fxLinkedNotionalSchedule.varyingNotionalInterimExchangePaymentDates.dateRelativeTo.href">
		<xsl:choose>
			<xsl:when test="$swapStream2.indexed = 'true' and string-length(/MxML/trades/trade/tradeBody/currencySwap/stream[2]/streamTemplate/indexationRulesLists/indexationRulesList[indexedObjectNature = 'outstandingCapital']) &gt; 0">
				<xsl:value-of select="$swapStream2.paymentDates.id"/>
			</xsl:when>
		</xsl:choose>
	</xsl:variable>
	<xsl:variable name="swapStream1.fxLinkedNotionalSchedule.varyingNotionalFixingDates.period">
		<xsl:if test="$swapStream1.indexed = 'true' and string-length(/MxML/trades/trade/tradeBody/currencySwap/stream[1]/streamTemplate/indexationRulesLists/indexationRulesList[indexedObjectNature = 'outstandingCapital']) &gt; 0">
			<xsl:value-of select="'D'"/>
